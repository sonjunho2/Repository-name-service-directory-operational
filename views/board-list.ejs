<!doctype html><html lang="ko"><head><% const brand=settings?.brand||{name:'서비스 디렉터리',showLogo:false,showName:true,logo:'',link:'/'}; %><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title><%=mode==='posts'?board.title:'커뮤니티 게시판'%> - <%=brand.name%></title><link rel="stylesheet" href="/public/css/style.css"></head><body>
<%- include('partials/public-mobile-menu') %>
<header class="top"><a class="brand" href="/">홈</a><a class="site-brand-center" href="<%=brand.link||'/'%>"><% if(brand.showLogo&&brand.logo){%><img src="<%=brand.logo%>" alt=""><%}%><% if(brand.showName){%><span><%=brand.name%></span><%}%></a><nav><a href="/boards">게시판</a><% if(me){%><a href="<%=me.role==='admin'?'/admin':me.is_vendor?'/vendor-dashboard':'/mypage'%>">내 메뉴</a><a href="/logout">로그아웃</a><%}else{%><a href="/login">로그인</a><%}%></nav></header>
<main class="board-wrap"><%- include('partials/board-top-banner') %>
<% if(mode==='categories'){%><div class="board-head"><div><h1>게시판</h1><p>관심 있는 게시판을 선택해 주세요.</p></div></div><div class="board-category-grid"><% boards.forEach(b=>{%><article class="board-category-card"><a href="/boards/<%=b.slug%>"><h2><%=b.title%></h2><p><%=b.description||'게시판에 참여해 보세요.'%></p><strong>게시글 <%=b.post_count||0%>개</strong></a><ul><% (recentByBoard[b.id]||[]).forEach(p=>{%><li><a href="/boards/<%=b.slug%>/<%=p.id%>"><%=p.title%></a></li><%})%></ul></article><%})%></div>
<%}else{%><div class="board-head"><div><h1><%=board.title%></h1><p><%=board.description||''%></p></div><form method="get" action="/boards/<%=board.slug%>" class="board-search"><input name="q" value="<%=qText%>" placeholder="제목/내용 검색"><button>검색</button></form></div><div class="board-table-wrap"><table class="board-table"><thead><tr><th>번호</th><th>제목</th><th>작성자</th><th>작성일</th><th>조회수</th></tr></thead><tbody><% posts.forEach(p=>{%><tr data-board-href="/boards/<%=board.slug%>/<%=p.id%>"><td><%=p.is_pinned?'공지':p.id%></td><td><a href="/boards/<%=board.slug%>/<%=p.id%>"><%=p.title%> <% if(p.comment_count){%><small>[<%=p.comment_count%>]</small><%}%></a></td><td><%=p.nickname||p.username||'탈퇴회원'%></td><td><%=fmtDate(p.created_at)%></td><td><%=p.views||0%></td></tr><%})%><% if(!posts.length){%><tr><td colspan="5" class="board-empty">등록된 게시글이 없습니다.</td></tr><%}%></tbody></table></div>
<div class="board-pagination"><a href="?page=1&q=<%=encodeURIComponent(qText)%>">처음</a><a href="?page=<%=Math.max(1,page-1)%>&q=<%=encodeURIComponent(qText)%>">이전</a><% for(let n=Math.max(1,page-2);n<=Math.min(totalPages,page+2);n++){%><a class="<%=n===page?'active':''%>" href="?page=<%=n%>&q=<%=encodeURIComponent(qText)%>"><%=n%></a><%}%><a href="?page=<%=Math.min(totalPages,page+1)%>&q=<%=encodeURIComponent(qText)%>">다음</a><a href="?page=<%=totalPages%>&q=<%=encodeURIComponent(qText)%>">마지막</a></div><div class="board-actions"><a href="/boards">게시판 목록</a><% if(canWrite){%><a class="board-write-btn" href="/boards/<%=board.slug%>/write">새 글 작성</a><%}%></div><%}%></main><script src="/public/js/app.js"></script></body></html>
