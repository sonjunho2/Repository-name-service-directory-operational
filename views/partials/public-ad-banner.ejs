<%
  const _publicAds=Array.isArray(typeof publicAdBanners!=='undefined'?publicAdBanners:[])?publicAdBanners:[];
  const _publicAdFallback=[
    {id:'ad-fallback-1',title:'프리미엄 배너',subtitle:'상단 배너 광고 영역',image_data:null,href:'/boards/ad-inquiry'},
    {id:'ad-fallback-2',title:'광고문의',subtitle:'배너 광고를 신청해 보세요',image_data:null,href:'/boards/ad-inquiry'}
  ];
  const _publicAdSource=_publicAds.length?_publicAds:_publicAdFallback;
  const _publicAdLoop=[];
  for(let i=0;i<8;i++){_publicAdSource.forEach(function(ad){_publicAdLoop.push(ad);});}
%>
<section class="public-ad-banner public-top-premium" aria-label="광고 배너">
  <div class="premium-row-slider unified-premium-slider public-top-premium-slider">
    <div class="premium-track">
      <% _publicAdLoop.forEach(function(ad){ %><a class="card premium public-top-premium-card" href="<%=ad.href||'#'%>"><div class="thumb"><% if(ad.image_data){ %><img src="<%=ad.image_data%>" alt="" loading="lazy" decoding="async"><% }else{ %><div class="noimg">AD</div><% } %></div><div class="ad-card-meta"><em>PREMIUM</em><h3><%=ad.title||'광고 배너'%></h3><p><%=ad.subtitle||'광고 영역'%></p></div></a><% }); %>
    </div>
  </div>
</section>
