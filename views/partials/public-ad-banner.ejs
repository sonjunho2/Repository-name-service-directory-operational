<%
  const _publicAds=Array.isArray(typeof publicAdBanners!=='undefined'?publicAdBanners:[])?publicAdBanners:[];
  const _publicAdFallback=[
    {id:'ad-fallback-1',title:'프리미엄 배너',subtitle:'상단 배너 광고 영역',image_data:null,href:'/boards/ad-inquiry'},
    {id:'ad-fallback-2',title:'광고문의',subtitle:'배너 광고를 신청해 보세요',image_data:null,href:'/boards/ad-inquiry'}
  ];
  const _publicAdSource=_publicAds.length?_publicAds:_publicAdFallback;
  const _publicAdLoop=[];
  for(let i=0;i<8;i++){_publicAdSource.forEach(function(ad){_publicAdLoop.push(ad);});}
%>
<section class="premium-showcase public-ad-banner" aria-label="광고 배너">
  <div class="premium-row-slider unified-premium-slider">
    <div class="premium-track">
      <% _publicAdLoop.forEach(function(v){
        const _href=v.href||((v.vendor_id||v.id)?('/vendor/'+(v.vendor_id||v.id)):'#');
        const _vendorMatch=String(_href).match(/^\/vendor\/(\d+)/);
        const _vendorId=v.vendor_id||(_vendorMatch?_vendorMatch[1]:'');
        const _isVendor=!!v.isVendor||!!v.vendor_id||!!_vendorId;
      %>
        <a class="card <%= _isVendor?'vendor-open premium':'premium banner-direct-open' %>" href="<%=_href%>" <%- _isVendor&&_vendorId?('data-vendor-id="'+_vendorId+'"'):'' %>>
          <div class="thumb">
            <% if(v.image_data){ %><img src="<%=v.image_data%>" alt="" loading="lazy" decoding="async"><% }else{ %><div class="noimg">IMAGE</div><% } %>
          </div>
          <div class="ad-card-meta">
            <em>PREMIUM</em>
            <h3><%=v.title||v.name||'광고 배너'%></h3>
            <p><%=v.subtitle||v.region||'광고 영역'%></p>
          </div>
        </a>
      <% }); %>
    </div>
  </div>
</section>
