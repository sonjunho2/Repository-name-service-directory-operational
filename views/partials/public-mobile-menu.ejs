<% const _boards=typeof publicBoardCategories!=='undefined'&&Array.isArray(publicBoardCategories)?publicBoardCategories:[]; const _me=typeof me!=='undefined'?me:null; %>
<button type="button" class="public-menu-toggle" data-public-menu-open aria-label="메뉴 열기" aria-controls="publicSideMenu" aria-expanded="false"><span></span><span></span><span></span></button>
<div class="public-menu-overlay" data-public-menu-close aria-hidden="true"></div>
<aside class="public-side-menu" id="publicSideMenu" aria-hidden="true">
  <div class="public-menu-head"><b>MENU</b><button type="button" data-public-menu-close aria-label="메뉴 닫기">×</button></div>
  <nav class="public-menu-nav" aria-label="공개 메뉴">
    <a class="public-menu-link" href="/">HOME</a>
    <div class="public-menu-group open" data-public-menu-community><button type="button" class="public-menu-group-title" data-public-submenu-toggle aria-expanded="true"><span>커뮤니티</span><em>⌄</em></button><div class="public-menu-children"><% const _communityBoards=_boards.filter(function(b){return b.slug!=='ad-inquiry';}); %><% _communityBoards.forEach(function(b){ %><a href="/boards/<%=b.slug%>"><%=b.title%></a><% }); %><% if(!_communityBoards.length){ %><span class="public-menu-empty">등록된 게시판이 없습니다.</span><% } %></div></div>
    <div class="public-menu-group open" data-public-menu-inquiry><button type="button" class="public-menu-group-title" data-public-submenu-toggle aria-expanded="true"><span>문의</span><em>⌄</em></button><div class="public-menu-children"><a href="/apply">입점신청</a><a href="/boards/ad-inquiry">광고문의</a></div></div>
    <% if(_me){ %><div class="public-menu-account"><div class="public-menu-section-label">내 계정</div><% if(_me.role==='admin'){ %><a class="public-menu-link" href="/admin">관리자메뉴</a><% } else if(_me.is_vendor){ %><a class="public-menu-link" href="/vendor-dashboard">업체메뉴</a><% } else { %><a class="public-menu-link" href="/mypage">내메뉴</a><% } %></div><% } %>
  </nav>
  <div class="public-menu-auth <%= _me ? 'single' : 'double' %>"><% if(_me){ %><a class="public-menu-auth-btn logout" href="/logout">로그아웃</a><% } else { %><a class="public-menu-auth-btn" href="/login">로그인</a><a class="public-menu-auth-btn primary" href="/join">회원가입</a><% } %></div>
</aside>
