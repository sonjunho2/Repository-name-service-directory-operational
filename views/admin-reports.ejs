<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>신고내역</title><link rel="stylesheet" href="/public/css/style.css"><style>.wrap{padding:24px}.memo{max-width:420px;white-space:pre-wrap;line-height:1.55}.filterbar{display:flex;gap:8px;flex-wrap:wrap;margin:0 0 14px}.filterbar button{height:38px;padding:0 14px;border-radius:999px;border:1px solid #39466c;background:#080d18;color:#dfe9ff;font-weight:900;cursor:pointer}.filterbar button.on{background:linear-gradient(90deg,#ff3fb4,#10d9ff);border-color:transparent;color:#fff}.searchbar{display:grid;grid-template-columns:1fr 110px;gap:10px;margin:0 0 18px}.searchbar input{height:42px;border-radius:12px;border:1px solid #39466c;background:#080d18;color:#fff;padding:0 14px}.searchbar button{height:42px;border:0;border-radius:999px;background:#222b43;color:#dfe9ff;font-weight:900;cursor:pointer}.done{color:#1fe087;font-weight:900}.btn{padding:7px 10px;border:0;border-radius:8px;background:#10d9ff;color:#111;font-weight:900;cursor:pointer}.hidden-row{display:none}@media(max-width:800px){.searchbar{grid-template-columns:1fr}}</style></head><body><header class="top"><b>신고내역</b><nav><a href="/admin">관리자</a><a href="/">사이트</a><a href="/logout">로그아웃</a></nav></header><main class="admin wrap"><section class="panel"><h2>업체 / 후기 신고내역</h2><div class="filterbar"><button type="button" class="on" data-filter="all">전체 <%=flags.length%></button><button type="button" data-filter="new">신규 <%=flags.filter(x=>x.status!=='done').length%></button><button type="button" data-filter="done">처리완료 <%=flags.filter(x=>x.status==='done').length%></button><button type="button" data-filter="vendor">업체신고 <%=flags.filter(x=>x.type==='vendor').length%></button><button type="button" data-filter="review">후기신고 <%=flags.filter(x=>x.type==='review').length%></button></div><div class="searchbar"><input id="reportSearch" placeholder="대상명 / 사유 / 신고내용 검색"><button type="button" id="reportSearchReset">초기화</button></div><table><tr><th>ID</th><th>구분</th><th>대상</th><th>사유</th><th>내용</th><th>상태</th><th>처리</th></tr><% flags.forEach(x=>{ const target=x.vendor_name||x.review_title||x.target_id; %><tr data-status="<%=x.status==='done'?'done':'new'%>" data-type="<%=x.type%>" data-search="<%=String((target||'')+' '+(x.reason||'')+' '+(x.content||'')).toLowerCase()%>"><td><%=x.id%></td><td><%=x.type==='vendor'?'업체':'후기'%></td><td><%=target%></td><td><%=x.reason%></td><td class="memo"><%=x.content||'-'%></td><td><%=x.status==='done'?'처리완료':'신규'%></td><td><% if(x.status==='done'){%><span class="done">완료</span><%}else{%><form method="post" action="/admin/reports/<%=x.id%>/done"><button class="btn">처리완료</button></form><%}%></td></tr><%})%></table></section></main><script>let currentFilter='all';function applyReportFilter(){const q=(document.getElementById('reportSearch')?.value||'').trim().toLowerCase();document.querySelectorAll('tr[data-status]').forEach(row=>{const okFilter=currentFilter==='all'||row.dataset.status===currentFilter||row.dataset.type===currentFilter;const okSearch=!q||row.dataset.search.includes(q);row.classList.toggle('hidden-row',!(okFilter&&okSearch));});}document.querySelectorAll('.filterbar button').forEach(btn=>btn.addEventListener('click',()=>{document.querySelectorAll('.filterbar button').forEach(b=>b.classList.remove('on'));btn.classList.add('on');currentFilter=btn.dataset.filter;applyReportFilter();}));document.getElementById('reportSearch')?.addEventListener('input',applyReportFilter);document.getElementById('reportSearchReset')?.addEventListener('click',()=>{document.getElementById('reportSearch').value='';applyReportFilter();});</script></body></html>