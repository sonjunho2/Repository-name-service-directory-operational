<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>신고내역</title><link rel="stylesheet" href="/public/css/style.css"><style>.wrap{padding:24px}.memo{max-width:420px;white-space:pre-wrap;line-height:1.55}.done{color:#1fe087;font-weight:900}.btn{padding:7px 10px;border:0;border-radius:8px;background:#10d9ff;color:#111;font-weight:900;cursor:pointer}</style></head><body><header class="top"><b>신고내역</b><nav><a href="/admin">관리자</a><a href="/">사이트</a><a href="/logout">로그아웃</a></nav></header><main class="admin wrap"><section class="panel"><h2>업체 / 후기 신고내역</h2><table><tr><th>ID</th><th>구분</th><th>대상</th><th>사유</th><th>내용</th><th>상태</th><th>처리</th></tr><% flags.forEach(x=>{%><tr><td><%=x.id%></td><td><%=x.type==='vendor'?'업체':'후기'%></td><td><%=x.vendor_name||x.review_title||x.target_id%></td><td><%=x.reason%></td><td class="memo"><%=x.content||'-'%></td><td><%=x.status==='done'?'처리완료':'신규'%></td><td><% if(x.status==='done'){%><span class="done">완료</span><%}else{%><form method="post" action="/admin/reports/<%=x.id%>/done"><button class="btn">처리완료</button></form><%}%></td></tr><%})%></table></section></main></body></html>