<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title><%=title%></title><link rel="stylesheet" href="/public/css/style.css"><link rel="stylesheet" href="/public/css/inquiry-polish.css"><style>.wrap{max-width:860px;margin:32px auto;padding:0 18px}.box{border:1px solid #29324f;border-radius:18px;background:#101525;padding:24px}.form{display:grid;grid-template-columns:1fr 1fr;gap:10px}.form input,.form select,.form textarea{height:42px;border-radius:12px;border:1px solid #29324f;background:#070b15;color:#fff;padding:0 12px;box-sizing:border-box}.form textarea{grid-column:1/3;height:130px;padding:12px}.form button{grid-column:1/3;height:46px;border:0;border-radius:999px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900}.done{color:#1fe087;font-weight:900}.err{color:#ff6b6b;font-weight:900}@media(max-width:800px){.form{grid-template-columns:1fr}.form textarea,.form button{grid-column:1}}</style></head><body><header class="top"><a class="brand" href="/">서비스 디렉터리</a><nav><a href="/">홈</a><% if(me){%><a href="/logout">로그아웃</a><%}else{%><a href="/login">로그인</a><%}%></nav></header><main class="wrap"><section class="box"><h2><%=title%></h2><% if(done){%><p class="done">신청이 접수되었습니다. 관리자가 확인 후 연락드리겠습니다.</p><%}else{%><% if(error){%><p class="err"><%=error%></p><%}%><form method="post" action="/inquiry" enctype="multipart/form-data" class="form"><input type="hidden" name="type" value="<%=type%>"><input name="company_name" placeholder="업체명" required><input name="name" placeholder="담당자명"><input name="phone" placeholder="연락처"><input name="kakao" placeholder="카카오톡 ID 또는 링크"><input name="email" placeholder="이메일"><select name="category"><option value="">업종 선택</option><% ((settings&&settings.categories)||['카페','뷰티','맛집','교육','기타']).forEach(x=>{%><option value="<%=x%>"><%=x%></option><%})%></select><select name="region"><option value="">지역 선택</option><% ((settings&&settings.regions)||['서울','부산','대구','인천','광주','대전','제주']).forEach(x=>{%><option value="<%=x%>"><%=x%></option><%})%></select><input type="file" name="main_image" accept="image/*"><input type="file" name="banner_image" accept="image/*"><textarea name="content" placeholder="신청 내용 / 업체 소개"></textarea><button>신청하기</button></form><%}%></section></main></body></html>
