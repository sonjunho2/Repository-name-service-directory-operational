<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title><%=title%></title><link rel="stylesheet" href="/public/css/style.css"><link rel="stylesheet" href="/public/css/home-card-layout-v48.css"><link rel="stylesheet" href="/public/css/vendor-popup-layout-v50.css"><link rel="stylesheet" href="/public/css/inquiry-polish.css">
  <style>.wrap{max-width:860px;margin:32px auto;padding:0 18px}.box{border:1px solid #29324f;border-radius:18px;background:#101525;padding:24px}.form{display:grid;grid-template-columns:1fr 1fr;gap:10px}.form input,.form select,.form textarea{height:42px;border-radius:12px;border:1px solid #29324f;background:#070b15;color:#fff;padding:0 12px;box-sizing:border-box}.form textarea{grid-column:1/3;height:130px;padding:12px}.form button{grid-column:1/3;height:46px;border:0;border-radius:999px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900}.inquiry-image-field{grid-column:1/3;display:grid;gap:7px;padding:14px;border:1px dashed #10d9ff;border-radius:14px;background:#07101f}.inquiry-image-field span{font-weight:900}.inquiry-image-field small{color:#b9c6e4;line-height:1.5}.done{color:#1fe087;font-weight:900}.err{color:#ff6b6b;font-weight:900}@media(max-width:800px){.form{grid-template-columns:1fr}.form textarea,.form button,.inquiry-image-field{grid-column:1}}</style>
</head>
<body class="ui-theme ui-public-page ui-form-page">
  <% const siteBrand=(settings&&settings.brand)?settings.brand:{name:'서비스 디렉터리',showLogo:false,showName:true,logo:'',link:'/'}; %>
  <header class="top"><a class="brand" href="/">홈</a><a class="site-brand-center" href="<%=siteBrand.link||'/'%>"><% if(siteBrand.showLogo&&siteBrand.logo){ %><img src="<%=siteBrand.logo%>" alt=""><% } %><% if(siteBrand.showName){ %><span><%=siteBrand.name%></span><% } %></a><nav><a href="/">홈</a><% if(me){ %><a href="/logout">로그아웃</a><% }else{ %><a href="/login">로그인</a><% } %></nav></header>
  <%- include('partials/public-ad-banner') %>
  <main class="wrap"><section class="box"><h2><%=title%></h2><% if(done){ %><p class="done">신청이 접수되었습니다. 관리자가 확인 후 연락드리겠습니다.</p><% }else{ %><% if(error){ %><p class="err"><%=error%></p><% } %><form method="post" action="/inquiry" enctype="multipart/form-data" class="form"><input type="hidden" name="type" value="<%=type%>"><input name="company_name" placeholder="업체명" required><input name="name" placeholder="담당자명"><input name="phone" placeholder="연락처"><input name="kakao" placeholder="카카오톡 ID 또는 링크"><input name="email" placeholder="이메일"><select name="category"><option value="">업종 선택</option><% ((settings&&settings.categories)||['카페','뷰티','맛집','교육','기타']).forEach(x=>{ %><option value="<%=x%>"><%=x%></option><% }) %></select><select name="region"><option value="">지역 선택</option><% ((settings&&settings.regions)||['서울','부산','대구','인천','광주','대전','제주']).forEach(x=>{ %><option value="<%=x%>"><%=x%></option><% }) %></select><% if(type==='apply'){ %><label class="inquiry-image-field"><span>대표이미지</span><input type="file" name="main_image" accept="image/jpeg,image/png,image/gif,image/webp"><small>업체 카드, 업체정보, 프리미엄 배너에 공통으로 사용됩니다.<br>권장 비율: 세로형 4:5 · JPG, PNG, GIF, WEBP 지원 · 최대 5MB</small></label><% } %><textarea name="content" placeholder="신청 내용 / 업체 소개"></textarea><button>신청하기</button></form><% } %></section></main>
  <%- include('partials/vendor-modal') %>
  <script src="/public/js/app.js"></script>
</body>
</html>
