<!doctype html>
<html lang="ko">
<head>
  <% const brand=settings?.brand||{name:'서비스 디렉터리',showLogo:false,showName:true,logo:'',link:'/'}; const layout=board.layout_type||'list'; const isAdInquiry=board.slug==='ad-inquiry'; const layoutHelp={list:'일반 게시글을 작성합니다.',gallery:'이미지 중심 게시글입니다. 대표 이미지를 등록하세요.',webzine:'대표 이미지와 소개글이 목록에 함께 표시됩니다.',qna:'질문을 남기면 관리자가 답변합니다.',faq:'FAQ는 관리자만 작성하는 것을 권장합니다. 제목은 질문, 내용은 답변으로 작성합니다.',private:'1:1 문의는 작성자와 관리자만 확인할 수 있습니다.'}; %>
  <meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>글쓰기 - <%=board.title%></title><link rel="stylesheet" href="/public/css/style.css"><link rel="stylesheet" href="/public/css/home-card-layout-v48.css"><link rel="stylesheet" href="/public/css/vendor-popup-layout-v50.css">
</head>
<body>
<%- include('partials/public-mobile-menu') %>
<header class="top"><a class="brand" href="/">홈</a><a class="site-brand-center" href="<%=brand.link||'/'%>"><% if(brand.showLogo&&brand.logo){ %><img src="<%=brand.logo%>" alt=""><% } %><% if(brand.showName){ %><span><%=brand.name%></span><% } %></a><nav><a href="/boards/<%=board.slug%>"><%=board.title%></a></nav></header>
<%- include('partials/public-ad-banner') %>
<main class="board-wrap">
  <div class="board-head"><div><h1><%=isAdInquiry?'광고문의 작성':board.title+' 글쓰기'%></h1><p><%=isAdInquiry?'배너 광고, 프리미엄 노출, 제휴 관련 문의 내용을 남겨주세요.':layoutHelp[layout]||layoutHelp.list%><% if(isAdInquiry){ %><br>작성한 문의는 본인과 관리자만 확인할 수 있습니다.<% } %></p></div></div>
  <% if(error){ %><div class="board-form-error"><%=error%></div><% } %>
  <form class="board-form" method="post" action="/boards/<%=board.slug%>/write" enctype="multipart/form-data">
    <label>제목<input name="title" minlength="2" maxlength="100" required placeholder="<%=isAdInquiry?'문의 제목을 입력하세요.':''%>"></label>
    <label>내용<textarea name="content" minlength="2" maxlength="5000" required placeholder="<%=isAdInquiry?'광고 목적, 희망 상품, 연락 가능한 방법 등을 입력하세요.':''%>"></textarea></label>
    <% if(board.image_enabled){ %><label>이미지<input type="file" name="image" accept="image/jpeg,image/png,image/gif,image/webp"></label><div class="board-image-preview"><img alt="이미지 미리보기"></div><% } %>
    <div class="board-actions"><a href="/boards/<%=board.slug%>">취소</a><button class="board-write-btn">등록</button></div>
  </form>
</main>
<%- include('partials/vendor-modal') %>
<script src="/public/js/app.js"></script>
</body>
</html>
