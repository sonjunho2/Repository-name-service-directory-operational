<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>업체 등록 신청</title>
<link rel="stylesheet" href="/public/css/style.css">
<style>
.wrap{max-width:900px;margin:30px auto;padding:0 18px}
.box{border:1px solid #29324f;border-radius:18px;background:#101525;padding:24px}
.box h2{margin:0 0 18px;font-size:28px;line-height:1.25}
.form{display:grid;grid-template-columns:1fr 1fr;gap:12px}.form input,.form select,.form textarea{height:44px;border-radius:12px;border:1px solid #29324f;background:#070b15;color:#fff;padding:0 12px}.form textarea{grid-column:1/3;height:120px;padding:12px;line-height:1.55}.form button{grid-column:1/3;height:48px;border:0;border-radius:999px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900}
.form input[type="file"]{padding:10px 12px;line-height:22px}.full{grid-column:1/3}.image-guide{grid-column:1/3;border:1px dashed #10d9ff;background:#06111c;border-radius:16px;padding:16px;color:#dfe9ff;line-height:1.6}.image-guide b{color:#10d9ff}.image-guide-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;margin-top:12px}.image-guide-grid span{display:block;border:1px solid #29324f;background:#070b15;border-radius:12px;padding:12px;font-size:13px;line-height:1.4}.image-guide-grid strong{display:block;color:#10d9ff;font-size:12px;margin-bottom:5px}.apply-preview-row{grid-column:1/3;display:grid;grid-template-columns:180px minmax(0,1fr);gap:14px;align-items:center;border:1px solid #29324f;background:#070b15;border-radius:16px;padding:14px}.apply-card-preview{width:180px;aspect-ratio:4/5;border-radius:14px;overflow:hidden;background:#050913;border:1px solid #29324f;position:relative}.apply-card-preview:before{content:'IMAGE';position:absolute;inset:0;display:grid;place-items:center;color:#4d5875;font-weight:900;letter-spacing:.08em}.apply-card-preview:after{content:'업체명';position:absolute;left:12px;right:12px;bottom:12px;color:#fff;font-size:18px;font-weight:900;text-shadow:0 2px 10px #000}.apply-preview-row p{margin:0;color:#c8d0e8;line-height:1.65}.done-box{border:1px solid #1fe087;background:#123b2b;color:#dfffee;border-radius:14px;padding:16px;line-height:1.6}
@media(max-width:760px){.form{grid-template-columns:1fr}.form textarea,.form button,.full,.image-guide,.apply-preview-row{grid-column:1}.image-guide-grid{grid-template-columns:1fr 1fr}.apply-preview-row{grid-template-columns:1fr}.apply-card-preview{width:160px}}
@media(max-width:520px){.image-guide-grid{grid-template-columns:1fr}}
</style>
</head>
<body>
<% const siteBrand=(settings&&settings.brand)?settings.brand:{name:'서비스 디렉터리',showLogo:false,showName:true,logo:'',link:'/'}; %>
<header class="top"><a class="brand" href="/">홈</a><a class="site-brand-center" href="<%=siteBrand.link||'/'%>">
    <% if(siteBrand.showLogo&&siteBrand.logo){ %><img src="<%=siteBrand.logo%>" alt=""><% } %>
    <% if(siteBrand.showName){ %><span><%=siteBrand.name%></span><% } %>
  </a><nav><a href="/mypage">마이페이지</a><a href="/logout">로그아웃</a></nav></header>
<main class="wrap">
  <section class="box">
    <h2>업체 등록 신청</h2>
    <% if(done){%>
      <div class="done-box">신청이 접수되었습니다. 관리자가 확인 후 업체회원으로 연결합니다.</div>
    <%}else{%>
      <% if(error){%><p style="color:#ff6b6b"><%=error%></p><%}%>
      <form method="post" action="/vendor-apply" enctype="multipart/form-data" class="form">
        <input name="company_name" placeholder="업체명" required>
        <select name="category"><% settings.categories.forEach(x=>{%><option><%=x%></option><%})%></select>
        <select name="region"><% settings.regions.forEach(x=>{%><option><%=x%></option><%})%></select>
        <input name="phone" placeholder="연락처">
        <input name="kakao_url" placeholder="카카오톡 링크">
        <input name="email" placeholder="이메일">
        <div class="image-guide">
          <b>대표 이미지/GIF 권장 규격</b><br>
          등록한 이미지는 홈의 프리미엄, 추천업체, 일반업체 카드에 공통으로 사용됩니다. 카드가 4:5 기준으로 표시되므로 아래 규격을 권장합니다.
          <div class="image-guide-grid">
            <span><strong>권장 크기</strong>720 × 900px</span>
            <span><strong>권장 비율</strong>4:5 세로형</span>
            <span><strong>파일 형식</strong>JPG / PNG / WEBP / GIF</span>
            <span><strong>최대 용량</strong>5MB 이하</span>
          </div>
        </div>
        <div class="apply-preview-row">
          <div class="apply-card-preview"></div>
          <p>이미지 중앙의 중요한 글자와 연락처가 잘리지 않도록 여백을 조금 두고 제작하는 것이 좋습니다. 너무 가로로 긴 이미지는 카드 안에서 일부가 잘릴 수 있습니다.</p>
        </div>
        <input class="full" type="file" name="image" accept="image/*">
        <textarea name="content" placeholder="업체 소개 / 신청 내용"></textarea>
        <button>신청하기</button>
      </form>
    <%}%>
  </section>
</main>
</body>
</html>
