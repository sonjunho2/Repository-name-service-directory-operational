<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>업체관리</title><link rel="stylesheet" href="/public/css/style.css"><style>.wrap{max-width:1100px;margin:30px auto;padding:0 18px}.box{border:1px solid #29324f;border-radius:18px;background:#101525;padding:22px;margin-bottom:18px}.form{display:grid;grid-template-columns:1fr 1fr;gap:10px}.form input,.form select,.form textarea{height:42px;border-radius:12px;border:1px solid #29324f;background:#070b15;color:#fff;padding:0 12px}.form textarea{grid-column:1/3;height:120px;padding:12px}.form button{grid-column:1/3;height:46px;border:0;border-radius:999px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900}@media(max-width:800px){.form{grid-template-columns:1fr}.form textarea,.form button{grid-column:1}}
.paybox{border:1px solid #10d9ff;border-radius:14px;background:#06111c;padding:14px;margin:10px 0}
.paybox b{color:#10d9ff}.paybox code{display:block;word-break:break-all;background:#030712;border:1px solid #29324f;border-radius:10px;padding:10px;margin-top:8px}
.expiry-alert{border:1px solid #ffdc4d;background:rgba(255,220,77,.12);border-radius:14px;padding:14px;margin-bottom:18px;color:#ffdc4d;font-weight:900}
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:12px}.stat-card{border:1px solid #29324f;background:#070b15;border-radius:14px;padding:14px}.stat-card b{display:block;color:#8d98b8;margin-bottom:8px}.stat-card strong{font-size:24px}.pay-history{overflow-x:auto}@media(max-width:800px){.stat-grid{grid-template-columns:1fr 1fr}}
.upgrade-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:12px}.upgrade-card{border:1px solid #29324f;background:#070b15;border-radius:16px;padding:18px;display:flex;flex-direction:column;min-height:300px}.upgrade-card h4{margin:0 0 10px}.upgrade-card p{min-height:46px}.upgrade-card strong{display:block;font-size:22px;color:#10d9ff;margin:10px 0 14px}.upgrade-card form{display:flex;flex-direction:column;gap:10px;margin-top:auto}.upgrade-card textarea{height:76px!important;min-height:76px!important;background:#070b15!important;color:#fff!important;border:1px solid #29324f!important;border-radius:12px!important;padding:12px!important}.upgrade-card button{height:42px;border:0;border-radius:999px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900}.renewal-box{border:1px solid #10d9ff;border-radius:14px;background:#06111c;padding:16px;margin-top:12px}
.renewal-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;align-items:center}
.renewal-form-grid select{height:44px;background:#070b15;color:#fff;border:1px solid #29324f;border-radius:12px;padding:0 12px}
.renewal-form-grid textarea{grid-column:1/3;height:92px!important;min-height:92px!important;background:#070b15!important;color:#fff!important;border:1px solid #29324f!important;border-radius:12px!important;padding:12px!important;resize:vertical}
.renewal-form-grid button{grid-column:1/3;height:48px;border:0;border-radius:999px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900}
.renewal-actions{grid-column:1/3;display:grid;grid-template-columns:1fr;gap:10px}
.current-plan{border:1px solid #10d9ff;background:linear-gradient(135deg,rgba(16,217,255,.15),rgba(255,63,180,.08));border-radius:16px;padding:18px;margin:0 0 18px}.current-plan-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}.current-plan-item{background:#070b15;border:1px solid #29324f;border-radius:12px;padding:12px}.current-plan-item b{display:block;color:#8d98b8;margin-bottom:8px}.current-plan-item strong{font-size:22px;color:#10d9ff}@media(max-width:900px){.upgrade-grid,.current-plan-grid{grid-template-columns:1fr}.renewal-form-grid{grid-template-columns:1fr}.renewal-form-grid textarea,.renewal-form-grid button,.renewal-actions{grid-column:1}}
</style></head><body><header class="top"><a class="brand" href="/">서비스 디렉터리</a><nav><a href="/">사이트</a><a href="/logout">로그아웃</a></nav></header><main class="wrap"><% if(vendor&&vendor.status==="expired"){%><div class="expiry-alert">광고 기간이 만료되어 현재 노출이 중지되었습니다. 연장 신청 후 입금확인이 완료되면 다시 노출됩니다.</div><%}else if(expiryNotice){%><div class="expiry-alert">노출 만기 <%=expiryNotice.daysLeft%>일 남았습니다. 만기일: <%=expiryNotice.expire_at%></div><%}%><section class="box"><h2>업체관리</h2><% if(vendor){%>
<div class="current-plan">
  <h3>현재 이용 상태</h3>
  <div class="current-plan-grid">
    <div class="current-plan-item"><b>현재 등급</b><strong><%=vendor.banner_active?'프리미엄배너':vendor.membership_type==="recommended"?'추천업체':'일반업체'%></strong></div>
    <div class="current-plan-item"><b>목록 노출</b><strong><%=vendor.membership_type==="recommended"?'추천목록':'일반목록'%></strong></div>
    <div class="current-plan-item"><b>등록 만기일</b><strong><%=vendor.expire_at||'-'%></strong></div>
    <div class="current-plan-item"><b>남은 기간</b><strong><%=pricingPreview?.remainDays||0%>일</strong></div><div class="current-plan-item"><b>노출 상태</b><strong><%=vendor.status==="expired"||((pricingPreview?.remainDays||0)<=0&&vendor.expire_at)?"만료/노출중지":vendor.status==="active"?"노출중":vendor.status==="hidden"?"숨김":"검수중"%></strong></div>
  </div>
  <p style="margin-top:12px;color:#c8d0e8">상품변경 신청은 입금확인 시점부터 즉시 적용되며, 기존 만기일에 선택한 연장기간이 더해집니다.</p>
</div><div class="box" style="background:#070b15"><h3>업체 통계</h3><div class="stat-grid"><div class="stat-card"><b>총 조회수</b><strong><%=vendor.views||0%></strong></div><div class="stat-card"><b>오늘 조회</b><strong><%=viewStats?.today_views||0%></strong></div><div class="stat-card"><b>7일 조회</b><strong><%=viewStats?.week_views||0%></strong></div><div class="stat-card"><b>30일 조회</b><strong><%=viewStats?.month_views||0%></strong></div><div class="stat-card"><b>후기</b><strong><%=stats?.review_count||0%></strong></div><div class="stat-card"><b>평균평점</b><strong><%=stats?.avg_rating||"-"%></strong></div><div class="stat-card"><b>찜</b><strong><%=stats?.favorite_count||0%></strong></div><div class="stat-card"><b>신고</b><strong><%=stats?.report_count||0%></strong></div></div><p>상품등급: <b><%=vendor.membership_type==="recommended"?"추천등록":"일반등록"%></b> · 등록만기일: <b><%=vendor.expire_at||"-"%></b> · 배너: <b><%=vendor.banner_active?"활성":"-"%></b> <%=vendor.banner_until||""%></p></div><p><b><%=vendor.name%></b> / <%=vendor.region%> / <%=vendor.category%></p><p>수정 내용은 바로 반영되지 않고 관리자 승인 후 반영됩니다.</p><form method="post" action="/vendor-dashboard/update-request" enctype="multipart/form-data" class="form"><input name="name" value="<%=vendor.name||''%>" placeholder="업체명"><select name="category"><% settings.categories.forEach(x=>{%><option <%=vendor.category===x?'selected':''%>><%=x%></option><%})%></select><select name="region"><% settings.regions.forEach(x=>{%><option <%=vendor.region===x?'selected':''%>><%=x%></option><%})%></select><input name="phone" value="<%=vendor.phone||''%>" placeholder="연락처"><input name="kakao_url" value="<%=vendor.kakao_url||''%>" placeholder="카카오톡 링크"><input name="business_hours" value="<%=vendor.business_hours||''%>" placeholder="영업시간"><input name="tags" value="<%=vendor.tags||''%>" placeholder="태그"><input type="file" name="image" accept="image/*"><textarea name="description" placeholder="업체소개"><%=vendor.description||''%></textarea><button>수정요청 보내기</button></form><%}else{%><p>연결된 업체가 없습니다.</p><%}%></section><section class="box">
  <h3>상품 변경 / 업그레이드</h3>
  <p>현재 등급과 환경설정 가격에 따라 신청 가능한 상품이 표시됩니다. 입금완료 후 관리자가 입금확인하면 자동 적용됩니다.</p>
  <% const _rate=Number(settings.raw.usdt_krw_rate||1400); const _membership=vendor?.membership_type||'general'; const _banner=!!vendor?.banner_active; const _fmt=n=>Number(n||0).toLocaleString(); const _usdt=n=>((Number(n||0))/_rate).toFixed(2); const priceRec=Number(pricingPreview?.recommended_upgrade||0); const priceBannerGeneral=Number(pricingPreview?.banner_from_general||0); const priceBannerRec=Number(pricingPreview?.banner_from_recommended||0); %>
  <div class="paybox">
    <b>입금주소</b>
    <p>네트워크: <%=settings.raw.usdt_network||"TRC20"%></p>
    <code><%=settings.raw.usdt_address||"관리자가 입금주소를 설정하지 않았습니다."%></code>
  </div>
  <div class="upgrade-grid">
    <% if(_membership==='general'){%>
      <div class="upgrade-card">
        <h4>일반 → 추천 업그레이드</h4>
        <p>일반목록에서 추천목록으로 이동합니다.</p>
        <strong><%=_fmt(priceRec)%>원 / <%=_usdt(priceRec)%> USDT</strong>
        <form method="post" action="/vendor-dashboard/ad-request">
          <input type="hidden" name="product_type" value="recommended_upgrade">
          <input type="hidden" name="period" value="30">
          <textarea name="content" placeholder="요청사항"></textarea>
          <button>추천 업그레이드 신청</button>
        </form>
      </div>
      <div class="upgrade-card">
        <h4>일반 → 프리미엄배너</h4>
        <p>추천업체로 자동 승격되고 프리미엄배너가 활성화됩니다.</p>
        <strong><%=_fmt(priceBannerGeneral)%>원 / <%=_usdt(priceBannerGeneral)%> USDT</strong>
        <form method="post" action="/vendor-dashboard/ad-request">
          <input type="hidden" name="product_type" value="banner_from_general">
          <input type="hidden" name="period" value="30">
          <textarea name="content" placeholder="배너 요청사항"></textarea>
          <button>프리미엄배너 신청</button>
        </form>
      </div>
    <% }else{%>
      <div class="upgrade-card">
        <h4>추천 → 프리미엄배너</h4>
        <p>추천등급은 유지하고 프리미엄배너가 추가됩니다.</p>
        <strong><%=_fmt(priceBannerRec)%>원 / <%=_usdt(priceBannerRec)%> USDT</strong>
        <form method="post" action="/vendor-dashboard/ad-request">
          <input type="hidden" name="product_type" value="banner_from_recommended">
          <input type="hidden" name="period" value="30">
          <textarea name="content" placeholder="배너 요청사항"></textarea>
          <button>프리미엄배너 신청</button>
        </form>
      </div>
    <%}%>
  </div>
</section><section class="box"><h3>프리미엄배너 신청</h3><p>프리미엄배너 승인 시 추천업체로 자동 승격되며, 기존 등록 만기일에 맞춰 배너도 함께 종료됩니다.</p><div class="paybox"><b>배너 가격</b><p><%=Number(settings.raw.banner_price_krw||0).toLocaleString()%>원 / <%=((Number(settings.raw.banner_price_krw||0))/(Number(settings.raw.usdt_krw_rate||1400))).toFixed(2)%> USDT</p><p>네트워크: <%=settings.raw.usdt_network||"TRC20"%></p><code><%=settings.raw.usdt_address||"관리자가 입금주소를 설정하지 않았습니다."%></code></div><form method="post" action="/vendor-dashboard/banner-request" enctype="multipart/form-data" class="form"><input name="title" placeholder="배너 제목" required><input name="subtitle" placeholder="배너 부제목"><input name="link_url" placeholder="연결 링크 URL"><input type="file" name="image" accept="image/*" required><button>배너 신청하기</button></form></section><section class="box">
  <h3>광고 연장 신청</h3>
  <% const gPrice=Number(pricingPreview?.renewal_general||0); const rPrice=Number(pricingPreview?.renewal_recommended||0); const bPrice=Number(pricingPreview?.renewal_banner||0); const rate2=Number(settings.raw.usdt_krw_rate||1400); const usdt2=n=>((Number(n||0))/rate2).toFixed(2); %>
  <div class="paybox">
    <b>연장 상품 가격</b><p>아래 금액은 현재 남은 기간 차액과 30일 연장 기준이 반영된 예상금액입니다.</p>
    <p>일반업체 30일 <%=gPrice.toLocaleString()%>원 / <%=usdt2(gPrice)%> USDT</p>
    <p>추천업체 30일 <%=rPrice.toLocaleString()%>원 / <%=usdt2(rPrice)%> USDT</p>
    <p>프리미엄배너 <%=bPrice.toLocaleString()%>원 / <%=usdt2(bPrice)%> USDT</p>
    <p>네트워크: <%=settings.raw.usdt_network||"TRC20"%></p>
    <code><%=settings.raw.usdt_address||"관리자가 입금주소를 설정하지 않았습니다."%></code>
  </div>
  <form method="post" action="/vendor-dashboard/ad-request" class="renewal-box">
    <div class="renewal-form-grid">
      <select name="product_type">
        <option value="renewal_general">일반업체 연장</option>
        <option value="renewal_recommended" <%=vendor?.membership_type==='recommended'&&!vendor?.banner_active?'selected':''%>>추천업체 연장</option>
        <option value="renewal_banner" <%=vendor?.banner_active?'selected':''%>>프리미엄배너 연장</option>
      </select>
      <select name="period">
        <option value="30">30일</option>
        <option value="60">60일</option>
        <option value="90">90일</option>
      </select>
      <textarea name="content" placeholder="요청사항"></textarea>
      <button>연장 신청하기</button>
    </div>
  </form>
</section><section class="box"><h3>배너/광고 신청 내역</h3><table><tr><th>구분</th><th>내용</th><th>상태</th><th>메모</th></tr><% (bannerRequests||[]).forEach(r=>{%><tr><td>배너</td><td><%=r.title%><br><small><%=Number(r.krw_price||0).toLocaleString()%>원 / <%=r.usdt_amount||0%> USDT</small></td><td><%=r.status==='approved'?'승인':r.status==='rejected'?'반려':r.payment_status==='waiting'?'입금확인대기':'입금대기'%></td><td><%=r.admin_memo||'-'%><% if(r.status==='new'&&r.payment_status!=='waiting'){%><form method="post" action="/vendor-dashboard/banner-request/<%=r.id%>/paid"><button>입금완료</button></form><%}%></td></tr><%})%><% (adRequests||[]).forEach(r=>{%><tr><td>광고연장</td><td><%=r.plan%> / <%=r.period%>일<br><small><%=r.product_type==='recommended_upgrade'?'일반→추천':r.product_type==='banner_from_general'?'일반→배너':r.product_type==='banner_from_recommended'?'추천→배너':r.product_type==='renewal_general'?'일반연장':r.product_type==='renewal_recommended'?'추천연장':r.product_type==='renewal_banner'?'배너연장':r.product_type||''%></small><br><small><%=Number(r.krw_price||0).toLocaleString()%>원 / <%=r.usdt_amount||0%> USDT</small></td><td><%=r.status==='approved'?'승인':r.status==='rejected'?'반려':r.payment_status==='waiting'?'입금확인대기':'입금대기'%></td><td><%=r.admin_memo||'-'%><% if(r.status==='new'&&r.payment_status!=='waiting'){%><form method="post" action="/vendor-dashboard/ad-request/<%=r.id%>/paid"><button>입금완료</button></form><%}%></td></tr><%})%></table></section><section class="box">
  <h3>결제내역</h3>
  <div class="pay-history">
    <table>
      <tr><th>상품</th><th>원화</th><th>USDT</th><th>상태</th><th>결제일</th><th>메모</th></tr>
      <% (paymentLogs||[]).forEach(p=>{%>
        <tr>
          <td><%=p.product_type==='banner'?'프리미엄배너':p.product_type==='recommended'?'추천등록':p.product_type||'-'%></td>
          <td><%=Number(p.krw_price||0).toLocaleString()%>원</td>
          <td><%=p.usdt_amount||0%> USDT</td>
          <td><%=p.status||'paid'%></td>
          <td><%=p.paid_at?new Date(p.paid_at).toLocaleString('ko-KR'):'-'%></td>
          <td><%=p.memo||'-'%></td>
        </tr>
      <%})%>
    </table>
  </div>
</section><section class="box"><h3>수정요청 내역</h3><table><tr><th>ID</th><th>업체명</th><th>상태</th><th>관리자 메모</th></tr><% requests.forEach(r=>{%><tr><td><%=r.id%></td><td><%=r.name%></td><td><%=r.status==='approved'?'승인':r.status==='rejected'?'반려':'대기'%></td><td><%=r.admin_memo||'-'%></td></tr><%})%></table></section></main></body></html>
