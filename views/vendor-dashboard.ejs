<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>업체관리</title><link rel="stylesheet" href="/public/css/style.css"><style>.wrap{max-width:1100px;margin:30px auto;padding:0 18px}.box{border:1px solid #29324f;border-radius:18px;background:#101525;padding:22px;margin-bottom:18px}.form{display:grid;grid-template-columns:1fr 1fr;gap:10px}.form input,.form select,.form textarea{height:42px;border-radius:12px;border:1px solid #29324f;background:#070b15;color:#fff;padding:0 12px}.form textarea{grid-column:1/3;height:120px;padding:12px}.form button{grid-column:1/3;height:46px;border:0;border-radius:999px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900}@media(max-width:800px){.form{grid-template-columns:1fr}.form textarea,.form button{grid-column:1}}
.paybox{border:1px solid #10d9ff;border-radius:14px;background:#06111c;padding:14px;margin:10px 0}
.paybox b{color:#10d9ff}.paybox code{display:block;word-break:break-all;background:#030712;border:1px solid #29324f;border-radius:10px;padding:10px;margin-top:8px}
.expiry-alert{border:1px solid #ffdc4d;background:rgba(255,220,77,.12);border-radius:14px;padding:14px;margin-bottom:18px;color:#ffdc4d;font-weight:900}
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:12px}.stat-card{border:1px solid #29324f;background:#070b15;border-radius:14px;padding:14px}.stat-card b{display:block;color:#8d98b8;margin-bottom:8px}.stat-card strong{font-size:24px}.pay-history{overflow-x:auto}@media(max-width:800px){.stat-grid{grid-template-columns:1fr 1fr}}
.upgrade-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:12px}.upgrade-card{border:1px solid #29324f;background:#070b15;border-radius:16px;padding:18px;display:flex;flex-direction:column;min-height:300px}.upgrade-card h4{margin:0 0 10px}.upgrade-card p{min-height:46px}.upgrade-card strong{display:block;font-size:22px;color:#10d9ff;margin:10px 0 14px}.upgrade-card form{display:flex;flex-direction:column;gap:10px;margin-top:auto}.upgrade-card textarea{height:76px!important;min-height:76px!important;background:#070b15!important;color:#fff!important;border:1px solid #29324f!important;border-radius:12px!important;padding:12px!important}.upgrade-card button{height:42px;border:0;border-radius:999px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900}.renewal-box{border:1px solid #10d9ff;border-radius:14px;background:#06111c;padding:16px;margin-top:12px}
.renewal-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;align-items:center}
.renewal-form-grid select{height:44px;background:#070b15;color:#fff;border:1px solid #29324f;border-radius:12px;padding:0 12px}
.renewal-form-grid textarea{grid-column:1/3;height:92px!important;min-height:92px!important;background:#070b15!important;color:#fff!important;border:1px solid #29324f!important;border-radius:12px!important;padding:12px!important;resize:vertical}
.renewal-form-grid button{grid-column:1/3;height:48px;border:0;border-radius:999px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900}
.renewal-actions{grid-column:1/3;display:grid;grid-template-columns:1fr;gap:10px}
.current-plan{border:1px solid #10d9ff;background:linear-gradient(135deg,rgba(16,217,255,.15),rgba(255,63,180,.08));border-radius:16px;padding:18px;margin:0 0 18px}.current-plan-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}.current-plan-item{background:#070b15;border:1px solid #29324f;border-radius:12px;padding:12px}.current-plan-item b{display:block;color:#8d98b8;margin-bottom:8px}.current-plan-item strong{font-size:22px;color:#10d9ff}@media(max-width:900px){.upgrade-grid,.current-plan-grid{grid-template-columns:1fr}.renewal-form-grid{grid-template-columns:1fr}.renewal-form-grid textarea,.renewal-form-grid button,.renewal-actions{grid-column:1}}
.pay-status{display:inline-flex;align-items:center;height:24px;padding:0 9px;border-radius:999px;font-size:12px;font-weight:900}.pay-wait{background:#29324f;color:#dfe9ff}.pay-check{background:#3d3412;color:#ffdc4d}.pay-done{background:#123b2b;color:#1fe087}.pay-bad{background:#3b1212;color:#ff6b6b}.inline-actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}.inline-actions form{margin:0}.inline-actions button{height:34px;padding:0 12px}
.vendor-edit-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.vendor-edit-grid .full{grid-column:1/3}.preview-card{border:1px solid #10d9ff;background:#06111c;border-radius:16px;padding:16px;margin-top:14px}.preview-card img{max-width:180px;border-radius:12px;border:1px solid #29324f}.tag-preview{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}.tag-preview span{background:#29324f;border-radius:999px;padding:5px 9px;font-size:12px}.image-note{color:#8d98b8;font-size:13px;margin-top:6px}@media(max-width:900px){.vendor-edit-grid{grid-template-columns:1fr}.vendor-edit-grid .full{grid-column:1}}
.vendor-layout{display:grid;grid-template-columns:240px 1fr;gap:18px;align-items:start}
.vendor-side{position:sticky;top:16px;border:1px solid #29324f;background:#070b15;border-radius:18px;padding:16px}
.vendor-side h3{margin:0 0 12px}.vendor-menu-group{margin-top:14px;padding-top:14px;border-top:1px solid #29324f}
.vendor-menu-title{font-size:13px;color:#8d98b8;font-weight:900;margin-bottom:8px}
.vendor-menu-btn{width:100%;height:38px;border:0;border-radius:10px;background:transparent;color:#dfe9ff;text-align:left;padding:0 12px;font-weight:800;cursor:pointer}
.vendor-menu-btn:hover,.vendor-menu-btn.active{background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff}
.vendor-panel{display:none}.vendor-panel.active{display:block}
.home-summary{display:grid;grid-template-columns:1fr 1fr;gap:14px}.quick-list{border:1px solid #29324f;border-radius:14px;background:#070b15;padding:14px}
.quick-list h4{margin:0 0 10px}.quick-list div{display:flex;justify-content:space-between;border-bottom:1px solid #202842;padding:8px 0;gap:12px}.quick-list div:last-child{border-bottom:0}
.vendor-edit-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.vendor-edit-grid .full{grid-column:1/3}
.preview-card{border:1px solid #10d9ff;background:#06111c;border-radius:16px;padding:16px;margin:14px 0}
.preview-card img{max-width:180px;border-radius:12px;border:1px solid #29324f}.tag-preview{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px}.tag-preview span{background:#29324f;border-radius:999px;padding:5px 9px;font-size:12px}
.clean-table{width:100%;border-collapse:collapse}.clean-table th,.clean-table td{border:1px solid #29324f;padding:10px;text-align:left;vertical-align:top}.clean-table th{background:#171d30}
@media(max-width:900px){.vendor-layout{grid-template-columns:1fr}.vendor-side{position:static}.home-summary,.vendor-edit-grid{grid-template-columns:1fr}.vendor-edit-grid .full{grid-column:1}.vendor-menu-btn{text-align:center}}
</style></head><body><header class="top"><a class="brand" href="/">서비스 디렉터리</a><nav><a href="/">사이트</a><a href="/logout">로그아웃</a></nav></header><main class="wrap">
  <% if(vendor&&vendor.status==="expired"){%>
    <div class="expiry-alert">광고 기간이 만료되어 현재 노출이 중지되었습니다. 연장 신청 후 입금확인이 완료되면 다시 노출됩니다.</div>
  <%}else if(expiryNotice){%>
    <div class="expiry-alert">노출 만기 <%=expiryNotice.daysLeft%>일 남았습니다. 만기일: <%=fmtDate(expiryNotice.expire_at)%></div>
  <%}%>

  <% if(!vendor){%>
    <section class="box"><h2>업체관리</h2><p>연결된 업체가 없습니다.</p></section>
  <%}else{%>
  <div class="vendor-layout">
    <aside class="vendor-side">
      <h3>업체관리</h3>
      <button type="button" class="vendor-menu-btn active" data-vendor-panel="home">홈</button>

      <div class="vendor-menu-group">
        <div class="vendor-menu-title">업체내용 변경</div>
        <button type="button" class="vendor-menu-btn" data-vendor-panel="edit">업체정보 수정</button>
      </div>

      <div class="vendor-menu-group">
        <div class="vendor-menu-title">상품신청</div>
        <button type="button" class="vendor-menu-btn" data-vendor-panel="upgrade">변경/연장 신청</button>
        
        <button type="button" class="vendor-menu-btn" data-vendor-panel="banner">프리미엄배너 신청</button>
      </div>

      <div class="vendor-menu-group">
        <div class="vendor-menu-title">내역관리</div>
        <button type="button" class="vendor-menu-btn" data-vendor-panel="requests">배너/상품 신청내역</button>
        <button type="button" class="vendor-menu-btn" data-vendor-panel="payments">결제내역</button>
        <button type="button" class="vendor-menu-btn" data-vendor-panel="updateHistory">수정요청내역</button>
      </div>
    </aside>

    <div class="vendor-content">

      <div id="vendor-panel-home" class="vendor-panel active">
        <section class="box">
          <h2>현재 이용 상태</h2>
          <div class="current-plan">
            <div class="current-plan-grid">
              <div class="current-plan-item"><b>현재 등급</b><strong><%=vendor.ad_type==='none'?'광고없음':vendor.banner_active?'추천광고+프리미엄배너':vendor.ad_type==='recommended'?'추천광고':'일반광고'%></strong></div>
              <div class="current-plan-item"><b>목록 노출</b><strong><%=vendor.ad_type==='none'?'노출안함':vendor.ad_type==='recommended'?'추천목록':'일반목록'%></strong></div>
              <div class="current-plan-item"><b>등록 만기일</b><strong><%=fmtDate(vendor.expire_at)%></strong></div>
              <div class="current-plan-item"><b>남은 기간</b><strong><%=pricingPreview?.remainDays||0%>일</strong></div>
              <div class="current-plan-item"><b>노출 상태</b><strong><%=vendor.status==="expired"||((pricingPreview?.remainDays||0)<=0&&vendor.expire_at)?"만료/노출중지":vendor.status==="active"?"노출중":vendor.status==="hidden"?"숨김":"검수중"%></strong></div>
            </div>
          </div>
        </section>

        <section class="box">
          <h3>업체 통계</h3>
          <div class="stat-grid">
            <div class="stat-card"><b>총 조회수</b><strong><%=vendor.views||0%></strong></div>
            <div class="stat-card"><b>오늘 조회</b><strong><%=viewStats?.today_views||0%></strong></div>
            <div class="stat-card"><b>7일 조회</b><strong><%=viewStats?.week_views||0%></strong></div>
            <div class="stat-card"><b>30일 조회</b><strong><%=viewStats?.month_views||0%></strong></div>
            <div class="stat-card"><b>후기</b><strong><%=stats?.review_count||0%></strong></div>
            <div class="stat-card"><b>평균평점</b><strong><%=stats?.avg_rating||"-"%></strong></div>
            <div class="stat-card"><b>찜</b><strong><%=stats?.favorite_count||0%></strong></div>
            <div class="stat-card"><b>신고</b><strong><%=stats?.report_count||0%></strong></div>
          </div>
        </section>

        <section class="box">
          <h3>최근 내역 요약</h3>
          <div class="home-summary">
            <div class="quick-list">
              <h4>최근 상품/광고 신청</h4>
              <% (adRequests||[]).slice(0,5).forEach(r=>{%>
                <div><span><%=r.plan||'-'%></span><b><%=r.status==='approved'?'승인':r.status==='rejected'?'반려':r.status==='cancelled'?'취소':r.payment_status==='waiting'?'입금확인대기':'입금대기'%></b></div>
              <%})%>
              <% if(!(adRequests||[]).length){%><div><span>신청내역 없음</span><b>-</b></div><%}%>
            </div>
            <div class="quick-list">
              <h4>최근 결제내역</h4>
              <% (paymentLogs||[]).slice(0,5).forEach(p=>{%>
                <div><span><%=p.product_type==='banner'?'프리미엄배너':p.product_type==='recommended'?'추천등록':p.product_type==='general'?'일반등록':p.product_type||'-'%></span><b><%=Number(p.krw_price||0).toLocaleString()%>원</b></div>
              <%})%>
              <% if(!(paymentLogs||[]).length){%><div><span>결제내역 없음</span><b>-</b></div><%}%>
            </div>
          </div>
        </section>
      </div>

      <div id="vendor-panel-edit" class="vendor-panel">
        <section class="box">
          <h3>업체정보 수정요청</h3>
          <p>수정요청은 관리자 승인 후 실제 업체정보에 반영됩니다.</p>
          <div class="preview-card">
            <h4>현재 업체정보 미리보기</h4>
            <% if(vendor.image_data){%><img src="<%=vendor.image_data%>" alt="대표이미지"><%}%>
            <p><b><%=vendor.name%></b> · <%=vendor.category%> · <%=vendor.region%></p>
            <p>전화: <%=vendor.phone||'-'%> / 카카오: <%=vendor.kakao_url||'-'%></p>
            <p>영업시간: <%=vendor.business_hours||'-'%></p>
            <p>휴무/안내: <%=vendor.holiday_info||'-'%></p>
            <p>SNS: <%=vendor.sns_url||'-'%> / LINE: <%=vendor.line_url||'-'%> / Telegram: <%=vendor.telegram_url||'-'%></p>
            <div class="tag-preview">
              <% String(vendor.tags||'').split(',').map(x=>x.trim()).filter(Boolean).forEach(t=>{%><span>#<%=t%></span><%})%>
            </div>
          </div>

          <form method="post" action="/vendor-dashboard/update-request" enctype="multipart/form-data" class="vendor-edit-grid">
            <input name="name" value="<%=vendor.name||''%>" placeholder="업체명">
            <select name="category"><% (settings.categories||[]).forEach(c=>{%><option value="<%=c%>" <%=vendor.category===c?'selected':''%>><%=c%></option><%})%></select>
            <select name="region"><% (settings.regions||[]).forEach(r=>{%><option value="<%=r%>" <%=vendor.region===r?'selected':''%>><%=r%></option><%})%></select>
            <input name="phone" value="<%=vendor.phone||''%>" placeholder="연락처">
            <input name="kakao_url" value="<%=vendor.kakao_url||''%>" placeholder="카카오 링크 또는 ID">
            <input name="sns_url" value="<%=vendor.sns_url||''%>" placeholder="SNS 링크">
            <input name="line_url" value="<%=vendor.line_url||''%>" placeholder="LINE 링크 또는 ID">
            <input name="telegram_url" value="<%=vendor.telegram_url||''%>" placeholder="Telegram 링크 또는 ID">
            <input name="business_hours" value="<%=vendor.business_hours||''%>" placeholder="영업시간 예: 10:00 ~ 24:00">
            <input name="holiday_info" value="<%=vendor.holiday_info||''%>" placeholder="휴무/공지 예: 연중무휴">
            <textarea class="full" name="tags" placeholder="키워드/태그"><%=vendor.tags||''%></textarea>
            <textarea class="full" name="description" placeholder="업체 소개"><%=vendor.description||''%></textarea>
            <div class="full"><input type="file" name="image" accept="image/*"><div class="image-note">새 이미지를 선택하지 않으면 기존 대표이미지가 유지됩니다.</div></div>
            <button class="full">수정요청 보내기</button>
          </form>
        </section>
      </div>

      <div id="vendor-panel-upgrade" class="vendor-panel">
        <section class="box">
          <h3>변경/연장 신청</h3>
          <p>일반/추천 변경과 기간 연장을 함께 신청합니다. 일반 → 추천은 바로 적용을 선택하면 남은 기간 차액이 포함됩니다.</p>
          <% const gPrice=Number(pricingPreview?.renewal_general||0); const rPriceNoImmediate=Number(settings.raw.recommended_register_price_krw||0); const rPriceImmediate=Number(pricingPreview?.renewal_recommended||0); const rate2=Number(settings.raw.usdt_krw_rate||1400); const usdt2=n=>((Number(n||0))/rate2).toFixed(2); %>
          <div class="paybox">
            <b>변경/연장 예상금액</b>
            <p>일반업체 30일 <%=gPrice.toLocaleString()%>원 / <%=usdt2(gPrice)%> USDT</p>
            <p>추천업체 30일 <%=rPriceNoImmediate.toLocaleString()%>원 / <%=usdt2(rPriceNoImmediate)%> USDT</p>
            <% if(vendor.membership_type==='general'){%><p>일반 → 추천 바로 적용 예상금액: <%=rPriceImmediate.toLocaleString()%>원 / <%=usdt2(rPriceImmediate)%> USDT</p><%}%>
            <p>네트워크: <%=settings.raw.usdt_network||"TRC20"%></p>
            <code><%=settings.raw.usdt_address||"관리자가 입금주소를 설정하지 않았습니다."%></code>
          </div>
          <form method="post" action="/vendor-dashboard/ad-request" class="renewal-box">
            <div class="renewal-form-grid">
              <select name="product_type">
                <option value="renewal_general" <%=vendor?.membership_type==='general'?'selected':''%>>일반광고 신청/변경/연장</option>
                <option value="renewal_recommended" <%=vendor?.membership_type==='recommended'&&!vendor?.banner_active?'selected':''%>>추천광고 신청/변경/연장</option>
              </select>
              <select name="period"><option value="30">30일</option><option value="60">60일</option><option value="90">90일</option></select>
              <% if(vendor.membership_type==='general'){%>
                <label class="full" style="display:flex;gap:8px;align-items:center"><input type="checkbox" name="immediate_apply" value="1"> 추천업체로 바로 적용하기</label>
              <%}%>
              <textarea name="content" placeholder="요청사항"></textarea>
              <button>변경/연장 신청하기</button>
            </div>
          </form>
        </section>
      </div>

      <div id="vendor-panel-banner" class="vendor-panel">
        <section class="box">
          <h3>프리미엄배너 신청/연장</h3>
          <% const bannerPrice = vendor.membership_type==='recommended' ? Number(settings.raw.recommended_to_banner_price_krw||settings.raw.banner_price_krw||0) : Number(settings.raw.general_to_banner_price_krw||0); const bannerUsdt=((bannerPrice)/(Number(settings.raw.usdt_krw_rate||1400))).toFixed(2); %>
          <p>프리미엄배너는 추천광고 + 배너 노출 상품입니다. 일반업체는 추천승급 비용이 포함되어 가격이 다르게 표시됩니다.</p>
          <div class="paybox">
            <b><%=vendor.banner_active?'프리미엄배너 연장 가격':'프리미엄배너 신청 가격'%></b>
            <% if(vendor.membership_type==='recommended'){%>
              <p>추천광고 업체 배너 <%=vendor.banner_active?'연장':'추가'%>: <%=bannerPrice.toLocaleString()%>원 / <%=bannerUsdt%> USDT</p>
            <%}else{%>
              <p>일반업체 프리미엄배너: <%=bannerPrice.toLocaleString()%>원 / <%=bannerUsdt%> USDT</p>
              <p>추천광고 전환 + 프리미엄배너 노출이 함께 적용됩니다.</p>
            <%}%>
            <p>네트워크: <%=settings.raw.usdt_network||"TRC20"%></p>
            <code><%=settings.raw.usdt_address||"관리자가 입금주소를 설정하지 않았습니다."%></code>
          </div>

          <% if(vendor.banner_active){%>
            <form method="post" action="/vendor-dashboard/ad-request" class="renewal-box">
              <div class="renewal-form-grid">
                <input type="hidden" name="product_type" value="renewal_banner">
                <select name="period"><option value="30">30일</option><option value="60">60일</option><option value="90">90일</option></select>
                <textarea name="content" placeholder="배너 연장 요청사항"></textarea>
                <button>프리미엄배너 연장 신청하기</button>
              </div>
            </form>
          <%}else{%>
            <form method="post" action="/vendor-dashboard/banner-request" enctype="multipart/form-data" class="form">
              <input name="title" placeholder="배너 제목" required>
              <input name="subtitle" placeholder="배너 부제목">
              <input name="link_url" placeholder="연결 링크 URL">
              <input type="file" name="image" accept="image/*" required>
              <button>배너 신청하기</button>
            </form>
          <%}%>
        </section>
      </div>

      <div id="vendor-panel-requests" class="vendor-panel">
        <section class="box">
          <h3>배너/상품 신청내역</h3>
          <table class="clean-table"><tr><th>구분</th><th>내용</th><th>상태</th><th>메모/처리</th></tr>
          <% (bannerRequests||[]).forEach(r=>{%><tr><td>배너</td><td><%=r.title%><br><small><%=Number(r.krw_price||0).toLocaleString()%>원 / <%=r.usdt_amount||0%> USDT</small></td><td><%=r.status==='approved'?'입금완료/승인':r.status==='rejected'?'반려':r.status==='cancelled'?'취소':r.payment_status==='waiting'?'입금확인대기':'입금대기'%></td><td><%=r.admin_memo||'-'%><% if(r.status==='new'){%><div class="inline-actions"><% if(r.payment_status!=='waiting'){%><form method="post" action="/vendor-dashboard/banner-request/<%=r.id%>/paid"><button>입금완료</button></form><%}%><form method="post" action="/vendor-dashboard/banner-request/<%=r.id%>/cancel"><button>신청취소</button></form></div><%}%></td></tr><%})%>
          <% (adRequests||[]).forEach(r=>{%><tr><td>상품/광고</td><td><%=r.plan%> / <%=r.period%>일<br><small><%=Number(r.krw_price||0).toLocaleString()%>원 / <%=r.usdt_amount||0%> USDT</small></td><td><%=r.status==='approved'?'입금완료/승인':r.status==='rejected'?'반려':r.status==='cancelled'?'취소':r.payment_status==='waiting'?'입금확인대기':'입금대기'%></td><td><%=r.admin_memo||'-'%><% if(r.status==='new'){%><div class="inline-actions"><% if(r.payment_status!=='waiting'){%><form method="post" action="/vendor-dashboard/ad-request/<%=r.id%>/paid"><button>입금완료</button></form><%}%><form method="post" action="/vendor-dashboard/ad-request/<%=r.id%>/cancel"><button>신청취소</button></form></div><%}%></td></tr><%})%>
          </table>
        </section>
      </div>

      <div id="vendor-panel-payments" class="vendor-panel">
        <section class="box">
          <h3>결제내역</h3>
          <table class="clean-table"><tr><th>상품</th><th>원화</th><th>USDT</th><th>상태</th><th>결제일</th><th>메모</th></tr>
          <% (paymentLogs||[]).forEach(p=>{%><tr><td><%=p.product_type==='banner'?'프리미엄배너':p.product_type==='recommended'?'추천등록':p.product_type==='general'?'일반등록':p.product_type||'-'%></td><td><%=Number(p.krw_price||0).toLocaleString()%>원</td><td><%=p.usdt_amount||0%> USDT</td><td><%=p.status||'paid'%></td><td><%=fmtDateTime(p.paid_at)%></td><td><%=p.memo||'-'%></td></tr><%})%>
          <% if(!(paymentLogs||[]).length){%><tr><td colspan="6">결제내역이 없습니다.</td></tr><%}%>
          </table>
        </section>
      </div>

      <div id="vendor-panel-updateHistory" class="vendor-panel">
        <section class="box">
          <h3>수정요청내역</h3>
          <table class="clean-table"><tr><th>ID</th><th>업체명</th><th>상태</th><th>관리자 메모</th></tr>
          <% (requests||[]).forEach(r=>{%><tr><td><%=r.id%></td><td><%=r.name%></td><td><%=r.status==='approved'?'승인':r.status==='rejected'?'반려':'대기'%></td><td><%=r.admin_memo||'-'%></td></tr><%})%>
          <% if(!(requests||[]).length){%><tr><td colspan="4">수정요청내역이 없습니다.</td></tr><%}%>
          </table>
        </section>
      </div>

    </div>
  </div>
  <%}%>
</main>
<script>
document.querySelectorAll('.vendor-menu-btn[data-vendor-panel]').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.vendor-menu-btn[data-vendor-panel]').forEach(x=>x.classList.remove('active'));
    document.querySelectorAll('.vendor-panel').forEach(x=>x.classList.remove('active'));
    btn.classList.add('active');
    const target=document.getElementById('vendor-panel-'+btn.dataset.vendorPanel);
    if(target) target.classList.add('active');
    window.scrollTo({top:0,behavior:'smooth'});
  });
});
</script>
</body></html>
