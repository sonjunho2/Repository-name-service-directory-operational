<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>업체관리</title>
<link rel="stylesheet" href="/public/css/style.css">
<style>
.wrap{max-width:1320px;margin:30px auto;padding:0 18px}
.layout{display:grid;grid-template-columns:220px minmax(0,1fr);gap:22px}
.side,.box{border:1px solid #29324f;border-radius:18px;background:#101525;padding:20px}
.side{position:sticky;top:16px;height:max-content}
.side h2{margin-top:0}.menu-btn{width:100%;height:40px;border:0;border-radius:12px;background:transparent;color:#fff;text-align:left;padding:0 12px;font-weight:800;cursor:pointer}
.menu-btn.active,.menu-btn:hover{background:linear-gradient(90deg,#ff3fb4,#10d9ff)}
.group{border-top:1px solid #29324f;margin-top:14px;padding-top:14px}.group-title{color:#8d98b8;font-size:13px;margin-bottom:8px}
.panel{display:none}.panel.active{display:block}
.grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}.card{background:#070b15;border:1px solid #29324f;border-radius:14px;padding:16px;min-height:96px;box-sizing:border-box}
.card b{display:block;color:#8d98b8;margin-bottom:8px}.card strong{display:block;font-size:22px;color:#10d9ff;line-height:1.25;word-break:keep-all}
.form{display:grid;grid-template-columns:1fr 1fr;gap:10px}.form input,.form select,.form textarea{height:42px;border-radius:12px;border:1px solid #29324f;background:#070b15;color:#fff;padding:0 12px}.form textarea{grid-column:1/3;height:90px;padding:12px}.form button{grid-column:1/3;height:46px;border:0;border-radius:999px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900}
.paybox{border:1px solid #10d9ff;background:#06111c;border-radius:14px;padding:14px;margin:12px 0}.paybox b{color:#10d9ff}.addr{display:grid;grid-template-columns:1fr auto;gap:8px}.addr input{height:42px;border-radius:10px;border:1px solid #29324f;background:#070b15;color:#fff;padding:0 12px}.addr button{border:0;border-radius:10px;background:#29324f;color:#fff;padding:0 14px}
.table{width:100%;border-collapse:collapse}.table th,.table td{border:1px solid #29324f;padding:9px;text-align:left}.table th{background:#171d30}
.actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}.actions form{margin:0}.actions button{height:36px;border:0;border-radius:999px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;padding:0 14px}
@media(max-width:900px){.layout,.grid,.form{grid-template-columns:1fr}.form textarea,.form button{grid-column:1}.side{position:static}.addr{grid-template-columns:1fr}}
.status-waiting{display:inline-flex;align-items:center;gap:6px;background:#3d3412;color:#ffdc4d;border:1px solid #ffdc4d;border-radius:999px;padding:6px 12px;font-weight:900}
.status-waiting:before{content:'●';animation:blink 1s infinite}
@keyframes blink{0%,100%{opacity:.3}50%{opacity:1}}
.file-guide{border:1px dashed #10d9ff;background:#06111c;border-radius:12px;padding:12px;margin:10px 0;color:#dfe9ff}
.file-guide b{color:#10d9ff}
.banner-preview{display:flex;gap:12px;align-items:center;border:1px solid #29324f;background:#070b15;border-radius:14px;padding:12px;margin:12px 0}
.banner-preview img{width:120px;height:80px;object-fit:cover;border-radius:10px;border:1px solid #29324f}
.vendor-home-section{margin-top:18px}
.vendor-status-list{display:grid;gap:10px}
.vendor-status-item{border:1px solid #29324f;background:#070b15;border-radius:14px;padding:14px;display:grid;grid-template-columns:1fr auto;gap:12px;align-items:center}
.vendor-status-item b{display:block;color:#fff;margin-bottom:4px}
.vendor-status-item small{color:#8d98b8}
.vendor-status-badge{display:inline-flex;align-items:center;height:28px;padding:0 10px;border-radius:999px;font-size:13px;font-weight:900}
.vendor-status-unpaid{background:#29324f;color:#dfe9ff}
.vendor-status-waiting{background:#3d3412;color:#ffdc4d;border:1px solid #ffdc4d}
.vendor-status-approved{background:#123b2b;color:#1fe087}
.vendor-status-rejected,.vendor-status-cancelled{background:#3b1212;color:#ff6b6b}
.vendor-empty{border:1px dashed #29324f;background:#070b15;border-radius:14px;padding:16px;color:#8d98b8}
@media(max-width:900px){.vendor-status-item{grid-template-columns:1fr}}
.vendor-stat-note{display:block;margin-top:8px;color:#8d98b8;font-size:12px;font-weight:700;line-height:1.35}.vendor-stat-grid{display:grid;grid-template-columns:repeat(4,minmax(160px,1fr));gap:12px}.vendor-stat-card{background:#070b15;border:1px solid #29324f;border-radius:14px;padding:16px;min-height:104px;box-sizing:border-box}.vendor-stat-card b{display:block;color:#8d98b8;margin-bottom:8px}.vendor-stat-card strong{display:block;font-size:26px;color:#10d9ff;line-height:1.2;word-break:keep-all}.vendor-stat-card.good{border-color:#1fe087;background:linear-gradient(135deg,rgba(31,224,135,.12),rgba(16,217,255,.04))}.vendor-stat-card.warn{border-color:#ffdc4d;background:linear-gradient(135deg,rgba(255,220,77,.14),rgba(16,217,255,.04))}.vendor-stat-card.danger{border-color:#ff6b6b;background:linear-gradient(135deg,rgba(255,107,107,.16),rgba(255,63,180,.04))}.vendor-insight{margin-top:14px;border:1px solid #29324f;border-radius:14px;background:#070b15;padding:14px;color:#dfe9ff;line-height:1.6}.vendor-insight b{color:#10d9ff}@media(max-width:1180px){.vendor-stat-grid,.grid{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:760px){.vendor-stat-grid,.grid{grid-template-columns:1fr}.layout{grid-template-columns:1fr}.side{position:static}}</style>
</head>
<body>
<header><b>업체관리</b><span><a href="/">사이트</a> <a href="/logout">로그아웃</a></span></header>

<main class="wrap">
<% if(!vendor){ %>
  <section class="box"><h1>업체관리</h1><p>연결된 업체가 없습니다.</p></section>
<% } else { 
  const adLabel = vendor.ad_type==='recommended' ? (vendor.banner_active?'추천광고 + 프리미엄배너':'추천광고') : vendor.ad_type==='general' ? '일반광고' : '광고없음';
  const listLabel = vendor.ad_type==='recommended' ? '추천목록' : vendor.ad_type==='general' ? '일반목록' : '노출안함';
  const exposeLabel = vendor.ad_type==='none' ? '노출안함' : (vendor.expire_at && (pricingPreview.remainDays||0) < 0) ? '광고만료' : '노출중';
  const rate = Number(settings.raw.usdt_krw_rate||1400);
  const usdt = n => ((Number(n||0))/rate).toFixed(2);
%>
  <div class="layout">
    <aside class="side">
      <h2>업체관리</h2>
      <button class="menu-btn active" data-panel="home">홈</button>
      <div class="group">
        <div class="group-title">업체내용 변경</div>
        <button class="menu-btn" data-panel="edit">업체정보 수정</button>
      </div>
      <div class="group">
        <div class="group-title">상품신청</div>
        <button class="menu-btn" data-panel="plan">변경/연장 신청</button>
        <button class="menu-btn" data-panel="banner">프리미엄배너 신청</button>
      </div>
      <div class="group">
        <div class="group-title">내역관리</div>
        <button class="menu-btn" data-panel="history">신청내역</button>
        <button class="menu-btn" data-panel="payments">결제내역</button>
      </div>
    </aside>

    <div>
      <section id="panel-home" class="panel active">
        <div class="box">
          <h1>현재 이용 상태</h1>
          <div class="grid">
            <div class="card"><b>현재 광고</b><strong><%=adLabel%></strong></div>
            <div class="card"><b>목록 노출</b><strong><%=listLabel%></strong></div>
            <div class="card"><b>등록 만기일</b><strong><%=fmtDate(vendor.expire_at)%></strong></div>
            <div class="card"><b>노출 상태</b><strong><%=exposeLabel%></strong></div>
          </div>
        </div>

        <div class="box vendor-home-section">
          <h2>진행중인 신청</h2>
          <%
            const activeAdsHome=(adRequests||[]).filter(r=>r.status==='new').map(r=>Object.assign({},r,{_kind:'광고',_title:r.plan||'변경/연장 신청'}));
            const activeBannersHome=(bannerRequests||[]).filter(r=>r.status==='new').map(r=>Object.assign({},r,{_kind:'배너',_title:r.title||'프리미엄배너 신청'}));
            const activeRequestsHome=[...activeAdsHome,...activeBannersHome];
            const payStatusLabelHome=s=>s==='waiting'?'입금확인중':s==='paid'?'입금완료':s==='rejected'?'반려':s==='cancelled'?'취소':'입금대기';
            const payStatusClassHome=s=>s==='waiting'?'vendor-status-waiting':s==='paid'?'vendor-status-approved':s==='rejected'?'vendor-status-rejected':s==='cancelled'?'vendor-status-cancelled':'vendor-status-unpaid';
          %>
          <% if(activeRequestsHome.length){ %>
            <div class="vendor-status-list">
              <% activeRequestsHome.slice(0,5).forEach(r=>{ %>
                <div class="vendor-status-item">
                  <div>
                    <b><%=r._kind%> · <%=r._title%></b>
                    <small><%=Number(r.krw_price||0).toLocaleString()%>원 / <%=r.usdt_amount||0%> USDT</small>
                  </div>
                  <span class="vendor-status-badge <%=payStatusClassHome(r.payment_status)%>"><%=payStatusLabelHome(r.payment_status)%></span>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="vendor-empty">진행중인 신청이 없습니다.</div>
          <% } %>
        </div>

        <div class="box vendor-home-section">
          <h2>최근 결제</h2>
          <% if((paymentLogs||[]).length){ %>
            <div class="vendor-status-list">
              <% (paymentLogs||[]).slice(0,5).forEach(p=>{ %>
                <div class="vendor-status-item">
                  <div>
                    <b><%=p.product_type==='banner'?'프리미엄배너':p.product_type==='recommended'?'추천광고':p.product_type==='general'?'일반광고':p.product_type||'결제'%></b>
                    <small><%=Number(p.krw_price||0).toLocaleString()%>원 / <%=p.usdt_amount||0%> USDT</small>
                  </div>
                  <span class="vendor-status-badge vendor-status-approved"><%=fmtDateTime(p.paid_at)%></span>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="vendor-empty">최근 결제내역이 없습니다.</div>
          <% } %>
        </div>

        <div class="box vendor-home-section">
          <h2>업체 통계</h2>
          <%
            const remainDays = Number(pricingPreview.remainDays||0);
            const monthViews = Number(viewStats.month_views||0);
            const weekViews = Number(viewStats.week_views||0);
            const todayViews = Number(viewStats.today_views||0);
            const reviewCount = Number(stats.review_count||0);
            const favoriteCount = Number(stats.favorite_count||0);
            const reportCount = Number(stats.report_count||0);
            const avgRating = stats.avg_rating || '-';
            const remainClass = !vendor.expire_at ? '' : remainDays < 0 ? 'danger' : remainDays <= 7 ? 'warn' : 'good';
            const remainText = !vendor.expire_at ? '미설정' : remainDays < 0 ? '만료' : remainDays + '일';
          %>
          <div class="vendor-stat-grid">
            <div class="vendor-stat-card"><b>오늘 조회</b><strong><%=todayViews.toLocaleString()%></strong><span class="vendor-stat-note">오늘 상세페이지 방문</span></div>
            <div class="vendor-stat-card"><b>7일 조회</b><strong><%=weekViews.toLocaleString()%></strong><span class="vendor-stat-note">최근 7일 누적</span></div>
            <div class="vendor-stat-card"><b>30일 조회</b><strong><%=monthViews.toLocaleString()%></strong><span class="vendor-stat-note">최근 30일 누적</span></div>
            <div class="vendor-stat-card <%=remainClass%>"><b>광고 잔여일</b><strong><%=remainText%></strong><span class="vendor-stat-note"><%=fmtDate(vendor.expire_at)%></span></div>
            <div class="vendor-stat-card"><b>찜</b><strong><%=favoriteCount.toLocaleString()%></strong><span class="vendor-stat-note">회원 관심 수</span></div>
            <div class="vendor-stat-card"><b>후기</b><strong><%=reviewCount.toLocaleString()%></strong><span class="vendor-stat-note">등록된 후기</span></div>
            <div class="vendor-stat-card"><b>평균 평점</b><strong><%=avgRating%></strong><span class="vendor-stat-note">후기 평점 평균</span></div>
            <div class="vendor-stat-card <%=reportCount>0?'danger':''%>"><b>신고</b><strong><%=reportCount.toLocaleString()%></strong><span class="vendor-stat-note">신고 누적</span></div>
          </div>
          <div class="vendor-insight">
            <b>운영 팁</b><br>
            조회수는 상세페이지 방문 기준입니다. 7일 조회가 늘고 있는데 찜/후기가 적다면 소개글, 태그, 대표이미지를 수정요청으로 개선해보세요.
          </div>
        </div>
      </section>

      <section id="panel-edit" class="panel">
        <div class="box">
          <h2>업체정보 수정요청</h2>
          <form method="post" action="/vendor-dashboard/update-request" enctype="multipart/form-data" class="form">
            <input name="name" value="<%=vendor.name||''%>" placeholder="업체명">
            <select name="category"><% (settings.categories||[]).forEach(c=>{ %><option value="<%=c%>" <%=vendor.category===c?'selected':''%>><%=c%></option><% }) %></select>
            <select name="region"><% (settings.regions||[]).forEach(r=>{ %><option value="<%=r%>" <%=vendor.region===r?'selected':''%>><%=r%></option><% }) %></select>
            <input name="phone" value="<%=vendor.phone||''%>" placeholder="연락처">
            <input name="kakao_url" value="<%=vendor.kakao_url||''%>" placeholder="카카오">
            <input name="business_hours" value="<%=vendor.business_hours||''%>" placeholder="영업시간">
            <textarea name="tags" placeholder="태그"><%=vendor.tags||''%></textarea>
            <textarea name="description" placeholder="소개"><%=vendor.description||''%></textarea>
            <div class="file-guide">
              <b>대표 이미지/GIF 권장 규격</b><br>
              권장 크기: 가로 1200px 이상 / 비율 16:9 또는 4:3<br>
              권장 용량: 5MB 이하<br>
              가능 파일: JPG, PNG, WEBP, GIF<br>
              이 이미지는 일반광고, 추천광고, 프리미엄배너에 공통으로 사용됩니다.
            </div>
            <input type="file" name="image" accept="image/*">
            <button>수정요청 보내기</button>
          </form>
        </div>
      </section>

      <section id="panel-plan" class="panel">
        <div class="box">
          <h2>변경/연장 신청</h2>
          <% const activeAds=(adRequests||[]).filter(r=>r.status==='new'); %>
          <% if(activeAds.length){ %>
            <div class="paybox">
              <b>진행중인 변경/연장 결제</b>
              <% activeAds.forEach(pay=>{ %>
                <p><b><%=pay.plan%></b> / <%=Number(pay.krw_price||0).toLocaleString()%>원 / <%=pay.usdt_amount||0%> USDT / <%- pay.payment_status==='waiting'?'<span class="status-waiting">입금확인중...</span>':'입금대기' %></p>
                <div class="addr"><input id="adAddr<%=pay.id%>" readonly value="<%=settings.raw.usdt_address||''%>"><button type="button" onclick="navigator.clipboard.writeText(document.getElementById('adAddr<%=pay.id%>').value)">주소복사</button></div>
                <div class="actions">
                  <% if(pay.payment_status!=='waiting'){ %><form method="post" action="/vendor-dashboard/ad-request/<%=pay.id%>/paid"><button>입금완료</button></form><% } %>
                  <form method="post" action="/vendor-dashboard/ad-request/<%=pay.id%>/cancel"><button>신청취소</button></form>
                </div>
              <% }) %>
            </div>
          <% } %>
          <div class="paybox">
            <b>예상금액</b>
            <p>일반광고 30일 <%=Number(pricingPreview.renewal_general||0).toLocaleString()%>원 / <%=usdt(pricingPreview.renewal_general)%> USDT</p>
            <p>추천광고 30일 <%=Number(settings.raw.recommended_register_price_krw||0).toLocaleString()%>원 / <%=usdt(settings.raw.recommended_register_price_krw)%> USDT</p>
          </div>
          <form method="post" action="/vendor-dashboard/ad-request" class="form">
            <select name="product_type">
              <option value="renewal_general">일반광고 신청/변경/연장</option>
              <option value="renewal_recommended">추천광고 신청/변경/연장</option>
            </select>
            <select name="period"><option value="30">30일</option><option value="60">60일</option><option value="90">90일</option></select>
            <% if(vendor.ad_type!=='recommended'){ %><label><input type="checkbox" name="immediate_apply" value="1"> 추천광고 바로 적용</label><% } %>
            <textarea name="content" placeholder="요청사항"></textarea>
            <button>변경/연장 신청하기</button>
          </form>
        </div>
      </section>

      <section id="panel-banner" class="panel">
        <div class="box">
          <h2>프리미엄배너 신청/연장</h2>
          <% const activeBanners=(bannerRequests||[]).filter(r=>r.status==='new'); %>
          <% if(activeBanners.length){ %>
            <div class="paybox">
              <b>진행중인 프리미엄배너 결제</b>
              <% activeBanners.forEach(pay=>{ %>
                <p><b><%=pay.title%></b> / <%=Number(pay.krw_price||0).toLocaleString()%>원 / <%=pay.usdt_amount||0%> USDT / <%- pay.payment_status==='waiting'?'<span class="status-waiting">입금확인중...</span>':'입금대기' %></p>
                <div class="addr"><input id="bnAddr<%=pay.id%>" readonly value="<%=settings.raw.usdt_address||''%>"><button type="button" onclick="navigator.clipboard.writeText(document.getElementById('bnAddr<%=pay.id%>').value)">주소복사</button></div>
                <div class="actions">
                  <% if(pay.payment_status!=='waiting'){ %><form method="post" action="/vendor-dashboard/banner-request/<%=pay.id%>/paid"><button>입금완료</button></form><% } %>
                  <form method="post" action="/vendor-dashboard/banner-request/<%=pay.id%>/cancel"><button>신청취소</button></form>
                </div>
              <% }) %>
            </div>
          <% } %>
          <div class="paybox">
            <b>배너 가격</b>
            <% const bPrice = vendor.ad_type==='recommended' ? Number(settings.raw.recommended_to_banner_price_krw||settings.raw.banner_price_krw||0) : Number(settings.raw.general_to_banner_price_krw||0); %>
            <p><%=bPrice.toLocaleString()%>원 / <%=usdt(bPrice)%> USDT</p>
          </div>
          <% if(vendor.banner_active){ %>
            <form method="post" action="/vendor-dashboard/ad-request" class="form">
              <input type="hidden" name="product_type" value="renewal_banner">
              <select name="period"><option value="30">30일</option><option value="60">60일</option><option value="90">90일</option></select>
              <textarea name="content" placeholder="배너 연장 요청사항"></textarea>
              <button>배너 연장 신청</button>
            </form>
          <% } else { %>
            <div class="file-guide">
              <b>배너 이미지는 업체 대표 이미지/GIF를 그대로 사용합니다.</b><br>
              이미지를 바꾸려면 먼저 [업체정보 수정]에서 대표 이미지를 변경 요청하세요.<br>
              권장 크기: 가로 1200px 이상 / 권장 용량 5MB 이하 / JPG, PNG, WEBP, GIF
            </div>
            <% if(vendor.image_data){ %>
              <div class="banner-preview">
                <img src="<%=vendor.image_data%>" alt="현재 대표이미지">
                <div>
                  <b>현재 배너로 사용될 이미지</b><br>
                  일반광고/추천광고/프리미엄배너에 공통 사용됩니다.
                </div>
              </div>
            <% } else { %>
              <div class="file-guide">현재 등록된 대표 이미지가 없습니다. 업체정보 수정에서 대표 이미지를 먼저 등록하세요.</div>
            <% } %>
            <div class="file-guide">
              <b>프리미엄배너 등록 정보</b><br>
              배너 제목: 업체명 자동 사용<br>
              배너 설명: 업체소개/업종 자동 사용<br>
              연결 링크: 등록된 카카오 링크 자동 사용<br>
              배너 이미지: 대표 이미지/GIF 자동 사용
            </div>
            <form method="post" action="/vendor-dashboard/banner-request" class="form">
              <button <%=vendor.image_data?'':'disabled'%>>현재 업체정보로 배너 신청</button>
            </form>
          <% } %>
        </div>
      </section>

      <section id="panel-history" class="panel">
        <div class="box">
          <h2>신청내역</h2>
          <table class="table"><tr><th>구분</th><th>상품</th><th>금액</th><th>상태</th></tr>
          <% (adRequests||[]).forEach(r=>{ %><tr><td>광고</td><td><%=r.plan%></td><td><%=Number(r.krw_price||0).toLocaleString()%>원</td><td><%- r.status==='approved'?'승인':r.status==='rejected'?'반려':r.status==='cancelled'?'취소':r.payment_status==='waiting'?'<span class="status-waiting">입금확인중...</span>':'입금대기' %></td></tr><% }) %>
          <% (bannerRequests||[]).forEach(r=>{ %><tr><td>배너</td><td><%=r.title%></td><td><%=Number(r.krw_price||0).toLocaleString()%>원</td><td><%- r.status==='approved'?'승인':r.status==='rejected'?'반려':r.status==='cancelled'?'취소':r.payment_status==='waiting'?'<span class="status-waiting">입금확인중...</span>':'입금대기' %></td></tr><% }) %>
          </table>
        </div>
      </section>

      <section id="panel-payments" class="panel">
        <div class="box">
          <h2>결제내역</h2>
          <table class="table"><tr><th>상품</th><th>금액</th><th>USDT</th><th>일자</th></tr>
          <% (paymentLogs||[]).forEach(p=>{ %><tr><td><%=p.product_type%></td><td><%=Number(p.krw_price||0).toLocaleString()%>원</td><td><%=p.usdt_amount||0%></td><td><%=fmtDateTime(p.paid_at)%></td></tr><% }) %>
          </table>
        </div>
      </section>
    </div>
  </div>
<% } %>
</main>

<script>
document.querySelectorAll('.menu-btn[data-panel]').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.menu-btn[data-panel]').forEach(x=>x.classList.remove('active'));
    document.querySelectorAll('.panel').forEach(x=>x.classList.remove('active'));
    btn.classList.add('active');
    const target=document.getElementById('panel-'+btn.dataset.panel);
    if(target)target.classList.add('active');
  });
});
const params=new URLSearchParams(location.search);
if(params.get('panel')){
  const b=document.querySelector('.menu-btn[data-panel="'+params.get('panel')+'"]');
  if(b)b.click();
}
</script>
</body>
</html>
