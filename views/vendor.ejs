<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title><%=vendor.name%></title><link rel="stylesheet" href="/public/css/style.css"><style>.wrap{max-width:1050px;margin:30px auto;padding:0 18px}.hero-detail{display:grid;grid-template-columns:360px 1fr;gap:22px;border:1px solid #29324f;background:#101525;border-radius:20px;padding:22px}.photo{height:280px;border-radius:16px;overflow:hidden;background:#080d18;display:grid;place-items:center}.photo img{width:100%;height:100%;object-fit:cover}.info h1{margin:0 0 10px;font-size:34px}.badge{display:inline-block;padding:6px 10px;border-radius:999px;background:#ffdc4d;color:#111;font-weight:900}.actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px}.btn{height:42px;padding:0 16px;border:0;border-radius:12px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900;text-decoration:none;display:inline-flex;align-items:center}.box{margin-top:18px;border:1px solid #29324f;background:#101525;border-radius:18px;padding:20px}.review{border-top:1px solid #29324f;padding:12px 0}.review:first-child{border-top:0}@media(max-width:800px){.hero-detail{grid-template-columns:1fr}.photo{height:240px}}</style></head><body><header class="top"><a class="brand" href="/">서비스 디렉터리</a><nav><a href="/">홈</a><% if(me){%><a href="/mypage">마이페이지</a><a href="/logout">로그아웃</a><%}else{%><a href="/login">로그인</a><%}%></nav></header><main class="wrap"><section class="hero-detail"><div class="photo"><% if(vendor.image_data){%><img src="<%=vendor.image_data%>" alt=""><%}else{%>IMAGE<%}%></div><div class="info"><% if(vendor.is_premium){%><span class="badge">PREMIUM</span><%}%><h1><%=vendor.name%></h1><p><%=vendor.region%> · <%=vendor.category%></p><p>평점 <b>★ <%=vendor.avg_rating||'-'%></b> · 후기 <%=vendor.review_count||0%>개 · 찜 <%=vendor.favorite_count||0%>개 · 조회 <%=vendor.views||0%></p><p>영업시간: <%=vendor.business_hours||'-'%></p><p>전화: <%=vendor.phone||'-'%></p><div class="actions"><% if(vendor.phone){%><a class="btn" href="tel:<%=vendor.phone%>">전화하기</a><%}%><% if(vendor.kakao_url){%><a class="btn" href="<%=vendor.kakao_url%>" target="_blank">카톡문의</a><%}%><% if(me){%><% if(vendor.is_favorited){%><form method="post" action="/favorite/<%=vendor.id%>/delete"><button class="btn">찜삭제</button></form><%}else{%><form method="post" action="/favorite/<%=vendor.id%>"><button class="btn">찜하기</button></form><%}%><%}%></div></div></section><section class="box"><h2>업체소개</h2><p><%=vendor.description||'등록된 소개가 없습니다.'%></p><p><%=vendor.tags||''%></p></section><section class="box"><h2>후기</h2><% reviews.forEach(r=>{%><div class="review"><b><%=r.title%></b><p>★ <%=r.rating%> · <%=r.nickname||'회원'%></p><p><%=r.content%></p></div><%})%><% if(me){%><form method="post" action="/review"><input type="hidden" name="vendor_id" value="<%=vendor.id%>"><input name="title" placeholder="후기 제목"><select name="rating"><option value="5">5점</option><option value="4">4점</option><option value="3">3점</option><option value="2">2점</option><option value="1">1점</option></select><textarea name="content" placeholder="후기 내용"></textarea><button class="btn">후기 작성</button></form><%}%></section></main></body></html>
