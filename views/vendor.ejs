<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%=vendor.name%></title>
  <link rel="stylesheet" href="/public/css/style.css">
</head>
<body>
<header class="top">
  <b><a href="/">서비스 디렉터리</a></b>
  <nav>
    <a href="/">홈</a>
    <% if(me){%><a href="/logout">로그아웃</a><%}else{%><a href="/login">로그인</a><%}%>
  </nav>
</header>

<main class="detail vendor-detail">
  <section class="vendor-hero panel">
    <div class="vendor-photo">
      <% if(vendor.image_data){%>
        <img src="<%=vendor.image_data%>" alt="<%=vendor.name%>">
      <%}else{%>
        <div class="noimg">IMAGE</div>
      <%}%>
    </div>
    <div class="vendor-summary">
      <em><%=vendor.is_premium?'PREMIUM':vendor.is_recommended?'RECOMMEND':'NORMAL'%></em>
      <h1><%=vendor.name%></h1>
      <p class="vendor-meta"><%=vendor.region%> · <%=vendor.category%> · 조회 <%=vendor.views%></p>
      <div class="info-list">
        <div><b>연락처</b><span><%=vendor.phone||'등록된 연락처가 없습니다.'%></span></div>
        <div><b>영업시간</b><span><%=vendor.business_hours||'등록된 영업시간이 없습니다.'%></span></div>
      </div>
      <% if(vendor.phone){ %>
        <a class="call-btn" href="tel:<%=vendor.phone%>">전화하기</a>
      <% } %>
    </div>
  </section>

  <section class="panel vendor-section">
    <h2>업체소개</h2>
    <p class="vendor-desc"><%=vendor.description||'등록된 업체소개가 없습니다.'%></p>
  </section>

  <section class="panel vendor-section">
    <h2>후기</h2>
    <% if(reviews.length){ %>
      <% reviews.forEach(r=>{ %>
        <article class="review">
          <b>★<%=r.rating%> <%=r.title%></b>
          <p><%=r.content%></p>
          <small><%=r.nickname||'탈퇴회원'%></small>
        </article>
      <%})%>
    <% } else { %>
      <p class="empty-text">아직 등록된 후기가 없습니다.</p>
    <% } %>

    <% if(me){%>
      <form method="post" action="/review" class="form review-form">
        <input type="hidden" name="vendor_id" value="<%=vendor.id%>">
        <input name="title" placeholder="후기 제목" required>
        <select name="rating"><option>5</option><option>4</option><option>3</option><option>2</option><option>1</option></select>
        <textarea name="content" placeholder="내용" required></textarea>
        <button>후기 등록</button>
      </form>
    <%}else{%>
      <p class="empty-text">후기 작성은 로그인 후 가능합니다.</p>
    <%}%>
  </section>
</main>
</body>
</html>