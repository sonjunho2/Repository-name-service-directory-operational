<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title><%=vendor.name%></title><link rel="stylesheet" href="/public/css/style.css"></head><body><header class="top"><b><a href="/">서비스 디렉터리</a></b><nav><a href="/">홈</a><% if(me){%><a href="/logout">로그아웃</a><%}else{%><a href="/login">로그인</a><%}%></nav></header><main class="detail"><div class="detailHero"><% if(vendor.image_data){%><img src="<%=vendor.image_data%>"><%}%><div><em><%=vendor.is_premium?'PREMIUM':vendor.is_recommended?'RECOMMEND':'NORMAL'%></em><h1><%=vendor.name%></h1><p><%=vendor.region%> · <%=vendor.category%> · 조회 <%=vendor.views%></p><p><%=vendor.description%></p></div></div><section class="panel"><h2>후기</h2><% reviews.forEach(r=>{ %><article class="review"><b>★<%=r.rating%> <%=r.title%></b><p><%=r.content%></p><small><%=r.nickname||'탈퇴회원'%></small></article><%})%><% if(me){%><form method="post" action="/review" class="form"><input type="hidden" name="vendor_id" value="<%=vendor.id%>"><input name="title" placeholder="후기 제목" required><select name="rating"><option>5</option><option>4</option><option>3</option><option>2</option><option>1</option></select><textarea name="content" placeholder="내용" required></textarea><button>후기 등록</button></form><%}else{%><p>후기 작성은 로그인 후 가능합니다.</p><%}%></section></main></body></html>
