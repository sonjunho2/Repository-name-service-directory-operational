<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>신청내역</title><link rel="stylesheet" href="/public/css/style.css"><style>.wrap{padding:24px}.memo{max-width:360px;white-space:pre-wrap;line-height:1.55}.filterbar{display:flex;gap:8px;flex-wrap:wrap;margin:0 0 14px}.filterbar button{height:38px;padding:0 14px;border-radius:999px;border:1px solid #39466c;background:#080d18;color:#dfe9ff;font-weight:900;cursor:pointer}.filterbar button.on{background:linear-gradient(90deg,#ff3fb4,#10d9ff);border-color:transparent;color:#fff}.searchbar{display:grid;grid-template-columns:1fr 110px;gap:10px;margin:0 0 18px}.searchbar input{height:42px;border-radius:12px;border:1px solid #39466c;background:#080d18;color:#fff;padding:0 14px}.searchbar button{height:42px;border:0;border-radius:999px;background:#222b43;color:#dfe9ff;font-weight:900;cursor:pointer}.image-links a{display:inline-block;margin:3px 0;padding:6px 10px;border:1px solid #2aa8ff;border-radius:8px;color:#dfe9ff;text-decoration:none}.approve-btn{margin-top:8px;padding:7px 10px;border:0;border-radius:8px;background:#ffdc4d;color:#111;font-weight:900;cursor:pointer}.banner-btn{margin-top:8px;padding:7px 10px;border:0;border-radius:8px;background:#10d9ff;color:#111;font-weight:900;cursor:pointer}.status{display:inline-block;margin-top:8px;color:#1fe087;font-weight:900}.banner-status{display:inline-block;margin-top:8px;color:#10d9ff;font-weight:900}.hidden-row{display:none}@media(max-width:800px){.searchbar{grid-template-columns:1fr}}</style></head><body><header class="top"><b>신청내역</b><nav><a href="/admin">관리자</a><a href="/">사이트</a><a href="/logout">로그아웃</a></nav></header><main class="admin wrap"><section class="panel"><h2>광고문의 / 입점신청</h2><div class="filterbar"><button type="button" class="on" data-filter="all">전체 <%=inquiries.length%></button><button type="button" data-filter="new">신규 <%=inquiries.filter(x=>x.status!=='approved').length%></button><button type="button" data-filter="approved">승인완료 <%=inquiries.filter(x=>x.status==='approved').length%></button><button type="button" data-filter="apply">입점신청 <%=inquiries.filter(x=>x.type==='apply').length%></button><button type="button" data-filter="ad">광고문의 <%=inquiries.filter(x=>x.type!=='apply').length%></button></div><div class="searchbar"><input id="inquirySearch" placeholder="업체명 / 담당자 / 연락처 / 지역 / 업종 검색"><button type="button" id="inquirySearchReset">초기화</button></div><table><tr><th>ID</th><th>구분</th><th>업체명</th><th>담당자</th><th>연락처</th><th>지역/업종</th><th>내용</th><th>이미지</th><th>처리</th></tr><% inquiries.forEach(x=>{%><tr data-status="<%=x.status==='approved'?'approved':'new'%>" data-type="<%=x.type==='apply'?'apply':'ad'%>" data-search="<%=String((x.company_name||'')+' '+(x.name||'')+' '+(x.phone||'')+' '+(x.kakao||'')+' '+(x.email||'')+' '+(x.region||'')+' '+(x.category||'')).toLowerCase()%>"><td><%=x.id%></td><td><%=x.type==='apply'?'입점신청':'광고문의'%></td><td><%=x.company_name%></td><td><%=x.name||'-'%></td><td><%=x.phone%><br><%=x.kakao||''%><br><%=x.email||''%></td><td><%=x.region||'-'%>/<%=x.category||'-'%></td><td class="memo"><%=x.content%></td><td class="image-links"><% if(x.main_image_data){%><a href="/admin/inquiry-image/<%=x.id%>/main" target="_blank">대표보기</a><br><%}else{%>대표없음<br><%}%><% if(x.banner_image_data){%><a href="/admin/inquiry-image/<%=x.id%>/banner" target="_blank">배너보기</a><%}else{%>배너없음<%}%></td><td><% if(x.status==='approved'){%><span class="status">업체 등록완료</span><%}else if(x.type==='apply'){%><form method="post" action="/admin/inquiries/<%=x.id%>/approve"><button class="approve-btn" onclick="return confirm('이 신청내용으로 업체를 등록할까요?')">업체등록</button></form><%}else{%>-<%}%><% if(x.banner_status==='approved'){%><br><span class="banner-status">배너 등록완료</span><%}else if(x.banner_image_data){%><form method="post" action="/admin/inquiries/<%=x.id%>/banner"><button class="banner-btn" onclick="return confirm('이 배너이미지를 프리미엄 배너로 등록할까요?')">배너등록</button></form><%}%></td></tr><%})%></table></section></main><script>let currentFilter='all';function applyInquiryFilter(){const q=(document.getElementById('inquirySearch')?.value||'').trim().toLowerCase();document.querySelectorAll('tr[data-status]').forEach(row=>{const okFilter=currentFilter==='all'||row.dataset.status===currentFilter||row.dataset.type===currentFilter;const okSearch=!q||row.dataset.search.includes(q);row.classList.toggle('hidden-row',!(okFilter&&okSearch));});}document.querySelectorAll('.filterbar button').forEach(btn=>btn.addEventListener('click',()=>{document.querySelectorAll('.filterbar button').forEach(b=>b.classList.remove('on'));btn.classList.add('on');currentFilter=btn.dataset.filter;applyInquiryFilter();}));document.getElementById('inquirySearch')?.addEventListener('input',applyInquiryFilter);document.getElementById('inquirySearchReset')?.addEventListener('click',()=>{document.getElementById('inquirySearch').value='';applyInquiryFilter();});</script></body></html>