<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>신청내역</title><link rel="stylesheet" href="/public/css/style.css"><style>.wrap{padding:24px}.memo{max-width:360px;white-space:pre-wrap;line-height:1.55}</style></head><body><header class="top"><b>신청내역</b><nav><a href="/admin">관리자</a><a href="/">사이트</a><a href="/logout">로그아웃</a></nav></header><main class="admin wrap"><section class="panel"><h2>광고문의 / 입점신청</h2><table><tr><th>ID</th><th>구분</th><th>업체명</th><th>담당자</th><th>연락처</th><th>지역/업종</th><th>내용</th><th>이미지</th></tr><% inquiries.forEach(x=>{%><tr><td><%=x.id%></td><td><%=x.type==='apply'?'입점신청':'광고문의'%></td><td><%=x.company_name%></td><td><%=x.name||'-'%></td><td><%=x.phone%><br><%=x.kakao||''%><br><%=x.email||''%></td><td><%=x.region||'-'%>/<%=x.category||'-'%></td><td class="memo"><%=x.content%></td><td>대표:<%=x.main_image_data?'있음':'없음'%><br>배너:<%=x.banner_image_data?'있음':'없음'%></td></tr><%})%></table></section></main></body></html>