<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>신청내역</title><link rel="stylesheet" href="/public/css/style.css"><style>.wrap{padding:24px}.memo{max-width:360px;white-space:pre-wrap;line-height:1.55}.image-links a{display:inline-block;margin:3px 0;padding:6px 10px;border:1px solid #2aa8ff;border-radius:8px;color:#dfe9ff;text-decoration:none}.approve-btn{margin-top:8px;padding:7px 10px;border:0;border-radius:8px;background:#ffdc4d;color:#111;font-weight:900;cursor:pointer}.banner-btn{margin-top:8px;padding:7px 10px;border:0;border-radius:8px;background:#10d9ff;color:#111;font-weight:900;cursor:pointer}.status{display:inline-block;margin-top:8px;color:#1fe087;font-weight:900}.banner-status{display:inline-block;margin-top:8px;color:#10d9ff;font-weight:900}</style></head><body><header class="top"><b>신청내역</b><nav><a href="/admin">관리자</a><a href="/">사이트</a><a href="/logout">로그아웃</a></nav></header><main class="admin wrap"><section class="panel"><h2>광고문의 / 입점신청</h2><table><tr><th>ID</th><th>구분</th><th>업체명</th><th>담당자</th><th>연락처</th><th>지역/업종</th><th>내용</th><th>이미지</th><th>처리</th></tr><% inquiries.forEach(x=>{%><tr><td><%=x.id%></td><td><%=x.type==='apply'?'입점신청':'광고문의'%></td><td><%=x.company_name%></td><td><%=x.name||'-'%></td><td><%=x.phone%><br><%=x.kakao||''%><br><%=x.email||''%></td><td><%=x.region||'-'%>/<%=x.category||'-'%></td><td class="memo"><%=x.content%></td><td class="image-links"><% if(x.main_image_data){%><a href="/admin/inquiry-image/<%=x.id%>/main" target="_blank">대표보기</a><br><%}else{%>대표없음<br><%}%><% if(x.banner_image_data){%><a href="/admin/inquiry-image/<%=x.id%>/banner" target="_blank">배너보기</a><%}else{%>배너없음<%}%></td><td><% if(x.status==='approved'){%><span class="status">업체 등록완료</span><%}else if(x.type==='apply'){%><form method="post" action="/admin/inquiries/<%=x.id%>/approve"><button class="approve-btn" onclick="return confirm('이 신청내용으로 업체를 등록할까요?')">업체등록</button></form><%}else{%>-<%}%><% if(x.banner_status==='approved'){%><br><span class="banner-status">배너 등록완료</span><%}else if(x.banner_image_data){%><form method="post" action="/admin/inquiries/<%=x.id%>/banner"><button class="banner-btn" onclick="return confirm('이 배너이미지를 프리미엄 배너로 등록할까요?')">배너등록</button></form><%}%></td></tr><%})%></table></section></main></body></html>