<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>м„ңл№„мҠӨ л””л үн„°лҰ¬</title>
  <link rel="stylesheet" href="/public/css/style.css">
  <style>#vendorModal.show{display:block!important}.card-rating{display:inline-flex!important;align-items:center!important;margin:6px 0 8px!important;padding:6px 10px!important;border:1px solid #39466c!important;border-radius:999px!important;color:#ffdc4d!important;background:#080d18!important;font-size:13px!important;font-weight:900!important;width:max-content!important}.modal-vendor-info{padding-bottom:18px;border-bottom:1px solid #29324f;margin-bottom:24px}.modal-vendor-info em{display:inline-block;background:#ffdc4d;color:#111;padding:7px 12px;border-radius:999px;font-weight:900;font-style:italic}.modal-vendor-info h2{font-size:38px;margin:12px 0 10px;line-height:1.12}.modal-vendor-info p{color:#c8d0e8;margin:0}.modal-vendor-head{display:grid;grid-template-columns:360px 1fr;gap:24px;align-items:stretch}.modal-vendor-photo{height:276px;border-radius:18px;overflow:hidden;background:#080d18;border:1px solid #29324f;display:grid;place-items:center}.modal-vendor-photo img{width:100%;height:100%;object-fit:cover}.modal-info-list{display:grid!important;grid-template-columns:1fr!important;grid-template-rows:1fr 1fr;gap:16px!important;margin-bottom:0;height:276px}.modal-info-box{min-height:130px!important;padding:20px!important;background:#080d18!important;border:1px solid #29324f!important;border-radius:16px!important}.modal-info-box b{display:block;color:#10d9ff;margin-bottom:13px;font-size:18px}.modal-info-box span{font-size:17px;line-height:1.45}.contact-box{display:grid!important;grid-template-columns:1fr 160px;grid-template-rows:auto 1fr;column-gap:18px;align-items:center}.contact-box b{grid-column:1/3}.contact-box span{align-self:center}.contact-box .call-btn{grid-column:2;grid-row:2;width:160px;height:52px;margin:0;align-self:center;justify-self:end}.modal-section{margin-top:24px;border-top:1px solid #29324f;padding-top:22px}.modal-section h3{margin:0 0 14px;font-size:23px}.modal-desc-box{background:#080d18;border:1px solid #29324f;border-radius:16px;padding:18px 20px}.review-title{display:flex;align-items:center;justify-content:space-between;gap:16px}.review-write-btn{width:auto!important;height:42px!important;min-height:42px!important;padding:0 18px!important;border:1px solid #2aa8ff!important;background:transparent!important;color:#dfe9ff!important;border-radius:12px!important}.review-write-btn:hover{background:linear-gradient(90deg,#ff3fb4,#10d9ff)!important;border-color:transparent!important}@media(max-width:900px){.modal-vendor-head{grid-template-columns:1fr}.modal-vendor-photo{height:260px}.modal-info-list{height:auto}.modal-info-box{min-height:auto!important}.contact-box{grid-template-columns:1fr}.contact-box b{grid-column:1}.contact-box .call-btn{grid-column:1;grid-row:auto;justify-self:start;margin-top:12px}}</style>
</head>
<body>
<header class="top">
  <a class="brand" href="/">м„ңл№„мҠӨ л””л үн„°лҰ¬</a>
  <nav>
    <a href="/">нҷҲ</a>
    <% if(me){ %>
      <span><%=me.nickname%></span>
      <a href="/logout">лЎңк·ём•„мӣғ</a>
      <% if(me.role==='admin'){%><a href="/admin">кҙҖлҰ¬мһҗ</a><%}%>
    <% }else{ %>
      <a href="/login">лЎңк·ёмқё</a>
      <a href="/join">нҡҢмӣҗк°Җмһ…</a>
    <% } %>
  </nav>
</header>

<section class="selector-wrap first-block">
  <div class="selector-head">вҳ… м—…мў…м„ нғқ</div>
  <div class="selector-list">
    <a href="/">м „мІҙ</a>
    <% ['м№ҙнҺҳ','л·°нӢ°','л§ӣм§‘','көҗмңЎ','кё°нғҖ'].forEach(x=>{ %><a href="/?category=<%=x%>"><%=x%></a><%})%>
  </div>
  <div class="selector-head region">в–Ұ м§Җм—ӯм„ нғқ</div>
  <div class="selector-list">
    <a href="/">м „мІҙ</a>
    <% ['м„ңмҡё','л¶ҖмӮ°','лҢҖкө¬','мқёмІң','кҙ‘мЈј','лҢҖм „','м ңмЈј'].forEach(x=>{ %><a href="/?region=<%=x%>"><%=x%></a><%})%>
  </div>
</section>

<section class="promo-search-wrap">
  <div class="premium-row-slider">
    <div class="premium-track">
      <% const loopBanners = banners.length ? banners : [{title:'н”„лҰ¬лҜём—„ л°°л„Ҳ',subtitle:'кҙҖлҰ¬мһҗм—җм„ң мқҙлҜём§Җ м—…лЎңл“ң к°ҖлҠҘ',link_url:'#',image_data:null},{title:'мқҙлІӨнҠё л°°л„Ҳ',subtitle:'мҠ¬лқјмқҙл“ңлЎң л…ём¶ңлҗ©лӢҲлӢӨ',link_url:'#',image_data:null},{title:'кҙ‘кі  л°°л„Ҳ',subtitle:'м—¬лҹ¬ к°ң м№ҙл“ң л°°л„Ҳ м§Җмӣҗ',link_url:'#',image_data:null}]; %>
      <% loopBanners.concat(loopBanners).forEach((b)=>{ %>
        <a class="premium-banner-card" href="<%=b.link_url||'#'%>">
          <% if(b.image_data){%><img src="<%=b.image_data%>" alt=""><%}%>
          <span>PREMIUM</span>
          <strong><%=b.title%></strong>
          <small><%=b.subtitle||'н”„лҰ¬лҜём—„ м№ҙл“ң л°°л„Ҳ'%></small>
        </a>
      <%})%>
    </div>
  </div>

  <form class="side-search">
    <input name="search" value="<%=query.search||''%>" placeholder="м—…мІҙлӘ…кІҖмғү">
    <select name="category">
      <option value="">м „мІҙм—…мў… м„ нғқ</option>
      <% ['м№ҙнҺҳ','л·°нӢ°','л§ӣм§‘','көҗмңЎ','кё°нғҖ'].forEach(x=>{ %>
        <option <%=query.category===x?'selected':''%>><%=x%></option>
      <%})%>
    </select>
    <select name="region">
      <option value="">м „мІҙм§Җм—ӯм„ нғқ</option>
      <% ['м„ңмҡё','л¶ҖмӮ°','лҢҖкө¬','мқёмІң','кҙ‘мЈј','лҢҖм „','м ңмЈј'].forEach(x=>{ %>
        <option <%=query.region===x?'selected':''%>><%=x%></option>
      <%})%>
    </select>
    <button>кІҖмғү</button>
  </form>
</section>

<main class="layout">
  <section class="content-area">
    <div class="section-title">
      <h2>м¶”мІңм—…мІҙ</h2>
      <span>н”„лҰ¬лҜём—„кіј м¶”мІң м—…мІҙлҘј лЁјм Җ ліҙм—¬мӨҚлӢҲлӢӨ.</span>
    </div>
    <div class="grid featured-grid">
      <% vendors.filter(v=>v.is_recommended||v.is_premium).forEach(v=>{ %>
        <a class="card vendor-open <%=v.is_premium?'premium':'recommend'%>" href="/vendor/<%=v.id%>" data-vendor-id="<%=v.id%>">
          <div class="thumb">
            <% if(v.image_data){%><img src="<%=v.image_data%>" alt=""><%} else {%><div class="noimg">IMAGE</div><%}%>
          </div>
          <em><%=v.is_premium?'PREMIUM':'RECOMMEND'%></em>
          <h3><%=v.name%></h3>
          <span class="card-rating"><%=v.review_count>0?'вӯҗ '+v.avg_rating+' В· нӣ„кё° '+v.review_count+'к°ң':'вӯҗ нҸүм җ м—ҶмқҢ'%></span>
          <p><%=v.region%> В· <%=v.category%></p>
          <span><%=v.tags||'л“ұлЎқлҗң нғңк·ёк°Җ м—ҶмҠөлӢҲлӢӨ.'%></span>
        </a>
      <%})%>
    </div>

    <div class="section-title mt">
      <h2>мқјл°ҳм—…мІҙ</h2>
      <span>мөңк·ј л“ұлЎқлҗң мқјл°ҳ м—…мІҙ лӘ©лЎқмһ…лӢҲлӢӨ.</span>
    </div>
    <div class="grid normal-grid">
      <% vendors.filter(v=>!v.is_recommended&&!v.is_premium).forEach(v=>{ %>
        <a class="card vendor-open normal-card" href="/vendor/<%=v.id%>" data-vendor-id="<%=v.id%>">
          <div class="thumb small">
            <% if(v.image_data){%><img src="<%=v.image_data%>" alt=""><%} else {%><div class="noimg">IMAGE</div><%}%>
          </div>
          <h3><%=v.name%></h3>
          <span class="card-rating"><%=v.review_count>0?'вӯҗ '+v.avg_rating+' В· нӣ„кё° '+v.review_count+'к°ң':'вӯҗ нҸүм җ м—ҶмқҢ'%></span>
          <p><%=v.region%> В· <%=v.category%></p>
          <span><%=v.tags||''%></span>
        </a>
      <%})%>
    </div>
  </section>

  <aside class="right-board">
    <div class="side-box hot">
      <h3>мӢ к·ңм—…мІҙ</h3>
      <% vendors.slice(0,6).forEach(v=>{ %>
        <a class="mini-row vendor-open" href="/vendor/<%=v.id%>" data-vendor-id="<%=v.id%>">
          <b>NEW</b>
          <span><%=v.name%></span>
        </a>
      <%})%>
    </div>
    <div class="side-box">
      <h3>кіөм§ҖмӮ¬н•ӯ</h3>
      <% notices.forEach(n=>{ %>
        <div class="sideitem"><b><%=n.is_pinned?'[н•„лҸ…] ':''%><%=n.title%></b><p><%=n.content%></p></div>
      <%})%>
    </div>
    <div class="side-box">
      <h3>мөңмӢ  нӣ„кё°</h3>
      <% reviews.forEach(r=>{ %>
        <div class="sideitem"><b><%=r.title%></b><p><%=r.vendor_name%> В· вҳ…<%=r.rating%></p></div>
      <%})%>
    </div>
  </aside>
</main>

<div id="vendorModal" aria-hidden="true" style="display:none;position:fixed;left:0;right:0;top:0;bottom:0;z-index:100;">
  <div data-close="1" style="position:absolute;left:0;right:0;top:0;bottom:0;background:rgba(0,0,0,.78);"></div>
  <div style="position:relative;width:min(950px,calc(100% - 32px));max-height:86vh;margin:5vh auto;background:#101525;border:1px solid #29324f;border-radius:22px;box-shadow:0 30px 100px #000;overflow:auto;color:#f5f7ff;">
    <button type="button" data-close="1" style="float:right;margin:14px;width:42px;height:42px;border-radius:50%;font-size:28px;background:#090d18;color:#fff;border:1px solid #29324f;cursor:pointer;">Г—</button>
    <div id="vendorModalContent" style="padding:30px;clear:both;">л¶Ҳлҹ¬мҳӨлҠ” мӨ‘...</div>
  </div>
</div>

<script src="/public/js/app.js"></script>
</body>
</html>