<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>서비스 디렉터리</title>
  <link rel="stylesheet" href="/public/css/style.css">
  <style>#vendorModal.show{display:block!important}.modal-vendor-info{padding-bottom:18px;border-bottom:1px solid #29324f;margin-bottom:24px}.modal-vendor-info em{display:inline-block;background:#ffdc4d;color:#111;padding:7px 12px;border-radius:999px;font-weight:900;font-style:italic}.modal-vendor-info h2{font-size:38px;margin:12px 0 10px;line-height:1.12}.modal-vendor-info p{color:#c8d0e8;margin:0}.modal-vendor-head{display:grid;grid-template-columns:360px 1fr;gap:24px;align-items:stretch}.modal-vendor-photo{height:276px;border-radius:18px;overflow:hidden;background:#080d18;border:1px solid #29324f;display:grid;place-items:center}.modal-vendor-photo img{width:100%;height:100%;object-fit:cover}.modal-info-list{display:grid!important;grid-template-columns:1fr!important;grid-template-rows:1fr 1fr;gap:16px!important;margin-bottom:0;height:276px}.modal-info-box{min-height:130px!important;padding:20px!important;background:#080d18!important;border:1px solid #29324f!important;border-radius:16px!important}.modal-info-box b{display:block;color:#10d9ff;margin-bottom:13px;font-size:18px}.modal-info-box span{font-size:17px;line-height:1.45}.contact-box{display:grid!important;grid-template-columns:1fr 160px;grid-template-rows:auto 1fr;column-gap:18px;align-items:center}.contact-box b{grid-column:1/3}.contact-box span{align-self:center}.contact-box .call-btn{grid-column:2;grid-row:2;width:160px;height:52px;margin:0;align-self:center;justify-self:end}.modal-section{margin-top:24px;border-top:1px solid #29324f;padding-top:22px}.modal-section h3{margin:0 0 14px;font-size:23px}.modal-desc-box{background:#080d18;border:1px solid #29324f;border-radius:16px;padding:18px 20px}.review-title{display:flex;align-items:center;justify-content:space-between;gap:16px}.review-write-btn{width:auto!important;height:42px!important;min-height:42px!important;padding:0 18px!important;border:1px solid #2aa8ff!important;background:transparent!important;color:#dfe9ff!important;border-radius:12px!important}.review-write-btn:hover{background:linear-gradient(90deg,#ff3fb4,#10d9ff)!important;border-color:transparent!important}@media(max-width:900px){.modal-vendor-head{grid-template-columns:1fr}.modal-vendor-photo{height:260px}.modal-info-list{height:auto}.modal-info-box{min-height:auto!important}.contact-box{grid-template-columns:1fr}.contact-box b{grid-column:1}.contact-box .call-btn{grid-column:1;grid-row:auto;justify-self:start;margin-top:12px}}</style>
</head>
<body>
<header class="top">
  <a class="brand" href="/">서비스 디렉터리</a>
  <nav>
    <a href="/">홈</a>
    <% if(me){ %>
      <span><%=me.nickname%></span>
      <a href="/logout">로그아웃</a>
      <% if(me.role==='admin'){%><a href="/admin">관리자</a><%}%>
    <% }else{ %>
      <a href="/login">로그인</a>
      <a href="/join">회원가입</a>
    <% } %>
  </nav>
</header>

<section class="selector-wrap first-block">
  <div class="selector-head">★ 업종선택</div>
  <div class="selector-list">
    <a href="/">전체</a>
    <% ['카페','뷰티','맛집','교육','기타'].forEach(x=>{ %><a href="/?category=<%=x%>"><%=x%></a><%})%>
  </div>
  <div class="selector-head region">▦ 지역선택</div>
  <div class="selector-list">
    <a href="/">전체</a>
    <% ['서울','부산','대구','인천','광주','대전','제주'].forEach(x=>{ %><a href="/?region=<%=x%>"><%=x%></a><%})%>
  </div>
</section>

<section class="promo-search-wrap">
  <div class="premium-row-slider">
    <div class="premium-track">
      <% const loopBanners = banners.length ? banners : [{title:'프리미엄 배너',subtitle:'관리자에서 이미지 업로드 가능',link_url:'#',image_data:null},{title:'이벤트 배너',subtitle:'슬라이드로 노출됩니다',link_url:'#',image_data:null},{title:'광고 배너',subtitle:'여러 개 카드 배너 지원',link_url:'#',image_data:null}]; %>
      <% loopBanners.concat(loopBanners).forEach((b)=>{ %>
        <a class="premium-banner-card" href="<%=b.link_url||'#'%>">
          <% if(b.image_data){%><img src="<%=b.image_data%>" alt=""><%}%>
          <span>PREMIUM</span>
          <strong><%=b.title%></strong>
          <small><%=b.subtitle||'프리미엄 카드 배너'%></small>
        </a>
      <%})%>
    </div>
  </div>

  <form class="side-search">
    <input name="search" value="<%=query.search||''%>" placeholder="업체명검색">
    <select name="category">
      <option value="">전체업종 선택</option>
      <% ['카페','뷰티','맛집','교육','기타'].forEach(x=>{ %>
        <option <%=query.category===x?'selected':''%>><%=x%></option>
      <%})%>
    </select>
    <select name="region">
      <option value="">전체지역선택</option>
      <% ['서울','부산','대구','인천','광주','대전','제주'].forEach(x=>{ %>
        <option <%=query.region===x?'selected':''%>><%=x%></option>
      <%})%>
    </select>
    <button>검색</button>
  </form>
</section>

<main class="layout">
  <section class="content-area">
    <div class="section-title">
      <h2>추천업체</h2>
      <span>프리미엄과 추천 업체를 먼저 보여줍니다.</span>
    </div>
    <div class="grid featured-grid">
      <% vendors.filter(v=>v.is_recommended||v.is_premium).forEach(v=>{ %>
        <a class="card vendor-open <%=v.is_premium?'premium':'recommend'%>" href="/vendor/<%=v.id%>" data-vendor-id="<%=v.id%>">
          <div class="thumb">
            <% if(v.image_data){%><img src="<%=v.image_data%>" alt=""><%} else {%><div class="noimg">IMAGE</div><%}%>
          </div>
          <em><%=v.is_premium?'PREMIUM':'RECOMMEND'%></em>
          <h3><%=v.name%></h3>
          <p><%=v.region%> · <%=v.category%></p>
          <span><%=v.tags||'등록된 태그가 없습니다.'%></span>
        </a>
      <%})%>
    </div>

    <div class="section-title mt">
      <h2>일반업체</h2>
      <span>최근 등록된 일반 업체 목록입니다.</span>
    </div>
    <div class="grid normal-grid">
      <% vendors.filter(v=>!v.is_recommended&&!v.is_premium).forEach(v=>{ %>
        <a class="card vendor-open normal-card" href="/vendor/<%=v.id%>" data-vendor-id="<%=v.id%>">
          <div class="thumb small">
            <% if(v.image_data){%><img src="<%=v.image_data%>" alt=""><%} else {%><div class="noimg">IMAGE</div><%}%>
          </div>
          <h3><%=v.name%></h3>
          <p><%=v.region%> · <%=v.category%></p>
          <span><%=v.tags||''%></span>
        </a>
      <%})%>
    </div>
  </section>

  <aside class="right-board">
    <div class="side-box hot">
      <h3>신규업체</h3>
      <% vendors.slice(0,6).forEach(v=>{ %>
        <a class="mini-row vendor-open" href="/vendor/<%=v.id%>" data-vendor-id="<%=v.id%>">
          <b>NEW</b>
          <span><%=v.name%></span>
        </a>
      <%})%>
    </div>
    <div class="side-box">
      <h3>공지사항</h3>
      <% notices.forEach(n=>{ %>
        <div class="sideitem"><b><%=n.is_pinned?'[필독] ':''%><%=n.title%></b><p><%=n.content%></p></div>
      <%})%>
    </div>
    <div class="side-box">
      <h3>최신 후기</h3>
      <% reviews.forEach(r=>{ %>
        <div class="sideitem"><b><%=r.title%></b><p><%=r.vendor_name%> · ★<%=r.rating%></p></div>
      <%})%>
    </div>
  </aside>
</main>

<div id="vendorModal" aria-hidden="true" style="display:none;position:fixed;left:0;right:0;top:0;bottom:0;z-index:100;">
  <div data-close="1" style="position:absolute;left:0;right:0;top:0;bottom:0;background:rgba(0,0,0,.78);"></div>
  <div style="position:relative;width:min(950px,calc(100% - 32px));max-height:86vh;margin:5vh auto;background:#101525;border:1px solid #29324f;border-radius:22px;box-shadow:0 30px 100px #000;overflow:auto;color:#f5f7ff;">
    <button type="button" data-close="1" style="float:right;margin:14px;width:42px;height:42px;border-radius:50%;font-size:28px;background:#090d18;color:#fff;border:1px solid #29324f;cursor:pointer;">×</button>
    <div id="vendorModalContent" style="padding:30px;clear:both;">불러오는 중...</div>
  </div>
</div>

<script src="/public/js/app.js"></script>
</body>
</html>