<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>서비스 디렉터리</title><link rel="stylesheet" href="/public/css/style.css"></head><body>
<header class="top"><b>서비스 디렉터리</b><nav><a href="/">홈</a><% if(me){ %><span><%=me.nickname%></span><a href="/logout">로그아웃</a><% if(me.role==='admin'){%><a href="/admin">관리자</a><%}%><% }else{ %><a href="/login">로그인</a><a href="/join">회원가입</a><% } %></nav></header>
<section class="hero"><div><p class="eyebrow">운영형 포털 구조</p><h1>배너·업체·후기·회원관리까지 가능한 디렉터리</h1><form class="search"><input name="search" value="<%=query.search||''%>" placeholder="업체명/지역/태그 검색"><select name="category"><option value="">전체 업종</option><% ['카페','뷰티','맛집','교육','기타'].forEach(x=>{ %><option <%=query.category===x?'selected':''%>><%=x%></option><%})%></select><select name="region"><option value="">전체 지역</option><% ['서울','부산','대구','인천','광주','대전','제주'].forEach(x=>{ %><option <%=query.region===x?'selected':''%>><%=x%></option><%})%></select><button>검색</button></form></div><div class="slider"><% banners.forEach((b,i)=>{ %><a class="slide <%=i===0?'on':''%>" href="<%=b.link_url||'#'%>"><% if(b.image_data){%><img src="<%=b.image_data%>"><%}%><small>광고/공지</small><strong><%=b.title%></strong><span><%=b.subtitle||''%></span></a><%})%></div></section>
<section class="categoryBar"><div><b>★ 업종선택</b><a href="/?category=카페">카페</a><a href="/?category=뷰티">뷰티</a><a href="/?category=맛집">맛집</a><a href="/?region=서울">서울</a><a href="/?region=부산">부산</a></div></section>
<main class="layout"><section><h2>추천업체</h2><div class="grid"><% vendors.filter(v=>v.is_recommended||v.is_premium).forEach(v=>{ %><a class="card premium" href="/vendor/<%=v.id%>"><em><%=v.is_premium?'PREMIUM':'RECOMMEND'%></em><% if(v.image_data){%><img src="<%=v.image_data%>"><%}%><h3><%=v.name%></h3><p><%=v.region%> · <%=v.category%></p><span><%=v.tags||''%></span></a><%})%></div><h2>일반업체</h2><div class="grid normal"><% vendors.filter(v=>!v.is_recommended&&!v.is_premium).forEach(v=>{ %><a class="card" href="/vendor/<%=v.id%>"><% if(v.image_data){%><img src="<%=v.image_data%>"><%}%><h3><%=v.name%></h3><p><%=v.region%> · <%=v.category%></p><span><%=v.tags||''%></span></a><%})%></div></section><aside><h3>공지</h3><% notices.forEach(n=>{ %><div class="sideitem"><b><%=n.is_pinned?'[필독] ':''%><%=n.title%></b><p><%=n.content%></p></div><%})%><h3>최신 후기</h3><% reviews.forEach(r=>{ %><div class="sideitem"><b><%=r.title%></b><p><%=r.vendor_name%> · ★<%=r.rating%></p></div><%})%></aside></main>
<script src="/public/js/app.js"></script></body></html>
