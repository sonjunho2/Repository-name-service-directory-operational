<!doctype html>
<html lang="ko">
<head>
  <% const siteBrand=(typeof settings!=='undefined'&&settings&&settings.brand)?settings.brand:{name:'서비스 디렉터리',showLogo:false,showName:true,logo:'',link:'/'}; %>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%=siteBrand.name%> - 지역별 추천업체 모음</title>
  <meta name="description" content="지역별 추천업체, 프리미엄 업체, 후기와 연락처를 한곳에서 확인할 수 있는 서비스 디렉터리입니다.">
  <meta name="robots" content="index,follow">
  <meta property="og:type" content="website">
  <meta property="og:title" content="서비스 디렉터리 - 지역별 추천업체 모음">
  <meta property="og:description" content="지역별 추천업체와 프리미엄 업체 정보를 빠르게 확인하세요.">
  <meta property="og:site_name" content="<%=siteBrand.name%>">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="canonical" href="/">
  <link rel="stylesheet" href="/public/css/style.css">
  <link rel="stylesheet" href="/public/css/home-card-layout-v48.css">
  <link rel="stylesheet" href="/public/css/vendor-popup-layout-v50.css">
  <link rel="stylesheet" href="/public/css/mobile-branding-v55.css">
  <style>#vendorModal.show{display:block!important}.card-rating{display:inline-flex!important;align-items:center!important;margin:6px 0 8px!important;padding:6px 10px!important;border:1px solid #39466c!important;border-radius:999px!important;color:#ffdc4d!important;background:#080d18!important;font-size:13px!important;font-weight:900!important;width:max-content!important}.popular-rank{display:inline-flex!important;align-items:center!important;justify-content:center!important;width:28px!important;height:28px!important;border-radius:9px!important;background:linear-gradient(135deg,#ffdc4d,#ff3fb4)!important;color:#111!important;font-weight:900!important;margin-right:8px!important}.popular-view{margin-left:auto!important;color:#10d9ff!important;font-size:12px!important;font-weight:800!important}.modal-vendor-info{padding-bottom:18px;border-bottom:1px solid #29324f;margin-bottom:24px}.modal-vendor-info em{display:inline-block;background:#ffdc4d;color:#111;padding:7px 12px;border-radius:999px;font-weight:900;font-style:italic}.modal-vendor-info h2{font-size:38px;margin:12px 0 10px;line-height:1.12}.modal-vendor-info p{color:#c8d0e8;margin:0}.modal-vendor-head{display:grid;grid-template-columns:360px 1fr;gap:24px;align-items:stretch}.modal-vendor-photo{height:276px;border-radius:18px;overflow:hidden;background:#080d18;border:1px solid #29324f;display:grid;place-items:center}.modal-vendor-photo img{width:100%;height:100%;object-fit:cover}.modal-info-list{display:grid!important;grid-template-columns:1fr!important;grid-template-rows:1fr 1fr;gap:16px!important;margin-bottom:0;height:276px}.modal-info-box{min-height:130px!important;padding:20px!important;background:#080d18!important;border:1px solid #29324f!important;border-radius:16px!important}.modal-info-box b{display:block;color:#10d9ff;margin-bottom:13px;font-size:18px}.modal-info-box span{font-size:17px;line-height:1.45}.contact-box{display:grid!important;grid-template-columns:1fr 160px;grid-template-rows:auto 1fr;column-gap:18px;align-items:center}.contact-box b{grid-column:1/3}.contact-box span{align-self:center}.contact-box .call-btn{grid-column:2;grid-row:2;width:160px;height:52px;margin:0;align-self:center;justify-self:end}.modal-section{margin-top:24px;border-top:1px solid #29324f;padding-top:22px}.modal-section h3{margin:0 0 14px;font-size:23px}.modal-desc-box{background:#080d18;border:1px solid #29324f;border-radius:16px;padding:18px 20px}.review-title{display:flex;align-items:center;justify-content:space-between;gap:16px}.review-write-btn{width:auto!important;height:42px!important;min-height:42px!important;padding:0 18px!important;border:1px solid #2aa8ff!important;background:transparent!important;color:#dfe9ff!important;border-radius:12px!important}.review-write-btn:hover{background:linear-gradient(90deg,#ff3fb4,#10d9ff)!important;border-color:transparent!important}.promo-search-wrap{position:relative;z-index:2;overflow:visible}.side-search{position:relative;z-index:5;overflow:visible}.side-search input,.side-search select,.side-search button{position:relative;z-index:6;box-sizing:border-box;width:100%;min-height:46px}.side-search select option{background:#080d18;color:#fff}@media(max-width:900px){.modal-vendor-head{grid-template-columns:1fr}.modal-vendor-photo{height:260px}.modal-info-list{height:auto}.modal-info-box{min-height:auto!important}.contact-box{grid-template-columns:1fr}.contact-box b{grid-column:1}.contact-box .call-btn{grid-column:1;grid-row:auto;justify-self:start;margin-top:12px}}</style>
</head>
<body>
<%- include('partials/public-mobile-menu') %>
<header class="top">
  <a class="brand" href="/">홈</a>
  <a class="site-brand-center" href="<%=siteBrand.link||'/'%>">
    <% if(siteBrand.showLogo&&siteBrand.logo){ %><img src="<%=siteBrand.logo%>" alt=""><% } %>
    <% if(siteBrand.showName){ %><span><%=siteBrand.name%></span><% } %>
  </a>
  <nav>
    <a href="/boards">커뮤니티</a>
    <% if(me){ %>
      <% if(me.role==='admin'){ %>
        <a href="/admin">관리자</a>
      <% } else if(me.is_vendor){ %>
        <a href="/vendor-dashboard">업체관리</a>
      <% } else { %>
        <a href="/mypage">마이페이지</a>
      <% } %>
      <a href="/logout">로그아웃</a>
    <% }else{ %>
      <a href="/login">로그인</a>
      <a href="/join">회원가입</a>
    <% } %>
  </nav>
</header>
<% const categories=(settings&&settings.categories&&settings.categories.length)?settings.categories:['카페','뷰티','맛집','교육','기타']; const regions=(settings&&settings.regions&&settings.regions.length)?settings.regions:['서울','부산','대구','인천','광주','대전','제주']; %>

<section class="main-hero first-block">
  <form class="hero-filter" autocomplete="off" method="get" action="/">
    <input name="search" value="<%=query.search||''%>" placeholder="업체명, 태그, 키워드 검색" autocomplete="off">
    <select name="category">
      <option value="">전체 업종</option>
      <% categories.forEach(x=>{ %>
        <option value="<%=x%>" <%=query.category===x?'selected':''%>><%=x%></option>
      <%})%>
    </select>
    <select name="region">
      <option value="">전체 지역</option>
      <% regions.forEach(x=>{ %>
        <option value="<%=x%>" <%=query.region===x?'selected':''%>><%=x%></option>
      <%})%>
    </select>
    <select name="sort">
      <option value="default" <%=query.sort==='default'||!query.sort?'selected':''%>>기본순</option>
      <option value="views" <%=query.sort==='views'?'selected':''%>>조회수순</option>
      <option value="rating" <%=query.sort==='rating'?'selected':''%>>평점순</option>
      <option value="reviews" <%=query.sort==='reviews'?'selected':''%>>후기순</option>
      <option value="latest" <%=query.sort==='latest'?'selected':''%>>최신순</option>
    </select>
    <button>검색</button>
  </form>
</section>

<section class="premium-showcase">
  <div class="showcase-title">
    <h2>프리미엄</h2>
  </div>
  <div class="premium-row-slider unified-premium-slider">
    <div class="premium-track">
      <%
        const premiumVendors = vendors.filter(v=>v.banner_active);
        // 관리자 직접 배너는 업체연동 배너와 함께 프리미엄 슬라이더에 노출합니다.
        // vendor_id가 있는 banners 행은 premiumVendors와 중복될 수 있어 관리자직접 배너만 별도로 합칩니다.
        const bannerItems = (typeof banners !== 'undefined' ? banners : [])
          .filter(b=>!b.vendor_id)
          .map(b=>({
            id: 'banner-' + b.id,
            name: b.title || '프리미엄 배너',
            region: b.subtitle || '슬라이드로 노출됩니다',
            category: '',
            image_data: b.image_data || null,
            href: b.link_url || '#',
            isBannerOnly: true
          }));
        const fallbackBanners = [
          {id:'dummy-1',name:'프리미엄 배너',region:'슬라이드로 노출됩니다',category:'',image_data:null,href:'#',isBannerOnly:true},
          {id:'dummy-2',name:'광고 배너',region:'대표이미지/GIF 노출 영역',category:'',image_data:null,href:'#',isBannerOnly:true},
          {id:'dummy-3',name:'이벤트 배너',region:'관리자 배너목록으로 관리',category:'',image_data:null,href:'#',isBannerOnly:true}
        ];
        const mergedPremiumItems = premiumVendors.concat(bannerItems);
        const sourcePremium = mergedPremiumItems.length ? mergedPremiumItems : fallbackBanners;
        const premiumLoop = [];
        for(let i=0;i<6;i++){ sourcePremium.forEach(v=>premiumLoop.push(v)); }
      %>
      <% premiumLoop.forEach(v=>{ %>
        <a class="card <%=v.isBannerOnly ? 'premium banner-direct-open' : 'vendor-open premium'%>" href="<%=v.href || ('/vendor/' + v.id)%>" <%- v.isBannerOnly ? '' : ('data-vendor-id="' + v.id + '"') %>>
          <div class="thumb">
            <% if(v.image_data){%><img src="<%=v.image_data%>" alt="" loading="lazy" decoding="async"><%} else {%><div class="noimg">IMAGE</div><%}%>
          </div>
          <div class="ad-card-meta">
            <em>PREMIUM</em>
            <h3><%=v.name%></h3>
            <p><%=v.region%><%=v.category ? ' · ' + v.category : ''%></p>
          </div>
        </a>
      <%})%>
    </div>
  </div>
</section>

<main class="layout">
  <section class="content-area">
    <div class="section-title">
      <h2>추천업체</h2>
    </div>
    <div class="grid featured-grid unified-ad-grid">
      <% vendors.filter(v=>v.ad_type==='recommended').forEach(v=>{ %>
        <a class="card vendor-open recommend" href="/vendor/<%=v.id%>" data-vendor-id="<%=v.id%>">
          <div class="thumb">
            <% if(v.image_data){%><img src="<%=v.image_data%>" alt="" loading="lazy" decoding="async"><%} else {%><div class="noimg">IMAGE</div><%}%>
          </div>
          <div class="ad-card-meta">
            <em>RECOMMEND</em>
            <h3><%=v.name%></h3>
            <p><%=v.region%> · <%=v.category%></p>
          </div>
        </a>
      <%})%>
    </div>

    <div class="section-title mt">
      <h2>일반업체</h2>
    </div>
    <div class="grid normal-grid unified-ad-grid">
      <% vendors.filter(v=>v.ad_type==='general').forEach(v=>{ %>
        <a class="card vendor-open normal-card" href="/vendor/<%=v.id%>" data-vendor-id="<%=v.id%>">
          <div class="thumb small">
            <% if(v.image_data){%><img src="<%=v.image_data%>" alt="" loading="lazy" decoding="async"><%} else {%><div class="noimg">IMAGE</div><%}%>
          </div>
          <div class="ad-card-meta compact">
            <h3><%=v.name%></h3>
            <p><%=v.region%> · <%=v.category%></p>
          </div>
        </a>
      <%})%>
    </div>
  </section>

  <aside class="right-board">
    <div class="side-box hot">
      <h3>추천 노출 업체</h3>
      <% vendors.slice(0,6).forEach(v=>{ %>
        <a class="mini-row vendor-open" href="/vendor/<%=v.id%>" data-vendor-id="<%=v.id%>">
          <b>NEW</b>
          <span><%=v.name%></span>
        </a>
      <%})%>
    </div>
    <div class="side-box hot">
      <h3>인기업체 TOP10</h3>
      <% vendors.slice().sort((a,b)=>((b.views||0)+(b.favorite_count||0)*5)-((a.views||0)+(a.favorite_count||0)*5)).slice(0,10).forEach((v,idx)=>{ %>
        <a class="mini-row vendor-open" href="/vendor/<%=v.id%>" data-vendor-id="<%=v.id%>">
          <b class="popular-rank"><%=idx+1%></b>
          <span><%=v.name%></span>
          <small class="popular-view">조회 <%=v.views||0%> · 찜 <%=v.favorite_count||0%></small>
        </a>
      <%})%>
    </div>
    <div class="side-box">
      <h3>공지사항</h3>
      <% notices.forEach(n=>{ %>
        <div class="sideitem"><b><%=n.is_pinned?'[필독] ':''%><%=n.title%></b><p><%=n.content%></p></div>
      <%})%>
    </div>
    <div class="side-box">
      <h3>최신 후기</h3>
      <% reviews.forEach(r=>{ %>
        <div class="sideitem"><b><%=r.title%></b><p><%=r.vendor_name%> · ★<%=r.rating%></p></div>
      <%})%>
    </div>
  </aside>
</main>

<%- include('partials/vendor-modal') %>
<script src="/public/js/app.js"></script>
</body>
</html>
