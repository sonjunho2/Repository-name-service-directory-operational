<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>마이페이지</title>
<link rel="stylesheet" href="/public/css/style.css">
<link rel="stylesheet" href="/public/css/mypage-polish.css">
<style>
.wrap{max-width:1000px;margin:30px auto;padding:0 18px}
.box{border:1px solid #29324f;border-radius:18px;background:#101525;padding:22px;margin-bottom:18px}
.btn{display:inline-flex;align-items:center;justify-content:center;height:42px;padding:0 16px;border-radius:12px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;text-decoration:none;font-weight:900}
.apply-hero{display:grid;grid-template-columns:minmax(0,1fr) 210px;gap:18px;align-items:center}
.apply-hero h2{margin:0 0 10px;font-size:28px;line-height:1.25}
.apply-hero p{margin:0 0 14px;color:#c8d0e8;line-height:1.65}
.apply-preview{width:100%;max-width:210px;aspect-ratio:4/5;border:1px solid #29324f;border-radius:18px;background:#070b15;overflow:hidden;position:relative;box-shadow:0 18px 48px rgba(0,0,0,.35)}
.apply-preview:before{content:'720 x 900';position:absolute;left:12px;top:12px;z-index:2;background:#ffdc4d;color:#111;border-radius:999px;padding:7px 10px;font-size:12px;font-weight:900}
.apply-preview:after{content:'4:5 업체 카드';position:absolute;left:12px;right:12px;bottom:12px;z-index:2;color:#fff;font-size:18px;font-weight:900;text-shadow:0 2px 10px #000}
.apply-preview-bg{position:absolute;inset:0;background:linear-gradient(145deg,rgba(255,63,180,.55),rgba(16,217,255,.35)),radial-gradient(circle at 50% 35%,rgba(255,255,255,.22),transparent 35%)}
.apply-guide{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;margin-top:14px}
.apply-guide span{display:block;border:1px solid #29324f;background:#070b15;border-radius:12px;padding:12px;color:#dfe9ff;font-size:13px;line-height:1.4}
.apply-guide b{display:block;color:#10d9ff;margin-bottom:5px;font-size:12px}
table{width:100%;border-collapse:collapse;margin-top:12px;background:#070b15}th,td{border:1px solid #29324f;padding:10px;text-align:left}th{background:#171d30}
@media(max-width:800px){.apply-hero{grid-template-columns:1fr}.apply-preview{max-width:180px}.apply-guide{grid-template-columns:1fr 1fr}}
@media(max-width:520px){.apply-guide{grid-template-columns:1fr}}
</style>
</head>
<body class="ui-theme ui-public-page ui-detail-page">
<% const siteBrand=(settings&&settings.brand)?settings.brand:{name:'서비스 디렉터리',showLogo:false,showName:true,logo:'',link:'/'}; %>
<%
  const reviewStatusLabel=(status)=>({visible:'표시중',hidden:'숨김',deleted:'삭제됨'}[status]||status||'대기');
  const inquiryStatusLabel=(status)=>({new:'접수',pending:'처리중',answered:'답변완료',approved:'승인',rejected:'반려',done:'완료'}[status]||status||'대기');
  const inquiryTypeLabel=(type)=>({apply:'입점신청',ad:'광고문의'}[type]||type||'문의');
%>
<header class="top"><a class="brand" href="/">홈</a><a class="site-brand-center" href="<%=siteBrand.link||'/'%>">
    <% if(siteBrand.showLogo&&siteBrand.logo){ %><img src="<%=siteBrand.logo%>" alt=""><% } %>
    <% if(siteBrand.showName){ %><span><%=siteBrand.name%></span><% } %>
  </a><nav><a href="/">홈</a><a href="/logout">로그아웃</a></nav></header>
<main class="wrap">
  <section class="box">
    <div class="apply-hero">
      <div>
        <h2>마이페이지</h2>
        <p>일반회원 페이지입니다. 업체를 운영한다면 업체 등록 신청 후 관리자 승인/연결을 통해 업체회원으로 전환할 수 있습니다.</p>
        <a class="btn" href="/vendor-apply">업체 등록 신청</a>
      </div>
      <div class="apply-preview" aria-hidden="true"><div class="apply-preview-bg"></div></div>
    </div>
    <div class="apply-guide">
      <span><b>대표 이미지</b>홈 카드에 맞춰 720 × 900px 권장</span>
      <span><b>비율</b>4:5 세로형 이미지/GIF 권장</span>
      <span><b>형식</b>JPG / PNG / WEBP / GIF</span>
      <span><b>용량</b>최대 5MB 이하 권장</span>
    </div>
  </section>
  <section class="box"><h3>찜한 업체</h3><% if((favorites||[]).length){ %><table><tr><th>업체</th><th>지역/업종</th><th>관리</th></tr><% favorites.forEach(f=>{%><tr><td><a href="/vendor/<%=f.vendor_id%>"><%=f.vendor_name%></a></td><td><%=f.region%> / <%=f.category%></td><td><form method="post" action="/favorite/<%=f.vendor_id%>/delete"><button>찜삭제</button></form></td></tr><%})%></table><% } else { %><p>찜한 업체가 없습니다.</p><% } %></section>
  <section class="box"><h3>내 후기</h3><% if((reviews||[]).length){ %><table><tr><th>업체</th><th>제목</th><th>평점</th><th>상태</th></tr><% reviews.forEach(r=>{%><tr><td><%=r.vendor_name||'삭제된 업체'%></td><td style="max-width:360px;white-space:normal;word-break:break-word"><%=r.title%></td><td>★ <%=r.rating%></td><td><%=reviewStatusLabel(r.status)%></td></tr><%})%></table><% } else { %><p>작성한 후기가 없습니다.</p><% } %></section>
  <section class="box"><h3>문의 내역</h3><% if((inquiries||[]).length){ %><table><tr><th>유형</th><th>제목</th><th>내용</th><th>상태</th><th>작성일</th></tr><% inquiries.forEach(i=>{%><tr><td><%=inquiryTypeLabel(i.type)%></td><td><%=i.company_name||'-'%></td><td style="max-width:420px;white-space:normal;word-break:break-word"><%=i.content||'-'%></td><td><%=inquiryStatusLabel(i.status)%></td><td><%=fmtDateTime(i.created_at)%></td></tr><%})%></table><% } else { %><p>문의 내역이 없습니다.</p><% } %></section>
</main>
</body>
</html>
