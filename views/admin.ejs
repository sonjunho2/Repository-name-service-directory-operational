atus===mode;row.classList.toggle('hidden-row',!(okText&&okMode));});}reportSearch?.addEventListener('input',()=>applyReportFilter(document.querySelector('[data-report-filter].on')?.dataset.reportFilter||'all'));reportSearchReset?.addEventListener('click',()=>{reportSearch.value='';applyReportFilter('all');setSubButtons(document.querySelector('#reports .admin-sub-filter'),'data-report-filter','all')});document.querySelectorAll('[data-vreq-filter]').forEach(btn=>btn.addEventListener('click',()=>{setSubButtons(btn.closest('.admin-sub-filter'),'data-vreq-filter',btn.dataset.vreqFilter);applyVendorReqFilter(btn.dataset.vreqFilter)}));function applyVendorReqFilter(mode='all'){const q=(vendorReqSearch?.value||'').trim().toLowerCase();document.querySelectorAll('.vendor-request-row').forEach(row=>{const okText=!q||row.dataset.search.includes(q);const okMode=mode==='all'||row.dataset.status===mode;row.classList.toggle('hidden-row',!(okText&&okMode));});}vendorReqSearch?.addEventListener('input',()=>applyVendorReqFilter(document.querySelector('[data-vreq-filter].on')?.dataset.vreqFilter||'all'));vendorReqReset?.addEventListener('click',()=>{vendorReqSearch.value='';applyVendorReqFilter('all');setSubButtons(document.querySelector('#vendorRequests .admin-sub-filter'),'data-vreq-filter','all')});const hash=location.hash?.replace('#','');if(hash)showAdminPanel(hash);applyVendorFilter();sortVendorRows();applyBannerFilter();sortBannerRows();applyUserFilter();sortUserRows();applyNoticeFilter();sortNoticeRows();applyReviewFilter();sortReviewRows();</script><script>
