#reports{--report-border:#293451}.report-summary-grid{display:grid;grid-template-columns:repeat(7,minmax(110px,1fr));gap:10px;margin:0 0 14px}.report-summary-grid button{display:grid;gap:7px;text-align:left;padding:14px;border:1px solid var(--report-border);border-radius:12px;background:#0b1221;color:#dce7ff;cursor:pointer}.report-summary-grid b{font-size:12px;color:#9eabc8}.report-summary-grid strong{font-size:23px}.report-admin-filter{display:grid;grid-template-columns:minmax(250px,1.8fr) repeat(4,minmax(125px,.8fr)) auto;gap:8px;margin-bottom:14px}.report-admin-filter>*{min-width:0;height:42px}.report-table-wrap{overflow:auto;border:1px solid var(--report-border);border-radius:12px}.report-table-wrap table{min-width:1290px;table-layout:fixed;margin:0}.report-table-wrap th,.report-table-wrap td{white-space:normal;vertical-align:top}.report-row td>small,.report-target-cell small{display:block;margin-top:5px;color:#8491ad;font-size:11px}.report-type-badge,.report-status-badge,.report-target-status{display:inline-flex;align-items:center;min-height:24px;padding:0 9px;border:1px solid #384563;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}.report-type-badge.vendor{background:#102d35;color:#75e7fa}.report-type-badge.review{background:#2d203c;color:#dab1ff}.report-status-badge.new{background:#33280d;color:#ffd56a}.report-status-badge.done,.report-target-status.exists{background:#103225;color:#69e6ad}.report-status-badge.rejected,.report-status-badge.cancelled,.report-target-status.missing{background:#3b1320;color:#ff9db6}.report-target-link{display:block;width:auto!important;min-height:0!important;height:auto!important;padding:0!important;border:0!important;background:transparent!important;color:#84dfff!important;text-align:left;font-weight:900;cursor:pointer}.report-target-link:disabled{color:#9aa2b5!important;cursor:default}.report-content-clamp,.report-memo-clamp{display:-webkit-box;overflow:hidden;-webkit-box-orient:vertical;-webkit-line-clamp: