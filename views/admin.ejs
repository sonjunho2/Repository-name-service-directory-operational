  <% (adminBoards||[]).forEach(b=>{ const layoutType=_boardLayoutLabels[b.layout_type]?b.layout_type:'list'; const protectedBoard=_protectedBoardSlugs.includes(String(b.slug||'').toLowerCase()); const postCount=Number(b.post_count||0); %><tr data-board-id="<%=b.id%>" data-board-title="<%=b.title%>" data-board-slug="<%=b.slug%>" data-board-layout="<%=layoutType%>" data-board-role="<%=b.write_role||'member'%>" data-board-comment="<%=b.comment_enabled?'1':'0'%>" data-board-image="<%=b.image_enabled?'1':'0'%>" data-board-active="<%=b.is_active?'1':'0'%>" data-board-protected="<%=protectedBoard?'1':'0'%>" data-board-posts="<%=postCount%>"><td><%=b.id%></td><td><b><%=b.title%></b><small class="board-address-text">/boards/<%=b.slug%></small><div class="board-row-badges"><% if(protectedBoard){ %><span class="board-protection-badge">기본 게시판</span><% } %><% if(postCount>0){ %><span class="board-protection-badge limited">주소 변경 제한</span><% } %></div><textarea class="board-row-description" hidden><%=b.description||''%></textarea></td><td><span class="board-type-badge"><%=_boardLayoutLabels[layoutType]%></span></td><td><%=_boardRoleLabels[b.write_role]||'회원'%></td><td><span class="board-feature-badge <%=b.comment_enabled?'enabled':'disabled'%>"><%=b.comment_enabled?'댓글 사용':'댓글 미사용'%></span> <span class="board-feature-badge <%=b.image_enabled?'enabled':'disabled'%>"><%=b.image_enabled?'이미지 사용':'이미지 미사용'%></span></td><td><span class="board-visibility-badge <%=b.is_active?'active':'inactive'%>"><%=b.is_active?'공개':'비공개'%></span></td><td><div class="board-actions"><button type="button" data-board-settings-open="<%=b.id%>">설정</button><button type="button" data-board-move="up" aria-label="위로 이동">위</button><button type="button" data-board-move="down" aria-label="아래로 이동">아래</button></div></td></tr><% }) %>
  </tbody></table></div>
