</style><script>
(function(){
  function formPath(form){
    return (form.getAttribute('action')||'').toLowerCase();
  }
  function buttonText(btn){
    return (btn&&btn.innerText||btn&&btn.value||'').trim();
  }
  function messageFor(form,btn){
    var path=formPath(form);
    var text=buttonText(btn);
    if(path.includes('/restore-json'))return '백업 파일 기준으로 현재 운영 데이터가 복원됩니다. 계속 진행할까요?';
    if(path.includes('/reset-data'))return '전체 운영 데이터 초기화는 되돌리기 어렵습니다. 정말 진행할까요?';
    if(path.includes('/delete')||text.includes('삭제'))return '삭제 또는 비활성화 작업입니다. 정말 진행할까요?';
    if(path.includes('/approve')||text.includes('승인'))return '승인 처리 후 운영 화면에 반영될 수 있습니다. 계속 진행할까요?';
    if(path.includes('/reject')||text.includes('반려'))return '반려 처리하시겠습니까?';
    if(path.includes('/paid')||text.includes('입금확인')||text.includes('입금 확인'))return '입금확인 처리 후 광고/배너가 반영될 수 있습니다. 계속 진행할까요?';
    if(text.includes('초기화'))return '초기화 작업입니다. 정말 진행할까요?';
    return '';
  }
  document.addEventListener('submit',function(e){
    var form=e.target;
    if(!form||form.dataset.safeConfirmDone==='1')return;
    var btn=document.activeElement;
    var msg=messageFor(form,btn);
    if(!msg)return;
    if(!confirm(msg)){
      e.preventDefault();
      e.stopPropagation();
    }else{
      form.dataset.safeConfirmDone='1';
    }
  },true);
})();
</script><script>
(function(){
  var storageKey='adminListState';
  function allState(){try{return JSON.parse(sessionStorage.getItem(storageKey)||'{}')||{};}catch(e){return {};}}
  window.getAdminListState=function(key){return allState()[key]||{};};
  window.setAdminListState=function(key,patch){var all=allState();all[key]=Object.assign({},all[key]||{},patch||{});try{sessionStorage.setItem(storageKey,JSON.stringify(all));}catch(e){}return all[key];};
  window.getPanelKeyFromActivePanel=function(){var id=document.querySelector('.admin-panel.active')?.id||String(location.hash||'').replace('#','')||'dashboard';return id==='revenue'?'payments':id;};
  function value(id,fallback){var el=document.getElementById(id);return el?el.value:(fallback||'');}
  window.saveActiveAdminListState=function(key,page){key=key||window.getPanelKeyFromActivePanel();var patch={page:Math.max(1,Number(page||window.getAdminListState(key).page||1))};
    if(key==='payments')Object.assign(patch,{q:value('paymentHistorySearch'),product:value('paymentProductFilter','all'),source:value('paymentSourceFilter','all'),amountState:value('paymentAmountFilter','all'),dateFrom:value('paymentDateFrom'),dateTo:value('paymentDateTo'),sort:value('paymentHistorySort','latest')});
    else if(key==='vendors')Object.assign(patch,{q:value('vendorSearch'),status:value('vendorStatusFilter','all'),sort:value('vendorSortFilter','latest')});
    else if(key==='users')Object.assign(patch,{q:value('userSearch'),status:value('userStatusFilter','all'),sort:value('userSortFilter','latest')});
    else if(key==='inquiries')Object.assign(patch,{q:value('inquirySearch'),status:value('inquiryStatus','all'),sort:value('inquirySort','latest')});
    else if(key==='reports')Object.assign(patch,{q:value('reportSearch'),type:value('reportTypeFilter','all'),status:value('reportStatusFilter','all'),target:value('reportTargetFilter','all'),sort:value('reportSort','latest')});
    else if(key==='banners')Object.assign(patch,{q:value('bannerSearch'),type:value('bannerTypeFilter','all'),status:value('bannerStatusFilter','all')});
    else if(key==='notices')Object.assign(patch,{q:value('noticeSearch'),pinned:value('noticePinnedFilter','all'),sort:value('noticeSortFilter','latest')});
    else if(key==='reviews')Object.assign(patch,{q:value('reviewSearch'),status:value('reviewStatusFilter','all'),rating:value('reviewRatingFilter','all'),report:value('reviewReportFilter','all'),sort:value('reviewSortFilter','latest')});
    else if(key==='adminLogs')Object.assign(patch,{q:value('adminLogSearch'),admin:value('adminLogAdminFilter','all'),action:value('adminLogActionFilter','all'),target:value('adminLogTargetFilter','all'),dateFrom:value('adminLogDateFrom'),dateTo:value('adminLogDateTo'),sort:value('adminLogSort','latest')});
    else if(key==='vendorRequests')Object.assign(patch,{q:value('vendorRequestSearch'),status:value('vendorRequestStatus','all'),sort:value('vendorRequestSort','latest')});
    else if(key==='adCenter')Object.assign(patch,{q:value('adPaymentSearch'),kind:value('adPaymentKind','all'),state:value('adPaymentState','all'),sort:value('adPaymentSort','latest')});
    else if(key==='boardPosts')Object.assign(patch,{q:value('boardPostSearch'),board_id:value('boardPostBoardFilter','all'),status:value('boardPostStatusFilter','all'),pinned:value('boardPostPinnedFilter','all'),sort:value('boardPostSort','latest')});
    else if(key==='boardComments')Object.assign(patch,{q:value('boardCommentSearch'),board_id:value('boardCommentBoardFilter','all'),status:value('boardCommentStatusFilter','all'),sort:value('boardCommentSort','latest')});
    else if(key==='adInquiries')Object.assign(patch,{q:value('adInquirySearch'),status:value('adInquiryStatus','all')});
    if(key==='users'||key==='vendors'||key==='banners'||key==='vendorRequests'){var all=allState();all[key]=patch;try{sessionStorage.setItem(storageKey,JSON.stringify(all));}catch(e){}return patch;}
    return window.setAdminListState(key,patch);
  };
