><td><span class="banner-kind-badge <%=b.vendor_id?'banner-kind-vendor':'banner-kind-admin'%>"><%=b.vendor_id?'업체연동':'관리자직접'%></span><% if(b.vendor_name){%><br><small><%=b.vendor_name%></small><%}%></td><td><%=b.title%></td><td><%=b.vendor_id?'업체 상세 팝업':(b.link_url||'-')%></td><td><span class="<%=_bActive?'status-on':'status-off'%>"><%=_bActive?'● 노출':'● 숨김'%></span></td><td><%=b.sort_order%></td><td><div class="row-actions"><% if(b.vendor_id){%><button type="button" class="edit-vendor-btn" data-id="<%=b.vendor_id%>">업체 수정</button><%}else{%><button type="button" class="edit-banner-btn" data-id="<%=b.id%>">수정</button><form method="post" action="/admin/delete/banners/<%=b.id%>"><button onclick="return confirm('삭제할까요?')">삭제</button></form><%}%></div></td></tr><%})%><% const _bannerVendorIds=new Set((banners||[]).filter(b=>b.vendor_id).map(b=>String(b.vendor_id))); %><% (vendors||[]).filter(v=>v.banner_active&&!_bannerVendorIds.has(String(v.id))).forEach(v=>{ const _vbActive=_vendorBannerVisible(v); %><tr class="banner-row banner-vendor-row" data-id="vendor-<%=v.id%>" data-order="0" data-title="<%=String((v.name||'')+' '+(v.region||'')+' '+(v.category||'')).toLowerCase()%>" data-position="premium" data-active="<%=_vbActive?'active':'hidden'%>"><td>업체 <%=v.id%></td><td><span class="banner-kind-badge banner-kind-vendor">업체연동</span><br><small><%=v.name%></small></td><td><%=v.name%></td><td>업체 상세 팝업</td><td><span class="<%=_vbActive?'status-on':'status-off'%>"><%=_vbActive?'● 노출':'● 숨김'%></span></td><td>-</td><td><div class="row-actions"><button type="button" class="edit-vendor-btn" data-id="<%=v.id%>">업체 수정</button></div></td></tr><%})%></table></section><section id="users" class="panel admin-panel"><h2>회원 관리</h2>
