  async function load(kind,page){var isPosts=kind==='boardPosts',body=document.getElementById(isPosts?'boardPostAdminRows':'boardCommentAdminRows');if(!body||loading[kind])return false;page=Math.max(1,Number(page||window.getAdminListState?.(kind).page||1));loading[kind]=true;body.innerHTML='<tr><td colspan="'+(isPosts?10:8)+'">목록을 불러오는 중입니다.</td></tr>';
    var params=new URLSearchParams({page:String(page),limit:String(limit),sort:(document.getElementById(isPosts?'boardPostSort':'boardCommentSort')?.value||'latest')});var search=(document.getElementById(isPosts?'boardPostSearch':'boardCommentSearch')?.value||'').trim(),board=document.getElementById(isPosts?'boardPostBoardFilter':'boardCommentBoardFilter')?.value||'all',state=document.getElementById(isPosts?'boardPostStatusFilter':'boardCommentStatusFilter')?.value||'all';if(search)params.set('q',search);if(board!=='all')params.set('board_id',board);if(state!=='all')params.set('status',state);if(isPosts){var pinned=document.getElementById('boardPostPinnedFilter')?.value||'all';if(pinned!=='all')params.set('pinned',pinned);}
