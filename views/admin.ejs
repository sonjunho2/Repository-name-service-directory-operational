  const _centerUnpaid=_centerAll.filter(x=>x.status==='new'&&(!x.payment_status||x.payment_status==='unpaid')).length;
  const _centerWaiting=_centerAll.filter(x=>x.status==='new'&&x.payment_status==='waiting').length;
  const _centerApproved=_centerAll.filter(x=>x.status==='approved').length;
  const _centerRejected=_centerAll.filter(x=>x.status==='rejected').length;
  const _centerCancelled=_centerAll.filter(x=>x.status==='cancelled').length;
  const _centerStatus=x=>x.status==='approved'?'approved':x.status==='rejected'?'rejected':x.status==='cancelled'?'cancelled':x.payment_status==='waiting'?'waiting':'unpaid';
%>

