<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>관리자</title><link rel="stylesheet" href="/public/css/style.css"><style>.admin-shell{display:grid;grid-template-columns:240px 1fr;min-height:calc(100vh - 68px)}.admin-sidebar{background:#080d18;border-right:1px solid #29324f;padding:22px}.admin-sidebar h2{margin:0 0 18px}.admin-sidebar a{display:flex;align-items:center;height:44px;margin:0 0 8px;padding:0 14px;border-radius:12px;color:#dfe9ff;text-decoration:none;font-weight:900}.admin-sidebar a.active,.admin-sidebar a:hover{background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff}.admin-sidebar .line{height:1px;background:#29324f;margin:16px 0}.admin-content{padding:26px;min-width:0}.admin-panel{display:none}.admin-panel.active{display:block}.admin-content .panel{max-width:none;width:100%;margin:0;padding:28px}.admin-content input,.admin-content select,.admin-content textarea{width:100%;height:42px;box-sizing:border-box;border-radius:10px;padding:0 12px;background:#070b15;border:1px solid #29324f;color:#fff}.admin-content textarea{height:82px;padding:12px}.gridform{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px}.gridform textarea,.form-actions{grid-column:1/5}.form-actions{display:grid;grid-template-columns:1fr 140px;gap:10px}.admin-content label{height:42px;display:flex;align-items:center;gap:8px;padding:0 12px;border:1px solid #29324f;border-radius:10px;background:#070b15}.admin-content button{height:38px;border:0;border-radius:999px;padding:0 16px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900;cursor:pointer}.admin-content table{width:100%;border-collapse:collapse;margin-top:14px;background:#070b15}.admin-content th,.admin-content td{border:1px solid #29324f;padding:11px;white-space:nowrap;vertical-align:middle}.admin-content th{background:#171d30}.row-actions{display:flex;gap:8px}.cancel-edit{background:#222b43!important}.dash-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}.dash-card{padding:22px;border:1px solid #29324f;border-radius:18px;background:#070b15}.dash-card b{display:block;color:#c8d0e8;margin-bottom:10px}.dash-card strong{font-size:34px}.dash-card.hot{background:linear-gradient(135deg,rgba(255,63,180,.25),rgba(16,217,255,.13))}.dash-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}.dash-list{padding:18px;border:1px solid #29324f;border-radius:18px;background:#070b15}.dash-list a{display:flex;justify-content:space-between;padding:10px 0;color:#dfe9ff;text-decoration:none;border-bottom:1px solid #1d263d}.vendor-admin-filter{display:grid;grid-template-columns:1.5fr 1fr 1fr 120px;gap:10px;margin:0 0 18px}.vendor-admin-filter button{height:42px}.hidden-row{display:none!important}.external-content .top,.external-content header{display:none!important}.external-content .admin,.external-content .wrap{padding:0!important;margin:0!important;max-width:none!important}.external-content .panel{padding:0!important;background:transparent!important;border:0!important}@media(max-width:1200px){.gridform,.dash-grid,.dash-row,.vendor-admin-filter{grid-template-columns:1fr 1fr}.gridform textarea,.form-actions{grid-column:1/3}}@media(max-width:800px){.admin-shell,.gridform,.dash-grid,.dash-row,.vendor-admin-filter{grid-template-columns:1fr}.gridform textarea,.form-actions{grid-column:1}}</style></head><body><header class="top"><b>관리자</b><nav><a href="/">사이트</a><a href="/logout">로그아웃</a></nav></header><div class="admin-shell"><aside class="admin-sidebar"><h2>관리 메뉴</h2><a class="active" href="#dashboard" data-panel="dashboard">대시보드</a><a href="#vendors" data-panel="vendors">업체관리</a><a href="#banners" data-panel="banners">배너관리</a><a href="#users" data-panel="users">회원관리</a><a href="#notices" data-panel="notices">공지관리</a><a href="#reviews" data-panel="reviews">후기관리</a><div class="line"></div><a href="#inquiries" data-panel="inquiries">광고/입점 신청</a><a href="#reports" data-panel="reports">신고내역</a><a href="/">사이트 보기</a></aside><main class="admin-content">
<section id="dashboard" class="panel admin-panel active"><h2>대시보드</h2><div class="dash-grid"><div class="dash-card hot"><b>전체 업체</b><strong><%=vendors.length%></strong></div><div class="dash-card"><b>프리미엄 업체</b><strong><%=vendors.filter(v=>v.is_premium).length%></strong></div><div class="dash-card"><b>일반 업체</b><strong><%=vendors.filter(v=>!v.is_premium&&!v.is_recommended).length%></strong></div><div class="dash-card"><b>전체 회원</b><strong><%=users.length%></strong></div><div class="dash-card"><b>전체 배너</b><strong><%=banners.length%></strong></div><div class="dash-card"><b>전체 후기</b><strong><%=reviews.length%></strong></div><div class="dash-card"><b>신청내역</b><strong><%=inquiries.length%></strong></div><div class="dash-card"><b>신규 신청</b><strong><%=inquiries.filter(x=>x.status!=='approved').length%></strong></div></div><div class="dash-row"><div class="dash-list"><h3>조회수 TOP5</h3><% vendors.slice().sort((a,b)=>(b.views||0)-(a.views||0)).slice(0,5).forEach((v,i)=>{%><a href="#vendors" data-panel="vendors"><span><%=i+1%>. <%=v.name%></span><b>조회 <%=v.views||0%></b></a><%})%></div><div class="dash-list"><h3>바로가기</h3><a href="#inquiries" data-panel="inquiries"><span>광고/입점 신청</span><b><%=inquiries.length%>건</b></a><a href="#reports" data-panel="reports"><span>신고내역</span><b>확인</b></a><a href="#banners" data-panel="banners"><span>배너 관리</span><b><%=banners.length%>개</b></a><a href="#reviews" data-panel="reviews"><span>후기 관리</span><b><%=reviews.length%>개</b></a></div></div></section>
<section id="vendors" class="panel admin-panel"><h2>업체 관리</h2><form id="vendorForm" method="post" action="/admin/vendor" enctype="multipart/form-data" class="gridform"><input type="hidden" name="id"><input name="name" placeholder="업체명" required><input name="category" placeholder="업종" required><input name="region" placeholder="지역" required><input name="phone" placeholder="연락처"><input name="kakao_url" placeholder="카카오톡 문의 링크"><input name="business_hours" placeholder="영업시간"><input name="tags" placeholder="태그"><select name="status"><option value="active">노출</option><option value="hidden">숨김</option></select><label><input type="checkbox" name="is_recommended">추천업체</label><label><input type="checkbox" name="is_premium">프리미엄</label><input type="file" name="image" accept="image/*"><textarea name="description" placeholder="업체소개"></textarea><div class="form-actions"><button id="vendorSubmitBtn">업체 등록</button><button type="button" id="cancelVendorEdit" class="cancel-edit" style="display:none">취소</button></div></form><div class="vendor-admin-filter"><input id="vendorSearch" placeholder="업체명 검색"><select id="vendorTypeFilter"><option value="all">전체 구분</option><option value="premium">프리미엄</option><option value="recommend">추천</option><option value="normal">일반</option></select><select id="vendorStatusFilter"><option value="all">전체 상태</option><option value="active">노출</option><option value="hidden">숨김</option></select><button type="button" id="vendorFilterReset">초기화</button></div><table><tr><th>ID</th><th>구분</th><th>업체명</th><th>지역/업종</th><th>영업시간</th><th>상태</th><th>관리</th></tr><% vendors.forEach(v=>{ const t=v.is_premium?'premium':v.is_recommended?'recommend':'normal'; %><tr class="vendor-row" data-name="<%=String(v.name||'').toLowerCase()%>" data-type="<%=t%>" data-status="<%=v.status%>"><td><%=v.id%></td><td><%=v.is_premium?'프리미엄':v.is_recommended?'추천':'일반'%></td><td><%=v.name%></td><td><%=v.region%>/<%=v.category%></td><td><%=v.business_hours||'-'%></td><td><%=v.status%></td><td><div class="row-actions"><button type="button" class="edit-vendor-btn" data-id="<%=v.id%>">수정</button><form method="post" action="/admin/delete/vendors/<%=v.id%>"><button onclick="return confirm('삭제할까요?')">삭제</button></form></div></td></tr><%})%></table></section>
<section id="banners" class="panel admin-panel"><h2>배너 관리</h2><form id="bannerForm" method="post" action="/admin/banner" enctype="multipart/form-data" class="gridform"><input type="hidden" name="id"><input name="title" placeholder="배너 제목" required><input name="subtitle" placeholder="부제목"><input name="link_url" placeholder="링크 URL"><input name="sort_order" type="number" placeholder="정렬순서" value="0"><select name="position"><option value="premium">프리미엄</option><option value="main">메인</option></select><label><input type="checkbox" name="is_active" checked>노출</label><input type="file" name="image" accept="image/*"><div class="form-actions"><button id="bannerSubmitBtn">배너 등록</button><button type="button" id="cancelBannerEdit" class="cancel-edit" style="display:none">취소</button></div></form><table><tr><th>ID</th><th>제목</th><th>위치</th><th>순서</th><th>상태</th><th>관리</th></tr><% banners.forEach(b=>{%><tr><td><%=b.id%></td><td><%=b.title%></td><td><%=b.position%></td><td><%=b.sort_order%></td><td><%=b.is_active?'노출':'숨김'%></td><td><div class="row-actions"><button type="button" class="edit-banner-btn" data-id="<%=b.id%>">수정</button><form method="post" action="/admin/delete/banners/<%=b.id%>"><button onclick="return confirm('삭제할까요?')">삭제</button></form></div></td></tr><%})%></table></section>
<section id="users" class="panel admin-panel"><h2>회원 관리</h2><table><tr><th>ID</th><th>아이디</th><th>닉네임</th><th>권한</th><th>상태</th><th>수정</th></tr><% users.forEach(u=>{%><tr><td><%=u.id%></td><td><%=u.username%></td><td><input form="userForm<%=u.id%>" name="nickname" value="<%=u.nickname%>"></td><td><select form="userForm<%=u.id%>" name="role"><option <%=u.role==='user'?'selected':''%>>user</option><option <%=u.role==='admin'?'selected':''%>>admin</option></select></td><td><select form="userForm<%=u.id%>" name="status"><option <%=u.status==='active'?'selected':''%>>active</option><option <%=u.status==='blocked'?'selected':''%>>blocked</option></select></td><td><form id="userForm<%=u.id%>" method="post" action="/admin/user" class="row-actions"><input type="hidden" name="id" value="<%=u.id%>"><input name="password" placeholder="새 비번"><button>저장</button></form></td></tr><%})%></table></section>
<section id="notices" class="panel admin-panel"><h2>공지 관리</h2><form method="post" action="/admin/notice" class="gridform"><input name="title" placeholder="제목" required><textarea name="content" placeholder="내용" required></textarea><label><input type="checkbox" name="is_pinned">상단 고정</label><button>공지 등록</button></form><table><tr><th>ID</th><th>제목</th><th>삭제</th></tr><% notices.forEach(n=>{%><tr><td><%=n.id%></td><td><%=n.title%></td><td><form method="post" action="/admin/delete/notices/<%=n.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
<section id="reviews" class="panel admin-panel"><h2>후기 관리</h2><table><tr><th>ID</th><th>업체</th><th>제목</th><th>평점</th><th>삭제</th></tr><% reviews.forEach(r=>{%><tr><td><%=r.id%></td><td><%=r.vendor_name%></td><td><%=r.title%></td><td><%=r.rating%></td><td><form method="post" action="/admin/delete/reviews/<%=r.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
<section id="inquiries" class="panel admin-panel"><div class="external-content" data-url="/admin/inquiries"><div>신청내역을 불러오는 중...</div></div></section><section id="reports" class="panel admin-panel"><div class="external-content" data-url="/admin/reports"><div>신고내역을 불러오는 중...</div></div></section>
</main></div><script>const ADMIN_VENDORS=<%- JSON.stringify(vendors).replace(/</g,'\\u003c') %>;const ADMIN_BANNERS=<%- JSON.stringify(banners).replace(/</g,'\\u003c') %>;function showAdminPanel(id){document.querySelectorAll('.admin-panel').forEach(p=>p.classList.remove('active'));const p=document.getElementById(id);if(p){p.classList.add('active');loadExternal(p)}document.querySelectorAll('[data-panel]').forEach(a=>a.classList.toggle('active',a.dataset.panel===id));}document.querySelectorAll('[data-panel]').forEach(a=>a.addEventListener('click',e=>{e.preventDefault();showAdminPanel(a.dataset.panel);history.replaceState(null,'','#'+a.dataset.panel)}));async function loadExternal(p){const box=p.querySelector('.external-content[data-url]');if(!box||box.dataset.loaded)return;try{const res=await fetch(box.dataset.url,{credentials:'same-origin'});const html=await res.text();const doc=new DOMParser().parseFromString(html,'text/html');const inner=doc.querySelector('main .panel')||doc.querySelector('.panel')||doc.body;box.innerHTML=inner.innerHTML;box.dataset.loaded='1'}catch(e){box.innerHTML='내용을 불러오지 못했습니다.'}}function applyVendorFilter(){const q=(vendorSearch?.value||'').trim().toLowerCase();const t=vendorTypeFilter?.value||'all';const s=vendorStatusFilter?.value||'all';document.querySelectorAll('.vendor-row').forEach(row=>{const okName=!q||row.dataset.name.includes(q);const okType=t==='all'||row.dataset.type===t;const okStatus=s==='all'||row.dataset.status===s;row.classList.toggle('hidden-row',!(okName&&okType&&okStatus));});}['input','change'].forEach(ev=>{vendorSearch?.addEventListener(ev,applyVendorFilter);vendorTypeFilter?.addEventListener(ev,applyVendorFilter);vendorStatusFilter?.addEventListener(ev,applyVendorFilter);});vendorFilterReset?.addEventListener('click',()=>{vendorSearch.value='';vendorTypeFilter.value='all';vendorStatusFilter.value='all';applyVendorFilter();});const vf=document.getElementById('vendorForm'),bf=document.getElementById('bannerForm');document.querySelectorAll('.edit-vendor-btn').forEach(btn=>btn.onclick=()=>{const v=ADMIN_VENDORS.find(x=>String(x.id)===String(btn.dataset.id));if(!v)return;showAdminPanel('vendors');vf.id.value=v.id||'';vf.name.value=v.name||'';vf.category.value=v.category||'';vf.region.value=v.region||'';vf.phone.value=v.phone||'';vf.kakao_url.value=v.kakao_url||'';vf.business_hours.value=v.business_hours||'';vf.tags.value=v.tags||'';vf.status.value=v.status||'active';vf.description.value=v.description||'';vf.is_recommended.checked=!!v.is_recommended;vf.is_premium.checked=!!v.is_premium;vendorSubmitBtn.textContent='업체 수정';cancelVendorEdit.style.display='block';vf.scrollIntoView({behavior:'smooth'})});cancelVendorEdit.onclick=()=>{vf.reset();vf.id.value='';vendorSubmitBtn.textContent='업체 등록';cancelVendorEdit.style.display='none'};document.querySelectorAll('.edit-banner-btn').forEach(btn=>btn.onclick=()=>{const b=ADMIN_BANNERS.find(x=>String(x.id)===String(btn.dataset.id));if(!b)return;showAdminPanel('banners');bf.id.value=b.id||'';bf.title.value=b.title||'';bf.subtitle.value=b.subtitle||'';bf.link_url.value=b.link_url||'';bf.sort_order.value=b.sort_order||0;bf.position.value=b.position||'premium';bf.is_active.checked=!!b.is_active;bannerSubmitBtn.textContent='배너 수정';cancelBannerEdit.style.display='block';bf.scrollIntoView({behavior:'smooth'})});cancelBannerEdit.onclick=()=>{bf.reset();bf.id.value='';bf.is_active.checked=true;bannerSubmitBtn.textContent='배너 등록';cancelBannerEdit.style.display='none'};showAdminPanel((location.hash||'#dashboard').replace('#',''));</script></body></html>