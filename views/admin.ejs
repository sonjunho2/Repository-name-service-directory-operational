</section></main></div><script>const ADMIN_VENDORS=<%- JSON.stringify(vendors).replace(/</g,'\u003c') %>;const ADMIN_BANNERS=<%- JSON.stringify(banners).replace(/</g,'\u003c') %>;function showAdminPanel(id){document.querySelectorAll('.admin-panel').forEach(p=>p.classList.remove('active'));const p=document.getElementById(id);if(p){p.classList.add('active')}document.querySelectorAll('[data-panel]').forEach(a=>a.classList.toggle('active',a.dataset.panel===id));}document.querySelectorAll('[data-panel]').forEach(a=>a.addEventListener('click',e=>{e.preventDefault();showAdminPanel(a.dataset.panel);history.replaceState(null,'','#'+a.dataset.panel)}));function applyIntegratedReady(){}function applyVendorFilter(){const q=(vendorSearch?.value||'').trim().toLowerCase();const t=vendorTypeFilter?.value||'all';const s=vendorStatusFilter?.value||'all';document.querySelectorAll('.vendor-row').forEach(row=>{const okName=!q||row.dataset.name.includes(q);const okType=t==='all'||row.dataset.type===t;const okStatus=s==='all'||row.dataset.status===s;row.classList.toggle('hidden-row',!(okName&&okType&&okStatus));});}function sortVendorRows(){const table=document.querySelector('#vendors table');if(!table)return;const rows=[...table.querySelectorAll('.vendor-row')];const mode=document.getElementById('vendorSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='views')return Number(b.dataset.views)-Number(a.dataset.views);if(mode==='reviews')return Number(b.dataset.reviews)-Number(a.dataset.reviews);if(mode==='rating')return Number(b.dataset.rating)-Number(a.dataset.rating);if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.id)-Number(b.dataset.id);});rows.forEach(r=>table.appendChild(r));}function applyBannerFilter(){const q=(bannerSearch?.value||'').trim().toLowerCase();const p=bannerPositionFilter?.value||'all';const s=bannerStatusFilter?.value||'all';document.querySelectorAll('.banner-row').forEach(row=>{const okTitle=!q||row.dataset.title.includes(q);const okPos=p==='all'||row.dataset.position===p;const okStatus=s==='all'||row.dataset.active===s;row.classList.toggle('hidden-row',!(okTitle&&okPos&&okStatus));});}function sortBannerRows(){const table=document.querySelector('#banners table');if(!table)return;const rows=[...table.querySelectorAll('.banner-row')];const mode=document.getElementById('bannerSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='order')return Number(a.dataset.order)-Number(b.dataset.order)||Number(b.dataset.id)-Number(a.dataset.id);if(mode==='active')return (b.dataset.active==='active')-(a.dataset.active==='active')||Number(a.dataset.order)-Number(b.dataset.order);if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.order)-Number(b.dataset.order)||Number(b.dataset.id)-Number(a.dataset.id);});rows.forEach(r=>table.appendChild(r));}function applyUserFilter(){const q=(userSearch?.value||'').trim().toLowerCase();const r=userRoleFilter?.value||'all';const s=userStatusFilter?.value||'all';document.querySelectorAll('.user-row').forEach(row=>{const okText=!q||row.dataset.text.includes(q);const okRole=r==='all'||row.dataset.role===r;const okStatus=s==='all'||row.dataset.status===s;row.classList.toggle('hidden-row',!(okText&&okRole&&okStatus));});}function sortUserRows(){const table=document.querySelector('#users table');if(!table)return;const rows=[...table.querySelectorAll('.user-row')];const mode=document.getElementById('userSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);if(mode==='admin')return (b.dataset.role==='admin')-(a.dataset.role==='admin')||Number(b.dataset.id)-Number(a.dataset.id);if(mode==='blocked')return (b.dataset.status==='blocked')-(a.dataset.status==='blocked')||Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.id)-Number(b.dataset.id);});rows.forEach(r=>table.appendChild(r));}function applyNoticeFilter(){const q=(noticeSearch?.value||'').trim().toLowerCase();const s=noticeStatusFilter?.value||'all';document.querySelectorAll('.notice-row').forEach(row=>{const ok=!q||row.dataset.search.includes(q);const st=s==='all'||(s==='pinned'&&row.dataset.pinned==='1')||(s==='normal'&&row.dataset.pinned!=='1');row.classList.toggle('hidden-row',!(ok&&st));});}function sortNoticeRows(){const table=document.querySelector('#notices table');if(!table)return;const rows=[...table.querySelectorAll('.notice-row')];const mode=document.getElementById('noticeSortFilter')?.value||'latest';rows.sort((a,b)=>{if(mode==='oldest')return Number(a.dataset.id)-Number(b.dataset.id);if(mode==='pinned')return Number(b.dataset.pinned)-Number(a.dataset.pinned)||Number(b.dataset.id)-Number(a.dataset.id);return Number(b.dataset.id)-Number(a.dataset.id);});rows.forEach(r=>table.appendChild(r));}function applyReviewFilter(){const q=(reviewSearch?.value||'').trim().toLowerCase();const r=reviewRatingFilter?.value||'all';document.querySelectorAll('.review-row').forEach(row=>{const ok=!q||row.dataset.search.includes(q);const rt=r==='all'||row.dataset.rating===r;row.classList.toggle('hidden-row',!(ok&&rt));});}function sortReviewRows(){const table=document.querySelector('#reviews table');if(!table)return;const rows=[...table.querySelectorAll('.review-row')];const mode=document.getElementById('reviewSortFilter')?.value||'latest';rows.sort((a,b)=>{if(mode==='rating')return Number(b.dataset.rating)-Number(a.dataset.rating)||Number(b.dataset.id)-Number(a.dataset.id);if(mode==='vendor')return a.dataset.vendor.localeCompare(b.dataset.vendor,'ko')||Number(b.dataset.id)-Number(a.dataset.id);return Number(b.dataset.id)-Number(a.dataset.id);});rows.forEach(r=>table.appendChild(r));}['vendorSearch','vendorTypeFilter','vendorStatusFilter','vendorSortFilter'].forEach(id=>document.getElementById(id)?.addEventListener('input',()=>{applyVendorFilter();sortVendorRows()}));vendorFilterReset?.addEventListener('click',()=>{vendorSearch.value='';vendorTypeFilter.value='