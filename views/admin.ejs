    return s;
  };
  window.normalizeAdminListPage=function(key,data,reload){var pages=Math.max(1,Number(data?.totalPages||1)),page=Math.max(1,Number(data?.page||1));if(page>pages){window.setAdminListState(key,{page:pages});setTimeout(function(){reload(pages);},0);return true;}return false;};
  window.reloadAdminPanelList=function(key){var map={vendors:'loadAdminVendors',users:'loadAdminUsers',inquiries:'loadAdminInquiries',reports:'loadAdminReports',banners:'loadAdminBanners',notices:'loadAdminNotices',reviews:'loadAdminReviews',adminLogs:'loadAdminLogs',vendorRequests:'loadAdminVendorRequests',adCenter:'loadAdminAdCenter',payments:'loadAdminPayments',boardPosts:'loadAdminBoardPosts',boardComments:'loadAdminBoardComments',adInquiries:'loadAdminAdInquiries'};var fn=window[map[key]];if(typeof fn==='function')return fn(window.getAdminListState(key).page||1);};
