  <th>결제</th>
  <th>상태</th>
  <th>처리</th>
</tr>
<% _centerAll.forEach(x=>{ const st=_centerStatus(x); %>
<tr class="ad-center-row" data-status="<%=st%>">
  <td><%=x.id%></td>
