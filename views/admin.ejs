  <form method="post" action="/admin/boards" class="board-settings-form" data-no-ajax>
    <div class="board-settings-main"><input name="title" placeholder="게시판 제목" required><input name="slug" placeholder="slug (영문/숫자/-/_)"><label class="board-layout-select"><span>게시판 유형</span><select name="layout_type"><% Object.keys(_boardLayoutLabels).forEach(t=>{ %><option value="<%=t%>"><%=_boardLayoutLabels[t]%></option><% }) %></select></label><select name="write_role" aria-label="쓰기 권한"><option value="member">회원</option><option value="admin">관리자</option><option value="all">전체</option><option value="guest">게스트</option></select></div>
    <div class="settings-help">slug는 주소로 사용합니다. 예: free → /boards/free<br>생성 후 게시글을 등록하면 주소 변경이 제한됩니다.</div>
    <textarea name="description" placeholder="게시판 설명"></textarea>
