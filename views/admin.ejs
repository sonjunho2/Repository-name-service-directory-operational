  function collectSearchRows(q){
    q=String(q||'').trim().toLowerCase();
    if(!q)return [];
    var out=[];
    document.querySelectorAll('table tr').forEach(function(row){
      var text=(row.innerText||'').trim();
      if(text&&text.toLowerCase().indexOf(q)!==-1){
        var panel=row.closest('.admin-panel');
        out.push({panel:panel&&panel.id?panel.id:'dashboard',title:text.split('\n').slice(0,2).join(' / ').slice(0,90),text:text.slice(0,180)});
      }
    });
    document.querySelectorAll('.admin-activity-item,.admin-live-item,.stage32-task').forEach(function(item){
      var text=(item.innerText||'').trim();
      if(text&&text.toLowerCase().indexOf(q)!==-1){
        var panel=item.getAttribute('data-panel')||'dashboard';
        out.push({panel:panel,title:text.split('\n')[0].slice(0,90),text:text.slice(0,180)});
      }
    });
    return out.slice(0,20);
  }
  function runSearch(){
    var input=document.getElementById('stage33SearchInput');
    var box=document.getElementById('stage33SearchResults');
    if(!input||!box)return;
