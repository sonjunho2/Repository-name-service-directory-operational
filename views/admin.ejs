      html+='<form method="post" action="/admin/inquiries/'+esc(x.id)+'/approve"><button class="approve-btn" onclick="if(!confirm(&quot;'+esc(message)+'&quot;))return false;this.form.dataset.safeConfirmDone=\'1\'">мЮЕм†Р мКємЭЄ</button></form>';
    }
    html+='<form method="post" action="/admin/inquiries/'+esc(x.id)+'/reject"><button class="reject-btn" onclick="if(!confirm(&quot;мЭі мЮЕм†РмЛ†м≤≠мЭД л∞Шл†§нХ†кєМмЪФ?&quot;))return false;this.form.dataset.safeConfirmDone=\'1\'">л∞Шл†§</button></form></div>';
    return html;
  }
  function row(x){
