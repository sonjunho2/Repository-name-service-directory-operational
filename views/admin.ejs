  function date(v){if(!v)return '-';var d=new Date(v);return Number.isNaN(d.getTime())?'-':d.toLocaleString('ko-KR',{timeZone:'Asia/Seoul',year:'numeric',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit'});}
  function row(x){var url='/boards/ad-inquiry/'+Number(x.id||0),answered=x.answer_status==='answered';return '<tr><td>'+Number(x.id||0)+'</td><td><span class="admin-board-title" title="'+esc(x.title)+'">'+esc(x.title)+'</span></td><td>'+esc(x.nickname||x.username||'탈퇴회원')+'</td><td><span class="answer-badge '+(answered?'answered':'waiting')+'">'+(answered?'답변완료':'답변대기')+'</span></td><td>'+Number(x.comment_count||0)+'</td><td>'+Number(x.views||0)+'</td><td><span class="board-admin-muted">'+date(x.created_at)+'</span></td><td><div class="admin-board-actions"><a href="'+url+'" target="_blank" rel="noopener">보기</a><a href="'+url+'" target="_blank" rel="noopener">답변</a></div></td></tr>';}
