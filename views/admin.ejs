d #7a5a1e;border-radius:10px;background:rgba(255,220,77,.08);color:#ffd56a;font-weight:800}#users .user-detail-row[hidden]{display:none!important}#users .user-detail-row>td{padding:0!important;border-top:0}#users .user-detail-row:not([hidden])>td{padding:12px!important}.user-activity-badges{display:flex;flex-wrap:wrap;gap:5px}.user-activity-badges span{display:inline-flex;align-items:center;min-height:22px;padding:0 7px;border-radius:999px;background:#17233b;color:#ffd56a;font-size:11px;font-weight:800}.user-vendor-meta{display:grid;gap:3px;line-height:1.35}.user-vendor-link-grid{display:grid;grid-template-columns:minmax(220px,1fr) minmax(280px,1fr) 180px;gap:10px;align-items:center}.user-vendor-link-grid>*{min-width:0}@media(max-width:1200px){#users .user-admin-filter{grid-template-columns:repeat(3,minmax(0,1fr))}.user-summary-grid{grid-template-columns:repeat(4,minmax(0,1fr))}.user-detail-grid{grid-template-columns:1fr 1fr}}@media(max-width:760px){#users .user-admin-filter,.user-summary-grid,.user-detail-grid,.user-vendor-link-grid{grid-template-columns:1fr}}
</style><script>
(function(){
  if(window.__adminUsersModuleV3)return;
  window.__adminUsersModuleV3=true;

  var userServerPage=Number(window.getAdminListState?.('users').page||1);
  var userServerLimit=20;
  var loading=false;
  var userSearchTimer=null;
  function ensureUserTools(){
    if(!document.getElementById('users'))return;
    window.restoreAdminListControls?.('users');
  }
  ensureUserTools();

  function userQuery(page){
    var params=new URLSearchParams();
    params.set('member_scope','general');
    params.set('page',String(page));
    params.set('limit',String(userServerLimit));
    var search=(document.getElementById('userSearch')?.value||'').trim();
    var role=document.getElementById('userRoleFilter')?.value||'all';
    var status=document.getElementById('userStatusFilter')?.value||'all';
    var vendorLink=document.getElementById('userLinkFilter')?.value||'all';
    var sort=document.getElementById('userSortFilter')?.value||'default';
    if(search)params.set('q',search);
    if(role!=='all')params.set('role',role);
    if(status!=='all')params.set('status',status);
    if(vendorLink!=='all')params.set('vendor_link',vendorLink);
    params.set('sort',sort);
    return params;
  }

  function roleText(u){
    if(u.role==='admin')return '관리자';
    if(u.is_vendor || u.vendor_id)return '업체회원';
    return '일반회원';
  }
  function roleBadge(u){
    if(u.role==='admin')return '<span class="role-badge role-admin">관리자</span>';
    if(u.is_vendor || u.vendor_id)return '<span class="role-badge role-vendor">업체회원</span>';
    return '<span class="role-badge role-user">일반회원</span>';
  }
  function statusText(v){
    return {active:'정상',blocked:'차단',suspended:'정지',inactive:'비활성'}[v]||v||'정상';
  }
  function vendorStatus(v){return {active:'운영중',hidden:'비노출',expired:'만료',inactive:'비활성',pending:'대기'}[v]||v||'-';}
  function adText(v){return {none:'광고없음',general:'일반광고',recommended:'추천광고'}[v]||v||'광고없음';}
  function userDate(v){if(!v)return '-';var d=new Date(v);return isNaN(d.getTime())?'-':d.toLocaleString('ko-KR',{timeZone:'Asia/Seoul',year:'numeric',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit',hour12:false});}
  function expireText(v){if(!v)return '-';var d=new Date(String(v).slice(0,10)+'T00:00:00+09:00');if(isNaN(d.getTime()))return '-';var today=new Date();var kst=new Date(today.toLocaleString('en-US',{timeZone:'Asia/Seoul'}));kst.setHours(0,0,0,0);var days=Math.ceil((d-kst)/86400000);return String(v).slice(0,10)+' · '+(days<0?'만료':days===0?'D-Day':'D-'+days);}
  function option(value,current,label){
    return '<option value="'+esc(value)+'" '+(value===current?'selected':'')+'>'+esc(label)+'</option>';
  }
  function roleOptions(current){
    return option('user',current,'일반회원')+option('admin',current,'관리자');
  }
  function statusOptions(current){
    current=current||'active';
    return option('active',current,'정상')+option('blocked',current,'차단')+option('suspended',current,'정지')+option('inactive',current,'비활성');
  }
  function userRow(u){
    var roleKey=u.account_type|| (u.role==='admin'?'admin':((u.is_vendor||u.vendor_id)?'vendor':'user'));
    var searchText=[u.username,u.nickname,u.vendor_name,u.vendor_region,u.vendor_category].filter(Boolean).join(' ').toLowerCase();
    var link=u.vendor_link_status||'unlinked',vendorHtml=link==='linked'?'<div class="user-vendor-meta"><b>'+esc(u.vendor_name||'-')+'</b><small>'+esc(u.vendor_region||'-')+' / '+esc(u.vendor_category||'-')+'</small><div><span class="'+(u.vendor_status==='active'?'done':'pending')+'">'+esc(vendorStatus(u.vendor_status))+'</span> · '+esc(adText(u.vendor_ad_type))+' · '+esc(expireText(u.vendor_expire_at))+'</div></div>':link==='broken'?'<span class="pending">업체 연결 필요</span>':link==='missing'?'<span class="rejected">연결 업체 없음</span>':'<span class="image-none">미연결</span>';
    var activity='<div class="user-activity-badges"><span class="pending">후기 '+Number(u.review_count||0)+'</span><span class="pending">찜 '+Number(u.favorite_count||0)+'</span><span class="pending">신청 '+Number(u.inquiry_count||0)+'</span><span class="pending">수정 '+Number(u.vendor_update_request_count||0)+'</span><span class="pending">결제 '+Number(u.payment_count||0)+'</span></div>';
    var protectedAttr=u.is_current_admin?' disabled title="현재 관리자 계정은 역할과 상태를 변경할 수 없습니다."':'';
    var manage='<button type="button" class="user-detail-toggle" data-id="'+esc(u.id)+'">상세보기</button>';
    if(u.vendor_id)manage+='<button type="button" class="user-vendor-view-btn" data-vendor-name="'+esc(u.vendor_name||'')+'">업체관리 보기</button>';
    if(u.can_unlink_vendor)manage+='<button type="button" class="user-unlink-btn" data-id="'+esc(u.id)+'">연결해제</button>';
    if(roleKey==='user'&&!u.is_current_admin)manage+='<button type="button" class="user-delete-btn" data-id="'+esc(u.id)+'">삭제</button>';
    return '<tr class="user-row" data-id="'+esc(u.id)+'" data-text="'+esc(searchText)+'" data-role="'+esc(roleKey)+'" data-status="'+esc(u.status||'active')+'">'+
      '<td>'+esc(u.id)+'</td><td><b>'+esc(u.username||'')+'</b><br><small>'+esc(u.nickname||'-')+'</small></td>'+
      '<td><span class="'+(u.status==='active'?'done':'rejected')+'">'+esc(statusText(u.status))+'</span></td><td>'+vendorHtml+'</td>'+
      '<td>'+esc(userDate(u.created_at))+'</td><td>'+esc(u.last_login_at?userDate(u.last_login_at):'-')+'</td>'+
      '<td><div class="user-edit-form"><input name="nickname" value="'+esc(u.nickname||'')+'" placeholder="닉네임" autocomplete="off"><input name="password" placeholder="새 비밀번호" autocomplete="new-password"><select name="role" hidden>'+roleOptions('user')+'</select><select name="status">'+statusOptions(u.status||'active')+'</select><button type="button" class="user-save-btn" data-id="'+esc(u.id)+'">저장</button></div><div class="user-manage-actions">'+manage+'</div></td></tr>'+userDetail(u);
  }
  function userDetail(u){var warnings=[];if(u.vendor_link_status==='broken')warnings.push('업체회원이지만 vendor_id가 없습니다.');if(u.vendor_link_status==='missing')warnings.push('vendor_id에 해당하는 업체가 없습니다.');if(Number(u.duplicate_vendor_link_count||0)>0)warnings.push('같은 업체가 다른 회원에게도 연결되어 있습니다.');if(u.status!=='active'&&(u.is_vendor||u.vendor_id))warnings.push('제한 상태인 업체회원입니다.');if(u.vendor_expire_at&&new Date(u.vendor_expire_at)<new Date())warnings.push('만료된 업체와 연결되어 있습니다.');var warning=warnings.length?'<div class="user-link-warning">'+warnings.map(esc).join('<br>')+'</div>':'';return '<tr class="user-detail-row" data-detail-for="'+esc(u.id)+'" hidden><td colspan="8"><div class="user-detail-panel">'+warning+'<div class="user-detail-grid"><section class="user-detail-box"><h4>회원정보</h4>ID '+esc(u.id)+'<br>아이디 '+esc(u.username||'-')+'<br>닉네임 '+esc(u.nickname||'-')+'<br>역할 '+esc(u.role||'-')+'<br>상태 '+esc(statusText(u.status))+'<br>가입일 '+esc(userDate(u.created_at))+'</section><section class="user-detail-box"><h4>업체연결</h4>업체 ID '+esc(u.vendor_id||'-')+'<br>업체명 '+esc(u.vendor_name||'-')+'<br>지역/업종 '+esc(u.vendor_region||'-')+' / '+esc(u.vendor_category||'-')+'<br>업체상태 '+esc(vendorStatus(u.vendor_status))+'<br>광고 '+esc(adText(u.vendor_ad_type))+'<br>광고만료 '+esc(expireText(u.vendor_expire_at))+'<br>배너 '+(u.vendor_banner_active?'노출':'미노출')+'<br>배너만료 '+esc(expireText(u.vendor_banner_until))+'</section><section class="user-detail-box"><h4>활동정보</h4>작성 후기 '+Number(u.review_count||0)+'<br>찜 '+Number(u.favorite_count||0)+'<br>입점·문의 '+Number(u.inquiry_count||0)+' (대기 '+Number(u.pending_inquiry_count||0)+')<br>업체 수정요청 '+Number(u.vendor_update_request_count||0)+' (대기 '+Number(u.pending_vendor_update_count||0)+')<br>결제내역 '+Number(u.payment_count||0)+'</section></div></div></td></tr>';}
  function usersPanel(){
    return document.getElementById('users');
  }
  function usersTable(){
    return document.getElementById('userManagementTable');
  }
  function ensurePager(table){
    return table?document.getElementById('userPager'):null;
  }
  function makeBtn(label,disabled,active,onClick){
    var b=document.createElement('button');
    b.type='button';
    b.textContent=label;
    if(disabled)b.disabled=true;
    if(active)b.classList.add('active');
    b.onclick=onClick;
    return b;
  }
  function showTableMessage(table,msg,cls){
    var body=document.getElementById('userTableBody');if(body)body.innerHTML='<tr class="'+(cls||'loading-row')+'"><td colspan="7">'+esc(msg)+'</td></tr>';
  }
  function renderPager(pager,data){
    pager.innerHTML='';
    var page=data.page||1,totalPages=data.totalPages||1,total=data.total||0,limit=data.limit||userServerLimit;
    var from=total?((page-1)*limit+1):0;
    var to=Math.min(page*limit,total);
    pager.appendChild(makeBtn('처음',page<=1,false,function(){loadUsers(1);}));
    pager.appendChild(makeBtn('이전',page<=1,false,function(){loadUsers(page-1);}));

    var start=Math.max(1,page-2);
    var end=Math.min(totalPages,start+4);
    start=Math.max(1,end-4);
    if(start>1){
      pager.appendChild(makeBtn('1',false,page===1,function(){loadUsers(1);}));
      if(start>2){
        var d=document.createElement('span'); d.className='dots'; d.textContent='...'; pager.appendChild(d);
      }
    }
    for(var p=start;p<=end;p++){
      (function(n){pager.appendChild(makeBtn(String(n),false,n===page,function(){loadUsers(n);}));})(p);
    }
    if(end<totalPages){
      if(end<totalPages-1){
        var d2=document.createElement('span'); d2.className='dots'; d2.textContent='...'; pager.appendChild(d2);
      }
      pager.appendChild(makeBtn(String(totalPages),false,page===totalPages,function(){loadUsers(totalPages);}));
    }

    pager.appendChild(makeBtn('다음',page>=totalPages,false,function(){loadUsers(page+1);}));
