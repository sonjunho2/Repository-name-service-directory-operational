  }
  function fixHeaders(table){
    return table;
  }
  function renderSummary(summary){document.querySelectorAll('#userSummaryGrid [data-user-summary]').forEach(function(el){el.textContent=Number(summary?.[el.dataset.userSummary]||0).toLocaleString('ko-KR');});}
  async function loadUsers(page){
    page=page||Number(window.getAdminListState?.('users').page||1);
    if(loading){clearTimeout(userSearchTimer);userSearchTimer=setTimeout(function(){loadUsers(page);},100);return;}
    var table=usersTable();
    if(!table)return;
    var pager=ensurePager(table);
    userServerPage=Math.max(1,page||1);
    window.saveActiveAdminListState?.('users',userServerPage);
    loading=true;
    showTableMessage(table,'회원목록을 불러오는 중입니다.','loading-row');
    var loadOk=false;
    if(pager)pager.innerHTML='<span class="server-user-info">회원목록을 불러오는 중입니다.</span>';
    try{
      var res=await fetch('/admin/api/users?'+userQuery(userServerPage).toString(),{credentials:'same-origin',headers:{'Accept':'application/json'}});
      var data=await res.json();
      if(!data.ok)throw new Error(data.error||'회원목록 로드 실패');
      if(userServerPage>Math.max(1,Number(data.totalPages||1))){loading=false;window.normalizeAdminListPage?.('users',data,loadUsers);return;}
      var body=document.getElementById('userTableBody');
      if(!body)throw new Error('회원 테이블 본문을 찾을 수 없습니다.');
      usersById.clear();(data.rows||[]).forEach(function(u){usersById.set(String(u.id),u);});
      body.innerHTML=(data.rows||[]).map(userRow).join('')||'<tr class="loading-row"><td colspan="5">표시할 일반회원이 없습니다.</td></tr>';
      renderSummary(data.summary||{});
      if(pager)renderPager(pager,data);
      loadOk=true;
    }catch(e){
      if(pager)pager.innerHTML='<span class="server-user-info">회원목록을 불러오지 못했습니다: '+esc(e.message||'오류')+'</span>';
    }finally{
      if(!loadOk)showTableMessage(table,'회원목록을 불러오지 못했습니다.','loading-row');
      loading=false;
    }
