      <a href="#settings" data-panel="settings">⚙ 환경설정<small>가격/백업/복원</small></a>
    </div>
  </div>
</div>
</section><section id="vendors" class="panel admin-panel"><% const vendorReviewStats={}; reviews.forEach(r=>{const id=r.vendor_id; if(id){vendorReviewStats[id]=vendorReviewStats[id]||{count:0,sum:0}; vendorReviewStats[id].count++; vendorReviewStats[id].sum+=Number(r.rating||0);}}); %><h2>업체 관리</h2>
<%
  const _vendorSafe=(typeof vendors!=='undefined'&&Array.isArray(vendors))?vendors:[];
  const _todayV=new Date(); _todayV.setHours(0,0,0,0);
  const _daysLeftV=v=>{
    if(!v.expire_at)return null;
    const d=new Date(v.expire_at); d.setHours(0,0,0,0);
    return Math.ceil((d-_todayV)/(1000*60*60*24));
  };
  const _vNoAd=_vendorSafe.filter(v=>!v.ad_type||v.ad_type==='none').length;
  const _vGeneral=_vendorSafe.filter(v=>v.ad_type==='general').length;
  const _vRecommended=_vendorSafe.filter(v=>v.ad_type==='recommended').length;
  const _vBanner=_vendorSafe.filter(v=>v.banner_active).length;
  const _vExpiring=_vendorSafe.filter(v=>{const d=_daysLeftV(v); return d!==null&&d>=0&&d<=7;}).length;
%>
<div class="vendor-summary">
  <div class="vendor-summary-card"><b>광고없음</b><strong><%=_vNoAd%></strong></div>
  <div class="vendor-summary-card general"><b>일반광고</b><strong><%=_vGeneral%></strong></div>
