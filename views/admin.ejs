<script>
(function(){
  if(window.__vendorFormDirectSaveV6)return;
  window.__vendorFormDirectSaveV6=true;

  async function submitVendorFormDirect(form){
    if(!form||form.dataset.vendorSubmitting==='1')return;
    if(typeof form.reportValidity==='function'&&!form.reportValidity())return;
    var submit=document.getElementById('vendorSubmitBtn');
    var oldText=submit?submit.textContent:'мЧЕм≤і мИШм†Х м†АмЮ•';
    form.dataset.vendorSubmitting='1';
    if(submit){submit.disabled=true;submit.classList.add('ajax-loading');submit.textContent='м†АмЮ•м§С...';}
    var success=false;
    try{
      var banner=form.elements.banner_active;
      var adType=form.elements.ad_type;
      if(banner&&banner.checked&&adType)adType.value='recommended';
      var res=await fetch('/admin/vendor',{
        method:'POST',body:new FormData(form),credentials:'same-origin',
        headers:{'X-Requested-With':'fetch','Accept':'application/json'}
      });
      var data=null;
      try{data=await res.json();}catch(parseErr){throw new Error('JSON мЭСлЛµмЭД нХімДЭнХШмІА л™їнЦИмКµлЛИлЛ§.');}
      if(!res.ok||!data||data.ok===false)throw new Error((data&&data.error)||('HTTP '+res.status));
      success=true;
      try{if(typeof toast==='function')toast('мЧЕм≤і м†Хл≥ік∞А м†АмЮ•лРШмЧИмКµлЛИлЛ§.','ok');}catch(_toastErr){}
      try{
        if(typeof window.forceCloseVendorModal==='function')window.forceCloseVendorModal();
        else{
          var modal=document.getElementById('vendorModal');
          if(modal){
            if(document.activeElement&&modal.contains(document.activeElement)){try{document.activeElement.blur();}catch(_blurErr){}}
            modal.classList.remove('active','open','show','visible');modal.style.display='none';modal.setAttribute('aria-hidden','true');
          }
          document.body.style.overflow='';
        }
      }catch(_closeErr){}
      var page=1;
      try{
        var state=window.getAdminListState?window.getAdminListState('vendors'):{};
        page=Number(state.page||1)||1;
        if(window.saveActiveAdminListState)window.saveActiveAdminListState('vendors',page);
        if(window.setAdminListState)window.setAdminListState('vendors',{page:page});
      }catch(_stateErr){}
      var refreshed=false;
      try{if(typeof window.loadAdminVendors==='function'){var ok=await window.loadAdminVendors(page);refreshed=ok!==false;}}catch(_loadErr){}
      try{if(!refreshed&&typeof window.reloadAdminPanelList==='function'){var ok2=await window.reloadAdminPanelList('vendors');refreshed=ok2!==false;}}catch(_reloadErr){}
      if(!refreshed){
        try{sessionStorage.setItem('adminReturnPanel','vendors');}catch(_e){}
        location.href='/admin#vendors';
        location.reload();
      }
    }catch(err){
      try{
        if(typeof toast==='function')toast('мЧЕм≤і м†Хл≥іл•Љ м†АмЮ•нХШмІА л™їнЦИмКµлЛИлЛ§.','bad',err&&err.message?err.message:'мЮ†мЛЬ нЫД лЛ§мЛЬ мЛЬлПДнХім£ЉмДЄмЪФ.');
        else alert(err&&err.message?err.message:'мЧЕм≤і м†Хл≥іл•Љ м†АмЮ•нХШмІА л™їнЦИмКµлЛИлЛ§.');
      }catch(_toastErr2){alert(err&&err.message?err.message:'мЧЕм≤і м†Хл≥іл•Љ м†АмЮ•нХШмІА л™їнЦИмКµлЛИлЛ§.');}
    }finally{
      form.dataset.vendorSubmitting='0';
      if(!success&&submit){submit.disabled=false;submit.classList.remove('ajax-loading');submit.textContent=oldText||'мЧЕм≤і мИШм†Х м†АмЮ•';}
    }
  }

  document.addEventListener('click',function(e){
    var btn=e.target&&e.target.closest&&e.target.closest('#vendorSubmitBtn');
    if(!btn)return;
    var form=document.getElementById('vendorForm');
    if(!form)return;
    e.preventDefault();e.stopPropagation();if(e.stopImmediatePropagation)e.stopImmediatePropagation();
    submitVendorFormDirect(form);
  },true);

  var form=document.getElementById('vendorForm');
  if(form)form.addEventListener('submit',function(e){
    e.preventDefault();e.stopPropagation();if(e.stopImmediatePropagation)e.stopImmediatePropagation();
    submitVendorFormDirect(form);
  },true);
})();
</script>

<script>
(function(){
  if(window.__adminBrandingPreviewV1)return;
  window.__adminBrandingPreviewV1=true;
  var root=document.querySelector('.brand-unified-preview-card');
  if(!root)return;
  var siteName=document.getElementById('siteNameInput');
  var siteLink=document.getElementById('siteLinkInput');
  var logoFile=document.querySelector('input[name="site_logo"]');
  var faviconFile=document.querySelector('input[name="site_favicon"]');
  var removeLogo=document.querySelector('input[name="remove_site_logo"]');
  var removeFavicon=document.querySelector('input[name="remove_site_favicon"]');
  var showLogo=document.querySelector('input[name="brand_show_logo"]');
  var showName=document.querySelector('input[name="brand_show_name"]');
  var logoHeight=document.querySelector('input[name="brand_logo_height"]');
  var nameSize=document.querySelector('input[name="brand_name_size"]');
  var logoPreview=root.querySelector('.brand-unified-preview-logo');
  var namePreview=root.querySelector('.brand-unified-preview-name');
  var emptyPreview=root.querySelector('.brand-unified-preview-empty');
  var faviconPreview=root.querySelector('.brand-unified-preview-favicon');
  var faviconDefault=root.querySelector('.brand-unified-preview-favicon-default');
  var linkPreview=root.querySelector('.brand-unified-preview-link');
  var logoObjectUrl='',faviconObjectUrl='';

  function clamp(value,min,max,fallback){var number=Number(value);return Number.isFinite(number)?Math.max(min,Math.min(max,number)):fallback;}
  function hasSource(image){return !!(image&&image.getAttribute('src'));}
  function updateBrandPreview(){
    var logoVisible=!!(showLogo&&showLogo.checked&&!removeLogo?.checked&&hasSource(logoPreview));
    var nameVisible=!!(showName&&showName.checked);
    if(logoPreview){logoPreview.style.display=logoVisible?'block':'none';logoPreview.style.height=clamp(logoHeight?.value,24,120,56)+'px';}
    if(namePreview){namePreview.style.display=nameVisible?'inline':'none';namePreview.style.fontSize=clamp(nameSize?.value,14,72,32)+'px';namePreview.textContent=(siteName?.value||'').trim()||'мДЬлєДмК§ лФФл†ЙнД∞л¶ђ';}
    if(emptyPreview)emptyPreview.style.display=(!logoVisible&&!nameVisible)?'inline':'none';
    if(linkPreview)linkPreview.textContent=(siteLink?.value||'').trim()||'/';
    var faviconVisible=!!(!removeFavicon?.checked&&hasSource(faviconPreview));
    if(faviconPreview)faviconPreview.style.display=faviconVisible?'block':'none';
    if(faviconDefault)faviconDefault.style.display=faviconVisible?'none':'inline-flex';
  }
  function useFile(input,image,type){
    var file=input&&input.files&&input.files[0];
    if(!file||!image)return;
    if(type==='logo'&&logoObjectUrl)URL.revokeObjectURL(logoObjectUrl);
    if(type==='favicon'&&faviconObjectUrl)URL.revokeObjectURL(faviconObjectUrl);
    var url=URL.createObjectURL(file);
    if(type==='logo'){logoObjectUrl=url;if(removeLogo)removeLogo.checked=false;}
    else{faviconObjectUrl=url;if(removeFavicon)removeFavicon.checked=false;}
    image.src=url;
    updateBrandPreview();
  }
  function bindBrandPreviewInputs(){
    [siteName,siteLink,logoHeight,nameSize].forEach(function(input){if(input){input.addEventListener('input',updateBrandPreview);input.addEventListener('change',updateBrandPreview);}});
    [showLogo,showName,removeLogo,removeFavicon].forEach(function(input){if(input)input.addEventListener('change',updateBrandPreview);});
    if(logoFile)logoFile.addEventListener('change',function(){useFile(logoFile,logoPreview,'logo');});
    if(faviconFile)faviconFile.addEventListener('change',function(){useFile(faviconFile,faviconPreview,'favicon');});
    if(logoPreview)logoPreview.addEventListener('error',function(){logoPreview.removeAttribute('src');updateBrandPreview();});
    if(faviconPreview)faviconPreview.addEventListener('error',function(){faviconPreview.removeAttribute('src');updateBrandPreview();});
    window.addEventListener('beforeunload',function(){if(logoObjectUrl)URL.revokeObjectURL(logoObjectUrl);if(faviconObjectUrl)URL.revokeObjectURL(faviconObjectUrl);},{once:true});
  }
  bindBrandPreviewInputs();
  updateBrandPreview();
})();
</script>

