<script>
(function(){
  if(window.__adminQaPolish1)return;
  window.__adminQaPolish1=true;


  function fixUserHeaders(){
    var users=document.getElementById('users');
    if(!users)return;
    users.querySelectorAll('th').forEach(function(th){
      var t=(th.textContent||'').trim();
      if(t==='등급/만기')th.textContent='상태';
      if(t==='수정')th.textContent='관리';
    });
    var ths=users.querySelectorAll('table th');
    ths.forEach(function(th,idx){
      if((th.textContent||'').trim()==='상태' && idx>0){
        var next=ths[idx+1];
        if(next && (next.textContent||'').trim()==='상태')next.textContent='새 비밀번호';
      }
    });
  }

  async function submitVendorLink(form){
    var fd=new FormData(form);
    var btn=form.querySelector('button');
    var old=btn?btn.textContent:'';
    if(btn){btn.disabled=true;btn.textContent='연결중...';}
    try{
      var res=await fetch('/admin/link-user-vendor',{method:'POST',body:fd,credentials:'same-origin',headers:{'X-Requested-With':'fetch'}});
      var data=null;
      try{data=await res.json();}catch(e){}
      if(!res.ok||data?.ok===false)throw new Error(data?.error||('HTTP '+res.status));
      toast('업체회원으로 연결되었습니다.','ok');
      setTimeout(function(){location.reload();},700);
    }catch(e){
      toast('업체회원 연결 실패: '+(e.message||'오류'),'bad');
    }finally{
      if(btn){btn.disabled=false;btn.textContent=old;}
    }
  }

  function addLiveRetry(){
    var body=document.getElementById('adminLiveBody');
    if(!body)return;
    if((body.textContent||'').indexOf('불러오지 못했습니다')===-1)return;
    if(body.querySelector('.live-retry-btn'))return;
    var btn=document.createElement('button');
    btn.type='button';
    btn.className='admin-live-btn live-retry-btn';
    btn.textContent='다시 불러오기';
    btn.onclick=function(){
      fetch('/admin/api/live-summary',{credentials:'same-origin',headers:{'Accept':'application/json'}})
        .then(function(r){return r.json();})
        .then(function(d){toast(d&&d.ok?'알림센터 API 정상':'알림센터 응답 확인 필요',d&&d.ok?'ok':'bad');})
        .catch(function(e){toast('알림센터 API 오류: '+e.message,'bad');});
    };
    body.appendChild(btn);
  }

  document.addEventListener('submit',function(e){
    var form=e.target;
    if(form && form.getAttribute('action')==='/admin/link-user-vendor'){
      e.preventDefault();
      e.stopPropagation();
      submitVendorLink(form);
    }
  },true);

  document.addEventListener('DOMContentLoaded',function(){
    fixUserHeaders();
    setInterval(addLiveRetry,2000);
  });
  window.addEventListener('hashchange',function(){setTimeout(fixUserHeaders,300);});
  document.addEventListener('click',function(){setTimeout(fixUserHeaders,300);},true);
})();
</script>

<script>
(function(){
  if(window.__adminStableUiV24)return;
  window.__adminStableUiV24=true;

  function normalizeLoadingPager(pager, unit){
    if(!pager)return;
    var text=(pager.textContent||'').trim();
    if(text.indexOf('불러오는 중입니다')===-1)return;
    var panel=pager.closest('.admin-panel');
    var table=panel&&panel.querySelector('table');
    var rowCount=table?Math.max(0,table.querySelectorAll('tr').length-1):0;
    var span=pager.querySelector('span')||pager;
    if(rowCount>0){
      span.textContent='현재 표시된 '+rowCount+unit+' 기준으로 표시 중입니다.';
    }else{
      span.textContent='표시할 데이터가 없습니다.';
    }
  }

  function normalizeAllLoadingPagers(){
    normalizeLoadingPager(document.querySelector('.server-vendor-pager'),'개 업체');
    normalizeLoadingPager(document.querySelector('.server-user-pager'),'명');
    normalizeLoadingPager(document.querySelector('.server-inquiry-pager'),'건');
    normalizeLoadingPager(document.querySelector('.server-payment-pager'),'건');
    normalizeLoadingPager(document.querySelector('.server-report-pager'),'건');
  }

  function improveSettingsLabels(){
    document.querySelectorAll('.settings-tab').forEach(function(btn){
      var key=btn.getAttribute('data-settings-tab');
      if(key==='basic')btn.textContent='브랜딩 / 업종지역';
      if(key==='payment')btn.textContent='결제 / 광고가격';
      if(key==='admin')btn.textContent='관리자 / 백업';
    });
    var basic=document.getElementById('settings-basic');
    if(basic&&!basic.querySelector('.settings-safe-notice')){
      var notice=document.createElement('div');
      notice.className='settings-safe-notice';
      notice.innerHTML='<b>운영 설정 안내</b><span>브랜딩과 업종/지역은 메인 화면 표시에만 반영됩니다. 광고 결제, 승인, 만기 계산 로직은 별도로 유지됩니다.</span>';
      basic.insertBefore(notice,basic.firstElementChild);
    }
  }

  function bindFaviconPreviewFallback(){
    document.querySelectorAll('input[type="file"][name="site_logo"],input[type="file"][name="site_favicon"]').forEach(function(input){
      if(input.dataset.v24PreviewBound)return;
      input.dataset.v24PreviewBound='1';
      input.addEventListener('change',function(){
        var file=input.files&&input.files[0];
        if(!file)return;
        var url=URL.createObjectURL(file);
        var card=input.name==='site_logo'
          ? document.querySelector('.brand-logo-preview')?.closest('.brand-preview-card')
          : document.querySelector('.brand-favicon-preview')?.closest('.brand-preview-card');
        if(!card)return;
        var img=card.querySelector('img');
        if(!img){
          img=document.createElement('img');
          img.className=input.name==='site_logo'?'brand-logo-preview':'brand-favicon-preview';
          var empty=card.querySelector('.brand-empty-preview');
          if(empty)empty.remove();
          card.appendChild(img);
        }
        img.src=url;
      });
    });
  }

  document.addEventListener('DOMContentLoaded',function(){
    improveSettingsLabels();
    bindFaviconPreviewFallback();
    setTimeout(normalizeAllLoadingPagers,2500);
    setTimeout(normalizeAllLoadingPagers,5000);
  });
  window.addEventListener('hashchange',function(){
    setTimeout(function(){improveSettingsLabels();bindFaviconPreviewFallback();normalizeAllLoadingPagers();},800);
    setTimeout(normalizeAllLoadingPagers,3000);
  });
  document.addEventListener('click',function(){
    setTimeout(function(){improveSettingsLabels();bindFaviconPreviewFallback();normalizeAllLoadingPagers();},1200);
  },true);
})();
</script>


