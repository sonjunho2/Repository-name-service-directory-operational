</form>
  </div>
</div><div class="vendor-admin-filter"><input id="vendorSearch" placeholder="업체명 검색"><select id="vendorTypeFilter"><option value="all">전체 광고</option><option value="noad">광고없음</option><option value="general">일반광고</option><option value="recommended">추천광고</option><option value="banner">프리미엄배너</option><option value="expiring">7일 이내 만료</option></select><select id="vendorStatusFilter"><option value="all">전체 상태</option><option value="pending">검수중</option><option value="active">노출</option><option value="hidden">숨김</option><option value="expired">만료</option></select><select id="vendorSortFilter"><option value="default">기본순</option><option value="views">조회수순</option><option value="reviews">후기순</option><option value="rating">평점순</option><option value="latest">최신등록순</option></select><button type="button" id="vendorFilterReset">초기화</button></div>
<table><tr><th>ID</th><th>구분</th><th>업체명</th><th>지역/업종</th><th>조회</th><th>후기</th><th>평점</th><th>만기상태</th><th>영업시간</th><th>상태</th><th>관리</th></tr><% vendors.forEach(v=>{ const t=v.is_premium?'premium':v.is_recommended?'recommend':'normal'; const st=vendorReviewStats[v.id]||{count:0,sum:0}; const avg=st.count?(st.sum/st.count).toFixed(1):'-'; %><tr class="vendor-row" data-id="<%=v.id%>" data-views="<%=v.views||0%>" data-reviews="<%=st.count%>" data-rating="<%=avg==='-'?0:avg%>" data-ad-type="<%=v.ad_type||'none'%>" data-membership="<%=v.ad_type||'none'%>" data-expire="<%=v.expire_at||''%>" data-banner-active="<%=v.banner_active?'1':'0'%>" data-banner-until="<%=v.banner_until?fmtDate(v.banner_until):''%>" data-name="<%=String(v.name||'').toLowerCase()%>" data-type="<%=(!v.ad_type||v.ad_type==='none')?'noad':v.banner_active?'banner':v.ad_type==='recommended'?'recommended':'general'%>" data-expiring="<% const _dlFilter=(v.expire_at?Math.ceil((new Date(v.expire_at).setHours(0,0,0,0)-new Date().setHours(0,0,0,0))/(1000*60*60*24)):9999); %><%=_dlFilter>=0&&_dlFilter<=7?'1':'0'%>" data-status="<%=v.status%>" data-region="<%=v.region||''%>" data-category="<%=v.category||''%>" data-vendor-name="<%=v.name||''%>" data-business-hours="<%=v.business_hours||''%>"><td><%=v.id%></td><td>
  <div class="vendor-ad-status">
    <%- v.banner_active?'<span class="ad-badge ad-banner">추천광고 + 프리미엄배너</span>':v.ad_type==='recommended'?'<span class="ad-badge ad-recommended">추천광고</span>':v.ad_type==='general'?'<span class="ad-badge ad-general">일반광고</span>':'<span class="ad-badge ad-none">광고없음</span>' %>
    <small><%=v.banner_active?'배너 사용중':'배너 없음'%></small>
  </div>
</td><td><%=v.name%></td><td><%=v.region%>/<%=v.category%></td><td class="stat-cell"><%=v.views||0%></td><td class="stat-cell"><%=st.count%></td><td class="stat-cell"><%=avg==='-'?'-':'★ '+avg%></td>
<td>
  <% const _todayVendor=new Date(); _todayVendor.setHours(0,0,0,0); let _daysLeft=null; if(v.expire_at){ const _exp=new Date(v.expire_at); _exp.setHours(0,0,0,0); _daysLeft=Math.ceil((_exp-_todayVendor)/(1000*60*60*24)); } %>
  <% if(!v.expire_at){%><span class="expiry-badge expiry-empty">만기없음</span><%}else if(_daysLeft<0||v.status==='expired'){%><span class="expiry-badge expiry-expired">만료</span><%}else if(_daysLeft<=7){%><span class="expiry-badge expiry-soon"><%=_daysLeft%>일 남음</span><%}else{%><span class="expiry-badge expiry-ok"><%=_daysLeft%>일 남음</span><%}%>
