  document.addEventListener('click',function(e){var toggle=e.target.closest('[data-admin-password-toggle]');if(toggle){var form=toggle.closest('form'),input=form?.elements[toggle.dataset.adminPasswordToggle];if(input){var visible=input.type==='text';input.type=visible?'password':'text';toggle.textContent=visible?'보기':'숨기기';toggle.setAttribute('aria-label',(input.placeholder||'비밀번호')+' '+(visible?'보기':'숨기기'));}return;}var generate=e.target.closest('[data-admin-password-generate]');if(generate){var form=generate.closest('form'),password=generatePassword(),a=generate.dataset.adminPasswordGenerate==='create'?'password':'new_password',b=generate.dataset.adminPasswordGenerate==='create'?'password_confirm':'new_password_confirm';form.elements[a].value=password;form.elements[b].value=password;form.elements[a].type='text';form.elements[b].type='text';form.querySelectorAll('[data-admin-password-toggle="'+a+'"],[data-admin-password-toggle="'+b+'"]').forEach(function(button){button.textContent='숨기기';});return;}var copy=e.target.closest('[data-admin-password-copy]');if(copy){copyText(copy.closest('form')?.elements[copy.dataset.adminPasswordCopy]?.value||'');return;}if(e.target.closest('[data-admin-password-result-copy]')){copyText(resultPassword);return;}if(e.target.closest('[data-admin-password-result-close]')||e.target===resultModal){closePasswordResult();return;}var logSettings=e.target.closest('[data-admin-log-navigate="settings"]');if(logSettings){showAdminPanel('settings');history.replaceState(null,'','#settings');window.activateAdminSettingsTab?.('admin');setTimeout(loadAdminAccounts,0);return;}var manage=e.target.closest('[data-admin-account-manage]');if(manage){openModal(manage.dataset.adminAccountManage);return;}if(e.target.closest('[data-admin-account-close]')||e.target===modal)closeModal();var tab=e.target.closest('.settings-tab[data-settings-tab="admin"]');if(tab)setTimeout(loadAdminAccounts,0);});
