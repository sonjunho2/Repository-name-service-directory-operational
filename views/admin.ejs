(function(){
  if(window.__adminVendorManagementV1)return;
  window.__adminVendorManagementV1=true;
  var vendorServerPage=Number(window.getAdminListState?.('vendors').page||1);
  var vendorServerLimit=20;
  var vendorServerReady=false;
  var vendorLoading=false;
  var vendorSearchTimer=null;
  var vendorSummaryQuick='all';

  function vendorQuery(page){
    var params=new URLSearchParams();
    params.set('page',String(page));
    params.set('limit',String(vendorServerLimit));
    var search=(document.getElementById('vendorSearch')?.value||'').trim();
    var adType=document.getElementById('vendorTypeFilter')?.value||'all';
    var status=document.getElementById('vendorStatusFilter')?.value||'all';
    var sort=document.getElementById('vendorSortFilter')?.value||'latest';
    if(!['all','noad','general','recommended','banner'].includes(adType)){adType='all';document.getElementById('vendorTypeFilter').value='all';}
    if(!['all','active','pending','hidden','expired'].includes(status)){status='all';document.getElementById('vendorStatusFilter').value='all';}
    if(!['latest','oldest','name','expire'].includes(sort)){sort='latest';document.getElementById('vendorSortFilter').value='latest';}
    if(search)params.set('q',search);
    if(vendorSummaryQuick!=='all')params.set('quick',vendorSummaryQuick);
    else if(adType!=='all')params.set('quick',adType);
    if(status!=='all')params.set('status',status);
    params.set('sort',sort);
    return params;
  }

  function fmtDate(v){
    if(!v)return '-';
    var d=new Date(v);
    if(isNaN(d.getTime()))return '-';
    var y=d.getFullYear();
    var m=String(d.getMonth()+1).padStart(2,'0');
    var day=String(d.getDate()).padStart(2,'0');
    return y+'-'+m+'-'+day;
  }
  function daysLeft(v){
    if(!v)return null;
    var today=new Date(); today.setHours(0,0,0,0);
    var d=new Date(v); d.setHours(0,0,0,0);
    if(isNaN(d.getTime()))return null;
    return Math.ceil((d-today)/(1000*60*60*24));
  }
  function expireText(value){var d=daysLeft(value),date=fmtDate(value);if(d===null)return '-';if(d<0)return date+' · 만료';if(d<=7)return date+' · '+d+'일 남음';return date;}
  function adBadge(v){
    if(v.banner_active)return '<span class="ad-badge ad-banner">추천광고 + 프리미엄배너</span><small>배너 사용중</small>';
    if(v.ad_type==='recommended')return '<span class="ad-badge ad-recommended">추천광고</span><small>배너 없음</small>';
    if(v.ad_type==='general')return '<span class="ad-badge ad-general">일반광고</span><small>배너 없음</small>';
    return '<span class="ad-badge ad-none">광고없음</span><small>배너 없음</small>';
  }
  function expiryBadge(v){
    var d=daysLeft(v.expire_at);
    if(!v.expire_at)return '<span class="expiry-badge expiry-empty">만기없음</span><br><small>-</small>';
    if(d<0||v.status==='expired')return '<span class="expiry-badge expiry-expired">만료</span><br><small>'+fmtDate(v.expire_at)+'</small>';
    if(d<=7)return '<span class="expiry-badge expiry-soon">'+d+'일 남음</span><br><small>'+fmtDate(v.expire_at)+'</small>';
    return '<span class="expiry-badge expiry-ok">'+d+'일 남음</span><br><small>'+fmtDate(v.expire_at)+'</small>';
  }
  function statusLabel(v){
    return v.status==='active'?'운영중':v.status==='pending'?'검수중':v.status==='hidden'?'숨김':v.status==='expired'?'광고만료':'-';
  }
  function adLabel(v){
    return v.ad_type==='recommended'?'추천광고':v.ad_type==='general'?'일반광고':'광고없음';
  }
  function statusBadge(v){
    var cls=v.status==='pending'?'status-pending':v.status==='active'?'status-on':'status-off';
    var txt=v.status==='pending'?'검수중':v.status==='active'?'노출':v.status==='expired'?'만료':'숨김';
    return '<span class="'+cls+'">'+txt+'</span>';
  }
  function publicStatus(v){var key=v.public_state||'unknown';var text={active:'정상노출',pending:'승인대기',hidden:'숨김',blocked:'차단',expired:'만료',no_ad:'광고없음',no_expire:'만기없음',unknown:'확인필요'}[key]||'확인필요';return '<span class="vendor-status-badge '+key+'">'+text+'</span>';}
  function adState(v){var key=v.ad_status||'expired',type=v.ad_type==='recommended'?'추천광고':v.ad_type==='general'?'일반광고':'광고없음',text=key==='active'?'정상노출':key==='expiring'?'만료예정':v.ad_type&&v.ad_type!=='none'?'만료/비노출':'광고없음';return '<span class="vendor-status-badge '+key+'">'+text+'</span><span class="vendor-subtext">'+type+'<br>'+expireText(v.expire_at)+'</span>';}
  function bannerState(v){var key=v.banner_status||'inactive',text=key==='active'?'배너노출':key==='expiring'?'배너만료예정':key==='expired'?'배너만료':'배너없음';return '<span class="vendor-status-badge '+(key==='inactive'?'inactive':key)+'">'+text+'</span><span class="vendor-subtext">'+expireText(v.banner_until)+'</span>';}
  function rowHtml(v){
    var linked=v.has_linked_user?('<b>'+esc(v.linked_username||'-')+'</b><span class="vendor-subtext">'+esc(v.linked_nickname||'-')+' · '+esc(v.linked_user_status||'-')+'</span>'):'<span class="vendor-link-warning">미연결</span>';
    return '<tr class="vendor-row" data-id="'+esc(v.id)+'" data-ad-type="'+esc(v.ad_type||'none')+'" data-expire="'+esc(v.expire_at||'')+'" data-banner-active="'+(v.banner_active?'1':'0')+'" data-status="'+esc(v.status||'')+'" data-region="'+esc(v.region||'')+'" data-category="'+esc(v.category||'')+'" data-vendor-name="'+esc(v.name||'')+'" data-business-hours="'+esc(v.business_hours||'')+'">'+
      '<td>'+esc(v.id)+'</td><td>'+linked+'</td>'+
      '<td><b>'+esc(v.name||'')+'</b><span class="vendor-subtext">'+esc(v.phone||'-')+'</span>'+(v.image_exists?'<button type="button" class="image-preview-btn vendor-image-btn" data-src="/admin/vendors/'+esc(v.id)+'/image">이미지</button>':'')+'</td>'+
      '<td>'+esc(v.region||'-')+'<span class="vendor-subtext">'+esc(v.category||'-')+'</span></td><td>'+publicStatus(v)+'</td><td>'+adState(v)+'</td><td>'+bannerState(v)+'</td>'+
      '<td><div class="row-actions"><button type="button" class="vendor-detail-btn" data-id="'+esc(v.id)+'">상세</button><button type="button" class="edit-vendor-btn" data-id="'+esc(v.id)+'">수정</button><form method="post" action="/admin/delete/vendors/'+esc(v.id)+'"><button onclick="return confirm(&quot;삭제할까요?&quot;)">삭제</button></form></div></td>'+
      '</tr><tr class="vendor-detail-row" data-detail-for="'+esc(v.id)+'" hidden><td colspan="8"><div class="vendor-detail-grid"><div><b>기본정보</b><p>ID '+esc(v.id)+' · '+esc(v.name||'-')+'<br>'+esc(v.region||'-')+' / '+esc(v.category||'-')+'<br>'+esc(v.phone||'-')+'<br>'+esc(v.kakao_url||'-')+'<br>'+esc(v.business_hours||'-')+'<br>'+esc(v.tags||'-')+'</p><p class="vendor-description">'+esc(v.description||'-')+'</p></div><div><b>노출정보</b><p>상태 '+esc(v.status||'-')+'<br>광고 '+esc(v.ad_type||'none')+' / '+esc(fmtDate(v.expire_at))+'<br>배너 '+(v.banner_active?'활성':'비활성')+' / '+esc(fmtDate(v.banner_until))+'</p></div></div></td></tr>';
  }
  function ensurePager(table){
    return document.getElementById('vendorPager');
  }
  function makePagerButton(label,disabled,active,onClick){
    var b=document.createElement('button');
    b.type='button';
    b.textContent=label;
    if(disabled)b.disabled=true;
    if(active)b.classList.add('active');
    b.onclick=onClick;
    return b;
  }
  function showTableMessage(table,msg,cls){
    var body=document.getElementById('vendorTableBody');
    if(body)body.innerHTML='<tr class="'+(cls||'loading-row')+'"><td colspan="8">'+esc(msg)+'</td></tr>';
  }
  function addPageNumbers(pager,page,totalPages){
    var start=Math.max(1,page-2);
    var end=Math.min(totalPages,start+4);
    start=Math.max(1,end-4);
    if(start>1){
      pager.appendChild(makePagerButton('1',false,page===1,function(){loadVendors(1);}));
      if(start>2){
        var dots=document.createElement('span');
        dots.className='dots';
        dots.textContent='...';
        pager.appendChild(dots);
      }
    }
    for(var p=start;p<=end;p++){
      (function(n){
        pager.appendChild(makePagerButton(String(n),false,n===page,function(){loadVendors(n);}));
      })(p);
    }
    if(end<totalPages){
      if(end<totalPages-1){
        var dots2=document.createElement('span');
        dots2.className='dots';
        dots2.textContent='...';
        pager.appendChild(dots2);
      }
      pager.appendChild(makePagerButton(String(totalPages),false,page===totalPages,function(){loadVendors(totalPages);}));
    }
  }
  async function loadVendors(page){
    page=page||Number(window.getAdminListState?.('vendors').page||1);
    if(vendorLoading){clearTimeout(vendorSearchTimer);return new Promise(function(resolve){vendorSearchTimer=setTimeout(async function(){resolve(await loadVendors(page));},100);});}
    var panel=document.getElementById('vendors');
    if(!panel)return false;
    var table=document.getElementById('vendorManagementTable');
    if(!table)return false;
    var pager=ensurePager(table);
    vendorServerPage=Math.max(1,page||1);
    window.saveActiveAdminListState?.('vendors',vendorServerPage);
    vendorLoading=true;
    showTableMessage(table,'업체목록을 불러오는 중입니다.','loading-row');
    if(pager)pager.innerHTML='<span class="server-vendor-info">업체목록을 불러오는 중입니다.</span>';
    try{
      var res=await fetch('/admin/api/vendors?'+vendorQuery(vendorServerPage).toString(),{headers:{'Accept':'application/json'}});
      var data=await res.json();
      if(!data.ok)throw new Error('load failed');
      if(vendorServerPage>Math.max(1,Number(data.totalPages||1))){vendorLoading=false;window.normalizeAdminListPage?.('vendors',data,loadVendors);return true;}
      var body=document.getElementById('vendorTableBody');
      body.innerHTML=(data.rows||[]).length?(data.rows||[]).map(rowHtml).join(''):'<tr><td colspan="8">조건에 맞는 업체가 없습니다.</td></tr>';
      Object.entries(data.summary||{}).forEach(function(entry){var el=document.querySelector('[data-vendor-summary="'+entry[0]+'"]');if(el)el.textContent=Number(entry[1]||0).toLocaleString();});
      if(pager){
        pager.innerHTML='';
        var from=data.total?((data.page-1)*data.limit+1):0;
        var to=Math.min(data.page*data.limit,data.total);
        pager.appendChild(makePagerButton('처음',data.page<=1,false,function(){loadVendors(1);}));
        pager.appendChild(makePagerButton('이전',data.page<=1,false,function(){loadVendors(data.page-1);}));
        addPageNumbers(pager,data.page,data.totalPages);
        pager.appendChild(makePagerButton('다음',data.page>=data.totalPages,false,function(){loadVendors(data.page+1);}));
        pager.appendChild(makePagerButton('마지막',data.page>=data.totalPages,false,function(){loadVendors(data.totalPages);}));
        var info=document.createElement('span');
        info.className='server-vendor-info';
        info.textContent='총 '+data.total+'개 업체 · 현재 '+from+'-'+to+'개 표시';
        pager.appendChild(info);
      }
      window.__adminVendorRowsById = window.__adminVendorRowsById || {};
      (data.rows||[]).forEach(function(v){ window.__adminVendorRowsById[String(v.id)] = v; });
      vendorServerReady=true;
      if(window.applyPanelPagination)try{window.applyPanelPagination(true);}catch(e){}
      vendorLoading=false;
      return true;
    }catch(e){
      vendorLoading=false;
      showTableMessage(table,'업체목록을 불러오지 못했습니다.','loading-row');
      if(pager)pager.innerHTML='<span class="server-vendor-info">서버 페이지 데이터를 불러오지 못했습니다. 기존 목록을 표시합니다.</span>';
      return false;
    }
  }
  window.loadAdminVendors=loadVendors;
  document.getElementById('vendorSearch')?.addEventListener('input',function(){
    vendorSummaryQuick='all';
    clearTimeout(vendorSearchTimer);
    vendorSearchTimer=setTimeout(function(){loadVendors(1);},300);
  });
  document.getElementById('vendorTypeFilter')?.addEventListener('change',function(){vendorSummaryQuick='all';loadVendors(1);});
  document.getElementById('vendorStatusFilter')?.addEventListener('change',function(){vendorSummaryQuick='all';loadVendors(1);});
  document.getElementById('vendorSortFilter')?.addEventListener('change',function(){loadVendors(1);});
  document.getElementById('vendorFilterReset')?.addEventListener('click',function(){vendorSummaryQuick='all';vendorSearch.value='';vendorTypeFilter.value='all';vendorStatusFilter.value='all';vendorSortFilter.value='latest';loadVendors(1);});
  document.getElementById('vendorSummaryGrid')?.addEventListener('click',function(e){var b=e.target.closest('[data-vendor-card]');if(!b)return;var key=b.dataset.vendorCard;vendorStatusFilter.value=key==='pending'?'pending':'all';vendorTypeFilter.value='all';vendorSummaryQuick=['active','inactive','expiring'].includes(key)?key:'all';if(key==='expiring')vendorSortFilter.value='expire';this.querySelectorAll('button').forEach(function(x){x.classList.toggle('active',x===b);});loadVendors(1);});
  document.getElementById('vendorTableBody')?.addEventListener('click',function(e){var detail=e.target.closest('.vendor-detail-btn');if(!detail)return;var row=detail.closest('tr'),target=row.nextElementSibling;if(target&&target.classList.contains('vendor-detail-row')){var opening=target.hidden;document.querySelectorAll('#vendorTableBody .vendor-detail-row').forEach(function(x){x.hidden=true;});target.hidden=!opening;}});
})();
