자 목록을 갱신하지 못했습니다.','bad');return;}toastMessage(kind==='create'?'관리자를 추가했습니다.':kind==='delete'?'관리자를 삭제했습니다.':kind==='update'?'관리자 정보를 수정했습니다.':kind==='password'?'관리자 비밀번호를 변경했습니다.':'관리자 상태를 변경했습니다.','ok');}catch(err){toastMessage(message(err.message),'bad');}finally{plainUsername='';plainPassword='';form.dataset.adminAccountSubmitting='0';if(button)button.disabled=false;}},true);
