  mount(['adCenter','revenue'],adTabs,'ad-payment-tabs');
  if(!window.__adminSectionTabsV1){window.__adminSectionTabsV1=true;document.addEventListener('click',function(e){var b=e.target.closest('[data-admin-panel-target]');if(!b)return;e.preventDefault();var id=b.dataset.adminPanelTarget;if(!document.getElementById(id))return;window.saveActiveAdminListState?.(document.querySelector('.admin-panel.active')?.id);showAdminPanel(id);history.pushState(null,'','#'+id);var loaders={adCenter:'loadAdminAdCenter',revenue:'loadAdminPayments',boardPosts:'loadAdminBoardPosts',notices:'loadAdminNotices',reviews:'loadAdminReviews',reports:'loadAdminReports',adInquiries:'loadAdminAdInquiries'};if(typeof window[loaders[id]]==='function')window[loaders[id]](1);});window.addEventListener('popstate',function(){showAdminPanel((location.hash||'#dashboard').slice(1));});}
