</style><script>
(function(){
  if(window.__adminUsersModuleV3)return;
  window.__adminUsersModuleV3=true;

  var userServerPage=Number(window.getAdminListState?.('users').page||1);
  var userServerLimit=20;
  var loading=false;
  var userSearchTimer=null;
  var usersById=new Map();
  function ensureUserTools(){
    if(!document.getElementById('users'))return;
    window.restoreAdminListControls?.('users');
  }
  ensureUserTools();

  function userQuery(page){
    var params=new URLSearchParams();
    params.set('member_scope','general');
    params.set('page',String(page));
    params.set('limit',String(userServerLimit));
    var search=(document.getElementById('userSearch')?.value||'').trim();
    var status=document.getElementById('userStatusFilter')?.value||'all';
    var sort=document.getElementById('userSortFilter')?.value||'latest';
    if(search)params.set('q',search);
    if(status!=='all')params.set('status',status);
    params.set('sort',sort);
    return params;
  }

  function statusText(v){
    return {active:'정상',blocked:'차단',suspended:'정지',inactive:'비활성'}[v]||v||'정상';
  }
  function userDate(v){if(!v)return '-';var d=new Date(v);return isNaN(d.getTime())?'-':d.toLocaleString('ko-KR',{timeZone:'Asia/Seoul',year:'numeric',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit',hour12:false});}
  function option(value,current,label){
    return '<option value="'+esc(value)+'" '+(value===current?'selected':'')+'>'+esc(label)+'</option>';
  }
  function statusOptions(current){
    current=current||'active';
    return option('active',current,'정상')+option('blocked',current,'차단')+option('suspended',current,'정지')+option('inactive',current,'비활성');
  }
  function userRow(u){return '<tr class="user-row" data-id="'+esc(u.id)+'"><td>'+esc(u.id)+'</td><td><b>'+esc(u.username||'')+'</b><br><small>닉네임: '+esc(u.nickname||'-')+'</small></td><td><span class="'+(u.status==='active'?'done':'rejected')+'">'+esc(statusText(u.status))+'</span></td><td>'+esc(userDate(u.created_at))+'</td><td><button type="button" class="user-manage-btn" data-id="'+esc(u.id)+'">관리</button></td></tr>';}
  function usersPanel(){
    return document.getElementById('users');
  }
  function usersTable(){
    return document.getElementById('userManagementTable');
  }
  function ensurePager(table){
    return table?document.getElementById('userPager'):null;
  }
  function makeBtn(label,disabled,active,onClick){
    var b=document.createElement('button');
    b.type='button';
    b.textContent=label;
    if(disabled)b.disabled=true;
    if(active)b.classList.add('active');
    b.onclick=onClick;
    return b;
  }
  function showTableMessage(table,msg,cls){
    var body=document.getElementById('userTableBody');if(body)body.innerHTML='<tr class="'+(cls||'loading-row')+'"><td colspan="5">'+esc(msg)+'</td></tr>';
  }
  function renderPager(pager,data){
    pager.innerHTML='';
    var page=data.page||1,totalPages=data.totalPages||1,total=data.total||0,limit=data.limit||userServerLimit;
    var from=total?((page-1)*limit+1):0;
    var to=Math.min(page*limit,total);
    pager.appendChild(makeBtn('처음',page<=1,false,function(){loadUsers(1);}));
    pager.appendChild(makeBtn('이전',page<=1,false,function(){loadUsers(page-1);}));

    var start=Math.max(1,page-2);
    var end=Math.min(totalPages,start+4);
    start=Math.max(1,end-4);
    if(start>1){
      pager.appendChild(makeBtn('1',false,page===1,function(){loadUsers(1);}));
      if(start>2){
        var d=document.createElement('span'); d.className='dots'; d.textContent='...'; pager.appendChild(d);
      }
    }
    for(var p=start;p<=end;p++){
      (function(n){pager.appendChild(makeBtn(String(n),false,n===page,function(){loadUsers(n);}));})(p);
    }
    if(end<totalPages){
      if(end<totalPages-1){
        var d2=document.createElement('span'); d2.className='dots'; d2.textContent='...'; pager.appendChild(d2);
      }
      pager.appendChild(makeBtn(String(totalPages),false,page===totalPages,function(){loadUsers(totalPages);}));
    }

    pager.appendChild(makeBtn('다음',page>=totalPages,false,function(){loadUsers(page+1);}));
    pager.appendChild(makeBtn('마지막',page>=totalPages,false,function(){loadUsers(totalPages);}));
    var info=document.createElement('span');
    info.className='server-user-info';
    info.textContent='총 '+total+'명 · 현재 '+from+'-'+to+'명 표시';
