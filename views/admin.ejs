<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>관리자</title><link rel="stylesheet" href="/public/css/style.css"><style>body{overflow-x:hidden}.admin-shell{display:grid;grid-template-columns:240px 1fr;min-height:calc(100vh - 68px)}.admin-sidebar{position:sticky;top:0;align-self:start;height:calc(100vh - 68px);padding:22px;background:#080d18;border-right:1px solid #29324f}.admin-sidebar h2{margin:0 0 18px;color:#fff;font-size:22px}.admin-sidebar a{display:flex;align-items:center;height:46px;margin-bottom:8px;padding:0 14px;border-radius:12px;color:#dfe9ff;text-decoration:none;font-weight:900;border:1px solid transparent}.admin-sidebar a:hover,.admin-sidebar a.active{background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff}.admin-sidebar .line{height:1px;background:#29324f;margin:16px 0}.admin-content{padding:24px;min-width:0}.admin-content .panel{scroll-margin-top:20px;margin-top:0}.admin-top-note{background:#101525;border:1px solid #29324f;border-radius:18px;padding:18px;margin-bottom:18px;color:#c8d0e8}.admin-top-note b{color:#fff}@media(max-width:900px){.admin-shell{grid-template-columns:1fr}.admin-sidebar{position:relative;height:auto}.admin-content{padding:14px}}</style></head><body><header class="top"><b>관리자</b><nav><a href="/">사이트</a><a href="/logout">로그아웃</a></nav></header><div class="admin-shell"><aside class="admin-sidebar"><h2>관리 메뉴</h2><a class="active" href="#vendors">업체관리</a><a href="#banners">배너관리</a><a href="#users">회원관리</a><a href="#notices">공지관리</a><a href="#reviews">후기관리</a><div class="line"></div><a href="/admin/inquiries">광고/입점 신청</a><a href="/admin/reports">신고내역</a><a href="/">사이트 보기</a></aside><main class="admin admin-content"><div class="admin-top-note"><b>운영 관리 화면</b><br>좌측 메뉴를 클릭하면 우측에서 해당 관리 영역으로 이동합니다.</div>
<section id="vendors" class="panel"><h2>업체 관리</h2><form method="post" action="/admin/vendor" enctype="multipart/form-data" class="form gridform"><input name="name" placeholder="업체명" required><input name="category" placeholder="업종" required><input name="region" placeholder="지역" required><input name="phone" placeholder="연락처"><input name="kakao_url" placeholder="카카오톡 문의 링크"><input name="business_hours" placeholder="영업시간 예: 10:00 ~ 24:00 / 연중무휴"><input name="tags" placeholder="태그"><select name="status"><option value="active">노출</option><option value="hidden">숨김</option></select><label><input type="checkbox" name="is_recommended"> 추천업체</label><label><input type="checkbox" name="is_premium"> 프리미엄</label><input type="file" name="image" accept="image/*"><textarea name="description" placeholder="업체소개"></textarea><button>업체 등록</button></form><table><tr><th>ID</th><th>구분</th><th>업체명</th><th>지역/업종</th><th>영업시간</th><th>카카오</th><th>상태</th><th>삭제</th></tr><% vendors.forEach(v=>{%><tr><td><%=v.id%></td><td><%=v.is_premium?'프리미엄':v.is_recommended?'추천':'일반'%></td><td><%=v.name%></td><td><%=v.region%>/<%=v.category%></td><td><%=v.business_hours||'-'%></td><td><%=v.kakao_url?'등록':'-'%></td><td><%=v.status%></td><td><form method="post" action="/admin/delete/vendors/<%=v.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
<section id="banners" class="panel"><h2>프리미엄 슬라이드 배너 관리</h2><form method="post" action="/admin/banner" enctype="multipart/form-data" class="form gridform"><input name="title" placeholder="배너 제목" required><input name="subtitle" placeholder="부제목"><input name="link_url" placeholder="링크 URL"><input name="sort_order" type="number" placeholder="정렬순서" value="0"><select name="position"><option value="premium">프리미엄</option><option value="main">메인</option></select><label><input type="checkbox" name="is_active" checked> 노출</label><input type="file" name="image" accept="image/*"><button>배너 등록</button></form><table><tr><th>ID</th><th>제목</th><th>위치</th><th>순서</th><th>삭제</th></tr><% banners.forEach(b=>{%><tr><td><%=b.id%></td><td><%=b.title%></td><td><%=b.position%></td><td><%=b.sort_order%></td><td><form method="post" action="/admin/delete/banners/<%=b.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
<section id="users" class="panel"><h2>회원 관리</h2><table><tr><th>ID</th><th>아이디</th><th>닉네임</th><th>권한</th><th>상태</th><th>수정</th></tr><% users.forEach(u=>{%><tr><form method="post" action="/admin/user"><td><%=u.id%><input type="hidden" name="id" value="<%=u.id%>"></td><td><%=u.username%></td><td><input name="nickname" value="<%=u.nickname%>"></td><td><select name="role"><option <%=u.role==='user'?'selected':''%>>user</option><option <%=u.role==='admin'?'selected':''%>>admin</option></select></td><td><select name="status"><option <%=u.status==='active'?'selected':''%>>active</option><option <%=u.status==='blocked'?'selected':''%>>blocked</option></select></td><td><input name="password" placeholder="새 비번"><button>저장</button></td></form></tr><%})%></table></section>
<section id="notices" class="panel"><h2>공지 관리</h2><form method="post" action="/admin/notice" class="form"><input name="title" placeholder="제목" required><textarea name="content" placeholder="내용" required></textarea><label><input type="checkbox" name="is_pinned"> 상단 고정</label><button>공지 등록</button></form><table><tr><th>ID</th><th>제목</th><th>삭제</th></tr><% notices.forEach(n=>{%><tr><td><%=n.id%></td><td><%=n.title%></td><td><form method="post" action="/admin/delete/notices/<%=n.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
<section id="reviews" class="panel"><h2>후기 관리</h2><table><tr><th>ID</th><th>업체</th><th>제목</th><th>평점</th><th>삭제</th></tr><% reviews.forEach(r=>{%><tr><td><%=r.id%></td><td><%=r.vendor_name%></td><td><%=r.title%></td><td><%=r.rating%></td><td><form method="post" action="/admin/delete/reviews/<%=r.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
</main></div><script>document.querySelectorAll('.admin-sidebar a[href^="#"]').forEach(a=>a.addEventListener('click',()=>{document.querySelectorAll('.admin-sidebar a').forEach(x=>x.classList.remove('active'));a.classList.add('active')}));</script></body></html>