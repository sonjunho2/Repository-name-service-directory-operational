<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>관리자</title><link rel="stylesheet" href="/public/css/style.css"><style>.admin-shell{display:grid;grid-template-columns:240px 1fr;min-height:calc(100vh - 68px)}.admin-sidebar{background:#080d18;border-right:1px solid #29324f;padding:22px 16px}.admin-sidebar h2{margin:0 0 18px;padding:0 6px;font-size:24px;line-height:1.2}.admin-sidebar a{display:flex;align-items:center;width:100%;height:42px;margin:0 0 6px;padding:0 12px;border-radius:12px;color:#dfe9ff;text-decoration:none;font-weight:900;box-sizing:border-box}.admin-sidebar a.active,.admin-sidebar a:hover{background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff}.admin-sidebar .line{display:none}.admin-content{padding:26px;min-width:0}.admin-panel{display:none}.admin-panel.active{display:block}.admin-content .panel{max-width:none;width:100%;margin:0;padding:28px}.admin-content input,.admin-content select,.admin-content textarea{width:100%;height:42px;box-sizing:border-box;border-radius:10px;padding:0 12px;background:#070b15;border:1px solid #29324f;color:#fff}.admin-content textarea{height:82px;padding:12px}.gridform{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;align-items:center}.gridform textarea,.form-actions,.img-preview{grid-column:1/5}.form-actions{display:grid;grid-template-columns:1fr 140px;gap:10px;align-items:center}.admin-content label{height:42px;display:flex;align-items:center;gap:8px;padding:0 12px;border:1px solid #29324f;border-radius:10px;background:#070b15}.admin-content button{height:38px;border:0;border-radius:999px;padding:0 16px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900;cursor:pointer}.admin-content table{width:100%;border-collapse:collapse;margin-top:14px;background:#070b15}.admin-content th,.admin-content td{border:1px solid #29324f;padding:11px;white-space:nowrap;vertical-align:middle}.admin-content th{background:#171d30}.row-actions{display:flex;gap:8px}.cancel-edit{background:#222b43!important}.dash-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}.dash-card{padding:22px;border:1px solid #29324f;border-radius:18px;background:#070b15}.dash-card b{display:block;color:#c8d0e8;margin-bottom:10px}.dash-card strong{font-size:34px}.dash-card.hot{background:linear-gradient(135deg,rgba(255,63,180,.25),rgba(16,217,255,.13))}.dash-card.today{border-color:#10d9ff;background:linear-gradient(135deg,rgba(16,217,255,.16),rgba(255,63,180,.08))}.dash-card.alert{border-color:#ff6b6b;background:linear-gradient(135deg,rgba(255,107,107,.2),rgba(255,63,180,.08))}.dash-card.warn{border-color:#ffdc4d;background:linear-gradient(135deg,rgba(255,220,77,.16),rgba(16,217,255,.06))}.dash-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px}.dash-row.three{grid-template-columns:repeat(3,1fr)}.dash-list.scroll{max-height:360px;overflow:auto}.dash-list .rank{font-weight:900;color:#10d9ff}.table-wrap{width:100%;overflow-x:auto}.dash-list{padding:18px;border:1px solid #29324f;border-radius:18px;background:#070b15}.dash-list a,.dash-list div{display:flex;justify-content:space-between;gap:12px;padding:10px 0;color:#dfe9ff;text-decoration:none;border-bottom:1px solid #1d263d}.dash-list a:last-child,.dash-list div:last-child{border-bottom:0}.dash-list small{color:#8d98b8}.vendor-admin-filter,.banner-admin-filter,.user-admin-filter{display:grid;grid-template-columns:1.5fr 1fr 1fr 120px;gap:10px;margin:0 0 18px}.banner-admin-filter{grid-template-columns:1.5fr 1fr 1fr 1fr 120px}.user-admin-filter{grid-template-columns:1.5fr 1fr 1fr 1fr 120px}.notice-admin-filter,.review-admin-filter{display:grid;grid-template-columns:1.5fr 1fr 1fr 120px;gap:10px;margin:0 0 18px}.vendor-admin-filter button,.banner-admin-filter button,.user-admin-filter button,.notice-admin-filter button,.review-admin-filter button{height:42px}.vendor-admin-filter{grid-template-columns:1.5fr 1fr 1fr 1fr 120px}.status-on{color:#1fe087;font-weight:900}.status-off{color:#ff6b6b;font-weight:900}.status-pin{color:#ffdc4d;font-weight:900}.stat-cell{font-weight:900;color:#dfe9ff}.hidden-row{display:none!important}.img-preview{display:none;align-items:flex-start;gap:14px;padding:14px;border:1px solid #29324f;border-radius:14px;background:#070b15;color:#c8d0e8}.img-preview img{max-width:260px;max-height:150px;border-radius:12px;object-fit:cover;border:1px solid #29324f}.img-preview b{display:block;margin-bottom:6px;color:#fff}@media(max-width:800px){.admin-content{padding:14px}.admin-content .panel{padding:18px}.admin-sidebar{padding:14px}.admin-content table{font-size:13px}.dash-card strong{font-size:28px}.dash-list a,.dash-list div{align-items:flex-start;flex-direction:column;gap:4px}}@media(max-width:1200px){.gridform,.dash-grid,.dash-row,.vendor-admin-filter,.banner-admin-filter,.user-admin-filter,.notice-admin-filter,.review-admin-filter{grid-template-columns:1fr 1fr}.gridform textarea,.form-actions,.img-preview{grid-column:1/3}}@media(max-width:800px){.admin-shell,.gridform,.dash-grid,.dash-row,.vendor-admin-filter,.banner-admin-filter,.user-admin-filter,.notice-admin-filter,.review-admin-filter{grid-template-columns:1fr}.gridform textarea,.form-actions,.img-preview{grid-column:1}}.integrated-tools{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:0 0 18px}.integrated-card{padding:16px;border:1px solid #29324f;border-radius:16px;background:#070b15}.integrated-card b{display:block;color:#c8d0e8;margin-bottom:8px}.integrated-card strong{font-size:28px}.admin-sub-filter{display:flex;gap:8px;flex-wrap:wrap;margin:0 0 14px}.admin-sub-filter button{height:38px;padding:0 14px;border-radius:999px;border:1px solid #39466c;background:#080d18;color:#dfe9ff;font-weight:900;cursor:pointer}.admin-sub-filter button.on{background:linear-gradient(90deg,#ff3fb4,#10d9ff);border-color:transparent;color:#fff}.admin-searchbar{display:grid;grid-template-columns:1fr 170px 110px;gap:10px;margin:0 0 18px}.admin-searchbar input,.admin-searchbar select{height:42px;border-radius:12px;border:1px solid #39466c;background:#080d18;color:#fff;padding:0 14px}.admin-searchbar button{height:42px;border:0;border-radius:999px;background:#222b43;color:#dfe9ff;font-weight:900;cursor:pointer}.memo{max-width:420px;white-space:pre-wrap;line-height:1.55}.image-links a{display:inline-block;margin:3px 0;padding:6px 10px;border:1px solid #2aa8ff;border-radius:8px;color:#dfe9ff;text-decoration:none}.approve-btn{margin-top:8px;padding:7px 10px;border:0;border-radius:8px;background:#ffdc4d!important;color:#111!important;font-weight:900;cursor:pointer}.banner-btn{margin-top:8px;padding:7px 10px;border:0;border-radius:8px;background:#10d9ff!important;color:#111!important;font-weight:900;cursor:pointer}.done{color:#1fe087;font-weight:900}.pending{color:#ffdc4d;font-weight:900}.rejected{color:#ff6b6b;font-weight:900}.banner-status{display:inline-block;margin-top:8px;color:#10d9ff;font-weight:900}@media(max-width:900px){.integrated-tools,.admin-searchbar{grid-template-columns:1fr}}
.admin-content input[type="checkbox"]{width:18px!important;height:18px!important;min-width:18px;margin:0;accent-color:#10d9ff}
.admin-content input[type="file"]{padding:9px 12px;line-height:20px}
.admin-content label{justify-content:center;font-weight:900}
.gridform{align-items:center}
.gridform button{width:100%}
#vendorForm,#bannerForm,#notices form{margin-bottom:18px}
#vendorForm textarea,#notices textarea{min-height:78px}
#bannerForm label,#vendorForm label,#notices label{height:42px}
.dash-list.scroll{max-height:none;overflow:visible}
.dash-row.three .dash-list{min-height:220px}
.admin-content .panel{border-radius:18px}
.admin-searchbar{align-items:center}
.admin-sub-filter button{min-width:72px}
#vendors table,#banners table,#users table,#notices table,#reviews table,#inquiries table,#reports table{table-layout:auto}
.row-actions form{margin:0}
.row-actions button{min-width:58px}
@media(max-width:1000px){.admin-shell{grid-template-columns:200px 1fr}.admin-sidebar h2{font-size:21px}.admin-sidebar a{font-size:14px}.dash-row.three{grid-template-columns:1fr}.dash-list.scroll{max-height:none}}
@media(max-width:800px){.admin-sidebar{border-right:0;border-bottom:1px solid #29324f}.admin-sidebar a{height:40px}.admin-content input[type="checkbox"]{width:16px!important;height:16px!important;min-width:16px}}

.reject-btn{margin-top:8px;padding:7px 10px;border:0;border-radius:8px;background:#ff6b6b!important;color:#fff!important;font-weight:900;cursor:pointer}
.report-done-form{display:grid;grid-template-columns:minmax(160px,1fr) 92px;gap:8px;align-items:center;margin:0}
.report-done-form input{height:36px!important}
.status-pending{color:#ffdc4d;font-weight:900}
@media(max-width:900px){.report-done-form{grid-template-columns:1fr}.report-done-form button{width:100%}}

.settings-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}.settings-box{padding:18px;border:1px solid #29324f;border-radius:16px;background:#070b15}.settings-box h3{margin:0 0 14px}.settings-box textarea{height:230px!important;line-height:1.7}.settings-help{margin:8px 0 0;color:#8d98b8;font-size:13px}.settings-form{display:grid;gap:10px}.settings-form button{width:100%;height:42px}.admin-account-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}@media(max-width:900px){.settings-grid,.admin-account-grid{grid-template-columns:1fr}}
.settings-box select{height:42px}.vendor-member-badge{color:#10d9ff;font-weight:900}</style></head><body><header class="top"><b>관리자</b><nav><a href="/">사이트</a><a href="/logout">로그아웃</a></nav></header><div class="admin-shell"><aside class="admin-sidebar"><h2>관리 메뉴</h2><a class="active" href="#dashboard" data-panel="dashboard">대시보드</a><a href="#vendors" data-panel="vendors">업체관리</a><a href="#banners" data-panel="banners">배너관리</a><a href="#users" data-panel="users">회원관리</a><a href="#notices" data-panel="notices">공지관리</a><a href="#reviews" data-panel="reviews">후기관리</a><a href="#inquiries" data-panel="inquiries">광고/입점 신청</a><a href="#reports" data-panel="reports">신고내역</a><a href="#vendorRequests" data-panel="vendorRequests">업체수정요청</a><a href="#settings" data-panel="settings">환경설정</a></aside><main class="admin-content"><section id="dashboard" class="panel admin-panel active"><% const _today=new Date().toISOString().slice(0,10); const _isToday=x=>x&&x.created_at&&new Date(x.created_at).toISOString().slice(0,10)===_today; const _groupCount=(arr,key)=>Object.entries(arr.reduce((m,x)=>{const raw=x[key];const k=raw&&String(raw).trim()?String(raw).trim():"미지정";m[k]=(m[k]||0)+1;return m;},{})).sort((a,b)=>b[1]-a[1]); const _reviewStats={}; reviews.forEach(r=>{const id=r.vendor_id;if(id){_reviewStats[id]=_reviewStats[id]||{count:0,sum:0,name:r.vendor_name||"업체명 없음"};_reviewStats[id].count++;_reviewStats[id].sum+=Number(r.rating||0);}}); %><h2>대시보드</h2><div class="dash-grid"><a class="dash-card alert" href="#inquiries" data-panel="inquiries"><b>승인 대기 입점신청</b><strong><%=inquiries.filter(x=>x.status!=='approved').length%></strong></a><a class="dash-card alert" href="#reports" data-panel="reports"><b>미처리 신고</b><strong id="pendingReportCount">확인중</strong></a><a class="dash-card warn" href="#vendors" data-panel="vendors"><b>숨김 업체</b><strong><%=vendors.filter(v=>v.status==='hidden').length%></strong></a><a class="dash-card warn" href="#banners" data-panel="banners"><b>비활성 배너</b><strong><%=banners.filter(b=>!b.is_active).length%></strong></a><div class="dash-card today"><b>오늘 가입 회원</b><strong><%=users.filter(_isToday).length%></strong></div><div class="dash-card today"><b>오늘 등록 업체</b><strong><%=vendors.filter(_isToday).length%></strong></div><div class="dash-card today"><b>오늘 작성 후기</b><strong><%=reviews.filter(_isToday).length%></strong></div><div class="dash-card today"><b>오늘 신청</b><strong><%=inquiries.filter(_isToday).length%></strong></div><div class="dash-card hot"><b>전체 업체</b><strong><%=vendors.length%></strong></div><div class="dash-card"><b>프리미엄 업체</b><strong><%=vendors.filter(v=>v.is_premium).length%></strong></div><div class="dash-card"><b>일반 업체</b><strong><%=vendors.filter(v=>!v.is_premium&&!v.is_recommended).length%></strong></div><div class="dash-card"><b>전체 회원</b><strong><%=users.length%></strong></div><div class="dash-card"><b>전체 배너</b><strong><%=banners.length%></strong></div><div class="dash-card"><b>전체 후기</b><strong><%=reviews.length%></strong></div><div class="dash-card"><b>신청내역</b><strong><%=inquiries.length%></strong></div><div class="dash-card"><b>신규 신청</b><strong><%=inquiries.filter(x=>x.status!=='approved').length%></strong></div><a class="dash-card alert" href="#vendorRequests" data-panel="vendorRequests"><b>업체 수정요청</b><strong><%=(vendorRequests||[]).filter(x=>x.status==="new").length%></strong></a></div><div class="dash-row"><div class="dash-list"><h3>조회수 TOP5</h3><% vendors.slice().sort((a,b)=>(b.views||0)-(a.views||0)).slice(0,5).forEach((v,i)=>{%><a href="#vendors" data-panel="vendors"><span><%=i+1%>. <%=v.name%></span><b>조회 <%=v.views||0%></b></a><%})%></div><div class="dash-list"><h3>바로가기</h3><a href="#inquiries" data-panel="inquiries"><span>광고/입점 신청</span><b><%=inquiries.length%>건</b></a><a href="#reports" data-panel="reports"><span>신고내역</span><b>확인</b></a><a href="#banners" data-panel="banners"><span>배너 관리</span><b><%=banners.length%>개</b></a><a href="#reviews" data-panel="reviews"><span>후기 관리</span><b><%=reviews.length%>개</b></a></div></div><div class="dash-row"><div class="dash-list"><h3>최근 가입 회원 5명</h3><% users.slice(0,5).forEach(u=>{%><div><span><%=u.nickname||u.username%></span><small><%=u.username%></small></div><%})%></div><div class="dash-list"><h3>최근 등록 업체 5개</h3><% vendors.slice(0,5).forEach(v=>{%><a href="#vendors" data-panel="vendors"><span><%=v.name%></span><small><%=v.region%> / <%=v.category%></small></a><%})%></div><div class="dash-list"><h3>최근 작성 후기 5개</h3><% reviews.slice(0,5).forEach(r=>{%><a href="#reviews" data-panel="reviews"><span><%=r.vendor_name%></span><small>★ <%=r.rating%> · <%=r.title%></small></a><%})%></div></div><div class="dash-row three"><div class="dash-list scroll"><h3>인기 업체 TOP10</h3><% vendors.slice().sort((a,b)=>(b.views||0)-(a.views||0)).slice(0,10).forEach((v,i)=>{%><a href="#vendors" data-panel="vendors"><span><span class="rank"><%=i+1%>.</span> <%=v.name%></span><small>조회 <%=v.views||0%></small></a><%})%></div><div class="dash-list scroll"><h3>지역별 업체 수</h3><% _groupCount(vendors,"region").slice(0,10).forEach(([name,count],i)=>{%><div><span><span class="rank"><%=i+1%>.</span> <%=name%></span><small><%=count%>개</small></div><%})%></div><div class="dash-list scroll"><h3>업종별 업체 수</h3><% _groupCount(vendors,"category").slice(0,10).forEach(([name,count],i)=>{%><div><span><span class="rank"><%=i+1%>.</span> <%=name%></span><small><%=count%>개</small></div><%})%></div></div><div class="dash-row"><div class="dash-list scroll"><h3>후기 많은 업체 TOP10</h3><% Object.values(_reviewStats).sort((a,b)=>b.count-a.count).slice(0,10).forEach((v,i)=>{%><a href="#reviews" data-panel="reviews"><span><span class="rank"><%=i+1%>.</span> <%=v.name%></span><small>후기 <%=v.count%>개 · 평균 ★ <%=v.count?(v.sum/v.count).toFixed(1):"-"%></small></a><%})%></div><div class="dash-list"><h3>관리자 화면 점검</h3><div><span>검색/필터/정렬</span><small>업체·배너·회원·공지·후기 적용</small></div><div><span>운영 알림</span><small>신청·신고·숨김·비활성 확인</small></div><div><span>모바일 최적화</span><small>관리자 카드/표시 영역 개선</small></div></div></div></section><section id="vendors" class="panel admin-panel"><% const vendorReviewStats={}; reviews.forEach(r=>{const id=r.vendor_id; if(id){vendorReviewStats[id]=vendorReviewStats[id]||{count:0,sum:0}; vendorReviewStats[id].count++; vendorReviewStats[id].sum+=Number(r.rating||0);}}); %><h2>업체 관리</h2><form id="vendorForm" method="post" action="/admin/vendor" enctype="multipart/form-data" class="gridform"><input type="hidden" name="id"><input name="name" placeholder="업체명" required><input name="category" placeholder="업종" required><input name="region" placeholder="지역" required><input name="phone" placeholder="연락처"><input name="kakao_url" placeholder="카카오톡 문의 링크"><input name="business_hours" placeholder="영업시간"><input name="tags" placeholder="태그"><select name="status"><option value="pending">검수중</option><option value="active">노출</option><option value="hidden">숨김</option></select><label><input type="checkbox" name="is_recommended">추천업체</label><label><input type="checkbox" name="is_premium">프리미엄</label><input type="file" name="image" accept="image/*"><div class="img-preview" id="vendorImagePreview"><img alt="업체 이미지 미리보기"><div><b>업체 이미지 미리보기</b><span>선택한 이미지가 표시됩니다.</span></div></div><textarea name="description" placeholder="업체소개"></textarea><div class="form-actions"><button id="vendorSubmitBtn">업체 등록</button><button type="button" id="cancelVendorEdit" class="cancel-edit" style="display:none">취소</button></div></form><div class="vendor-admin-filter"><input id="vendorSearch" placeholder="업체명 검색"><select id="vendorTypeFilter"><option value="all">전체 구분</option><option value="premium">프리미엄</option><option value="recommend">추천</option><option value="normal">일반</option></select><select id="vendorStatusFilter"><option value="all">전체 상태</option><option value="pending">검수중</option><option value="active">노출</option><option value="hidden">숨김</option></select><select id="vendorSortFilter"><option value="default">기본순</option><option value="views">조회수순</option><option value="reviews">후기순</option><option value="rating">평점순</option><option value="latest">최신등록순</option></select><button type="button" id="vendorFilterReset">초기화</button></div><table><tr><th>ID</th><th>구분</th><th>업체명</th><th>지역/업종</th><th>조회</th><th>후기</th><th>평점</th><th>영업시간</th><th>상태</th><th>관리</th></tr><% vendors.forEach(v=>{ const t=v.is_premium?'premium':v.is_recommended?'recommend':'normal'; const st=vendorReviewStats[v.id]||{count:0,sum:0}; const avg=st.count?(st.sum/st.count).toFixed(1):'-'; %><tr class="vendor-row" data-id="<%=v.id%>" data-views="<%=v.views||0%>" data-reviews="<%=st.count%>" data-rating="<%=avg==='-'?0:avg%>" data-name="<%=String(v.name||'').toLowerCase()%>" data-type="<%=t%>" data-status="<%=v.status%>"><td><%=v.id%></td><td><%=v.is_premium?'프리미엄':v.is_recommended?'추천':'일반'%></td><td><%=v.name%></td><td><%=v.region%>/<%=v.category%></td><td class="stat-cell"><%=v.views||0%></td><td class="stat-cell"><%=st.count%></td><td class="stat-cell"><%=avg==='-'?'-':'★ '+avg%></td><td><%=v.business_hours||'-'%></td><td><span class="<%=v.status==='pending'?'status-pending':v.status==='active'?'status-on':'status-off'%>"><%=v.status==='pending'?'검수중':v.status==='active'?'노출':'숨김'%></span></td><td><div class="row-actions"><button type="button" class="edit-vendor-btn" data-id="<%=v.id%>">수정</button><form method="post" action="/admin/delete/vendors/<%=v.id%>"><button onclick="return confirm('삭제할까요?')">삭제</button></form></div></td></tr><%})%></table></section><section id="banners" class="panel admin-panel"><h2>배너 관리</h2><form id="bannerForm" method="post" action="/admin/banner" enctype="multipart/form-data" class="gridform"><input type="hidden" name="id"><input name="title" placeholder="배너 제목" required><input name="subtitle" placeholder="부제목"><input name="link_url" placeholder="링크 URL"><input name="sort_order" type="number" placeholder="정렬순서" value="0"><select name="position"><option value="premium">프리미엄</option><option value="main">메인</option></select><label><input type="checkbox" name="is_active" checked>노출</label><input type="file" name="image" accept="image/*"><div class="img-preview" id="bannerImagePreview"><img alt="배너 이미지 미리보기"><div><b>배너 이미지 미리보기</b><span>선택한 이미지가 표시됩니다.</span></div></div><div class="form-actions"><button id="bannerSubmitBtn">배너 등록</button><button type="button" id="cancelBannerEdit" class="cancel-edit" style="display:none">취소</button></div></form><div class="banner-admin-filter"><input id="bannerSearch" placeholder="배너 제목 검색"><select id="bannerPositionFilter"><option value="all">전체 위치</option><option value="premium">프리미엄</option><option value="main">메인</option></select><select id="bannerStatusFilter"><option value="all">전체 상태</option><option value="active">노출</option><option value="hidden">숨김</option></select><select id="bannerSortFilter"><option value="default">기본순</option><option value="order">정렬순서</option><option value="active">노출 우선</option><option value="latest">최신등록순</option></select><button type="button" id="bannerFilterReset">초기화</button></div><table><tr><th>ID</th><th>제목</th><th>위치</th><th>노출상태</th><th>정렬순서</th><th>관리</th></tr><% banners.forEach(b=>{%><tr class="banner-row" data-id="<%=b.id%>" data-order="<%=b.sort_order||0%>" data-title="<%=String(b.title||'').toLowerCase()%>" data-position="<%=b.position%>" data-active="<%=b.is_active?'active':'hidden'%>"><td><%=b.id%></td><td><%=b.title%></td><td><%=b.position%></td><td><span class="<%=b.is_active?'status-on':'status-off'%>"><%=b.is_active?'● 노출':'● 숨김'%></span></td><td><%=b.sort_order%></td><td><div class="row-actions"><button type="button" class="edit-banner-btn" data-id="<%=b.id%>">수정</button><form method="post" action="/admin/delete/banners/<%=b.id%>"><button onclick="return confirm('삭제할까요?')">삭제</button></form></div></td></tr><%})%></table></section><section id="users" class="panel admin-panel"><h2>회원 관리</h2><div class="user-admin-filter"><input id="userSearch" placeholder="아이디/닉네임 검색"><select id="userRoleFilter"><option value="all">전체 권한</option><option value="user">일반회원</option><option value="admin">관리자</option></select><select id="userStatusFilter"><option value="all">전체 상태</option><option value="active">정상</option><option value="blocked">차단</option></select><select id="userSortFilter"><option value="default">기본순</option><option value="latest">최신가입순</option><option value="admin">관리자 우선</option><option value="blocked">차단회원 우선</option></select><button type="button" id="userFilterReset">초기화</button></div><table><tr><th>ID</th><th>아이디</th><th>닉네임</th><th>권한</th><th>상태</th><th>수정</th></tr><% users.forEach(u=>{%><tr class="user-row" data-id="<%=u.id%>" data-text="<%=String((u.username||'')+' '+(u.nickname||'')).toLowerCase()%>" data-role="<%=u.role%>" data-status="<%=u.status%>"><td><%=u.id%></td><td><%=u.username%></td><td><input form="userForm<%=u.id%>" name="nickname" value="<%=u.nickname%>"></td><td><select form="userForm<%=u.id%>" name="role"><option <%=u.role==='user'?'selected':''%>>user</option><option <%=u.role==='admin'?'selected':''%>>admin</option></select></td><td><select form="userForm<%=u.id%>" name="status"><option <%=u.status==='active'?'selected':''%>>active</option><option <%=u.status==='blocked'?'selected':''%>>blocked</option></select></td><td><form id="userForm<%=u.id%>" method="post" action="/admin/user" class="row-actions"><input type="hidden" name="id" value="<%=u.id%>"><input name="password" placeholder="새 비번"><button>저장</button></form></td></tr><%})%></table><div class="settings-box" style="margin-top:18px"><h3>회원 → 업체회원 연결</h3><form method="post" action="/admin/link-user-vendor" class="settings-form"><div class="admin-account-grid"><select name="user_id" required><option value="">회원 선택</option><% users.forEach(u=>{%><option value="<%=u.id%>"><%=u.username%> / <%=u.nickname%> <%=u.is_vendor?'(업체회원)':''%></option><%})%></select><select name="vendor_id" required><option value="">업체 선택</option><% vendors.forEach(v=>{%><option value="<%=v.id%>"><%=v.name%> / <%=v.region%></option><%})%></select><button>업체회원으로 연결</button></div></form><p class="settings-help">회원이 업체 등록을 한 뒤 관리자가 해당 회원과 업체를 연결하면 업체회원으로 전환됩니다.</p></div></section><section id="notices" class="panel admin-panel"><h2>공지 관리</h2><form method="post" action="/admin/notice" class="gridform"><input name="title" placeholder="제목" required><textarea name="content" placeholder="내용" required></textarea><label><input type="checkbox" name="is_pinned">상단 고정</label><button>공지 등록</button></form><div class="notice-admin-filter"><input id="noticeSearch" placeholder="공지 제목 검색"><select id="noticePinnedFilter"><option value="all">전체 공지</option><option value="pinned">상단고정</option><option value="normal">일반공지</option></select><select id="noticeSortFilter"><option value="default">기본순</option><option value="latest">최신등록순</option><option value="pinned">상단고정 우선</option><option value="normal">일반공지 우선</option></select><button type="button" id="noticeFilterReset">초기화</button></div><table><tr><th>ID</th><th>제목</th><th>고정상태</th><th>삭제</th></tr><% notices.forEach(n=>{%><tr class="notice-row" data-id="<%=n.id%>" data-title="<%=String(n.title||'').toLowerCase()%>" data-pinned="<%=n.is_pinned?'pinned':'normal'%>"><td><%=n.id%></td><td><%=n.title%></td><td><span class="<%=n.is_pinned?'status-pin':'status-off'%>"><%=n.is_pinned?'● 상단고정':'● 일반공지'%></span></td><td><form method="post" action="/admin/delete/notices/<%=n.id%>"><button onclick="return confirm('삭제할까요?')">삭제</button></form></td></tr><%})%></table></section><section id="reviews" class="panel admin-panel"><h2>후기 관리</h2><div class="review-admin-filter"><input id="reviewSearch" placeholder="업체명/후기제목 검색"><select id="reviewRatingFilter"><option value="all">전체 평점</option><option value="5">5점</option><option value="4">4점</option><option value="low">3점 이하</option></select><select id="reviewSortFilter"><option value="default">기본순</option><option value="latest">최신작성순</option><option value="high">평점 높은순</option><option value="low">평점 낮은순</option></select><button type="button" id="reviewFilterReset">초기화</button></div><table><tr><th>ID</th><th>업체</th><th>제목</th><th>평점</th><th>삭제</th></tr><% reviews.forEach(r=>{%><tr class="review-row" data-id="<%=r.id%>" data-text="<%=String((r.vendor_name||'')+' '+(r.title||'')).toLowerCase()%>" data-rating="<%=r.rating%>"><td><%=r.id%></td><td><%=r.vendor_name%></td><td><%=r.title%></td><td>★ <%=r.rating%></td><td><form method="post" action="/admin/delete/reviews/<%=r.id%>"><button onclick="return confirm('삭제할까요?')">삭제</button></form></td></tr><%})%></table></section><section id="inquiries" class="panel admin-panel"><h2>광고문의 / 입점신청</h2><div class="integrated-tools"><div class="integrated-card"><b>전체 신청</b><strong><%=inquiries.length%></strong></div><div class="integrated-card"><b>대기</b><strong><%=inquiries.filter(x=>x.status!=="approved"&&x.status!=="rejected").length%></strong></div><div class="integrated-card"><b>승인</b><strong><%=inquiries.filter(x=>x.status==="approved").length%></strong></div><div class="integrated-card"><b>반려</b><strong><%=inquiries.filter(x=>x.status==="rejected").length%></strong></div></div><div class="admin-sub-filter inquiry-filterbar"><button type="button" class="on" data-filter="all">전체 <%=inquiries.length%></button><button type="button" data-filter="new">대기 <%=inquiries.filter(x=>x.status!=="approved"&&x.status!=="rejected").length%></button><button type="button" data-filter="approved">승인 <%=inquiries.filter(x=>x.status==="approved").length%></button><button type="button" data-filter="rejected">반려 <%=inquiries.filter(x=>x.status==="rejected").length%></button><button type="button" data-filter="apply">입점신청 <%=inquiries.filter(x=>x.type==="apply").length%></button><button type="button" data-filter="ad">광고문의 <%=inquiries.filter(x=>x.type!=="apply").length%></button></div><div class="admin-searchbar"><input id="inquirySearch" placeholder="업체명 / 담당자 / 연락처 / 지역 / 업종 검색"><select id="inquirySort"><option value="latest">신청일 최신순</option><option value="oldest">신청일 오래된순</option><option value="status">처리상태순</option><option value="type">구분순</option></select><button type="button" id="inquirySearchReset">초기화</button></div><table><tr><th>ID</th><th>구분</th><th>업체명</th><th>담당자</th><th>연락처</th><th>지역/업종</th><th>내용</th><th>이미지</th><th>처리</th></tr><% inquiries.forEach(x=>{%><tr class="inquiry-row" data-id="<%=x.id%>" data-status="<%=x.status==='approved'?'approved':x.status==='rejected'?'rejected':'new'%>" data-type="<%=x.type==='apply'?'apply':'ad'%>" data-search="<%=String((x.company_name||'')+' '+(x.name||'')+' '+(x.phone||'')+' '+(x.kakao||'')+' '+(x.email||'')+' '+(x.region||'')+' '+(x.category||'')).toLowerCase()%>"><td><%=x.id%></td><td><%=x.type==='apply'?'입점신청':'광고문의'%></td><td><%=x.company_name%></td><td><%=x.name||'-'%></td><td><%=x.phone%><br><%=x.kakao||''%><br><%=x.email||''%></td><td><%=x.region||'-'%>/<%=x.category||'-'%></td><td class="memo"><%=x.content%></td><td class="image-links"><% if(x.main_image_data){%><a href="/admin/inquiry-image/<%=x.id%>/main" target="_blank">대표보기</a><br><%}else{%>대표없음<br><%}%><% if(x.banner_image_data){%><a href="/admin/inquiry-image/<%=x.id%>/banner" target="_blank">배너보기</a><%}else{%>배너없음<%}%></td><td><% if(x.status==='approved'){%><span class="done">업체 등록완료</span><%}else if(x.status==='rejected'){%><span class="rejected">반려</span><%}else{%><% if(x.type==='apply'){%><form method="post" action="/admin/inquiries/<%=x.id%>/approve"><button class="approve-btn" onclick="return confirm('이 신청내용으로 업체를 등록할까요?')">업체등록</button></form><%}%><form method="post" action="/admin/inquiries/<%=x.id%>/reject"><button class="reject-btn" onclick="return confirm('이 신청을 반려할까요?')">반려</button></form><%}%><% if(x.banner_status==='approved'){%><br><span class="banner-status">배너 등록완료</span><%}else if(x.banner_image_data){%><form method="post" action="/admin/inquiries/<%=x.id%>/banner"><button class="banner-btn" onclick="return confirm('이 배너이미지를 프리미엄 배너로 등록할까요?')">배너등록</button></form><%}%></td></tr><%})%></table></section><section id="reports" class="panel admin-panel"><% const reasonStats=Object.entries((flags||[]).reduce((m,x)=>{const k=x.reason||'기타';m[k]=(m[k]||0)+1;return m;},{})).sort((a,b)=>b[1]-a[1]); %><h2>업체 / 후기 신고내역</h2><div class="integrated-tools"><div class="integrated-card"><b>전체 신고</b><strong><%=flags.length%></strong></div><div class="integrated-card"><b>미처리</b><strong><%=flags.filter(x=>x.status!=='done').length%></strong></div><div class="integrated-card"><b>처리완료</b><strong><%=flags.filter(x=>x.status==='done').length%></strong></div><div class="integrated-card"><b>주요 사유</b><strong><%=reasonStats[0]?reasonStats[0][0]:'-'%></strong></div></div><div class="admin-sub-filter report-filterbar"><button type="button" class="on" data-filter="all">전체 <%=flags.length%></button><button type="button" data-filter="new">미처리 <%=flags.filter(x=>x.status!=='done').length%></button><button type="button" data-filter="done">처리완료 <%=flags.filter(x=>x.status==='done').length%></button><button type="button" data-filter="vendor">업체신고 <%=flags.filter(x=>x.type==='vendor').length%></button><button type="button" data-filter="review">후기신고 <%=flags.filter(x=>x.type==='review').length%></button></div><div class="admin-searchbar"><input id="reportSearch" placeholder="대상명 / 사유 / 신고내용 검색"><select id="reportSort"><option value="latest">신고일 최신순</option><option value="oldest">신고일 오래된순</option><option value="status">미처리 우선</option><option value="reason">신고사유순</option></select><button type="button" id="reportSearchReset">초기화</button></div><div class="integrated-tools"><% reasonStats.slice(0,8).forEach(([reason,count])=>{%><div class="integrated-card"><b><%=reason%></b><strong><%=count%></strong></div><%})%></div><table><tr><th>ID</th><th>구분</th><th>대상</th><th>사유</th><th>내용</th><th>상태</th><th>처리메모</th><th>처리일</th><th>처리</th></tr><% flags.forEach(x=>{ const target=x.vendor_name||x.review_title||x.target_id; %><tr class="report-row" data-id="<%=x.id%>" data-status="<%=x.status==='done'?'done':'new'%>" data-type="<%=x.type%>" data-reason="<%=String(x.reason||'')%>" data-search="<%=String((target||'')+' '+(x.reason||'')+' '+(x.content||'')).toLowerCase()%>"><td><%=x.id%></td><td><%=x.type==='vendor'?'업체':'후기'%></td><td><%=target%></td><td><%=x.reason%></td><td class="memo"><%=x.content||'-'%></td><td><span class="<%=x.status==='done'?'done':'pending'%>"><%=x.status==='done'?'처리완료':'미처리'%></span></td><td class="memo"><%=x.admin_memo||'-'%></td><td><%=x.processed_at?new Date(x.processed_at).toLocaleString('ko-KR'):'-'%></td><td><% if(x.status==='done'){%><span class="done">완료</span><%}else{%><form method="post" action="/admin/reports/<%=x.id%>/done" class="report-done-form"><input name="admin_memo" placeholder="처리 메모"><button class="banner-btn">처리완료</button></form><%}%></td></tr><%})%></table></section><section id="vendorRequests" class="panel admin-panel"><h2>업체 수정요청</h2><div class="integrated-tools"><div class="integrated-card"><b>전체 요청</b><strong><%=(vendorRequests||[]).length%></strong></div><div class="integrated-card"><b>대기</b><strong><%=(vendorRequests||[]).filter(x=>x.status==='new').length%></strong></div><div class="integrated-card"><b>승인</b><strong><%=(vendorRequests||[]).filter(x=>x.status==='approved').length%></strong></div><div class="integrated-card"><b>반려</b><strong><%=(vendorRequests||[]).filter(x=>x.status==='rejected').length%></strong></div></div><table><tr><th>ID</th><th>회원</th><th>현재업체</th><th>요청내용</th><th>상태</th><th>처리</th></tr><% (vendorRequests||[]).forEach(x=>{%><tr><td><%=x.id%></td><td><%=x.username%><br><small><%=x.nickname||''%></small></td><td><%=x.current_vendor_name||x.vendor_id%></td><td class="memo"><b><%=x.name%></b><br><%=x.region%>/<%=x.category%><br><%=x.phone||'-'%><br><%=x.business_hours||'-'%><br><%=x.description||'-'%></td><td><span class="<%=x.status==='approved'?'done':x.status==='rejected'?'rejected':'pending'%>"><%=x.status==='approved'?'승인':x.status==='rejected'?'반려':'대기'%></span><br><small><%=x.admin_memo||''%></small></td><td><% if(x.status==='new'){%><form method="post" action="/admin/vendor-requests/<%=x.id%>/approve" class="report-done-form"><input name="admin_memo" placeholder="처리 메모"><button class="approve-btn">승인</button></form><form method="post" action="/admin/vendor-requests/<%=x.id%>/reject" class="report-done-form" style="margin-top:8px"><input name="admin_memo" placeholder="반려 사유"><button class="reject-btn">반려</button></form><%}else{%>처리완료<%}%></td></tr><%})%></table></section><section id="settings" class="panel admin-panel"><h2>환경설정</h2><div class="settings-grid"><div class="settings-box"><h3>업종 / 지역 관리</h3><form method="post" action="/admin/settings/options" class="settings-form"><label>업종 목록</label><textarea name="categories" placeholder="한 줄에 하나씩 입력"><%=(settings?.raw?.categories)||''%></textarea><p class="settings-help">예: 안마, 마사지, 카페처럼 한 줄에 하나씩 입력합니다.</p><label>지역 목록</label><textarea name="regions" placeholder="한 줄에 하나씩 입력"><%=(settings?.raw?.regions)||''%></textarea><p class="settings-help">메인페이지 업종/지역 선택과 검색창에 바로 반영됩니다.</p><button>업종/지역 저장</button></form></div><div class="settings-box"><h3>관리자 계정 관리</h3><form method="post" action="/admin/settings/admin-account" class="settings-form"><div class="admin-account-grid"><input name="username" placeholder="관리자 아이디" value="<%=me?.username||''%>" required><input name="nickname" placeholder="관리자 닉네임" value="<%=me?.nickname||'관리자'%>"><input name="password" type="password" placeholder="새 비밀번호"></div><p class="settings-help">비밀번호를 비워두면 아이디/닉네임만 변경됩니다. 이 기능은 회원관리와 분리된 관리자 계정 설정입니다.</p><button>관리자 계정 저장</button></form><hr style="border:0;border-top:1px solid #29324f;margin:22px 0"><h3>운영 구조 안내</h3><div class="settings-help">현재 단계: 일반회원/업체회원 구분, 업체 마이페이지, 업체 수정요청 기능이 추가되었습니다.</div></div></div></section></main></div><script>const ADMIN_VENDORS=<%- JSON.stringify(vendors).replace(/</g,'\\u003c') %>;const ADMIN_BANNERS=<%- JSON.stringify(banners).replace(/</g,'\\u003c') %>;function showAdminPanel(id){document.querySelectorAll('.admin-panel').forEach(p=>p.classList.remove('active'));const p=document.getElementById(id);if(p){p.classList.add('active')}document.querySelectorAll('[data-panel]').forEach(a=>a.classList.toggle('active',a.dataset.panel===id));}document.querySelectorAll('[data-panel]').forEach(a=>a.addEventListener('click',e=>{e.preventDefault();showAdminPanel(a.dataset.panel);history.replaceState(null,'','#'+a.dataset.panel)}));function applyIntegratedReady(){}function applyVendorFilter(){const q=(vendorSearch?.value||'').trim().toLowerCase();const t=vendorTypeFilter?.value||'all';const s=vendorStatusFilter?.value||'all';document.querySelectorAll('.vendor-row').forEach(row=>{const okName=!q||row.dataset.name.includes(q);const okType=t==='all'||row.dataset.type===t;const okStatus=s==='all'||row.dataset.status===s;row.classList.toggle('hidden-row',!(okName&&okType&&okStatus));});}function sortVendorRows(){const table=document.querySelector('#vendors table');if(!table)return;const rows=[...table.querySelectorAll('.vendor-row')];const mode=document.getElementById('vendorSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='views')return Number(b.dataset.views)-Number(a.dataset.views);if(mode==='reviews')return Number(b.dataset.reviews)-Number(a.dataset.reviews);if(mode==='rating')return Number(b.dataset.rating)-Number(a.dataset.rating);if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.id)-Number(b.dataset.id);});rows.forEach(r=>table.appendChild(r));}function applyBannerFilter(){const q=(bannerSearch?.value||'').trim().toLowerCase();const p=bannerPositionFilter?.value||'all';const s=bannerStatusFilter?.value||'all';document.querySelectorAll('.banner-row').forEach(row=>{const okTitle=!q||row.dataset.title.includes(q);const okPos=p==='all'||row.dataset.position===p;const okStatus=s==='all'||row.dataset.active===s;row.classList.toggle('hidden-row',!(okTitle&&okPos&&okStatus));});}function sortBannerRows(){const table=document.querySelector('#banners table');if(!table)return;const rows=[...table.querySelectorAll('.banner-row')];const mode=document.getElementById('bannerSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='order')return Number(a.dataset.order)-Number(b.dataset.order)||Number(b.dataset.id)-Number(a.dataset.id);if(mode==='active')return (b.dataset.active==='active')-(a.dataset.active==='active')||Number(a.dataset.order)-Number(b.dataset.order);if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.order)-Number(b.dataset.order)||Number(b.dataset.id)-Number(a.dataset.id);});rows.forEach(r=>table.appendChild(r));}function applyUserFilter(){const q=(userSearch?.value||'').trim().toLowerCase();const r=userRoleFilter?.value||'all';const s=userStatusFilter?.value||'all';document.querySelectorAll('.user-row').forEach(row=>{const okText=!q||row.dataset.text.includes(q);const okRole=r==='all'||row.dataset.role===r;const okStatus=s==='all'||row.dataset.status===s;row.classList.toggle('hidden-row',!(okText&&okRole&&okStatus));});}function sortUserRows(){const table=document.querySelector('#users table');if(!table)return;const rows=[...table.querySelectorAll('.user-row')];const mode=document.getElementById('userSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);if(mode==='admin')return (b.dataset.role==='admin')-(a.dataset.role==='admin')||Number(b.dataset.id)-Number(a.dataset.id);if(mode==='blocked')return (b.dataset.status==='blocked')-(a.dataset.status==='blocked')||Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.id)-Number(b.dataset.id);});rows.forEach(r=>table.appendChild(r));}function applyNoticeFilter(){const q=(noticeSearch?.value||'').trim().toLowerCase();const f=noticePinnedFilter?.value||'all';document.querySelectorAll('.notice-row').forEach(row=>{const okTitle=!q||row.dataset.title.includes(q);const okPinned=f==='all'||row.dataset.pinned===f;row.classList.toggle('hidden-row',!(okTitle&&okPinned));});}function sortNoticeRows(){const table=document.querySelector('#notices table');if(!table)return;const rows=[...table.querySelectorAll('.notice-row')];const mode=document.getElementById('noticeSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);if(mode==='pinned')return (b.dataset.pinned==='pinned')-(a.dataset.pinned==='pinned')||Number(b.dataset.id)-Number(a.dataset.id);if(mode==='normal')return (b.dataset.pinned==='normal')-(a.dataset.pinned==='normal')||Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.id)-Number(b.dataset.id);});rows.forEach(r=>table.appendChild(r));}function applyReviewFilter(){const q=(reviewSearch?.value||'').trim().toLowerCase();const f=reviewRatingFilter?.value||'all';document.querySelectorAll('.review-row').forEach(row=>{const rating=parseInt(row.dataset.rating||0,10);const okText=!q||row.dataset.text.includes(q);const okRating=f==='all'||(f==='5'&&rating===5)||(f==='4'&&rating===4)||(f==='low'&&rating<=3);row.classList.toggle('hidden-row',!(okText&&okRating));});}function sortReviewRows(){const table=document.querySelector('#reviews table');if(!table)return;const rows=[...table.querySelectorAll('.review-row')];const mode=document.getElementById('reviewSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);if(mode==='high')return Number(b.dataset.rating)-Number(a.dataset.rating)||Number(b.dataset.id)-Number(a.dataset.id);if(mode==='low')return Number(a.dataset.rating)-Number(b.dataset.rating)||Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.id)-Number(b.dataset.id);});rows.forEach(r=>table.appendChild(r));}['input','change'].forEach(ev=>{vendorSearch?.addEventListener(ev,applyVendorFilter);vendorTypeFilter?.addEventListener(ev,applyVendorFilter);vendorStatusFilter?.addEventListener(ev,applyVendorFilter);vendorSortFilter?.addEventListener(ev,sortVendorRows);bannerSearch?.addEventListener(ev,applyBannerFilter);bannerPositionFilter?.addEventListener(ev,applyBannerFilter);bannerStatusFilter?.addEventListener(ev,applyBannerFilter);bannerSortFilter?.addEventListener(ev,sortBannerRows);userSearch?.addEventListener(ev,applyUserFilter);userRoleFilter?.addEventListener(ev,applyUserFilter);userStatusFilter?.addEventListener(ev,applyUserFilter);userSortFilter?.addEventListener(ev,sortUserRows);noticeSearch?.addEventListener(ev,applyNoticeFilter);noticePinnedFilter?.addEventListener(ev,applyNoticeFilter);noticeSortFilter?.addEventListener(ev,sortNoticeRows);reviewSearch?.addEventListener(ev,applyReviewFilter);reviewRatingFilter?.addEventListener(ev,applyReviewFilter);reviewSortFilter?.addEventListener(ev,sortReviewRows);});vendorFilterReset?.addEventListener('click',()=>{vendorSearch.value='';vendorTypeFilter.value='all';vendorStatusFilter.value='all';vendorSortFilter.value='default';applyVendorFilter();sortVendorRows();});bannerFilterReset?.addEventListener('click',()=>{bannerSearch.value='';bannerPositionFilter.value='all';bannerStatusFilter.value='all';bannerSortFilter.value='default';applyBannerFilter();sortBannerRows();});userFilterReset?.addEventListener('click',()=>{userSearch.value='';userRoleFilter.value='all';userStatusFilter.value='all';userSortFilter.value='default';applyUserFilter();sortUserRows();});noticeFilterReset?.addEventListener('click',()=>{noticeSearch.value='';noticePinnedFilter.value='all';noticeSortFilter.value='default';applyNoticeFilter();sortNoticeRows();});reviewFilterReset?.addEventListener('click',()=>{reviewSearch.value='';reviewRatingFilter.value='all';reviewSortFilter.value='default';applyReviewFilter();sortReviewRows();});function showPreview(box,src,text){if(!box)return;const img=box.querySelector('img');const span=box.querySelector('span');if(src){img.src=src;box.style.display='flex';if(span)span.textContent=text||'선택한 이미지가 표시됩니다.';}else{box.style.display='none';if(img)img.removeAttribute('src');}}function bindPreview(input,box){if(!input)return;input.addEventListener('change',()=>{const f=input.files&&input.files[0];if(!f)return showPreview(box,null);showPreview(box,URL.createObjectURL(f),'새로 선택한 이미지입니다.');});}const vf=document.getElementById('vendorForm'),bf=document.getElementById('bannerForm');bindPreview(vf?.image,document.getElementById('vendorImagePreview'));bindPreview(bf?.image,document.getElementById('bannerImagePreview'));document.querySelectorAll('.edit-vendor-btn').forEach(btn=>btn.onclick=()=>{const v=ADMIN_VENDORS.find(x=>String(x.id)===String(btn.dataset.id));if(!v)return;showAdminPanel('vendors');vf.id.value=v.id||'';vf.name.value=v.name||'';vf.category.value=v.category||'';vf.region.value=v.region||'';vf.phone.value=v.phone||'';vf.kakao_url.value=v.kakao_url||'';vf.business_hours.value=v.business_hours||'';vf.tags.value=v.tags||'';vf.status.value=v.status||'active';vf.description.value=v.description||'';vf.is_recommended.checked=!!v.is_recommended;vf.is_premium.checked=!!v.is_premium;showPreview(document.getElementById('vendorImagePreview'),v.image_data,'현재 등록된 업체 이미지입니다. 새 파일 선택 시 교체됩니다.');vendorSubmitBtn.textContent='업체 수정';cancelVendorEdit.style.display='block';vf.scrollIntoView({behavior:'smooth'})});cancelVendorEdit.onclick=()=>{vf.reset();vf.id.value='';showPreview(document.getElementById('vendorImagePreview'),null);vendorSubmitBtn.textContent='업체 등록';cancelVendorEdit.style.display='none'};document.querySelectorAll('.edit-banner-btn').forEach(btn=>btn.onclick=()=>{const b=ADMIN_BANNERS.find(x=>String(x.id)===String(btn.dataset.id));if(!b)return;showAdminPanel('banners');bf.id.value=b.id||'';bf.title.value=b.title||'';bf.subtitle.value=b.subtitle||'';bf.link_url.value=b.link_url||'';bf.sort_order.value=b.sort_order||0;bf.position.value=b.position||'premium';bf.is_active.checked=!!b.is_active;showPreview(document.getElementById('bannerImagePreview'),b.image_data,'현재 등록된 배너 이미지입니다. 새 파일 선택 시 교체됩니다.');bannerSubmitBtn.textContent='배너 수정';cancelBannerEdit.style.display='block';bf.scrollIntoView({behavior:'smooth'})});cancelBannerEdit.onclick=()=>{bf.reset();bf.id.value='';bf.is_active.checked=true;showPreview(document.getElementById('bannerImagePreview'),null);bannerSubmitBtn.textContent='배너 등록';cancelBannerEdit.style.display='none'};function updateReportAlert(){const el=document.getElementById('pendingReportCount');if(el)el.textContent=document.querySelectorAll('.report-row[data-status="new"]').length;}
let currentInquiryFilter='all';
function applyInquiryFilter(){
  const q=(document.getElementById('inquirySearch')?.value||'').trim().toLowerCase();
  document.querySelectorAll('.inquiry-row').forEach(row=>{
    const okFilter=currentInquiryFilter==='all'||row.dataset.status===currentInquiryFilter||row.dataset.type===currentInquiryFilter;
    const okSearch=!q||row.dataset.search.includes(q);
    row.classList.toggle('hidden-row',!(okFilter&&okSearch));
  });
}
function sortInquiries(){
  const table=document.querySelector('#inquiries table'); if(!table)return;
  const rows=[...table.querySelectorAll('.inquiry-row')];
  const mode=document.getElementById('inquirySort')?.value||'latest';
  const statusRank={new:0,rejected:1,approved:2};
  rows.sort((a,b)=>{
    if(mode==='oldest')return Number(a.dataset.id)-Number(b.dataset.id);
    if(mode==='status')return (statusRank[a.dataset.status]??9)-(statusRank[b.dataset.status]??9)||Number(b.dataset.id)-Number(a.dataset.id);
    if(mode==='type')return a.dataset.type.localeCompare(b.dataset.type)||Number(b.dataset.id)-Number(a.dataset.id);
    return Number(b.dataset.id)-Number(a.dataset.id);
  });
  rows.forEach(r=>table.appendChild(r));
}
document.querySelectorAll('.inquiry-filterbar button').forEach(btn=>btn.addEventListener('click',()=>{
  document.querySelectorAll('.inquiry-filterbar button').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on'); currentInquiryFilter=btn.dataset.filter; applyInquiryFilter();
}));
document.getElementById('inquirySearch')?.addEventListener('input',applyInquiryFilter);
document.getElementById('inquirySort')?.addEventListener('change',sortInquiries);
document.getElementById('inquirySearchReset')?.addEventListener('click',()=>{
  inquirySearch.value=''; inquirySort.value='latest'; currentInquiryFilter='all';
  document.querySelectorAll('.inquiry-filterbar button').forEach(b=>b.classList.toggle('on',b.dataset.filter==='all'));
  applyInquiryFilter(); sortInquiries();
});
let currentReportFilter='all';
function applyReportFilter(){
  const q=(document.getElementById('reportSearch')?.value||'').trim().toLowerCase();
  document.querySelectorAll('.report-row').forEach(row=>{
    const okFilter=currentReportFilter==='all'||row.dataset.status===currentReportFilter||row.dataset.type===currentReportFilter;
    const okSearch=!q||row.dataset.search.includes(q);
    row.classList.toggle('hidden-row',!(okFilter&&okSearch));
  });
}
function sortReports(){
  const table=document.querySelector('#reports table'); if(!table)return;
  const rows=[...table.querySelectorAll('.report-row')];
  const mode=document.getElementById('reportSort')?.value||'latest';
  rows.sort((a,b)=>{
    if(mode==='oldest')return Number(a.dataset.id)-Number(b.dataset.id);
    if(mode==='status')return (a.dataset.status==='done')-(b.dataset.status==='done')||Number(b.dataset.id)-Number(a.dataset.id);
    if(mode==='reason')return a.dataset.reason.localeCompare(b.dataset.reason)||Number(b.dataset.id)-Number(a.dataset.id);
    return Number(b.dataset.id)-Number(a.dataset.id);
  });
  rows.forEach(r=>table.appendChild(r));
}
document.querySelectorAll('.report-filterbar button').forEach(btn=>btn.addEventListener('click',()=>{
  document.querySelectorAll('.report-filterbar button').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on'); currentReportFilter=btn.dataset.filter; applyReportFilter();
}));
document.getElementById('reportSearch')?.addEventListener('input',applyReportFilter);
document.getElementById('reportSort')?.addEventListener('change',sortReports);
document.getElementById('reportSearchReset')?.addEventListener('click',()=>{
  reportSearch.value=''; reportSort.value='latest'; currentReportFilter='all';
  document.querySelectorAll('.report-filterbar button').forEach(b=>b.classList.toggle('on',b.dataset.filter==='all'));
  applyReportFilter(); sortReports();
});
sortInquiries(); sortReports();
showAdminPanel((location.hash||'#dashboard').replace('#',''));updateReportAlert();</script></body></html>
