    if(!q.trim()){
      box.innerHTML='<div class="stage33-result">검색어를 입력하면 현재 불러온 관리자 데이터에서 빠르게 찾습니다.</div>';
      return;
    }
    if(!rows.length){
      box.innerHTML='<div class="stage33-result">검색 결과가 없습니다.<small>현재 화면에 불러온 데이터 기준입니다.</small></div>';
      return;
    }
    box.innerHTML=rows.map(function(r){
      return '<a class="stage33-result" href="#'+esc(r.panel)+'" data-panel="'+esc(r.panel)+'"><b>'+esc(r.title)+'</b><small>'+esc(r.text)+'</small></a>';
    }).join('');
  }
  async function fetchStage33(){
    if(document.hidden)return;
    try{
      var res=await fetch('/admin/api/live-summary',{headers:{'Accept':'application/json'},credentials:'same-origin'});
      var data=await res.json();
      if(data&&data.ok){
        lastLiveData=data;
        renderCharts(data);
