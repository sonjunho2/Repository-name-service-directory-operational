(function(){
  function fmtDate(v){
    if(!v)return '-';
    var d=new Date(v);
    if(isNaN(d.getTime()))return '-';
    var y=d.getFullYear();
    var m=String(d.getMonth()+1).padStart(2,'0');
    var day=String(d.getDate()).padStart(2,'0');
    var hh=String(d.getHours()).padStart(2,'0');
    var mm=String(d.getMinutes()).padStart(2,'0');
    return y+'-'+m+'-'+day+' '+hh+':'+mm;
  }
  function addPageNumbers(pager,page,totalPages,loader){
    var start=Math.max(1,page-2);
    var end=Math.min(totalPages,start+4);
    start=Math.max(1,end-4);
    if(start>1){
      pager.appendChild(makeButton('1',false,page===1,function(){loader(1);}));
      if(start>2){var dots=document.createElement('span');dots.className='dots';dots.textContent='...';pager.appendChild(dots);}
    }
    for(var p=start;p<=end;p++){
      (function(n){pager.appendChild(makeButton(String(n),false,n===page,function(){loader(n);}));})(p);
    }
    if(end<totalPages){
      if(end<totalPages-1){var dots2=document.createElement('span');dots2.className='dots';dots2.textContent='...';pager.appendChild(dots2);}
      pager.appendChild(makeButton(String(totalPages),false,page===totalPages,function(){loader(totalPages);}));
    }
  }
  function renderPager(pager,data,unit,infoClass,loader){
    pager.innerHTML='';
    var from=data.total?((data.page-1)*data.limit+1):0;
    var to=Math.min(data.page*data.limit,data.total);
    pager.appendChild(makeButton('처음',data.page<=1,false,function(){loader(1);}));
    pager.appendChild(makeButton('이전',data.page<=1,false,function(){loader(data.page-1);}));
    addPageNumbers(pager,data.page,data.totalPages,loader);
    pager.appendChild(makeButton('다음',data.page>=data.totalPages,false,function(){loader(data.page+1);}));
    pager.appendChild(makeButton('마지막',data.page>=data.totalPages,false,function(){loader(data.totalPages);}));
    var info=document.createElement('span');
    info.className=infoClass;
    info.textContent='총 '+data.total+unit+' · 현재 '+from+'-'+to+unit+' 표시';
    pager.appendChild(info);
  }

  function showTableMessage(table,msg,cls){
    var header=table.querySelector('tr');
    var colspan=header?Math.max(1,header.children.length):1;
    table.innerHTML='';
    if(header)table.appendChild(header);
