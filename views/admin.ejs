    pager.innerHTML='<span class="server-report-info">신고 목록을 불러오는 중입니다.</span>';
    try{
      var res=await fetch('/admin/api/reports?'+reportQuery(reportPage).toString(),{headers:{Accept:'application/json'}});
      var data=await res.json();
      if(!res.ok||!data.ok)throw new Error(data.message||'load failed');
      if(reportPage>Math.max(1,Number(data.totalPages||1))){reportLoading=false;window.normalizeAdminListPage?.('reports',data,loadReports);return;}
      updateReportSummary(data.summary);
      body.innerHTML=(data.rows||[]).length?(data.rows||[]).map(reportRow).join(''):'<tr><td colspan="8" class="admin-list-empty">조건에 맞는 신고가 없습니다.</td></tr>';
      renderPager(pager,data,'건','server-report-info',loadReports);
    }catch(e){
      body.innerHTML='<tr><td colspan="8" class="admin-list-error">신고 목록을 불러오지 못했습니다.</td></tr>';
      pager.innerHTML='<span class="server-report-info">서버 페이지 데이터를 불러오지 못했습니다.</span>';
    }finally{reportLoading=false;}
  }
  window.loadAdminReports=loadReports;
  document.addEventListener('DOMContentLoaded',function(){
    try{
      var saved=sessionStorage.getItem('adminReturnPanel');
      if(saved){sessionStorage.removeItem('adminReturnPanel'); showAdminPanel(saved); history.replaceState(null,'','#'+saved);}
    }catch(e){}
  });
  document.getElementById('reports')?.addEventListener('click',function(e){
    var detail=e.target.closest('[data-report-detail]');
    if(detail){var row=document.querySelector('[data-report-detail-row="'+detail.dataset.reportDetail+'"]');if(row){row.hidden=!row.hidden;detail.textContent=row.hidden?'상세보기':'상세닫기';}return;}
    var card=e.target.closest('[data-report-card]');
    if(card){var mode=card.dataset.reportCard;document.getElementById('reportTypeFilter').value=(mode==='vendor'||mode==='review')?mode:'all';document.getElementById('reportStatusFilter').value=(mode==='new'||mode==='done'||mode==='rejected')?mode:'all';document.getElementById('reportTargetFilter').value=mode==='missing'?'missing':'all';loadReports(1);return;}
    var nav=e.target.closest('[data-report-nav]');
    if(nav&&!nav.disabled){var panel=nav.dataset.reportNav==='vendor'?'vendors':'reviews';showAdminPanel(panel);history.replaceState(null,'','#'+panel);var input=document.getElementById(panel==='vendors'?'vendorSearch':'reviewSearch');if(input)input.value=nav.dataset.targetName||'';window.setAdminListState?.(panel,{page:1,q:nav.dataset.targetName||''});window.reloadAdminPanelList?.(panel,1);}
  });
  document.getElementById('reportSearch')?.addEventListener('input',function(){
    clearTimeout(reportSearchTimer);
    reportSearchTimer=setTimeout(function(){loadReports(1);},300);
  });
  ['reportTypeFilter','reportStatusFilter','reportTargetFilter','reportSort'].forEach(function(id){document.getElementById(id)?.addEventListener('change',function(){loadReports(1);});});
  document.getElementById('reportSearchReset')?.addEventListener('click',function(){
    document.getElementById('reportSearch').value='';document.getElementById('reportTypeFilter').value='all';document.getElementById('reportStatusFilter').value='all';document.getElementById('reportTargetFilter').value='all';document.getElementById('reportSort').value='latest';loadReports(1);
  });
})();
</script><script>
(function(){
  if(window.__adminAjaxStage2)return;
  window.__adminAjaxStage2=true;


  function actionText(path,btnText){
    path=String(path||'').toLowerCase();
    btnText=String(btnText||'');
    if(path.includes('/delete')||btnText.includes('삭제'))return {doing:'삭제중...',done:'삭제되었습니다.',type:'warn',remove:true};
    if(path.includes('/approve')||btnText.includes('승인')||btnText.includes('등록완료'))return {doing:'승인중...',done:'승인 처리되었습니다.',type:'ok',doneRow:true};
    if(path.includes('/reject')||btnText.includes('반려'))return {doing:'반려중...',done:'반려 처리되었습니다.',type:'warn',doneRow:true};
    if(path.includes('/done')||btnText.includes('처리완료'))return {doing:'처리중...',done:'처리 완료되었습니다.',type:'ok',doneRow:true};
    if(path.includes('/paid')||btnText.includes('입금'))return {doing:'입금확인중...',done:'입금확인 처리되었습니다.',type:'ok',doneRow:true};
    if(path.includes('/settings')||btnText.includes('저장'))return {doing:'저장중...',done:'저장되었습니다.',type:'ok'};
    if(path.includes('/restore-json'))return {doing:'복원중...',done:'복원 요청이 처리되었습니다.',type:'warn',reload:true};
    if(path.includes('/reset-data'))return {doing:'초기화중...',done:'초기화 요청이 처리되었습니다.',type:'warn',reload:true};
    return {doing:'처리중...',done:'처리되었습니다.',type:'ok'};
  }

  function shouldSkip(form){
    if(!form||String(form.method||'').toLowerCase()!=='post')return true;
    if(form.matches('[data-local-admin-ajax]')||form.closest('[data-admin-account-form]'))return true;
    if(form.id==='vendorForm')return true;
    if(form.closest('#banners'))return true;
    if(form.closest('#notices'))return true;
    var action=String(form.getAttribute('action')||'');
    if(!action)return true;
    if(form.hasAttribute('data-no-ajax'))return true;
    if(action.includes('/admin/backup'))return true;
    if(action==='/admin/link-user-vendor')return true;
    return false;
  }

  function nearestRowOrBox(form){
    return form.closest('tr') || form.closest('.card') || form.closest('.box');
  }

  function updateRowAfter(form,meta){
    var target=nearestRowOrBox(form);
    if(!target)return;
    if(meta.remove){
      target.classList.add('ajax-row-remove');
      setTimeout(function(){target.remove();},240);
      return;
    }
    if(meta.doneRow){
      target.classList.add('ajax-row-done');
      var buttons=target.querySelectorAll('button');
      buttons.forEach(function(b){b.disabled=true;});
      var status=target.querySelector('.status-pending,.pending');
      if(status){
        status.className='done status-on';
        status.textContent='처리완료';
      }
      var actionCell=target.querySelector('td:last-child');
      if(actionCell && form.closest('#vendorRequests')){
        actionCell.innerHTML='<span class="done">처리완료</span>';
      }
    }
  }

  async function submitAjax(form,submitter){
    var action=form.getAttribute('action');
    var btn=submitter || form.querySelector('button[type="submit"],button:not([type])');
    var oldText=btn?btn.textContent:'';
    var meta=actionText(action,oldText);
    var panelKey=window.getActiveAdminPanelKey?.() || window.getPanelKeyFromActivePanel?.() || (location.hash||'').replace('#','');
    if(panelKey)window.saveActiveAdminListState?.(panelKey,window.getAdminListState?.(panelKey).page||1);

    if(btn){
      btn.classList.add('ajax-loading');
      btn.disabled=true;
      btn.textContent=meta.doing;
    }

    try{
      var fd=new FormData(form);
      var res=await fetch(action,{
        method:'POST',
        body:fd,
        credentials:'same-origin',
        headers:{'X-Requested-With':'fetch','Accept':'application/json'}
      });
      var contentType=String(res.headers.get('content-type')||'').toLowerCase();
      if(!contentType.includes('application/json')){
        throw new Error(res.redirected?'서버가 JSON 대신 HTML redirect를 반환했습니다.':'서버가 JSON이 아닌 응답을 반환했습니다.');
      }
      var data=null;
      try{data=await res.clone().json();}catch(parseErr){throw new Error('관리자 API JSON 응답을 해석하지 못했습니다.');}
      if(!res.ok || !data || data.ok===false)throw new Error((data&&data.error)||('HTTP '+res.status));

      toast(meta.done,meta.type);
      updateRowAfter(form,meta);

      var actionPath=String(action||'').toLowerCase();
      var formId=String(form.id||'');
      function closeAdminEditorIfNeeded(){
        var modal=document.getElementById('vendorModal');
        if(modal&&modal.classList.contains('active')){
          modal.classList.remove('active');
          document.body.style.overflow='';
        }
      }
      var needsListRefresh=(
        formId==='vendorForm' ||
        formId==='bannerForm' ||
        !!form.closest('#users') ||
        !!form.closest('#notices') ||
        !!form.closest('#reviews') ||
        !!form.closest('#inquiries') ||
        !!form.closest('#reports') ||
        (
          !!form.closest('#vendors') &&
          (actionPath.includes('/admin/vendor') || actionPath.includes('/admin/delete/vendors/'))
        ) ||
        (
          !!form.closest('#banners') &&
          (actionPath.includes('/admin/banner') || actionPath.includes('/admin/delete/banners/'))
        ) ||
        (
          !!form.closest('#adCenter') &&
          (actionPath.includes('/admin/ad-requests/') || actionPath.includes('/admin/banner-requests/')) &&
          (actionPath.includes('/payment-confirm') || actionPath.includes('/reject') || actionPath.includes('/cancel'))
        ) ||
        (
          !!form.closest('#vendorRequests') &&
          actionPath.includes('/admin/vendor-requests/') &&
          (actionPath.includes('/approve') || actionPath.includes('/reject'))
        )
      );
      if(needsListRefresh){
        closeAdminEditorIfNeeded();
        if(typeof window.reloadAdminPanelList==='function'&&panelKey){
          await window.reloadAdminPanelList(panelKey);
          if(panelKey==='vendorRequests'){
            if(typeof window.loadAdminVendors==='function')window.loadAdminVendors(window.getAdminListState?.('vendors').page||1);
            if(typeof window.loadDashboardSummary==='function')window.loadDashboardSummary();
          }
          if(panelKey==='inquiries'&&(actionPath.includes('/approve')||actionPath.includes('/reject'))){
            if(typeof window.loadAdminVendors==='function')window.loadAdminVendors(window.getAdminListState?.('vendors').page||1);
            if(typeof window.loadAdminUsers==='function')window.loadAdminUsers(window.getAdminListState?.('users').page||1);
            if(typeof window.loadDashboardSummary==='function')window.loadDashboardSummary();
          }
          if(panelKey==='reports'&&typeof window.loadDashboardSummary==='function')window.loadDashboardSummary();
          if(panelKey==='reviews'){
            if(typeof window.loadAdminVendors==='function')window.loadAdminVendors(window.getAdminListState?.('vendors').page||1);
            if(typeof window.loadDashboardSummary==='function')window.loadDashboardSummary();
          }
        }else{
          if(panelKey){try{sessionStorage.setItem('adminReturnPanel',panelKey);}catch(e){}}
          location.reload();
        }
        return;
      }

      if(meta.reload||form.closest('#settings')){
        setTimeout(function(){location.reload();},700);
      }
    }catch(err){
      toast('처리하지 못했습니다.','bad',err&&err.message?err.message:'잠시 후 다시 시도해주세요.');
    }finally{
      if(btn&&!meta.remove&&!meta.doneRow&&!meta.reload){
        btn.classList.remove('ajax-loading');
        btn.disabled=false;
        btn.textContent=oldText;
      }
    }
  }

  document.addEventListener('submit',function(e){
    var form=e.target;
    if(shouldSkip(form))return;

    var action=String(form.getAttribute('action')||'');
    if(action.includes('/admin/restore-json')||action.includes('/admin/settings/reset-data')){
      return;
    }

    e.preventDefault();
    e.stopPropagation();
    if(form.dataset.confirm&&!window.confirm(form.dataset.confirm))return;

    var submitter=e.submitter || document.activeElement;
    if(form.dataset.ajaxSubmitting==='1')return;
    form.dataset.ajaxSubmitting='1';

    submitAjax(form,submitter).finally(function(){
      setTimeout(function(){form.dataset.ajaxSubmitting='0';},500);
    });
  },true);

  document.addEventListener('click',function(e){
    var btn=e.target.closest('button');
    if(!btn)return;
    var form=btn.closest('form');
    if(!form||shouldSkip(form))return;
    form.__lastSubmitter=btn;
  },true);
})();
</script><script>
