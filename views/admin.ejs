  window.loadAdminAdInquiries=async function(page){var body=document.getElementById('adInquiryAdminRows');if(!body||busy)return false;if(!restored){window.restoreAdminListControls?.('adInquiries');restored=true;}page=Math.max(1,Number(page||window.getAdminListState?.('adInquiries').page||1));busy=true;body.innerHTML='<tr><td colspan="8">кіСк≥†лђЄмЭШл•Љ лґИлЯђмШ§лКФ м§СмЮЕлЛИлЛ§.</td></tr>';var q=(document.getElementById('adInquirySearch')?.value||'').trim(),status=document.getElementById('adInquiryStatus')?.value||'all',params=new URLSearchParams({page:String(page),limit:String(limit),status:status});if(q)params.set('q',q);window.setAdminListState?.('adInquiries',{page:page,q:q,status:status});try{var res=await fetch('/admin/api/ad-inquiries?'+params.toString(),{credentials:'same-origin',cache:'no-store',headers:{Accept:'application/json'}}),data=await res.json();if(!res.ok||!data.ok)throw new Error(data.error||'load_failed');if(page>Math.max(1,Number(data.totalPages||1))){busy=false;return window.loadAdminAdInquiries(Math.max(1,Number(data.totalPages||1)));}body.innerHTML=(data.rows||[]).map(row).join('')||'<tr><td colspan="8">м°∞к±імЧР лІЮлКФ кіСк≥†лђЄмЭШк∞А мЧЖмКµлЛИлЛ§.</td></tr>';var s=data.summary||{};document.getElementById('adInquiryTotal').textContent=Number(s.total||0);document.getElementById('adInquiryWaiting').textContent=Number(s.waiting||0);document.getElementById('adInquiryAnswered').textContent=Number(s.answered||0);pager(data);return true;}catch(e){body.innerHTML='<tr><td colspan="8">кіСк≥†лђЄмЭШл•Љ лґИлЯђмШ§мІА л™їнЦИмКµлЛИлЛ§.</td></tr>';return false;}finally{busy=false;}};
