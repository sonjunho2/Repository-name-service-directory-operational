  function compact(n){
    n=Number(n||0);
    if(n>=1000000)return Math.round(n/10000)+'만';
    if(n>=10000)return Math.round(n/1000)/10+'만';
    return n.toLocaleString();
  }
  function drawBars(id,rows){
    var el=document.getElementById(id);
    if(!el)return;
    rows=Array.isArray(rows)?rows:[];
    var max=Math.max(1,...rows.map(function(x){return Number(x.value||0);}));
    el.innerHTML=rows.map(function(x){
      var h=Math.max(4,Math.round((Number(x.value||0)/max)*86));
      return '<div class="stage33-bar-wrap"><div class="stage33-bar-value">'+compact(x.value)+'</div><div class="stage33-bar" style="height:'+h+'px"></div><div class="stage33-bar-label">'+esc(x.label)+'</div></div>';
    }).join('') || '<div class="stage33-bar-label">데이터 없음</div>';
  }
  function renderCharts(data){
    var charts=data&&data.charts?data.charts:{};
    drawBars('chartDailyViews',charts.dailyViews);
    drawBars('chartDailyUsers',charts.dailyUsers);
    drawBars('chartDailyRevenue',charts.dailyRevenue);
    drawBars('chartProductSales',charts.productSales);
    drawBars('chartRegionVendors',charts.regionVendors);
    var lf=document.getElementById('stage33LastFetch');
