  var panel=document.getElementById('inquiries'),body=document.getElementById('admissionTableBody'),pager=document.getElementById('inquiryPager'),reviewModal=document.getElementById('admissionReviewModal'),reviewBody=document.getElementById('admissionReviewModalBody'),reviewSubtitle=panel.querySelector('[data-admission-modal-subtitle]'),admissionsById=new Map();
