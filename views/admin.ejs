  function updateReportSummary(summary){
    Object.keys(summary||{}).forEach(function(key){var el=document.querySelector('[data-report-summary="'+key+'"]');if(el)el.textContent=Number(summary[key]||0).toLocaleString('ko-KR');});
  }
  async function loadReports(page){
