<script>
(function(){
  if(window.__adminQaPolish1)return;
  window.__adminQaPolish1=true;


  function fixUserHeaders(){
    var users=document.getElementById('users');
    if(!users)return;
    users.querySelectorAll('th').forEach(function(th){
      var t=(th.textContent||'').trim();
      if(t==='등급/만기')th.textContent='상태';
      if(t==='수정')th.textContent='관리';
    });
    var ths=users.querySelectorAll('table th');
    ths.forEach(function(th,idx){
      if((th.textContent||'').trim()==='상태' && idx>0){
        var next=ths[idx+1];
        if(next && (next.textContent||'').trim()==='상태')next.textContent='새 비밀번호';
      }
    });
  }

  async function submitVendorLink(form){
    if(!confirm('선택한 회원을 이 업체의 업체회원으로 연결할까요? 연결 후 해당 회원은 업체 대시보드를 사용할 수 있습니다.'))return;
    var fd=new FormData(form);
    var btn=form.querySelector('button');
    var old=btn?btn.textContent:'';
    if(btn){btn.disabled=true;btn.textContent='연결중...';}
    try{
      var res=await fetch('/admin/link-user-vendor',{method:'POST',body:fd,credentials:'same-origin',headers:{'X-Requested-With':'fetch'}});
      var data=null;
      try{data=await res.json();}catch(e){}
      if(!res.ok||data?.ok===false)throw new Error(data?.error||('HTTP '+res.status));
      toast('업체회원으로 연결되었습니다.','ok');
      window.saveActiveAdminListState?.('users',window.getAdminListState?.('users').page||1);
      if(typeof window.reloadAdminPanelList==='function')await window.reloadAdminPanelList('users');
      if(typeof window.loadAdminVendors==='function')window.loadAdminVendors(window.getAdminListState?.('vendors').page||1);
      if(typeof window.loadDashboardSummary==='function')window.loadDashboardSummary();
    }catch(e){
      toast('업체회원 연결 실패: '+(e.message||'오류'),'bad');
    }finally{
      if(btn){btn.disabled=false;btn.textContent=old;}
    }
  }

  function addLiveRetry(){
    var body=document.getElementById('adminLiveBody');
    if(!body)return;
    if((body.textContent||'').indexOf('불러오지 못했습니다')===-1)return;
    if(body.querySelector('.live-retry-btn'))return;
    var btn=document.createElement('button');
    btn.type='button';
    btn.className='admin-live-btn live-retry-btn';
    btn.textContent='다시 불러오기';
    btn.onclick=function(){
      fetch('/admin/api/live-summary',{credentials:'same-origin',headers:{'Accept':'application/json'}})
        .then(function(r){return r.json();})
        .then(function(d){toast(d&&d.ok?'알림센터 API 정상':'알림센터 응답 확인 필요',d&&d.ok?'ok':'bad');})
        .catch(function(e){toast('알림센터 API 오류: '+e.message,'bad');});
    };
    body.appendChild(btn);
  }

  document.addEventListener('submit',function(e){
    var form=e.target;
    if(form && form.getAttribute('action')==='/admin/link-user-vendor'){
      e.preventDefault();
      e.stopPropagation();
      submitVendorLink(form);
    }
  },true);

  document.addEventListener('DOMContentLoaded',function(){
    fixUserHeaders();
    var form=document.querySelector('form[action="/admin/link-user-vendor"]'),userSelect=form?.elements.user_id;
