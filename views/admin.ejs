  function fields(x){var result=fieldMap.map(function(f){var before=norm(x[f[1]]),after=norm(x[f[0]]);return {label:f[2],before:before,after:after,changed:before!==after};});if(x.has_image_data)result.push({label:'лМАнСЬ мЭілѓЄмІА',before:'',after:'',changed:true,image:true});return result;}
  function statusText(v){return v==='approved'?'мКємЭЄмЩДл£М':v==='rejected'?'л∞Шл†§':v==='cancelled'?'мЈ®мЖМ':'мКємЭЄлМАкЄ∞';}
  function connectionProblems(x){var a=[];if(!x.vendor_exists)a.push('мЧЕм≤і мЧЖмЭМ');if(!x.user_exists)a.push('нЪМмЫР мЧЖмЭМ');if(x.user_exists&&!x.link_matches_vendor)a.push('мЧЕм≤і мЧ∞к≤∞ лґИмЭЉмєШ');if(x.user_exists&&x.user_status!=='active')a.push('мВђмЪ©м§СмІА нЪМмЫР');if(x.user_exists&&(!x.user_is_vendor||!x.linked_vendor_id))a.push('мЧЕм≤інЪМмЫР мЧ∞к≤∞ мЧЖмЭМ');return a;}
  function actions(x){if(x.status!=='new')return '<span class="done">м≤Шл¶ђмЩДл£М</span>';var danger=connectionProblems(x).length||Number(x.changed_count||0)===0;var confirmText=danger?'нЪМмЫР лШРлКФ мЧЕм≤і мЧ∞к≤∞ мГБнГЬмЧР лђЄм†Ьк∞А мЮИмКµлЛИлЛ§. мГБмДЄ лВімЪ©мЭД нЩХмЭЄнЦИмКµлЛИлЛ§. к≥ДмЖН мКємЭЄнХ†кєМмЪФ?':'нШДмЮђ мЧЕм≤ім†Хл≥іл•Љ мЪФм≤≠ лВімЪ©мЬЉл°Ь л≥Ак≤љнХ†кєМмЪФ?';return '<div class="vendor-request-actions"><form method="post" action="/admin/vendor-requests/'+esc(x.id)+'/approve" class="vendor-request-action-form"><input name="admin_memo" placeholder="мКємЭЄ л©Фл™®"><button class="approve-btn" onclick="if(!confirm(&quot;'+esc(confirmText)+'&quot;))return false;this.form.dataset.safeConfirmDone=\'1\'">л≥Ак≤љ мКємЭЄ</button></form><form method="post" action="/admin/vendor-requests/'+esc(x.id)+'/reject" class="vendor-request-action-form"><input name="admin_memo" placeholder="л∞Шл†§ мВђмЬ†" required><button class="reject-btn" onclick="if(!confirm(&quot;мЭі мЧЕм≤ім†Хл≥і мИШм†ХмЪФм≤≠мЭД л∞Шл†§нХ†кєМмЪФ?&quot;))return false;this.form.dataset.safeConfirmDone=\'1\'">л∞Шл†§</button></form></div>';}
