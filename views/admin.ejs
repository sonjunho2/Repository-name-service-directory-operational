<script>function showAdminPanel(id){document.querySelectorAll('.admin-panel').forEach(p=>p.classList.remove('active'));const p=document.getElementById(id);if(p){p.classList.add('active')}const boardOperationPanels=['boardPosts','notices','reviews','reports','adInquiries'];const sidebarId=boardOperationPanels.includes(id)?'boardPosts':id;document.querySelectorAll('[data-panel]').forEach(a=>a.classList.toggle('active',a.dataset.panel===sidebarId));if(typeof window.syncBoardOperationTabs==='function')window.syncBoardOperationTabs(id);}document.querySelectorAll('[data-panel]').forEach(a=>a.addEventListener('click',e=>{e.preventDefault();showAdminPanel(a.dataset.panel);history.replaceState(null,'','#'+a.dataset.panel)}));function applyIntegratedReady(){}function applyUserFilter(){const q=(userSearch?.value||'').trim().toLowerCase();const r=userRoleFilter?.value||'all';const s=userStatusFilter?.value||'all';document.querySelectorAll('.user-row').forEach(row=>{const okText=!q||(row.dataset.text||'').includes(q);const okRole=r==='all'||row.dataset.role===r;const okStatus=s==='all'||row.dataset.status===s;row.classList.toggle('hidden-row',!(okText&&okRole&&okStatus));});}function sortUserRows(){const table=document.querySelector('#users table');if(!table)return;const rows=[...table.querySelectorAll('.user-row')];const mode=document.getElementById('userSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);if(mode==='admin')return (b.dataset.role==='admin')-(a.dataset.role==='admin')||Number(b.dataset.id)-Number(a.dataset.id);if(mode==='blocked')return (b.dataset.status==='blocked')-(a.dataset.status==='blocked')||Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.id)-Number(b.dataset.id);});rows.forEach(r=>table.appendChild(r));}['input','change'].forEach(ev=>{userSearch?.addEventListener(ev,applyUserFilter);userRoleFilter?.addEventListener(ev,applyUserFilter);userStatusFilter?.addEventListener(ev,applyUserFilter);userSortFilter?.addEventListener(ev,sortUserRows);});userFilterReset?.addEventListener('click',()=>{userSearch.value='';userRoleFilter.value='all';userStatusFilter.value='all';userSortFilter.value='default';applyUserFilter();sortUserRows();});function showPreview(box,src,text){if(!box)return;const img=box.querySelector('img');const span=box.querySelector('span');if(src){img.src=src;box.style.display='flex';if(span)span.textContent=text||'선택한 이미지가 표시됩니다.';}else{box.style.display='none';if(img)img.removeAttribute('src');}}function bindPreview(input,box){if(!input)return;input.addEventListener('change',()=>{const f=input.files&&input.files[0];if(!f)return showPreview(box,null);showPreview(box,URL.createObjectURL(f),'새로 선택한 이미지입니다.');});}const vf=document.getElementById('vendorForm');bindPreview(vf?.image,document.getElementById('vendorImagePreview'));cancelVendorEdit.onclick=()=>{vf.reset();vf.id.value='';showPreview(document.getElementById('vendorImagePreview'),null);vendorSubmitBtn.textContent='업체 등록';cancelVendorEdit.style.display='none'};
function updateReportAlert(){const el=document.getElementById('pendingReportCount');if(el)el.textContent=document.querySelectorAll('.report-row[data-status="new"]').length;}
