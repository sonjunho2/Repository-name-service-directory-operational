  <% const _boardLayoutLabels={list:'목록형',gallery:'갤러리형',webzine:'웹진형',qna:'Q&A형',faq:'FAQ형',private:'1:1 문의형'}; const _boardRoleLabels={admin:'관리자',member:'회원',guest:'게스트',all:'전체',user:'회원'}; const _protectedBoardSlugs=['notice','free','reviews','reports','ad-inquiry']; %>
  <div class="board-settings-toolbar"><div class="board-settings-count">전체 게시판 <strong><%=(adminBoards||[]).length%></strong></div><div class="board-settings-toolbar-actions"><button type="button" id="openBoardCreateModal">게시판 추가</button><button type="button" id="saveBoardOrder">순서 저장</button></div></div>
