    </div>
  </div>
</div>

<div class="admin-activity-grid">
  <div class="admin-activity-box">
    <h3>최근 신청</h3>
    <% const recentReqs=[...(inquiries||[]).slice(0,3).map(x=>({type:x.type==='apply'?'입점신청':'문의',title:x.company_name||x.name||'-',meta:(x.region||'')+' '+(x.category||''),status:x.status,created:x.created_at})), ...(adRequests||[]).slice(0,2).map(x=>({type:'광고신청',title:x.vendor_name||x.plan||'-',meta:Number(x.krw_price||0).toLocaleString()+'원',status:x.status,created:x.created_at})), ...(bannerRequests||[]).slice(0,2).map(x=>({type:'배너신청',title:x.vendor_name||x.title||'-',meta:Number(x.krw_price||0).toLocaleString()+'원',status:x.status,created:x.created_at}))].slice(0,5); %>
    <% if(recentReqs.length){ recentReqs.forEach(x=>{ %>
      <div class="admin-activity-item">
        <span class="admin-activity-badge <%=x.status==='new'?'wait':x.status==='approved'?'ok':x.status==='rejected'?'bad':''%>"><%=x.type%></span>
        <b><%=x.title%></b>
        <small><%=x.meta||'-'%></small>
      </div>
    <% }) } else { %>
      <div class="admin-activity-empty">최근 신청이 없습니다.</div>
    <% } %>
  </div>

  <div class="admin-activity-box">
    <h3>최근 결제</h3>
    <% const recentPays=(paymentLogs||[]).slice(0,5); %>
    <% if(recentPays.length){ recentPays.forEach(p=>{ %>
      <div class="admin-activity-item">
        <span class="admin-activity-badge ok"><%=p.product_type==='banner'?'배너':p.product_type==='recommended'?'추천광고':p.product_type==='general'?'일반광고':p.product_type||'결제'%></span>
        <b><%=p.vendor_name||p.username||'-'%></b>
        <small><%=Number(p.krw_price||0).toLocaleString()%>원 / <%=p.usdt_amount||0%> USDT</small>
      </div>
    <% }) } else { %>
      <div class="admin-activity-empty">최근 결제내역이 없습니다.</div>
    <% } %>
  </div>

  <div class="admin-activity-box">
    <h3>최근 관리자 작업</h3>
    <% const recentLogs=(adminLogs||[]).slice(0,5); %>
    <% if(recentLogs.length){ recentLogs.forEach(l=>{ %>
      <div class="admin-activity-item">
        <span class="admin-activity-badge"><%=l.action||'작업'%></span>
        <b><%=l.target_type||'system'%> #<%=l.target_id||'-'%></b>
        <small><%=l.memo||'-'%></small>
      </div>
    <% }) } else { %>
      <div class="admin-activity-empty">최근 관리자 작업이 없습니다.</div>
    <% } %>
  </div>
</div>
</section><section id="vendors" class="panel admin-panel"><% const vendorReviewStats={}; reviews.filter(r=>r.status==='visible').forEach(r=>{const id=r.vendor_id; if(id){vendorReviewStats[id]=vendorReviewStats[id]||{count:0,sum:0}; vendorReviewStats[id].count++; vendorReviewStats[id].sum+=Number(r.rating||0);}}); %><h2>업체 관리</h2>
<%
  const _vendorSafe=(typeof vendors!=='undefined'&&Array.isArray(vendors))?vendors:[];
  const _todayV=new Date(); _todayV.setHours(0,0,0,0);
  const _daysLeftV=v=>{
    if(!v.expire_at)return null;
    const d=new Date(v.expire_at); d.setHours(0,0,0,0);
    return Math.ceil((d-_todayV)/(1000*60*60*24));
  };
  const _vNoAd=_vendorSafe.filter(v=>!v.ad_type||v.ad_type==='none').length;
  const _vGeneral=_vendorSafe.filter(v=>v.ad_type==='general').length;
  const _vRecommended=_vendorSafe.filter(v=>v.ad_type==='recommended').length;
  const _vBanner=_vendorSafe.filter(v=>v.banner_active).length;
  const _vExpiring=_vendorSafe.filter(v=>{const d=_daysLeftV(v); return d!==null&&d>=0&&d<=7;}).length;
%>
<div class="vendor-summary">
  <div class="vendor-summary-card"><b>광고없음</b><strong><%=_vNoAd%></strong></div>
  <div class="vendor-summary-card general"><b>일반광고</b><strong><%=_vGeneral%></strong></div>
  <div class="vendor-summary-card recommended"><b>추천광고</b><strong><%=_vRecommended%></strong></div>
  <div class="vendor-summary-card banner"><b>프리미엄배너</b><strong><%=_vBanner%></strong></div>
  <div class="vendor-summary-card expire"><b>7일 이내 만료</b><strong><%=_vExpiring%></strong></div>
</div>
<p class="vendor-filter-note">업체목록은 광고상태, 노출상태, 만기상태를 기준으로 빠르게 확인할 수 있습니다.</p>
<div class="vendor-toolbar">
  <button type="button" id="openVendorCreateModal" class="vendor-add-open">업체 등록</button>
</div>

<div id="vendorModal" class="vendor-modal">
  <div class="vendor-modal-box">
    <div class="vendor-modal-head">
      <h3 id="vendorModalTitle">업체 등록</h3>
      <button type="button" id="closeVendorModal" class="vendor-modal-close">닫기</button>
    </div>
<form id="vendorForm" method="post" action="/admin/vendor" enctype="multipart/form-data">
  <input type="hidden" name="id">

  <div class="vendor-form-box">
    <h3>기본정보</h3>
    <div class="vendor-form-grid">
      <input name="name" placeholder="업체명" required>
      <select name="category" required><% (settings?.categories||[]).forEach(x=>{%><option value="<%=x%>"><%=x%></option><%})%></select>
      <select name="region" required><% (settings?.regions||[]).forEach(x=>{%><option value="<%=x%>"><%=x%></option><%})%></select>
      <input name="phone" placeholder="연락처">
      <input name="kakao_url" placeholder="카카오톡 문의 링크">
      <input name="tags" placeholder="태그">
    </div>
    <p class="vendor-form-help">업체명, 업종, 지역은 메인페이지 검색과 목록 노출에 사용됩니다. 관리자가 먼저 업체를 선등록한 뒤 회원관리에서 가입한 아이디와 연결할 수 있습니다.</p>
  </div>

  <div class="vendor-form-box">
    <h3>영업 / 소개</h3>
    <div class="vendor-form-grid two">
      <input name="business_hours" placeholder="영업시간">
      <textarea name="description" placeholder="업체소개"></textarea>
    </div>
  </div>

  <div class="vendor-form-box">
    <h3>광고 / 노출 설정</h3>
    <div class="vendor-form-grid">
      <select name="status"><option value="pending">검수중</option><option value="active">노출</option><option value="hidden">숨김</option><option value="expired">만료</option></select>
      <select name="ad_type"><option value="none">없음</option><option value="general">일반광고</option><option value="recommended">추천광고</option></select>
      <input name="expire_at" type="date" placeholder="광고/배너 만기일">
      <label><input type="checkbox" name="banner_active"> 배너활성</label>
    </div>
    <p class="vendor-form-help">배너활성 체크 시 광고상품은 자동으로 추천광고로 적용되며, 같은 만기일을 사용합니다.</p>
  </div>

  <div class="vendor-form-box">
    <h3>대표 이미지</h3>
    <div class="vendor-form-grid two">
      <input type="file" name="image" accept="image/*">
      <div class="img-preview" id="vendorImagePreview"><img alt="업체 이미지 미리보기"><div><b>업체 이미지 미리보기</b><span>선택한 이미지가 표시됩니다.</span></div></div>
    </div>
    <p class="vendor-form-help">대표 이미지는 일반목록, 추천목록, 프리미엄배너에 공통으로 사용됩니다.</p>
  </div>

  <div class="vendor-form-submit">
    <button id="vendorSubmitBtn">업체 등록</button>
    <button type="button" id="cancelVendorEdit" class="cancel-edit" style="display:none">취소</button>
  </div>
</form>
  </div>
</div><div class="vendor-admin-filter"><input id="vendorSearch" placeholder="업체명 검색"><select id="vendorTypeFilter"><option value="all">전체 광고</option><option value="noad">광고없음</option><option value="general">일반광고</option><option value="recommended">추천광고</option><option value="banner">프리미엄배너</option><option value="expiring">7일 이내 만료</option></select><select id="vendorStatusFilter"><option value="all">전체 상태</option><option value="pending">검수중</option><option value="active">노출</option><option value="hidden">숨김</option><option value="expired">만료</option></select><select id="vendorSortFilter"><option value="default">기본순</option><option value="views">조회수순</option><option value="reviews">후기순</option><option value="rating">평점순</option><option value="latest">최신등록순</option></select><button type="button" id="vendorFilterReset">초기화</button></div>
