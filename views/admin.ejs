<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>관리자</title><link rel="stylesheet" href="/public/css/style.css"></head><body><header class="top"><b>관리자</b><nav><a href="/">사이트</a><a href="/logout">로그아웃</a></nav></header><main class="admin">
<section id="vendors" class="panel"><h2>업체 관리</h2><form method="post" action="/admin/vendor" enctype="multipart/form-data" class="form gridform"><input name="name" placeholder="업체명" required><input name="category" placeholder="업종" required><input name="region" placeholder="지역" required><input name="phone" placeholder="연락처"><input name="tags" placeholder="태그"><select name="status"><option value="active">노출</option><option value="hidden">숨김</option></select><label><input type="checkbox" name="is_recommended"> 추천업체</label><label><input type="checkbox" name="is_premium"> 프리미엄</label><input type="file" name="image" accept="image/*"><textarea name="description" placeholder="설명"></textarea><button>업체 등록</button></form><table><tr><th>ID</th><th>구분</th><th>업체명</th><th>지역/업종</th><th>상태</th><th>삭제</th></tr><% vendors.forEach(v=>{%><tr><td><%=v.id%></td><td><%=v.is_premium?'프리미엄':v.is_recommended?'추천':'일반'%></td><td><%=v.name%></td><td><%=v.region%>/<%=v.category%></td><td><%=v.status%></td><td><form method="post" action="/admin/delete/vendors/<%=v.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
<section id="banners" class="panel"><h2>프리미엄 슬라이드 배너 관리</h2><form method="post" action="/admin/banner" enctype="multipart/form-data" class="form gridform"><input name="title" placeholder="배너 제목" required><input name="subtitle" placeholder="부제목"><input name="link_url" placeholder="링크 URL"><input name="sort_order" type="number" placeholder="정렬순서" value="0"><select name="position"><option value="premium">프리미엄</option><option value="main">메인</option></select><label><input type="checkbox" name="is_active" checked> 노출</label><input type="file" name="image" accept="image/*"><button>배너 등록</button></form><table><tr><th>ID</th><th>제목</th><th>위치</th><th>순서</th><th>삭제</th></tr><% banners.forEach(b=>{%><tr><td><%=b.id%></td><td><%=b.title%></td><td><%=b.position%></td><td><%=b.sort_order%></td><td><form method="post" action="/admin/delete/banners/<%=b.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
<section id="users" class="panel"><h2>회원 관리</h2><table><tr><th>ID</th><th>아이디</th><th>닉네임</th><th>권한</th><th>상태</th><th>수정</th></tr><% users.forEach(u=>{%><tr><form method="post" action="/admin/user"><td><%=u.id%><input type="hidden" name="id" value="<%=u.id%>"></td><td><%=u.username%></td><td><input name="nickname" value="<%=u.nickname%>"></td><td><select name="role"><option <%=u.role==='user'?'selected':''%>>user</option><option <%=u.role==='admin'?'selected':''%>>admin</option></select></td><td><select name="status"><option <%=u.status==='active'?'selected':''%>>active</option><option <%=u.status==='blocked'?'selected':''%>>blocked</option></select></td><td><input name="password" placeholder="새 비번"><button>저장</button></td></form></tr><%})%></table></section>
<section id="notices" class="panel"><h2>공지 관리</h2><form method="post" action="/admin/notice" class="form"><input name="title" placeholder="제목" required><textarea name="content" placeholder="내용" required></textarea><label><input type="checkbox" name="is_pinned"> 상단 고정</label><button>공지 등록</button></form><table><tr><th>ID</th><th>제목</th><th>삭제</th></tr><% notices.forEach(n=>{%><tr><td><%=n.id%></td><td><%=n.title%></td><td><form method="post" action="/admin/delete/notices/<%=n.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
<section class="panel"><h2>후기 관리</h2><table><tr><th>ID</th><th>업체</th><th>제목</th><th>평점</th><th>삭제</th></tr><% reviews.forEach(r=>{%><tr><td><%=r.id%></td><td><%=r.vendor_name%></td><td><%=r.title%></td><td><%=r.rating%></td><td><form method="post" action="/admin/delete/reviews/<%=r.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
</main></body></html>
