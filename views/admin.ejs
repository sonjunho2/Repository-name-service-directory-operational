  <a class="dash-card warn dashboard-card-link" href="#vendors" data-panel="vendors"><%-alertDot(S.expiring7)%><b>7일 내 만료</b><strong class="<%=level(S.expiring7)%>"><%=num(S.expiring7)%></strong></a>
