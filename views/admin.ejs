  var vendorServerLimit=20;
  var vendorServerReady=false;
  var vendorLoading=false;
  var vendorSearchTimer=null;

  function vendorQuery(page){
    var params=new URLSearchParams();
    params.set('page',String(page));
    params.set('limit',String(vendorServerLimit));
    var search=(document.getElementById('vendorSearch')?.value||'').trim();
    var status=document.getElementById('vendorStatusFilter')?.value||'all';
    var sort=document.getElementById('vendorSortFilter')?.value||'latest';
    if(!['all','active','pending','hidden','expired'].includes(status)){status='all';document.getElementById('vendorStatusFilter').value='all';}
    if(!['latest','oldest','name'].includes(sort)){sort='latest';document.getElementById('vendorSortFilter').value='latest';}
    if(search)params.set('q',search);
