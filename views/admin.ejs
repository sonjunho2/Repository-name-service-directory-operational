  document.getElementById('notices')?.addEventListener('click',function(ev){var d=ev.target.closest('[data-notice-detail]');if(d){var detail=document.querySelector('[data-detail-for="'+d.dataset.noticeDetail+'"]');if(detail){detail.hidden=!detail.hidden;d.textContent=detail.hidden?'상세보기':'상세닫기';}return;}var edit=ev.target.closest('[data-notice-edit]');if(edit){var n=rowsById.get(edit.dataset.noticeEdit);if(!n)return;document.getElementById('noticeId').value=n.id;document.getElementById('noticeTitle').value=n.title||'';document.getElementById('noticeContent').value=n.content||'';document.getElementById('noticePinned').checked=!!n.is_pinned;document.getElementById('noticeSubmitBtn').textContent='공지 수정 저장';document.getElementById('noticeCancelEdit').hidden=false;document.getElementById('noticeForm').scrollIntoView({behavior:'smooth',block:'start'});setTimeout(function(){document.getElementById('noticeTitle').focus();},250);return;}var card=ev.target.closest('[data-notice-card]');if(card){var m=card.dataset.noticeCard;if(m==='pinned'||m==='normal')document.getElementById('noticePinnedFilter').value=m;else if(m==='all')document.getElementById('noticePinnedFilter').value='all';if(m==='recent')document.getElementById('noticeSortFilter').value='latest';load(1);}});
  document.getElementById('notices')?.addEventListener('submit',async function(ev){var form=ev.target;if(!form.matches('#noticeForm,.notice-action-list form'))return;ev.preventDefault();if(form.dataset.submitting==='1')return;if(form.dataset.confirm&&!confirm(form.dataset.confirm))return;var button=ev.submitter||form.querySelector('button'),old=button?.textContent;form.dataset.submitting='1';if(button)button.disabled=true;try{var res=await fetch(form.action,{method:'POST',body:new FormData(form),credentials:'same-origin',headers:{'X-Requested-With':'fetch',Accept:'application/json'}}),data=await res.json();if(!res.ok||!data.ok)throw new Error(data.error||'처리하지 못했습니다.');if(form.id==='noticeForm'||String(document.getElementById('noticeId').value)===String(form.action.split('/').pop()))resetForm();await load(page);if(typeof window.loadDashboardSummary==='function')window.loadDashboardSummary();if(typeof toast==='function')toast(form.id==='noticeForm'?'공지를 저장했습니다.':'공지를 삭제했습니다.','ok');}catch(err){if(typeof toast==='function')toast(err.message,'bad');else alert(err.message);}finally{form.dataset.submitting='0';if(button){button.disabled=false;if(form.id!=='noticeForm')button.textContent=old;}}});
