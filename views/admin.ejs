      '<td><span class="admission-badge '+esc(x.status||'new')+'">'+esc(statusText(x.status))+'</span></td><td>'+actions(x)+'</td></tr>';
  }
  function reviewContent(x){var warning=risky(x),candidate=x.matched_vendor_name||(x.matched_vendor_id?'мЧЕм≤і #'+x.matched_vendor_id:'мЧЖмЭМ'),linked=x.linked_vendor_name||(x.applicant_vendor_id?'мЧЕм≤і #'+x.applicant_vendor_id:'мЧЖмЭМ');return '<div class="admission-review-grid">'+
