  var reviewModal=document.getElementById('vendorRequestReviewModal'),reviewBody=document.getElementById('vendorRequestReviewModalBody'),reviewSubtitle=panel.querySelector('[data-vendor-request-modal-subtitle]'),vendorRequestsById=new Map();
  var fieldMap=[['name','current_vendor_name','мЧЕм≤іл™Е'],['category','current_category','мЧЕмҐЕ'],['region','current_region','мІАмЧ≠'],['phone','current_phone','мЧ∞лЭљм≤Ш'],['kakao_url','current_kakao_url','мєімєімШ§'],['business_hours','current_business_hours','мШБмЧЕмЛЬк∞Д'],['tags','current_tags','нГЬкЈЄ'],['description','current_description','мЧЕм≤імЖМк∞Ь'],['sns_url','current_sns_url','SNS'],['line_url','current_line_url','LINE'],['telegram_url','current_telegram_url','нЕФл†ИкЈЄлЮ®'],['holiday_info','current_holiday_info','нЬілђім†Хл≥і']];
  function esc(v){return String(v==null?'':v).replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});}
  function norm(v){return String(v==null?'':v).trim();}
