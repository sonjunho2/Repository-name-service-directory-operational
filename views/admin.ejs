        task('광고신청',c.pendingAdRequests,'adCenter'),
        task('배너신청',c.pendingBannerRequests,'adCenter'),
        task('입금대기',c.waitingPayments,'adCenter'),
        task('신고',c.pendingReports,'reports')
      ].join('');
