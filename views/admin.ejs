  </form>
  <div class="board-settings-summary"><div><b>전체 <%=(adminBoards||[]).length%>개 게시판</b><span>slug는 게시판 주소입니다. 기본 게시판 또는 게시글이 있는 게시판의 주소는 변경할 수 없습니다.</span><span>위/아래 버튼으로 배치한 뒤 순서를 저장하세요.</span></div><button type="button" id="saveBoardOrder">순서 저장</button></div>
  <div class="table-wrap board-settings-table"><table><colgroup><col class="board-col-id"><col class="board-col-title"><col class="board-col-slug"><col class="board-col-type"><col class="board-col-role"><col class="board-col-toggle"><col class="board-col-toggle"><col class="board-col-toggle"><col class="board-col-order"><col class="board-col-actions"></colgroup><thead><tr><th>ID</th><th>제목</th><th>slug</th><th>게시판 유형</th><th>쓰기</th><th>댓글</th><th>이미지</th><th>노출</th><th>순서</th><th>관리</th></tr></thead><tbody id="boardSettingsRows">
  <% (adminBoards||[]).forEach(b=>{ const layoutType=_boardLayoutLabels[b.layout_type]?b.layout_type:'list'; const protectedBoard=_protectedBoardSlugs.includes(String(b.slug||'').toLowerCase()); const postCount=Number(b.post_count||0); %><tr data-board-id="<%=b.id%>"><td><%=b.id%></td><td class="board-title-cell"><form id="boardForm<%=b.id%>" method="post" action="/admin/boards/<%=b.id%>/update" data-no-ajax></form><input form="boardForm<%=b.id%>" name="title" value="<%=b.title%>" required><div class="board-row-badges"><% if(protectedBoard){ %><span class="mini-badge protected">기본 게시판</span><% } %><% if(postCount>0){ %><span class="mini-badge">글 <%=postCount%>개</span><% } %></div></td><td><input form="boardForm<%=b.id%>" name="slug" value="<%=b.slug%>" required <%=protectedBoard||postCount>0?'readonly class="readonly-input"':''%>><small class="board-slug-help">주소: /boards/<%=b.slug%></small></td><td><select form="boardForm<%=b.id%>" name="layout_type" aria-label="게시판 유형"><% Object.keys(_boardLayoutLabels).forEach(t=>{ %><option value="<%=t%>" <%=layoutType===t?'selected':''%>><%=_boardLayoutLabels[t]%></option><% }) %></select></td><td><select form="boardForm<%=b.id%>" name="write_role"><% ['member','admin','all','guest'].forEach(r=>{ %><option value="<%=r%>" <%=b.write_role===r?'selected':''%>><%=_boardRoleLabels[r]||r%></option><% }) %><% if(!['member','admin','all','guest'].includes(b.write_role)){ %><option value="<%=b.write_role%>" selected><%=_boardRoleLabels[b.write_role]||b.write_role%></option><% } %></select></td><td class="board-toggle-cell"><input form="boardForm<%=b.id%>" type="checkbox" name="comment_enabled" aria-label="댓글 사용" <%=b.comment_enabled?'checked':''%>></td><td class="board-toggle-cell"><input form="boardForm<%=b.id%>" type="checkbox" name="image_enabled" aria-label="이미지 사용" <%=b.image_enabled?'checked':''%>></td><td class="board-toggle-cell"><input form="boardForm<%=b.id%>" type="checkbox" name="is_active" aria-label="노출" <%=b.is_active?'checked':''%>></td><td><div class="board-order-actions"><button type="button" data-board-move="up" aria-label="위로 이동">위</button><button type="button" data-board-move="down" aria-label="아래로 이동">아래</button></div></td><td><div class="board-actions"><button form="boardForm<%=b.id%>">저장</button></div></td></tr><% }) %>
  </tbody></table></div>
</section>
