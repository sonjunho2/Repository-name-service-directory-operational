</script><script>
(function(){
  if(window.__adminKoreanLabels)return;
  window.__adminKoreanLabels=true;

  var labelMap={
    user:'일반회원',
    admin:'관리자',
    active:'정상',
    blocked:'차단',
    suspended:'일시정지',
    inactive:'휴면',
    pending:'대기',
    approved:'승인완료',
