  const form = document.getElementById('editVendorForm');
  function fmt(v){if(!v)return'';const d=new Date(v);if(isNaN(d))return String(v).slice(0,10);return d.toISOString().slice(0,10)}
  function openEditVendor(v){
    if(!v||!modal||!form)return;
    form.action='/admin/update/vendor/'+v.id;
    form.name.value=v.name||'';
    form.category.value=v.category||'';
    form.region.value=v.region||'';
    form.phone.value=v.phone||'';
    form.kakao_url.value=v.kakao_url||'';
    form.tags.value=v.tags||'';
    form.business_hours.value=v.business_hours||'';
    form.status.value=v.status||'active';
    form.ad_type.value=v.ad_type||'none';
    form.expire_at.value=fmt(v.expire_at);
    form.banner_active.checked=!!v.banner_active;
    if(form.linked_user_id)form.linked_user_id.value=v.user_id||v.linked_user_id||'';
    form.description.value=v.description||'';
    const preview=document.getElementById('editVendorImagePreview');
    if(preview){
      const img=preview.querySelector('img');
      if(v.image_data){img.src=v.image_data; preview.style.display='grid';}
      else{img.removeAttribute('src'); preview.style.display='none';}
    }
    modal.classList.add('show');
    modal.setAttribute('aria-hidden','false');
  }
  document.addEventListener('click',e=>{
    const edit=e.target.closest('.edit-vendor-btn');
    if(edit){const id=String(edit.dataset.id);openEditVendor(byId[id]);}
    const bannerEdit=e.target.closest('.banner-vendor-edit-btn');
    if(bannerEdit){const id=String(bannerEdit.dataset.vendorId);openEditVendor(byId[id]);}
    if(e.target.closest('[data-edit-close]')){modal?.classList.remove('show');modal?.setAttribute('aria-hidden','true');}
  });
  document.addEventListener('keydown',e=>{if(e.key==='Escape'){modal?.classList.remove('show');modal?.setAttribute('aria-hidden','true');}});
})();
</script>
<script>
(function(){
  function openNativeDate(input){
    if(!input)return;
    try{ if(typeof input.showPicker==='function'){input.showPicker(); return;} }catch(e){}
    try{ input.focus(); input.click(); }catch(e){}
  }
  function enhanceDateInputs(root){
    (root||document).querySelectorAll('input[type="date"]').forEach(function(input){
      if(input.dataset.dateEnhanced==='1')return;
      input.dataset.dateEnhanced='1';
      var wrap=document.createElement('span');
      wrap.className='admin-date-wrap';
      input.parentNode.insertBefore(wrap,input);
      wrap.appendChild(input);
      var btn=document.createElement('button');
      btn.type='button';
      btn.className='admin-date-pick-btn';
      btn.textContent='📅';
      btn.setAttribute('aria-label','날짜 선택');
      btn.addEventListener('click',function(){openNativeDate(input);});
      wrap.appendChild(btn);
      input.addEventListener('click',function(){openNativeDate(input);});
    });
  }
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',function(){enhanceDateInputs();});
  else enhanceDateInputs();
  document.addEventListener('click',function(e){
    if(e.target&&e.target.matches('[data-panel],.edit-vendor-btn,.banner-vendor-edit-btn'))setTimeout(function(){enhanceDateInputs();},80);
  },true);
})();
</script>
