 → 업체회원 연결</h3><form method="post" action="/admin/link-user-vendor" class="settings-form"><div class="admin-account-grid"><select name="user_id" required><option value="">회원 선택</option><% users.forEach(u=>{%><option value="<%=u.id%>"><%=u.username%> / <%=u.nickname%> <%=u.is_vendor?'(업체회원)':''%></option><%})%></select><select name="vendor_id" required><option value="">업체 선택</option><% vendors.forEach(v=>{%><option value="<%=v.id%>"><%=v.name%> / <%=v.region%> <%=v.linked_username?'(연결됨: '+v.linked_username+')':'(미연결)'%></option><%})%></select><button>업체회원으로 연결</button></div></form><p class="settings-help">관리자가 먼저 업체를 선등록한 뒤, 나중에 회원가입한 아이디와 연결할 수 있습니다. 연결 후 해당 회원은 업체관리에서 광고신청/업체정보 관리를 진행합니다. 이미 다른 아이디와 연결된 업체는 중복 연결되지 않습니다.</p></div></section><section id="notices" class="panel admin-panel"><h2>공지 관리</h2><form method="post" action="/admin/notice" class="gridform"><input name="title" placeholder="제목" required><textarea name="content" placeholder="내용" required></textarea><label><input type="checkbox" name="is_pinned">상단 고정</label><button>공지 등록</button></form><div class="notice-admin-filter"><input id="noticeSearch" placeholder="공지 제목 검색"><select id="noticePinnedFilter"><option value="all">전체 공지</option><option value="pinned">상단고정</option><option value="normal">일반공지</option></select><select id="noticeSortFilter"><option value="default">기본순</option><option value="latest">최신등록순</option><option value="pinned">상단고정 우선</option><option value="normal">일반공지 우선</option></select><button type="button" id="noticeFilterReset">초기화</button></div><table><tr><th>ID</th><th>제목</th><th>고정상태</th><th>삭제</th></tr><% notices.forEach(n=>{%><tr class="notice-row" data-id="<%=n.id%>" data-title="<%=String(n.title||'').toLowerCase()%>" data-pinned="<%=n.is_pinned?'pinned':'normal'%>"><td><%=n.id%></td><td><%=n.title%></td><td><span class="<%=n.is_pinned?'status-pin':'status-off'%>"><%=n.is_pinned?'● 상단고정':'● 일반공지'%></span></td><td><form method="post" action="/admin/delete/notices/<%=n.id%>"><button onclick="return confirm('삭제할까요?')">삭제</button></form></td></tr><%})%></table></section><section id="reviews" class="panel admin-panel"><h2>후기 관리</h2><div class="review-admin-filter"><input id="reviewSearch" placeholder="업체명/후기제목 검색"><select id="reviewRatingFilter"><option value="all">전체 평점</option><option value="5">5점</option><option value="4">4점</option><option value="low">3점 이하</option></select><select id="reviewSortFilter"><option value="default">기본순</option><option value="latest">최신작성순</option><option value="high">평점 높은순</option><option value="low">평점 낮은순</option></select><button type="button" id="reviewFilterReset">초기화</button></div><table><tr><th>ID</th><th>업체</th><th>제목</th><th>평점</th><th>삭제</th></tr><% reviews.forEach(r=>{%><tr class="review-row" data-id="<%=r.id%>" data-text="<%=String((r.vendor_name||'')+' '+(r.title||'')).toLowerCase()%>" data-rating="<%=r.rating%>"><td><%=r.id%></td><td><%=r.vendor_name%></td><td><%=r.title%></td><td>★ <%=r.rating%></td><td><form method="post" action="/admin/delete/reviews/<%=r.id%>"><button onclick="return confirm('삭제할까요?')">삭제</button></form></td></tr><%})%></table></section><section id="inquiries" class="panel admin-panel"><h2>광고문의 / 입점신청</h2><div class="integrated-tools"><div class="integrated-card"><b>전체 신청</b><strong><%=inquiries.length%></strong></div><div class="integrated-card"><b>대기</b><strong><%=inquiries.filter(x=>x.status!=="approved"&&x.status!=="rejected").length%></strong></div><div class="integrated-card"><b>승인</b><strong><%=inquiries.filter(x=>x.status==="approved").length%></strong></div><div class="integrated-card"><b>반려</b><strong><%=inquiries.filter(x=>x.status==="rejected").length%></strong></div></div><div class="admin-sub-filter inquiry-filterbar"><button type="button" class="on" data-filter="all">전체 <%=inquiries.length%></button><button type="button" data-filter="new">대기 <%=inquiries.filter(x=>x.status!=="approved"&&x.status!=="rejected").length%></button><button type="button" data-filter="approved">승인 <%=inquiries.filter(x=>x.status==="approved").length%></button><button type="button" data-filter="rejected">반려 <%=inquiries.filter(x=>x.status==="rejected").length%></button><button type="button" data-filter="apply">입점신청 <%=inquiries.filter(x=>x.type==="apply").length%></button><button type="button" data-filter="ad">광고문의 <%=inquiries.filter(x=>x.type!=="apply").length%></button></div><div class="admin-searchbar"><input id="inquirySearch" placeholder="업체명 / 담당자 / 연락처 / 지역 / 업종 검색"><select id="inquirySort"><option value="latest">신청일 최신순</option><option value="oldest">신청일 오래된순</option><option value="status">처리상태순</option><option value="type">구분순</option></select><button type="button" id="inquirySearchReset">초기화</button></div><table><tr><th>ID</th><th>구분</th><th>신청회원</th><th>업체명</th><th>담당자</th><th>연락처</th><th>지역/업종</th><th>내용</th><th>이미지</th><th>처리</th></tr><% inquiries.forEach(x=>{%><tr class="inquiry-row" data-id="<%=x.id%>" data-status="<%=x.status==='approved'?'approved':x.status==='rejected'?'rejected':'new'%>" data-type="<%=x.type==='apply'?'apply':'ad'%>" data-search="<%=String((x.company_name||'')+' '+(x.name||'')+' '+(x.phone||'')+' '+(x.kakao||'')+' '+(x.email||'')+' '+(x.region||'')+' '+(x.category||'')).toLowerCase()%>"><td><%=x.id%></td><td><%=x.type==='apply'?'입점신청':'광고문의'%></td><td><%=x.applicant_username?x.applicant_username:'비회원/미연결'%><br><small><%=x.applicant_nickname||''%></small></td><td><%=x.company_name%></td><td><%=x.name||'-'%></td><td><%=x.phone%><br><%=x.kakao||''%><br><%=x.email||''%></td><td><%=x.region||'-'%>/<%=x.category||'-'%></td><td class="memo"><%=x.content%></td><td class="image-links"><% const _inqHasPreview=(x.has_image_data||x.has_main_image_data||x.has_banner_image_data); const _inqPreviewUrl=_inqHasPreview?(`/admin/inquiry-image/${x.id}/main`):''; %><% if(_inqPreviewUrl){%><button type="button" class="image-preview-btn inquiry-image-preview" data-src="<%=_inqPreviewUrl%>" data-title="<%=x.company_name||'대표 이미지'%>">대표보기</button><%}else{%><span class="image-none">-</span><%}%></td><td><% if(x.status==='approved'){%><span class="done">업체 등록완료</span><%}else if(x.status==='rejected'){%><span class="rejected">반려</span><%}else{%><% if(x.type==='apply'){%><form method="post" action="/admin/inquiries/<%=x.id%>/approve"><button class="approve-btn" onclick="return confirm('이 신청내용으로 업체를 등록할까요?')">업체등록</button></form><%}%><form method="post" action="/admin/inquiries/<%=x.id%>/reject"><button class="reject-btn" onclick="return confirm('이 신청을 반려할까요?')">반려</button></form><%}%></td></tr><%})%></table></section><section id="reports" class="panel admin-panel"><% const reasonStats=Object.entries((flags||[]).reduce((m,x)=>{const k=x.reason||'기타';m[k]=(m[k]||0)+1;return m;},{})).sort((a,b)=>b[1]-a[1]); %><h2>업체 / 후기 신고내역</h2><div class="integrated-tools"><div class="integrated-card"><b>전체 신고</b><strong><%=flags.length%></strong></div><div class="integrated-card"><b>미처리</b><strong><%=flags.filter(x=>x.status!=='done').length%></strong></div><div class="integrated-card"><b>처리완료</b><strong><%=flags.filter(x=>x.status==='done').length%></strong></div><div class="integrated-card"><b>주요 사유</b><strong><%=reasonStats[0]?reasonStats[0][0]:'-'%></strong></div></div><div class="admin-sub-filter report-filterbar"><button type="button" class="on" data-filter="all">전체 <%=flags.length%></button><button type="button" data-filter="new">미처리 <%=flags.filter(x=>x.status!=='done').length%></button><button type="button" data-filter="done">처리완료 <%=flags.filter(x=>x.status==='done').length%></button><button type="button" data-filter="vendor">업체신고 <%=flags.filter(x=>x.type==='vendor').length%></button><button type="button" data-filter="review">후기신고 <%=flags.filter(x=>x.type==='review').length%></button></div><div class="admin-searchbar"><input id="reportSearch" placeholder="대상명 / 사유 / 신고내용 검색"><select id="reportSort"><option value="latest">신고일 최신순</option><option value="oldest">신고일 오래된순</option><option value="status">미처리 우선</option><option value="reason">신고사유순</option></select><button type="button" id="reportSearchReset">초기화</button></div><div class="integrated-tools"><% reasonStats.slice(0,8).forEach(([reason,count])=>{%><div class="integrated-card"><b><%=reason%></b><strong><%=count%></strong></div><%})%></div><table><tr><th>ID</th><th>구분</th><th>대상</th><th>사유</th><th>내용</th><th>상태</th><th>처리메모</th><th>처리일</th><th>처리</th></tr><% flags.forEach(x=>{ const target=x.vendor_name||x.review_title||x.target_id; %><tr class="report-row" data-id="<%=x.id%>" data-status="<%=x.status==='done'?'done':'new'%>" data-type="<%=x.type%>" data-reason="<%=String(x.reason||'')%>" data-search="<%=String((target||'')+' '+(x.reason||'')+' '+(x.content||'')).toLowerCase()%>"><td><%=x.id%></td><td><%=x.type==='vendor'?'업체':'후기'%></td><td><%=target%></td><td><%=x.reason%></td><td class="memo"><%=x.content||'-'%></td><td><span class="<%=x.status==='done'?'done':'pending'%>"><%=x.status==='done'?'처리완료':'미처리'%></span></td><td class="memo"><%=x.admin_memo||'-'%></td><td><%=x.processed_at?fmtDateTime(x.processed_at):'-'%></td><td><% if(x.status==='done'){%><span class="done">완료</span><%}else{%><form method="post" action="/admin/reports/<%=x.id%>/done" class="report-done-form"><input name="admin_memo" placeholder="처리 메모"><button class="banner-btn">처리완료</button></form><%}%></td></tr><%})%></table></section><section id="vendorRequests" class="panel admin-panel"><h2>업체 수정요청</h2><div class="integrated-tools"><div class="integrated-card"><b>전체 요청</b><strong><%=(vendorRequests||[]).length%></strong></div><div class="integrated-card"><b>대기</b><strong><%=(vendorRequests||[]).filter(x=>x.status==='new').length%></strong></div><div class="integrated-card"><b>승인</b><strong><%=(vendorRequests||[]).filter(x=>x.status==='approved').length%></strong></div><div class="integrated-card"><b>반려</b><strong><%=(vendorRequests||[]).filter(x=>x.status==='rejected').length%></strong></div></div><table><tr><th>ID</th><th>회원</th><th>현재업체</th><th>요청내용</th><th>상태</th><th>처리</th></tr><% (vendorRequests||[]).forEach(x=>{%><tr><td><%=x.id%></td><td><%=x.username%><br><small><%=x.nickname||''%></small></td><td><%=x.current_vendor_name||x.vendor_id%></td><td class="memo"><b><%=x.name%></b><br><%=x.region%>/<%=x.category%><br><%=x.phone||'-'%><br><%=x.business_hours||'-'%><br><%=x.description||'-'%></td><td><span class="<%=x.status==='approved'?'done':x.status==='rejected'?'rejected':'pending'%>"><%=x.status==='approved'?'승인':x.status==='rejected'?'반려':'대기'%></span><br><small><%=_cleanCenterMemo(x)%></small></td><td><% if(x.status==='new'){%><form method="post" action="/admin/vendor-requests/<%=x.id%>/approve" class="report-done-form"><input name="admin_memo" placeholder="처리 메모"><button class="approve-btn">승인</button></form><form method="post" action="/admin/vendor-requests/<%=x.id%>/reject" class="report-done-form" style="margin-top:8px"><input name="admin_memo" placeholder="반려 사유"><button class="reject-btn">반려</button></form><%}else{%>처리완료<%}%></td></tr><%})%></table></section><section id="bannerRequests" class="panel admin-panel"><h2>배너신청관리</h2>
<%
  const _bannerReqSafe=(typeof bannerRequests!=='undefined'&&Array.isArray(bannerRequests))?bannerRequests:[];
  const _bannerNew=_bannerReqSafe.filter(x=>x.status==='new').length;
  const _bannerUnpaid=_bannerReqSafe.filter(x=>x.status==='new'&&x.payment_status==='unpaid').length;
  const _bannerWaiting=_bannerReqSafe.filter(x=>x.status==='new'&&x.payment_status==='waiting').length;
  const _bannerApproved=_bannerReqSafe.filter(x=>x.status==='approved').length;
  const _bannerRejected=_bannerReqSafe.filter(x=>x.status==='rejected').length;
  const _bannerCancelled=_bannerReqSafe.filter(x=>x.status==='cancelled').length;
%>
<div class="request-summary">
  <div class="request-summary-card"><b>전체 신청</b><strong><%=_bannerReqSafe.length%></strong></div>
  <div class="request-summary-card waiting"><b>입금대기</b><strong><%=_bannerUnpaid%></strong></div>
  <div class="request-summary-card waiting"><b>입금확인중</b><strong><%=_bannerWaiting%></strong></div>
  <div class="request-summary-card approved"><b>승인완료</b><strong><%=_bannerApproved%></strong></div>
  <div class="request-summary-card rejected"><b>반려/취소</b><strong><%=_bannerRejected+_bannerCancelled%></strong></div>
</div>
<div class="integrated-tools"><div class="integrated-card"><b>전체 신청</b><strong><%=(bannerRequests||[]).length%></strong></div><div class="integrated-card"><b>대기</b><strong><%=(bannerRequests||[]).filter(x=>x.status==='new').length%></strong></div><div class="integrated-card"><b>승인</b><strong><%=(bannerRequests||[]).filter(x=>x.status==='approved').length%></strong></div><div class="integrated-card"><b>반려</b><strong><%=(bannerRequests||[]).filter(x=>x.status==='rejected').length%></strong></div></div><table><tr><th>ID</th><th>업체</th><th>제목</th><th>결제</th><th>링크</th><th>이미지</th><th>상태</th><th>처리</th></tr><% (bannerRequests||[]).forEach(x=>{%><tr><td><%=x.id%></td><td><%=x.vendor_name||x.vendor_id%><br><small><%=x.username||''%></small></td><td><b><%=x.title%></b><br><%=x.subtitle||''%></td><td><%=Number(x.krw_price||0).toLocaleString()%>원<br><%=x.usdt_amount||0%> USDT<br><% if(x.payment_expires_at){ %><small>기한: <%=fmtDateTime(x.payment_expires_at)%></small><br><% } %><small><%=_paymentRequestLabel(x)%></small><% if(x.status==='approved'||x.payment_status==='paid'||x.paid_usdt_amount||x.payment_txid){ %><span class="payment-trace">실제입금: <%=_centerPaidUsdt(x)||'미입력'%><% if(_centerPaidUsdt(x)){ %> USDT<% } %><em>TXID: <%=x.payment_txid||'미입력'%></em></span><% } %></td><td><%=x.link_url||'-'%></td><td><%=x.has_image_data?'이미지 있음':'-'%></td><td><span class="<%=x.status==='approved'?'done':(x.status==='rejected'||x.status==='cancelled')?'rejected':'pending'%>"><%=_paymentRequestStatusLabel(x)%></span><br><small><%=_cleanCenterMemo(x)%></small></td><td><% if(x.status==='new'){%><% if(x.payment_status==='waiting'){%><form method="post" action="/admin/banner-requests/<%=x.id%>/payment-confirm" class="payment-confirm-form"><input name="paid_usdt_amount" placeholder="실제 USDT" value="<%=x.usdt_amount||''%>"><input name="payment_txid" placeholder="TXID / 거래해시"><input name="admin_memo" placeholder="입금확인 메모"><button class="approve-btn">입금확인</button></form><%}else{%><span class="pending">입금대기</span><%}%><form method="post" action="/admin/banner-requests/<%=x.id%>/reject" class="report-done-form" style="margin-top:8px"><input name="admin_memo" placeholder="반려 사유"><button class="reject-btn">반려</button></form><form method="post" action="/admin/banner-requests/<%=x.id%>/cancel" class="report-done-form" style="margin-top:8px"><input name="admin_memo" placeholder="취소 메모"><button class="cancel-edit">취소</button></form><%}else{%>처리완료<%}%></td></tr><%})%></table></section>
<section id="adCenter" class="panel admin-panel">
<h2>광고센터</h2>
<%
  const _centerAds=(typeof adRequests!=='undefined'&&Array.isArray(adRequests)?adRequests:[]).map(x=>Object.assign({},x,{_kind:'ad',_kindLabel:'변경/연장',_product:x.plan||x.product_type||'-'}));
  const _centerBanners=(typeof bannerRequests!=='undefined'&&Array.isArray(bannerRequests)?bannerRequests:[]).map(x=>Object.assign({},x,{_kind:'banner',_kindLabel:'프리미엄배너',_product:'프리미엄배너 신청',_productSub:x.title||''}));
  const _centerAll=[..._centerAds,..._centerBanners].sort((a,b)=>(Number(b.id||0)-Number(a.id||0)));
  const _centerUnpaid=_centerAll.filter(x=>x.status==='new'&&(!x.payment_status||x.payment_status==='unpaid')).length;
  const _centerWaiting=_centerAll.filter(x=>x.status==='new'&&x.payment_status==='waiting').length;
  const _centerApproved=_centerAll.filter(x=>x.status==='approved').length;
  const _centerRejected=_centerAll.filter(x=>x.status==='rejected').length;
  const _centerCancelled=_centerAll.filter(x=>x.status==='cancelled').length;
  const _centerStatus=x=>x.status==='approved'?'approved':x.status==='rejected'?'rejected':x.status==='cancelled'?'cancelled':x.payment_status==='waiting'?'waiting':'unpaid';
%>

<div class="ad-center-summary">
  <div class="ad-center-card"><b>전체 신청</b><strong><%=_centerAll.length%></strong></div>
  <div class="ad-center-card waiting"><b>입금대기</b><strong><%=_centerUnpaid%></strong></div>
  <div class="ad-center-card waiting"><b>입금확인중</b><strong><%=_centerWaiting%></strong></div>
  <div class="ad-center-card done"><b>승인완료</b><strong><%=_centerApproved%></strong></div>
  <div class="ad-center-card bad"><b>반려/취소</b><strong><%=_centerRejected+_centerCancelled%></strong></div>
</div>

<div class="ad-center-filter">
  <button type="button" class="on" data-ad-center-filter="all">전체</button>
  <button type="button" data-ad-center-filter="unpaid">입금대기</button>
  <button type="button" data-ad-center-filter="waiting">입금확인중</button>
  <button type="button" data-ad-center-filter="approved">승인완료</button>
  <button type="button" data-ad-center-filter="rejected">반려</button>
  <button type="button" data-ad-center-filter="cancelled">취소</button>
</div>

<div class="table-wrap">
<table>
<tr>
  <th>ID</th>
  <th>구분</th>
  <th>업체</th>
  <th>상품</th>
  <th>결제</th>
  <th>상태</th>
  <th>처리</th>
</tr>
<% _centerAll.forEach(x=>{ const st=_centerStatus(x); %>
<tr class="ad-center-row" data-status="<%=st%>">
  <td><%=x.id%></td>
  <td>
    <% if(x._kind==='banner'){%>
      <span class="ad-kind-badge ad-kind-banner">프리미엄배너</span>
    <%}else{%>
      <span class="ad-kind-badge ad-kind-plan">변경/연장</span>
    <%}%>
  </td>
  <td><%=x.vendor_name||x.vendor_id||'-'%><br><small><%=x.username||''%></small></td>
  <td><b><%=x._product%></b><br><small><%=x._kind==='banner'?(x._productSub?'배너명: '+x._productSub:''):(x.period?x.period+'일':'')%></small></td>
  <td>
    <%=Number(x.krw_price||0).toLocaleString()%>원<br>
    <%=x.usdt_amount||0%> USDT<br>
    <% if(x.payment_expires_at){ %><small>기한: <%=fmtDateTime(x.payment_expires_at)%></small><br><% } %>
    <small><%=_paymentRequestLabel(x)%></small><% if(x.status==='approved'||x.payment_status==='paid'||x.paid_usdt_amount||x.payment_txid){ %><span class="payment-trace">실제입금: <%=_centerPaidUsdt(x)||'미입력'%><% if(_centerPaidUsdt(x)){ %> USDT<% } %><em>TXID: <%=x.payment_txid||'미입력'%></em></span><% } %>
  </td>
  <td>
    <span class="<%=x.status==='approved'?'done':x.status==='rejected'?'rejected':x.status==='cancelled'?'rejected':'pending'%>">
      <%=_paymentRequestStatusLabel(x)%>
    </span>
    <br><small><%=_cleanCenterMemo(x)%></small>
  </td>
  <td>
    <% if(x.status==='new'){%>
      <% if(x.payment_status==='waiting'){%>
        <form method="post" action="/admin/<%=x._kind==='banner'?'banner-requests':'ad-requests'%>/<%=x.id%>/payment-confirm" class="payment-confirm-form">
          <input name="paid_usdt_amount" placeholder="실제 USDT" value="<%=x.usdt_amount||''%>">
          <input name="payment_txid" placeholder="TXID / 거래해시">
          <input name="admin_memo" placeholder="입금확인 메모">
          <button class="approve-btn">입금확인</button>
        </form>
      <%}else{%>
        <span class="pending">입금대기</span>
      <%}%>
      <form method="post" action="/admin/<%=x._kind==='banner'?'banner-requests':'ad-requests'%>/<%=x.id%>/reject" class="report-done-form" style="margin-top:8px">
        <input name="admin_memo" placeholder="반려 사유">
        <button class="reject-btn">반려</button>
      </form>
      <form method="post" action="/admin/<%=x._kind==='banner'?'banner-requests':'ad-requests'%>/<%=x.id%>/cancel" class="report-done-form" style="margin-top:8px">
        <input name="admin_memo" placeholder="취소 메모">
        <button class="cancel-edit">취소</button>
      </form>
    <%}else{%>
      처리완료
    <%}%>
  </td>
</tr>
<%})%>
<% if(!_centerAll.length){%>
<tr><td colspan="7">광고 신청내역이 없습니다.</td></tr>
<%}%>
</table>
</div>
</section>
<section id="adRequests" class="panel admin-panel"><h2>광고연장관리</h2>
<%
  const _adReqSafe=(typeof adRequests!=='undefined'&&Array.isArray(adRequests))?adRequests:[];
  const _adNew=_adReqSafe.filter(x=>x.status==='new').length;
  const _adUnpaid=_adReqSafe.filter(x=>x.status==='new'&&x.payment_status==='unpaid').length;
  const _adWaiting=_adReqSafe.filter(x=>x.status==='new'&&x.payment_status==='waiting').length;
  const _adApproved=_adReqSafe.filter(x=>x.status==='approved').length;
  const _adRejected=_adReqSafe.filter(x=>x.status==='rejected').length;
  const _adCancelled=_adReqSafe.filter(x=>x.status==='cancelled').length;
%>
<div class="request-summary">
  <div class="request-summary-card"><b>전체 신청</b><strong><%=_adReqSafe.length%></strong></div>
  <div class="request-summary-card waiting"><b>입금대기</b><strong><%=_adUnpaid%></strong></div>
  <div class="request-summary-card waiting"><b>입금확인중</b><strong><%=_adWaiting%></strong></div>
  <div class="request-summary-card approved"><b>승인완료</b><strong><%=_adApproved%></strong></div>
  <div class="request-summary-card rejected"><b>반려/취소</b><strong><%=_adRejected+_adCancelled%></strong></div>
</div>
<div class="integrated-tools"><div class="integrated-card"><b>전체 신청</b><strong><%=(adRequests||[]).length%></strong></div><div class="integrated-card"><b>대기</b><strong><%=(adRequests||[]).filter(x=>x.status==='new').length%></strong></div><div class="integrated-card"><b>승인</b><strong><%=(adRequests||[]).filter(x=>x.status==='approved').length%></strong></div><div class="integrated-card"><b>반려</b><strong><%=(adRequests||[]).filter(x=>x.status==='rejected').length%></strong></div></div><table><tr><th>ID</th><th>업체</th><th>상품</th><th>상품구분</th><th>기간</th><th>결제</th><th>내용</th><th>상태</th><th>처리</th></tr><% (adRequests||[]).forEach(x=>{%><tr><td><%=x.id%></td><td><%=x.vendor_name||x.vendor_id%><br><small><%=x.username||''%></small></td><td><%=x.plan||'-'%></td><td><%=x.product_type==="recommended_upgrade"?"일반→추천":x.product_type==="banner_from_general"?"일반→배너":x.product_type==="banner_from_recommended"?"추천→배너":x.product_type==="renewal_general"?"일반연장":x.product_type==="renewal_recommended"?"추천연장":x.product_type==="renewal_banner"?"배너신청/연장":x.product_type==="schedule_to_general"?"일반변경/연장":x.product_type==="schedule_remove_banner"?"배너제거예약":x.product_type==="schedule_to_recommended"?"추천변경/연장":x.product_type||"추천등록"%></td><td><%=x.period||'-'%>일</td><td><%=Number(x.krw_price||0).toLocaleString()%>원<br><%=x.usdt_amount||0%> USDT<br><% if(x.payment_expires_at){ %><small>기한: <%=fmtDateTime(x.payment_expires_at)%></small><br><% } %><small><%=_paymentRequestLabel(x)%></small><% if(x.status==='approved'||x.payment_status==='paid'||x.paid_usdt_amount||x.payment_txid){ %><span class="payment-trace">실제입금: <%=_centerPaidUsdt(x)||'미입력'%><% if(_centerPaidUsdt(x)){ %> USDT<% } %><em>TXID: <%=x.payment_txid||'미입력'%></em></span><% } %></td><td class="memo"><%=x.content||'-'%></td><td><span class="<%=x.status==='approved'?'done':(x.status==='rejected'||x.status==='cancelled')?'rejected':'pending'%>"><%=_paymentRequestStatusLabel(x)%></span><br><small><%=_cleanCenterMemo(x)%></small></td><td><% if(x.status==='new'){%><% if(x.payment_status==='waiting'){%><form method="post" action="/admin/ad-requests/<%=x.id%>/payment-confirm" class="payment-confirm-form"><input name="paid_usdt_amount" placeholder="실제 USDT" value="<%=x.usdt_amount||''%>"><input name="payment_txid" placeholder="TXID / 거래해시"><input name="admin_memo" placeholder="입금확인 메모"><button class="approve-btn">입금확인</button></form><%}else{%><span class="pending">입금대기</span><%}%><form method="post" action="/admin/ad-requests/<%=x.id%>/reject" class="report-done-form" style="margin-top:8px"><input name="admin_memo" placeholder="반려 사유"><button class="reject-btn">반려</button></form><form method="post" action="/admin/ad-requests/<%=x.id%>/cancel" class="report-done-form" style="margin-top:8px"><input name="admin_memo" placeholder="취소 메모"><button class="cancel-edit">취소</button></form><%}else{%>처리완료<%}%></td></tr><%})%></table></section><section id="revenue" class="panel admin-panel">
  <h2>매출관리</h2>
<%
  const _paymentSafe=(typeof paymentLogs!=='undefined'&&Array.isArray(paymentLogs))?paymentLogs:((typeof payments!=='undefined'&&Array.isArray(payments))?payments:[]);
  const _revStats=(typeof revenueStats!=='undefined'&&revenueStats)?revenueStats:{};
  const _todayRevenue=Number(_revStats.today||0);
  const _monthRevenue=Number(_revStats.month||0);
  const _totalRevenue=Number(_revStats.total||0);
  const _paymentCount=Number(_revStats.count||_paymentSafe.length||0);
  const _usdtTotal=Number(_revStats.usdtTotal||0);
%>
<div class="revenue-summary">
  <div class="revenue-card hot"><b>오늘 매출</b><strong><%=_todayRevenue.toLocaleString()%>원</strong></div>
  <div class="revenue-card month"><b>이번달 매출</b><strong><%=_monthRevenue.toLocaleString()%>원</strong></div>
  <div class="revenue-card total"><b>누적 매출</b><strong><%=_totalRevenue.toLocaleString()%>원</strong></div>
  <div class="revenue-card"><b>결제 건수</b><strong><%=_paymentCount%>건</strong></div>
  <div class="revenue-card"><b>USDT 합계</b><strong><%=_usdtTotal.toFixed(2)%></strong></div>
</div>

<%
  const _paymentProductLabel=p=>p.product_type==='banner'?'프리미엄배너':p.product_type==='recommended'?'추천광고':p.product_type==='general'?'일반광고':p.product_type||'-';
  const _paymentStatusLabel=s=>s==='paid'?'결제완료':s==='waiting'?'입금확인중':s==='rejected'?'반려':s==='cancelled'?'취소':s||'-';
  const _paymentPaidUsdt=p=>p.paid_usdt_amount||((String(p.memo||'').match(/실제입금:\s*([0-9.]+)/)||[])[1]||'');
  const _paymentCleanMemo=p=>String(p.memo||'').replace(/\s*실제입금:\s*[0-9.]+\s*USDT\s*/g,'').trim()||'-';
%>
  <table>
    <tr><th>ID</th><th>업체</th><th>회원</th><th>상품</th><th>원화</th><th>요청 USDT</th><th>실제입금</th><th>TXID</th><th>상태</th><th>결제일</th><th>메모</th></tr>
    <% (paymentLogs||[]).forEach(p=>{%>
      <tr>
        <td><%=p.id%></td>
        <td><%=p.vendor_name||p.vendor_id%></td>
        <td><%=p.username||p.user_id||'-'%></td>
        <td><%=_paymentProductLabel(p)%></td>
        <td><%=Number(p.krw_price||0).toLocaleString()%>원</td>
        <td><%=p.usdt_amount||0%> USDT</td>
        <td><% if(_paymentPaidUsdt(p)){ %><b class="done"><%=_paymentPaidUsdt(p)%> USDT</b><% } else { %><span class="payment-muted">미입력</span><% } %></td>
        <td class="payment-txid"><%=p.payment_txid||'미입력'%></td>
        <td><span class="payment-status-label"><%=_paymentStatusLabel(p.status||'paid')%></span></td>
        <td><%=p.paid_at?fmtDateTime(p.paid_at):'-'%></td>
        <td class="memo"><%=_paymentCleanMemo(p)%></td>
      </tr>
    <%})%>
  </table>
</section><section id="adminLogs" class="panel admin-panel"><h2>관리자 로그</h2><div class="integrated-tools"><div class="integrated-card"><b>전체 로그</b><strong><%=(adminLogs||[]).length%></strong></div><div class="integrated-card"><b>최근 작업자</b><strong><%=(adminLogs&&adminLogs[0])?adminLogs[0].admin_username:'-'%></strong></div><div class="integrated-card"><b>최근 작업</b><strong><%=(adminLogs&&adminLogs[0])?adminLogs[0].action:'-'%></strong></div><div class="integrated-card"><b>표시 범위</b><strong>200</strong></div></div><table><tr><th>ID</th><th>관리자</th><th>작업</th><th>대상</th><th>메모</th><th>시간</th></tr><% (adminLogs||[]).forEach(x=>{%><tr><td><%=x.id%></td><td><%=x.admin_username||'-'%></td><td><b><%=x.action%></b></td><td><%=x.target_type%> #<%=x.target_id%></td><td class="memo"><%=x.memo||'-'%></td><td><%=x.created_at?fmtDateTime(x.created_at):'-'%></td></tr><%})%></table></section><section id="settings" class="panel admin-panel">
  <h2>환경설정</h2>

  <div class="settings-tabs">
    <button type="button" class="settings-tab active" data-settings-tab="basic">기본설정</button>
    <button type="button" class="settings-tab" data-settings-tab="payment">결제설정</button>
    <button type="button" class="settings-tab" data-settings-tab="admin">관리자설정</button>
  </div>

  <div id="settings-basic" class="settings-panel active">
    <form method="post" action="/admin/settings/options" enctype="multipart/form-data" class="settings-form">
      <input type="hidden" name="settings_section" value="basic">

      <div class="settings-box brand-settings-box" style="margin-bottom:18px">
        <h3 class="settings-section-title">사이트 브랜딩</h3>

        <div class="brand-config-section">
          <h4>기본 정보 / 이미지 등록</h4>
          <div class="brand-form-grid">
            <label for="siteNameInput">사이트명</label>
            <input id="siteNameInput" name="site_name" value="<%=(settings?.raw?.site_name)||'서비스 디렉터리'%>" placeholder="사이트명">

            <label for="siteLinkInput">링크 주소</label>
            <input id="siteLinkInput" name="site_link_url" value="<%=(settings?.raw?.site_link_url)||'/'%>" placeholder="/">

            <label>로고 이미지</label>
            <div class="brand-upload-row">
              <input type="file" name="site_logo" accept="image/*">
              <% if(settings?.raw?.site_logo_data){%><label class="brand-remove-check"><input type="checkbox" name="remove_site_logo"> 현재 로고 삭제</label><%}%>
            </div>

            <label>파비콘 이미지</label>
            <div class="brand-upload-row">
              <input type="file" name="site_favicon" accept="image/*">
              <% if(settings?.raw?.site_favicon_data){%><label class="brand-remove-check"><input type="checkbox" name="remove_site_favicon"> 현재 파비콘 삭제</label><%}%>
            </div>
          </div>

          <div class="brand-preview-grid">
            <div class="brand-preview-card">
              <b>현재 로고</b>
              <% if(settings?.raw?.site_logo_data){%>
                <img class="brand-logo-preview" src="<%=settings.raw.site_logo_data%>" alt="현재 로고">
              <%}else{%>
                <span class="brand-empty-preview">등록된 로고 없음</span>
              <%}%>
            </div>
            <div class="brand-preview-card">
              <b>현재 파비콘</b>
              <% if(settings?.raw?.site_favicon_data){%>
                <img class="brand-favicon-preview" src="<%=settings.raw.site_favicon_data%>" alt="현재 파비콘">
              <%}else{%>
                <span class="brand-empty-preview">기본 아이콘 사용중</span>
              <%}%>
            </div>
          </div>
        </div>

        <div class="brand-config-section brand-display-section">
          <h4>표시 설정</h4>
          <div class="brand-display-options">
            <label><input type="checkbox" name="brand_show_logo" <%=settings?.raw?.brand_show_logo==='on'?'checked':''%>> 로고 사용</label>
            <label><input type="checkbox" name="brand_show_name" <%=settings?.raw?.brand_show_name==='off'?'':'checked'%>> 사이트명 사용</label>
          </div>
          <p class="settings-help">로고와 사이트명은 각각 선택해서 상단 중앙에 표시됩니다. 둘 다 꺼도 기본 사이트명은 관리자 설정값으로 유지됩니다.</p>
        </div>
      </div>
      <div class="settings-split">
        <div class="settings-box">
          <h3 class="settings-section-title">업종 관리</h3>
          <textarea name="categories" placeholder="한 줄에 하나씩 입력"><%=(settings?.raw?.categories)||''%></textarea>
          <p class="settings-help">예: 안마, 마사지, 카페처럼 한 줄에 하나씩 입력합니다.</p>
        </div>

        <div class="settings-box">
          <h3 class="settings-section-title">지역 관리</h3>
          <textarea name="regions" placeholder="한 줄에 하나씩 입력"><%=(settings?.raw?.regions)||''%></textarea>
          <p class="settings-help">메인페이지 업종/지역 선택과 검색창에 바로 반영됩니다.</p>
        </div>
      </div>

      <button style="margin-top:16px">기본설정 저장</button>
    </form>
  </div>

  <div id="settings-payment" class="settings-panel">
    <form method="post" action="/admin/settings/options" class="settings-form">
      <input type="hidden" name="settings_section" value="payment">

      <div class="settings-box">
        <h3 class="settings-section-title">USDT 결제 설정</h3>
        <style>
          .usdt-rate-status{display:grid;grid-template-columns:1.2fr 1fr 1fr auto;gap:10px;margin:0 0 16px;padding:14px;border:1px solid #10d9ff;border-radius:16px;background:linear-gradient(135deg,rgba(16,217,255,.12),rgba(255,63,180,.05))}
          .usdt-rate-status div{border:1px solid #29324f;border-radius:12px;background:#070b15;padding:12px;min-height:62px}
          .usdt-rate-status b{display:block;color:#8d98b8;font-size:12px;margin-bottom:6px}
          .usdt-rate-status strong{display:block;color:#10d9ff;font-size:22px;line-height:1.15}
          .usdt-rate-status small{display:block;color:#c8d0e8;line-height:1.35}
          .usdt-rate-status button{height:100%!important;min-height:62px!important;border-radius:12px!important;background:#222b43!important}
          @media(max-width:1000px){.usdt-rate-status{grid-template-columns:1fr 1fr}.usdt-rate-status button{height:44px!important;min-height:44px!important}}
          @media(max-width:650px){.usdt-rate-status{grid-template-columns:1fr}}
        </style>
        <div class="usdt-rate-status">
          <div>
            <b>현재 적용 환율</b>
            <strong>1 USDT = <%=Number((settings?.raw?.usdt_rate_effective_value)||(settings?.raw?.usdt_krw_rate)||1400).toLocaleString()%>원</strong>
          </div>
          <div>
            <b>환율 출처</b>
            <small><%=(settings?.raw?.usdt_rate_effective_source)||'manual'%></small>
          </div>
          <div>
            <b>마지막 갱신</b>
            <small><%=(settings?.raw?.usdt_rate_effective_updated_at)||'-'%></small>
            <% if(settings?.raw?.usdt_rate_effective_error){ %><small style="color:#ffdc4d">오류: <%=settings.raw.usdt_rate_effective_error%></small><% } %>
          </div>
          <button type="button" onclick="if(confirm('USDT 환율을 지금 갱신할까요?')){const f=document.createElement('form');f.method='post';f.action='/admin/settings/usdt-rate-refresh';document.body.appendChild(f);f.submit();}">지금 환율 갱신</button>
        </div>
        <div class="settings-pay-grid">
          <label>USDT 입금주소</label>
          <input name="usdt_address" value="<%=(settings?.raw?.usdt_address)||''%>" placeholder="USDT 입금주소">

          <label>USDT 네트워크</label>
          <select name="usdt_network">
            <option value="TRC20" <%=settings?.raw?.usdt_network==='TRC20'?'selected':''%>>TRC20</option>
            <option value="ERC20" <%=settings?.raw?.usdt_network==='ERC20'?'selected':''%>>ERC20</option>
            <option value="BEP20" <%=settings?.raw?.usdt_network==='BEP20'?'selected':''%>>BEP20</option>
          </select>

          <label>자동 환율 사용</label>
          <label style="justify-content:flex-start"><input type="checkbox" name="usdt_rate_auto" <%=settings?.raw?.usdt_rate_auto==='off'?'':'checked'%>> 자동으로 최신 USDT/KRW 적용</label>

          <label>환율 출처</label>
          <select name="usdt_rate_source">
            <option value="auto" <%=(!settings?.raw?.usdt_rate_source||settings.raw.usdt_rate_source==='auto')?'selected':''%>>자동 선택</option>
            <option value="upbit" <%=settings?.raw?.usdt_rate_source==='upbit'?'selected':''%>>업비트</option>
            <option value="bithumb" <%=settings?.raw?.usdt_rate_source==='bithumb'?'selected':''%>>빗썸</option>
          </select>

          <label>보정률</label>
          <input name="usdt_rate_margin_percent" type="number" step="0.1" min="-10" max="10" value="<%=(settings?.raw?.usdt_rate_margin_percent)||0%>" placeholder="예: 1">

          <label>수동 기준값</label>
          <input name="usdt_krw_rate" type="number" value="<%=(settings?.raw?.usdt_krw_manual_rate)||(settings?.raw?.usdt_krw_rate)||1400%>" placeholder="자동 실패 시 사용할 값">

