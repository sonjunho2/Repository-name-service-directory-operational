<script>
/* 공통 유틸(admin 전역 공용): esc, toast, num, money, makeButton
   각 관리자 패널(회원/업체/입점/결제·신고 등) 모듈에서 중복 정의되던 함수를 여기 하나로 통합합니다.
   아래 패널별 모듈들은 이 스크립트 다음에 로드되며, 자체 정의를 제거하고 이 전역 함수를 그대로 사용합니다. */
function esc(v){
  return String(v==null?'':v).replace(/[&<>"']/g,function(c){
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
  });
}
function toast(message,type,detail){
  var wrap=document.querySelector('.admin-toast-wrap');
  if(!wrap){
    wrap=document.createElement('div');
    wrap.className='admin-toast-wrap';
    document.body.appendChild(wrap);
  }
  var el=document.createElement('div');
  el.className='admin-toast '+(type||'ok');
  el.innerHTML=String(message||'처리되었습니다.')+(detail?'<small>'+String(detail)+'</small>':'');
  wrap.appendChild(el);
  setTimeout(function(){el.style.opacity='0';el.style.transform='translateY(-8px)';},2600);
  setTimeout(function(){el.remove();},3100);
}
function num(n){return Number(n||0).toLocaleString();}
function money(n){return Number(n||0).toLocaleString()+'원';}
function makeButton(label,disabled,active,onClick){
  var b=document.createElement('button');
  b.type='button';
  b.textContent=label;
  if(disabled)b.disabled=true;
  if(active)b.classList.add('active');
  b.onclick=onClick;
  return b;
}
</script>
<script>
(function(){
  if(window.__adminAdInquiriesV1)return;window.__adminAdInquiriesV1=true;
  var busy=false,timer=null,limit=20,restored=false;
  function esc(v){return String(v??'').replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});}
  function date(v){if(!v)return '-';var d=new Date(v);return Number.isNaN(d.getTime())?'-':d.toLocaleString('ko-KR',{timeZone:'Asia/Seoul',year:'numeric',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit'});}
  function row(x){var url='/boards/ad-inquiry/'+Number(x.id||0),answered=x.answer_status==='answered',author=esc(x.nickname||x.username||'탈퇴회원'),comments=Number(x.comment_count||0).toLocaleString('ko-KR'),views=Number(x.views||0).toLocaleString('ko-KR');return '<tr class="ad-inquiry-row"><td><span class="ad-inquiry-id">#'+Number(x.id||0)+'</span><span class="ad-inquiry-date">'+date(x.created_at)+'</span></td><td><span class="admin-board-title" title="'+esc(x.title)+'">'+esc(x.title)+'</span><span class="ad-inquiry-author">작성자: '+author+'</span></td><td><span class="ad-inquiry-status '+(answered?'answered':'waiting')+'">'+(answered?'답변완료':'답변대기')+'</span></td><td><div class="ad-inquiry-activity"><span><b>댓글</b>'+comments+'</span><span><b>조회</b>'+views+'</span></div></td><td><div class="admin-board-actions"><a href="'+url+'" target="_blank" rel="noopener">문의 확인/답변</a></div></td></tr>';}
  function pager(data){var el=document.getElementById('adInquiryAdminPager');if(!el)return;var page=Math.max(1,Number(data.page||1)),pages=Math.max(1,Number(data.totalPages||1)),start=Math.max(1,page-2),end=Math.min(pages,page+2);function btn(label,target,disabled,active){return '<button type="button" class="admin-page-btn'+(active?' active':'')+'"'+(disabled?' disabled':' data-ad-inquiry-page="'+target+'"')+'>'+label+'</button>';}var html=btn('처음',1,page===1,false)+btn('이전',page-1,page===1,false);for(var n=start;n<=end;n++)html+=btn(String(n),n,false,n===page);html+=btn('다음',page+1,page===pages,false)+btn('마지막',pages,page===pages,false);el.innerHTML='<span class="admin-page-info">전체 '+Number(data.total||0)+'건 · '+page+'/'+pages+'페이지</span><div class="admin-page-buttons">'+html+'</div>';}
  window.loadAdminAdInquiries=async function(page){var body=document.getElementById('adInquiryAdminRows');if(!body||busy)return false;if(!restored){window.restoreAdminListControls?.('adInquiries');restored=true;}page=Math.max(1,Number(page||window.getAdminListState?.('adInquiries').page||1));busy=true;body.innerHTML='<tr><td colspan="5">광고문의를 불러오는 중입니다.</td></tr>';var q=(document.getElementById('adInquirySearch')?.value||'').trim(),status=document.getElementById('adInquiryStatus')?.value||'all',params=new URLSearchParams({page:String(page),limit:String(limit),status:status});if(q)params.set('q',q);window.setAdminListState?.('adInquiries',{page:page,q:q,status:status});try{var res=await fetch('/admin/api/ad-inquiries?'+params.toString(),{credentials:'same-origin',cache:'no-store',headers:{Accept:'application/json'}}),data=await res.json();if(!res.ok||!data.ok)throw new Error(data.error||'load_failed');if(page>Math.max(1,Number(data.totalPages||1))){busy=false;return window.loadAdminAdInquiries(Math.max(1,Number(data.totalPages||1)));}body.innerHTML=(data.rows||[]).map(row).join('')||'<tr><td colspan="5">조건에 맞는 광고문의가 없습니다.</td></tr>';var s=data.summary||{};document.getElementById('adInquiryTotal').textContent=Number(s.total||0);document.getElementById('adInquiryWaiting').textContent=Number(s.waiting||0);document.getElementById('adInquiryAnswered').textContent=Number(s.answered||0);pager(data);return true;}catch(e){body.innerHTML='<tr><td colspan="5">광고문의를 불러오지 못했습니다.</td></tr>';return false;}finally{busy=false;}};
  window.restoreAdminListControls?.('adInquiries');
  document.getElementById('adInquirySearch')?.addEventListener('input',function(){clearTimeout(timer);timer=setTimeout(function(){window.loadAdminAdInquiries(1);},300);});
  document.getElementById('adInquiryStatus')?.addEventListener('change',function(){window.loadAdminAdInquiries(1);});
  document.getElementById('adInquiryFilterReset')?.addEventListener('click',function(){clearTimeout(timer);document.getElementById('adInquirySearch').value='';document.getElementById('adInquiryStatus').value='all';window.loadAdminAdInquiries(1);});
  document.addEventListener('click',function(e){var b=e.target.closest('[data-ad-inquiry-page]');if(b)window.loadAdminAdInquiries(Number(b.dataset.adInquiryPage||1));});
})();
</script>

<script>
(function(){
  const modal=document.getElementById('vendorModal');
  const openBtn=document.getElementById('openVendorCreateModal');
  const closeBtn=document.getElementById('closeVendorModal');
  const cancelBtn=document.getElementById('cancelVendorEdit');
  const form=document.getElementById('vendorForm');
  const title=document.getElementById('vendorModalTitle');
  const submit=document.getElementById('vendorSubmitBtn');

  if(!modal||!form)return;

  function openModal(mode){
    if(title) title.textContent = mode==='edit' ? '업체 수정' : '업체 등록';
    if(submit) submit.textContent = mode==='edit' ? '업체 수정 저장' : '업체 등록';
    if(modal.parentElement!==document.body) document.body.appendChild(modal);
    modal.style.display='';
    modal.removeAttribute('aria-hidden');
    modal.classList.add('active');
    document.body.style.overflow='hidden';
  }

  window.forceCloseVendorModal=function(){
    var target=document.getElementById('vendorModal');
    try{
      if(document.activeElement&&target&&target.contains(document.activeElement))document.activeElement.blur();
    }catch(e){}
    if(target){
      target.classList.remove('active','open','show','visible');
      target.style.display='none';
      target.setAttribute('aria-hidden','true');
    }
    document.body.classList.remove('modal-open','vendor-modal-open');
    document.body.style.overflow='';
    var vendorForm=document.getElementById('vendorForm');
    if(vendorForm){vendorForm.reset();var id=vendorForm.querySelector('[name="id"]');if(id)id.value='';}
    var modalTitle=document.getElementById('vendorModalTitle');
    if(modalTitle)modalTitle.textContent='업체 등록';
    var submitButton=document.getElementById('vendorSubmitBtn');
    if(submitButton){submitButton.disabled=false;submitButton.classList.remove('ajax-loading');submitButton.textContent='업체 등록';}
    var cancelButton=document.getElementById('cancelVendorEdit');
    if(cancelButton)cancelButton.style.display='none';
    var preview=document.getElementById('vendorImagePreview');
    if(preview){preview.classList.remove('active','has-image','show');preview.style.display='';var image=preview.querySelector('img');if(image)image.removeAttribute('src');}
  };

  if(openBtn){
    openBtn.addEventListener('click',()=>{
      form.reset();
      const idInput=form.querySelector('input[name="id"]');
      if(idInput) idInput.value='';
      const preview=document.getElementById('vendorImagePreview');
      if(preview) preview.style.display='none';
      if(cancelBtn) cancelBtn.style.display='none';
      openModal('create');
    });
  }

  if(closeBtn) closeBtn.addEventListener('click',window.forceCloseVendorModal);
  if(cancelBtn) cancelBtn.addEventListener('click',window.forceCloseVendorModal);
  modal.addEventListener('click',e=>{
    if(e.target===modal) window.forceCloseVendorModal();
  });

  if(!window.__vendorFormDirectSubmitBound){
    window.__vendorFormDirectSubmitBound=true;
    form.addEventListener('submit',async function(e){
      e.preventDefault();
      e.stopPropagation();
      if(e.stopImmediatePropagation)e.stopImmediatePropagation();
      if(form.dataset.vendorSubmitting==='1')return;
      form.dataset.vendorSubmitting='1';
      var oldText=submit?submit.textContent:'';
      if(submit){submit.disabled=true;submit.classList.add('ajax-loading');submit.textContent='저장중...';}
      var success=false;
      try{
        var banner=form.elements.banner_active;
        var adType=form.elements.ad_type;
        if(banner&&banner.checked&&adType)adType.value='recommended';
        var res=await fetch('/admin/vendor',{
          method:'POST',body:new FormData(form),credentials:'same-origin',
          headers:{'X-Requested-With':'fetch','Accept':'application/json'}
        });
        var data=await res.json();
        if(!res.ok||!data||data.ok===false)throw new Error((data&&data.error)||('HTTP '+res.status));
        success=true;
        if(typeof toast==='function')toast('업체 정보가 저장되었습니다.','ok');
        window.forceCloseVendorModal();
        var state=window.getAdminListState?window.getAdminListState('vendors'):{};
        var page=Number(state.page||1)||1;
        if(window.saveActiveAdminListState)window.saveActiveAdminListState('vendors',page);
        if(window.setAdminListState)window.setAdminListState('vendors',{page:page});
        var refreshed=false;
        if(typeof window.loadAdminVendors==='function'){
          try{var ok=await window.loadAdminVendors(page);refreshed=ok!==false;}catch(_e){}
        }
        if(!refreshed&&typeof window.reloadAdminPanelList==='function'){
          try{var ok2=await window.reloadAdminPanelList('vendors');refreshed=ok2!==false;}catch(_e){}
        }
        if(!refreshed){
          try{sessionStorage.setItem('adminReturnPanel','vendors');}catch(_e){}
          location.href='/admin#vendors';
          location.reload();
        }
      }catch(err){
        if(typeof toast==='function')toast('업체 정보를 저장하지 못했습니다.','bad',err&&err.message?err.message:'잠시 후 다시 시도해주세요.');
        else alert(err&&err.message?err.message:'업체 정보를 저장하지 못했습니다.');
      }finally{
        form.dataset.vendorSubmitting='0';
        if(!success&&submit){submit.disabled=false;submit.classList.remove('ajax-loading');submit.textContent=oldText||'업체 수정 저장';}
      }
    });
  }
})();
</script>
