ocked">차단우선</option></select><button id="userFilterReset" type="button">초기화</button></div><div class="table-wrap"><table><tr><th>ID</th><th>역할</th><th>아이디</th><th>닉네임</th><th>이메일</th><th>연결업체</th><th>상태</th><th>가입일</th><th>관리</th></tr><% users.forEach(u=>{ const role=u.role==='admin'?'admin':u.is_vendor||u.vendor_id?'vendor':'user'; const status=u.status||'active'; %><tr class="user-row" data-id="<%=u.id%>" data-role="<%=role%>" data-status="<%=status%>" data-text="<%=String((u.username||'')+' '+(u.nickname||'')+' '+(u.email||'')).toLowerCase()%>"><td><%=u.id%></td><td><span class="role-badge role-<%=role%>"><%=role==='admin'?'관리자':role==='vendor'?'업체회원':'일반회원'%></span></td><td><b><%=u.username%></b></td><td><%=u.nickname||'-'%></td><td><%=u.email||'-'%></td><td><%=u.vendor_name?'<span class="vendor-member-badge">'+u.vendor_name+'</span>':'-'%></td><td><span class="<%=status==='active'?'status-on':'status-off'%>"><%=status==='active'?'정상':status==='blocked'?'차단':status==='suspended'?'일시정지':'비활성'%></span></td><td><%=u.created_at?fmtDateTime(u.created_at):'-'%></td><td><form method="post" action="/admin/update/user/<%=u.id%>" class="row-actions"><select name="role"><option value="user" <%=role==='user'?'selected':''%>>일반</option><option value="vendor" <%=role==='vendor'?'selected':''%>>업체</option><option value="admin" <%=role==='admin'?'selected':''%>>관리자</option></select><select name="status"><option value="active" <%=status==='active'?'selected':''%>>정상</option><option value="blocked" <%=status==='blocked'?'selected':''%>>차단</option><option value="suspended" <%=status==='suspended'?'selected':''%>>일시정지</option></select><button>저장</button></form></td></tr><%})%></table></div></section><section id="inquiries" class="panel admin-panel"><h2>입점 승인</h2><div class="admin-sub-filter"><button type="button" data-filter="all" class="on">전체</button><button type="button" data-filter="apply">입점신청</button><button type="button" data-filter="ad">광고문의</button><button type="button" data-filter="new">대기</button><button type="button" data-filter="approved">승인</button><button type="button" data-filter="rejected">반려</button></div><div class="admin-searchbar"><input id="inquirySearch" placeholder="업체명/담당자/연락처 검색"><select id="inquirySort"><option value="latest">최신순</option><option value="oldest">오래된순</option><option value="company">업체명순</option></select><button id="inquirySearchReset" type="button">초기화</button></div><table><tr><th>ID</th><th>구분</th><th>신청회원</th><th>업체명</th><th>담당자</th><th>연락처</th><th>지역/업종</th><th>처리</th></tr><% inquiries.forEach(x=>{%><tr class="inquiry-row" data-id="<%=x.id%>" data-status="<%=x.status%>" data-type="<%=x.type==='apply'?'apply':'ad'%>" data-search="<%=String((x.company_name||'')+' '+(x.name||'')+' '+(x.phone||'')+' '+(x.kakao||'')+' '+(x.email||'')+' '+(x.region||'')+' '+(x.category||'')).toLowerCase()%>"><td><%=x.id%></td><td><%=x.type==='apply'?'입점신청':'광고문의'%></td><td><%=x.applicant_username||'비회원/미연결'%><% if(x.applicant_nickname){%><br><small><%=x.applicant_nickname%></small><%}%></td><td><%=x.company_name||'-'%></td><td><%=x.name||'-'%></td><td><%=x.phone||'-'%><% if(x.kakao){%><br><small><%=x.kakao%></small><%}%><% if(x.email){%><br><small><%=x.email%></small><%}%></td><td><%=x.region||'-'%>/<%=x.category||'-'%></td><td><%=x.status==='approved'?'업체 등록완료':x.status==='rejected'?'반려됨':''%><% if(x.status==='new'){%><div class="row-actions"><form method="post" action="/admin/inquiries/<%=x.id%>/approve"><button class="approve-btn">승인</button></form><form method="post" action="/admin/inquiries/<%=x.id%>/reject"><button class="reject-btn">반려</button></form></div><%}%></td></tr><%})%></table></section><section id="adCenter" class="panel admin-panel"><h2>광고센터 통합관리</h2><% const payStatusLabel=s=>s==='waiting'?'입금확인중':s==='paid'?'입금완료':s==='rejected'?'반려':s==='cancelled'?'취소':'입금대기'; %><div class="integrated-tools"><div class="integrated-card"><b>광고신청 대기</b><strong><%=adRequests.filter(x=>x.status==='new').length%></strong></div><div class="integrated-card"><b>배너신청 대기</b><strong><%=bannerRequests.filter(x=>x.status==='new').length%></strong></div><div class="integrated-card"><b>입금확인중</b><strong><%=adRequests.concat(bannerRequests).filter(x=>x.payment_status==='waiting').length%></strong></div><div class="integrated-card"><b>승인완료</b><strong><%=adRequests.concat(bannerRequests).filter(x=>x.status==='approved').length%></strong></div></div><div class="admin-sub-filter"><button type="button" data-ad-filter="all" class="on">전체</button><button type="button" data-ad-filter="ad">광고</button><button type="button" data-ad-filter="banner">배너</button><button type="button" data-ad-filter="waiting">입금확인중</button><button type="button" data-ad-filter="new">대기</button><button type="button" data-ad-filter="approved">승인</button><button type="button" data-ad-filter="rejected">반려</button></div><div class="admin-searchbar"><input id="adCenterSearch" placeholder="업체명/상품/내용 검색"><select id="adCenterSort"><option value="latest">최신순</option><option value="price">금액순</option><option value="vendor">업체명순</option></select><button id="adCenterReset" type="button">초기화</button></div><table><tr><th>구분</th><th>ID</th><th>업체</th><th>상품/제목</th><th>금액</th><th>USDT</th><th>입금상태</th><th>처리상태</th><th>내용</th><th>처리</th></tr><% adRequests.forEach(r=>{%><tr class="ad-center-row" data-kind="ad" data-status="<%=r.status%>" data-pay="<%=r.payment_status%>" data-id="<%=r.id%>" data-price="<%=r.krw_price||0%>" data-vendor="<%=String(r.vendor_name||'').toLowerCase()%>" data-search="<%=String((r.vendor_name||'')+' '+(r.plan||'')+' '+(r.content||'')).toLowerCase()%>"><td>광고</td><td><%=r.id%></td><td><%=r.vendor_name%></td><td><%=r.plan%></td><td><%=Number(r.krw_price||0).toLocaleString()%>원</td><td><%=r.usdt_amount||0%></td><td><span class="pay-badge pay-<%=r.payment_status||'unpaid'%>"><%=payStatusLabel(r.payment_status)%></span></td><td><span class="<%=r.status==='approved'?'done':r.status==='rejected'?'rejected':'pending'%>"><%=r.stat