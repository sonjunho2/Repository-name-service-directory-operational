<script>
(function(){
  if(window.__adminSettingsTabRestoreV1)return;
  window.__adminSettingsTabRestoreV1=true;
  var STORAGE_KEY='adminSettingsActiveTab';

  function normalizeTab(key){
    key=String(key||'').replace(/^settings-/,'').trim();
    return ['basic','payment','admin','data'].includes(key)?key:'basic';
  }
  function activateSettingsTab(key){
    key=normalizeTab(key);
    document.querySelectorAll('.settings-tab[data-settings-tab]').forEach(function(btn){
      btn.classList.toggle('active',btn.getAttribute('data-settings-tab')===key);
    });
    document.querySelectorAll('.settings-panel').forEach(function(panel){
      panel.classList.toggle('active',panel.id==='settings-'+key);
    });
    try{sessionStorage.setItem(STORAGE_KEY,key);}catch(e){}
    if(key==='admin'&&typeof window.loadAdminAccounts==='function')window.loadAdminAccounts();
  }
  function restoreSettingsTab(){
    var settingsPanel=document.getElementById('settings');
    if(location.hash!=='#settings'&&!(settingsPanel&&settingsPanel.classList.contains('active')))return;
    var key='basic';
    try{key=sessionStorage.getItem(STORAGE_KEY)||'basic';}catch(e){}
    activateSettingsTab(key);
  }
  window.activateAdminSettingsTab=activateSettingsTab;

  document.addEventListener('click',function(e){
    var btn=e.target&&e.target.closest&&e.target.closest('.settings-tab[data-settings-tab]');
    if(!btn)return;
    activateSettingsTab(btn.getAttribute('data-settings-tab'));
  });
  document.addEventListener('submit',function(e){
    var form=e.target;
    if(!form||!form.closest('#settings'))return;
    var key='';
    var section=form.querySelector('input[name="settings_section"]');
    if(section&&section.value)key=section.value;
    else{
      var panel=form.closest('.settings-panel');
      if(panel&&panel.id)key=panel.id.replace('settings-','');
    }
    key=normalizeTab(key);
    try{sessionStorage.setItem(STORAGE_KEY,key);}catch(err){}
  },true);
  document.addEventListener('DOMContentLoaded',function(){
    setTimeout(restoreSettingsTab,0);
    setTimeout(restoreSettingsTab,250);
  });
  window.addEventListener('hashchange',function(){
    if(location.hash==='#settings')setTimeout(restoreSettingsTab,0);
  });
})();
</script>

<script>
