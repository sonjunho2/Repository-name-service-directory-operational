    else if(key==='adInquiries')Object.assign(patch,{q:value('adInquirySearch'),status:value('adInquiryStatus','all')});
    return window.setAdminListState(key,patch);
  };
  window.restoreAdminListControls=function(key){var s=window.getAdminListState(key);var set=function(id,v){var el=document.getElementById(id);if(el&&v!==undefined&&v!==null)el.value=v;};
