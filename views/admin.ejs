  function query(){var p=new URLSearchParams({page:String(currentPage),limit:String(limit),status:currentStatus,change:currentChange,sort:currentSort});if(currentSearch)p.set('q',currentSearch);return p;}
  function syncCards(){panel.querySelectorAll('[data-vendor-request-card]').forEach(function(b){var k=b.dataset.vendorRequestCard,active=k==='many'?currentChange==='many'&&currentStatus==='all':k==='waiting'?currentStatus==='new'&&currentChange==='all':k==='all'?currentStatus==='all'&&currentChange==='all':currentStatus===k&&currentChange==='all';b.classList.toggle('active',active);});}
  function drawPager(data){pager.innerHTML='';function add(label,page,disabled,active){var b=document.createElement('button');b.type='button';b.textContent=label;b.disabled=disabled;b.classList.toggle('active',active);b.addEventListener('click',function(){loadVendorRequests(page);});pager.appendChild(b);}add('이전',data.page-1,data.page<=1,false);for(var n=Math.max(1,data.page-2);n<=Math.min(data.totalPages,data.page+2);n++)add(String(n),n,false,n===data.page);add('다음',data.page+1,data.page>=data.totalPages,false);var s=document.createElement('span');s.className='server-vendor-info';s.textContent='총 '+data.total+'건 · '+data.page+'/'+data.totalPages+'페이지';pager.appendChild(s);}
  async function loadVendorRequests(page){if(loading)return false;currentPage=Math.max(1,Number(page||currentPage));currentSearch=(document.getElementById('vendorRequestSearch').value||'').trim();currentStatus=document.getElementById('vendorRequestStatus').value||'all';currentChange=document.getElementById('vendorRequestChange').value||'all';currentSort=document.getElementById('vendorRequestSort').value||'latest';loading=true;body.innerHTML='<tr><td colspan="8">업체 수정요청을 불러오는 중입니다.</td></tr>';try{var res=await fetch('/admin/api/vendor-update-requests?'+query().toString(),{credentials:'same-origin',cache:'no-store',headers:{Accept:'application/json','X-Requested-With':'fetch'}}),data=await res.json();if(!res.ok||!data.ok)throw new Error(data.error||'load_failed');if(currentPage>Math.max(1,Number(data.totalPages||1))){loading=false;return loadVendorRequests(Math.max(1,Number(data.totalPages||1)));}body.innerHTML=(data.rows||[]).map(row).join('')||'<tr><td colspan="8">조건에 맞는 업체 수정요청이 없습니다.</td></tr>';Object.keys(data.summary||{}).forEach(function(k){var el=panel.querySelector('[data-vendor-request-summary="'+k+'"]');if(el)el.textContent=Number(data.summary[k]||0).toLocaleString();});drawPager(data);syncCards();window.setAdminListState?.('vendorRequests',{page:currentPage,q:currentSearch,status:currentStatus,change:currentChange,sort:currentSort});return true;}catch(e){body.innerHTML='<tr><td colspan="8">업체 수정요청을 불러오지 못했습니다.</td></tr>';return false;}finally{loading=false;}}
  window.loadAdminVendorRequests=loadVendorRequests;window.restoreAdminListControls?.('vendorRequests');var saved=window.getAdminListState?.('vendorRequests')||{};currentPage=Math.max(1,Number(saved.page||1));currentStatus=document.getElementById('vendorRequestStatus').value||'all';currentChange=document.getElementById('vendorRequestChange').value||'all';currentSort=document.getElementById('vendorRequestSort').value||'latest';syncCards();
  document.getElementById('vendorRequestSearch').addEventListener('input',function(){clearTimeout(searchTimer);searchTimer=setTimeout(function(){loadVendorRequests(1);},300);});
  document.getElementById('vendorRequestStatus').addEventListener('change',function(){loadVendorRequests(1);});document.getElementById('vendorRequestChange').addEventListener('change',function(){loadVendorRequests(1);});document.getElementById('vendorRequestSort').addEventListener('change',function(){loadVendorRequests(1);});
  document.getElementById('vendorRequestReset').addEventListener('click',function(){document.getElementById('vendorRequestSearch').value='';document.getElementById('vendorRequestStatus').value='all';document.getElementById('vendorRequestChange').value='all';document.getElementById('vendorRequestSort').value='latest';loadVendorRequests(1);});
