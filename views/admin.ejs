  function randomIndex(max){var limit=Math.floor(4294967296/max)*max,a=new Uint32Array(1);do{crypto.getRandomValues(a);}while(a[0]>=limit);return a[0]%max;}
  function generatePassword(){var upper='ABCDEFGHJKLMNPQRSTUVWXYZ',lower='abcdefghijkmnopqrstuvwxyz',digits='23456789',special='!@#$%^&*',all=upper+lower+digits+special,out=[upper[randomIndex(upper.length)],lower[randomIndex(lower.length)],digits[randomIndex(digits.length)],special[randomIndex(special.length)]];while(out.length<14)out.push(all[randomIndex(all.length)]);for(var i=out.length-1;i>0;i--){var j=randomIndex(i+1),t=out[i];out[i]=out[j];out[j]=t;}return out.join('');}
  async function copyText(value){if(!value){toastMessage('먼저 비밀번호를 입력하거나 생성해주세요.','bad');return false;}try{if(navigator.clipboard?.writeText)await navigator.clipboard.writeText(value);else throw new Error('clipboard_unavailable');}catch(e){var area=document.createElement('textarea');area.value=value;area.style.position='fixed';area.style.opacity='0';document.body.appendChild(area);area.select();var ok=document.execCommand('copy');area.remove();if(!ok){toastMessage('비밀번호를 복사하지 못했습니다.','bad');return false;}}toastMessage('비밀번호를 복사했습니다.','ok');return true;}
  function showPasswordResult(username,password){resultUsername=String(username||'');resultPassword=String(password||'');if(!resultModal)return;resultModal.querySelector('[data-admin-password-result="username"]').textContent=resultUsername;resultModal.querySelector('[data-admin-password-result="password"]').textContent=resultPassword;resultModal.hidden=false;document.body.style.overflow='hidden';}
