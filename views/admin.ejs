      form.dataset.submitting='0';if(btn){btn.disabled=false;btn.textContent=old;}
    }
  }

  document.addEventListener('submit',function(e){
    var form=e.target;
    if(form && form.getAttribute('action')==='/admin/link-user-vendor'){
      e.preventDefault();
      e.stopPropagation();
      submitVendorLink(form);
