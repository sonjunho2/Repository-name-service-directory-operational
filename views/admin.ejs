  const setCards=function(selector,values){const cards=document.querySelectorAll(selector);values.forEach(function(value,index){if(cards[index]&&value!=null)cards[index].textContent=String(value);});};
  setCards('#inquiries .integrated-tools:first-of-type .integrated-card strong',[stats.inquiries?.total,stats.inquiries?.new,stats.inquiries?.approved,stats.inquiries?.rejected]);
  setCards('#vendorRequests .integrated-tools:first-of-type .integrated-card strong',[stats.vendorUpdateRequests?.total,stats.vendorUpdateRequests?.new,stats.vendorUpdateRequests?.approved,stats.vendorUpdateRequests?.rejected]);
  const setButton=function(selector,label,value){const button=document.querySelector(selector);if(button&&value!=null)button.textContent=label+' '+value;};
  setButton('#inquiries [data-filter="all"]','м†Дм≤і',stats.inquiries?.total);setButton('#inquiries [data-filter="new"]','лМАкЄ∞',stats.inquiries?.new);setButton('#inquiries [data-filter="approved"]','мКємЭЄ',stats.inquiries?.approved);setButton('#inquiries [data-filter="rejected"]','л∞Шл†§',stats.inquiries?.rejected);setButton('#inquiries [data-filter="apply"]','мЮЕм†РмЛ†м≤≠',stats.inquiries?.apply);setButton('#inquiries [data-filter="ad"]','кіСк≥†лђЄмЭШ',stats.inquiries?.ad);
  const logTotal=document.querySelector('#adminLogs [data-admin-log-summary="total"]');
  if(logTotal&&stats.adminLogs?.total!=null)logTotal.textContent=String(stats.adminLogs.total);
});
