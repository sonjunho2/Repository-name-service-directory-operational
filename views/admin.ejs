<script>
(function(){
  if(window.__adminDashboardSummaryV1)return;
  window.__adminDashboardSummaryV1=true;
  var root=document.getElementById('adminDashboardGrid'),recent=document.getElementById('adminDashboardRecent');
  if(!root||!recent)return;
  function esc(s){return String(s||'').replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});}
  function render(data){
    var cards=data&&data.cards||{};
    root.querySelectorAll('[data-summary-key]').forEach(function(card){var value=Number(cards[card.dataset.summaryKey]||0);card.querySelector('strong').textContent=card.dataset.money==='true'?value.toLocaleString('ko-KR')+'мЫР':value.toLocaleString('ko-KR')+'к±і';});
    var items=data&&data.recent||[];
    recent.innerHTML=items.length?items.map(function(x){return '<a class="admin-dashboard-recent-item" href="'+esc(x.link_url||'#')+'"><b>'+esc(x.title||'мХМл¶Љ')+'</b><span>'+esc(x.message||'')+' ¬Ј '+esc(new Date(x.created_at).toLocaleString('ko-KR',{hour12:false}))+'</span></a>';}).join(''):'<div class="admin-dashboard-empty">мµЬкЈЉ мХМл¶ЉмЭі мЧЖмКµлЛИлЛ§.</div>';
  }
  async function loadDashboardSummary(){
    try{var response=await fetch('/admin/api/dashboard-summary',{headers:{Accept:'application/json'},credentials:'same-origin',cache:'no-store'});var data=await response.json();if(!response.ok||!data.ok)throw new Error(data.error||'summary_failed');render(data);}catch(e){console.error('dashboard summary load failed',e);}
  }
  window.loadDashboardSummary=loadDashboardSummary;
  function setValue(id,value){var el=document.getElementById(id);if(el)el.value=value;}
  function goAdminSection(hash){
    if(!hash)return;
    var id=String(hash).replace(/^#/,'');
    if(typeof showAdminPanel==='function')showAdminPanel(id);
    history.replaceState(null,'','#'+id);
    setTimeout(function(){document.getElementById(id)?.scrollIntoView({behavior:'smooth',block:'start'});},0);
  }
  function selectFilter(selector,filter){document.querySelectorAll(selector).forEach(function(button){button.classList.toggle('on',button.dataset.filter===filter);});}
  function handleDashboardAction(action){
    var load;
    if(action==='ad-inquiry-waiting'){
      setValue('adInquirySearch','');setValue('adInquiryStatus','waiting');
      window.setAdminListState?.('adInquiries',{page:1,q:'',status:'waiting'});goAdminSection('#adInquiries');load=window.loadAdminAdInquiries;
    }else if(action==='apply-waiting'){
      setValue('inquirySearch','');setValue('inquiryStatus','new');window.setAdminInquiryFilter?.('waiting',{load:false});
      window.setAdminListState?.('inquiries',{page:1,q:'',status:'new',sort:'latest'});goAdminSection('#inquiries');load=window.loadAdminInquiries;
    }else if(action==='payment-waiting'){
      setValue('adPaymentSearch','');window.setAdminAdCenterDashboardFilter?.('waiting');
      window.setAdminListState?.('adCenter',{page:1,q:'',kind:'all',state:'waiting',sort:'latest'});goAdminSection('#adCenter');load=window.loadAdminAdCenter;
    }else if(action==='vendor-update-waiting'){
      setValue('vendorRequestSearch','');setValue('vendorRequestStatus','new');
      setValue('vendorRequestSort','latest');
      window.setAdminListState?.('vendorRequests',{page:1,q:'',status:'new',sort:'latest'});goAdminSection('#vendorRequests');load=window.loadAdminVendorRequests;
    }else if(action==='report-waiting'){
      setValue('reportSearch','');setValue('reportTypeFilter','all');setValue('reportStatusFilter','new');setValue('reportTargetFilter','all');
      window.setAdminListState?.('reports',{page:1,q:'',type:'all',status:'new',target:'all'});goAdminSection('#reports');load=window.loadAdminReports;
    }else if(action==='vendors-expiring'){
      setValue('vendorSearch','');setValue('vendorStatusFilter','all');setValue('vendorSortFilter','latest');
      window.setAdminListState?.('vendors',{page:1,q:'',status:'all',sort:'latest'});goAdminSection('#vendors');load=window.loadAdminVendors;
    }else if(action==='today-revenue'){
      goAdminSection('#revenue');
    }else if(action==='notifications-unread'){
      var unread=document.querySelector('#adminNotifyFilters [data-filter="unread"]');if(unread)unread.click();
      var center=document.getElementById('adminNotificationCenter');if(center&&!center.classList.contains('open'))document.getElementById('adminNotifyBtn')?.click();
    }
    if(typeof load==='function')load(1);
  }
  window.goAdminSection=goAdminSection;
  window.handleDashboardAction=handleDashboardAction;
  root.addEventListener('click',function(e){var card=e.target.closest('[data-dashboard-action]');if(!card)return;e.preventDefault();handleDashboardAction(card.dataset.dashboardAction);});
  document.addEventListener('DOMContentLoaded',loadDashboardSummary);
  window.addEventListener('hashchange',function(){if(location.hash==='#dashboard'||!location.hash)loadDashboardSummary();});
  document.addEventListener('click',function(e){if(e.target.closest('[data-panel="dashboard"]'))setTimeout(loadDashboardSummary,0);});
})();
</script>
