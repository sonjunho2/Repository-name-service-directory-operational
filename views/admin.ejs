<script>
(function(){
  if(window.__adminReviewManagementV1)return;
  window.__adminReviewManagementV1=true;
  var busy=false,timer=null,page=Number(window.getAdminListState?.('reviews').page||1),limit=20;
  function e(v){return String(v==null?'':v).replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});}
  function dt(v){if(!v)return '-';var d=new Date(v);if(isNaN(d.getTime()))return '-';return d.toLocaleString('sv-SE',{timeZone:'Asia/Seoul',year:'numeric',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit',hour12:false});}
  function val(id,f){return document.getElementById(id)?.value||f;}
  function query(p){var x=new URLSearchParams({page:String(p),limit:String(limit),sort:val('reviewSortFilter','latest')});var q=val('reviewSearch','').trim(),status=val('reviewStatusFilter','all'),rating=val('reviewRatingFilter','all'),report=val('reviewReportFilter','all');if(q)x.set('q',q);if(status!=='all')x.set('status',status);if(rating!=='all')x.set('rating',rating);if(report!=='all')x.set('report',report);return x;}
  function badge(status){var label={visible:'공개중',hidden:'숨김',deleted:'삭제됨'}[status]||status||'-';return '<span class="review-status-badge '+e(status||'')+'">'+e(label)+'</span>';}
  function actions(r){if(r.status==='deleted')return '<span class="review-action-finished">처리 없음</span>';var hide=r.status==='visible'?'<form method="post" action="/admin/reviews/'+e(r.id)+'/hide" data-confirm="이 후기를 숨김 처리할까요?"><button class="reject-btn">숨김</button></form>':'<form method="post" action="/admin/reviews/'+e(r.id)+'/show" data-confirm="이 후기를 다시 공개할까요?"><button class="approve-btn">다시 공개</button></form>';return '<div class="review-action-list">'+hide+'<form method="post" action="/admin/delete/reviews/'+e(r.id)+'" data-confirm="이 후기를 삭제 상태로 변경할까요? 후기와 신고 기록은 보존됩니다."><button class="reject-btn">삭제</button></form></div>';}
  function row(r){var vendor=r.vendor_exists?'<b>'+e(r.vendor_name||'-')+'</b><small>'+e([r.vendor_region,r.vendor_category].filter(Boolean).join(' / ')||'-')+'</small><button type="button" data-review-vendor="'+e(r.vendor_name||r.vendor_id)+'">업체보기</button>':'<span class="review-missing">삭제되었거나 존재하지 않는 업체</span>';var author='<b>'+e(r.author_label||'탈퇴회원')+'</b><small>'+e(r.username||'탈퇴회원')+'</small>';var reports='<b class="'+(r.has_pending_report?'review-report-warn':'')+'">전체 '+e(r.report_count||0)+' · 미처리 '+e(r.pending_report_count||0)+'</b>'+(Number(r.report_count)>0?'<button type="button" data-review-reports="'+e(r.id)+'">신고보기</button>':'');var detail='<div class="review-detail-grid"><section><b>후기정보</b><dl><dt>ID</dt><dd>#'+e(r.id)+'</dd><dt>제목</dt><dd>'+e(r.title||'-')+'</dd><dt>내용</dt><dd class="review-full-content">'+e(r.content||'-')+'</dd><dt>평점</dt><dd>★ '+e(r.rating)+'</dd><dt>상태</dt><dd>'+e(r.status||'-')+'</dd><dt>작성일</dt><dd>'+e(dt(r.created_at))+'</dd></dl></section><section><b>업체정보</b><dl><dt>업체 ID</dt><dd>'+e(r.vendor_id||'-')+'</dd><dt>업체명</dt><dd>'+e(r.vendor_name||'존재하지 않음')+'</dd><dt>지역 / 업종</dt><dd>'+e([r.vendor_region,r.vendor_category].filter(Boolean).join(' / ')||'-')+'</dd><dt>운영상태</dt><dd>'+e(r.vendor_status||'-')+'</dd><dt>광고상품</dt><dd>'+e(r.vendor_ad_type||'-')+'</dd></dl></section><section><b>작성자·신고정보</b><dl><dt>사용자 ID</dt><dd>'+e(r.user_id||'-')+'</dd><dt>아이디</dt><dd>'+e(r.username||'탈퇴회원')+'</dd><dt>닉네임</dt><dd>'+e(r.nickname||'-')+'</dd><dt>신고</dt><dd>전체 '+e(r.report_count||0)+' / 미처리 '+e(r.pending_report_count||0)+'</dd><dt>최근 신고일</dt><dd>'+e(dt(r.latest_report_at))+'</dd></dl></section></div>';
    return '<tr class="review-row" data-id="'+e(r.id)+'"><td><b>#'+e(r.id)+'</b><small>'+e(dt(r.created_at))+'</small></td><td>'+vendor+'</td><td>'+author+'</td><td><b>'+e(r.title||'-')+'</b><p class="review-content-clamp">'+e(r.content||'-')+'</p></td><td><span class="review-rating-badge">★ '+e(r.rating||0)+'</span></td><td>'+reports+'</td><td>'+badge(r.status)+'</td><td><button type="button" data-review-detail="'+e(r.id)+'">상세보기</button></td><td>'+actions(r)+'</td></tr><tr class="review-detail-row" data-detail-for="'+e(r.id)+'" hidden><td colspan="9">'+detail+'</td></tr>';}
  function summary(s){Object.keys(s||{}).forEach(function(k){var el=document.querySelector('[data-review-summary="'+k+'"]');if(el)el.textContent=Number(s[k]||0).toLocaleString('ko-KR');});}
  function pager(data){var root=document.getElementById('reviewPager');if(!root)return;root.innerHTML='';var pages=Math.max(1,Number(data.totalPages||1)),cur=Number(data.page||1);function add(label,p,disabled,active){var b=document.createElement('button');b.type='button';b.textContent=label;b.disabled=disabled;if(active)b.className='active';b.onclick=function(){load(p);};root.appendChild(b);}add('처음',1,cur<=1);add('이전',cur-1,cur<=1);for(var n=Math.max(1,cur-2);n<=Math.min(pages,cur+2);n++)add(String(n),n,false,n===cur);add('다음',cur+1,cur>=pages);add('마지막',pages,cur>=pages);var info=document.createElement('span');info.className='server-review-info';info.textContent='총 '+Number(data.total||0).toLocaleString('ko-KR')+'건';root.appendChild(info);}
  async function load(next){if(busy){clearTimeout(timer);timer=setTimeout(function(){load(next);},100);return;}var body=document.getElementById('reviewTableBody');if(!body)return;page=Math.max(1,Number(next||window.getAdminListState?.('reviews').page||1));window.saveActiveAdminListState?.('reviews',page);busy=true;body.innerHTML='<tr class="loading-row"><td colspan="9">후기목록을 불러오는 중입니다.</td></tr>';try{var res=await fetch('/admin/api/reviews?'+query(page),{headers:{Accept:'application/json'}}),data=await res.json();if(!res.ok||!data.ok)throw new Error(data.error||'load_failed');if(page>Math.max(1,Number(data.totalPages||1))){busy=false;window.normalizeAdminListPage?.('reviews',data,load);return;}summary(data.summary);body.innerHTML=(data.rows||[]).length?data.rows.map(row).join(''):'<tr><td colspan="9">조건에 맞는 후기가 없습니다.</td></tr>';pager(data);}catch(err){body.innerHTML='<tr><td colspan="9">후기목록을 불러오지 못했습니다.</td></tr>';}finally{busy=false;}}
  window.loadAdminReviews=load;window.restoreAdminListControls?.('reviews');
  document.getElementById('reviewSearch')?.addEventListener('input',function(){clearTimeout(timer);timer=setTimeout(function(){load(1);},300);});['reviewStatusFilter','reviewRatingFilter','reviewReportFilter','reviewSortFilter'].forEach(function(id){document.getElementById(id)?.addEventListener('change',function(){load(1);});});
  document.getElementById('reviewFilterReset')?.addEventListener('click',function(){document.getElementById('reviewSearch').value='';document.getElementById('reviewStatusFilter').value='all';document.getElementById('reviewRatingFilter').value='all';document.getElementById('reviewReportFilter').value='all';document.getElementById('reviewSortFilter').value='latest';load(1);});
  document.getElementById('reviews')?.addEventListener('click',function(ev){var d=ev.target.closest('[data-review-detail]');if(d){var x=document.querySelector('[data-detail-for="'+d.dataset.reviewDetail+'"]');if(x){x.hidden=!x.hidden;d.textContent=x.hidden?'상세보기':'상세닫기';}return;}var card=ev.target.closest('[data-review-card]');if(card){var m=card.dataset.reviewCard;document.getElementById('reviewStatusFilter').value=['visible','hidden','deleted'].includes(m)?m:'all';document.getElementById('reviewRatingFilter').value=m==='low'?'low':'all';document.getElementById('reviewReportFilter').value=['reported','pending'].includes(m)?m:'all';load(1);return;}var vendor=ev.target.closest('[data-review-vendor]');if(vendor){showAdminPanel('vendors');history.replaceState(null,'','#vendors');document.getElementById('vendorSearch').value=vendor.dataset.reviewVendor;window.setAdminListState?.('vendors',{page:1,q:vendor.dataset.reviewVendor});window.reloadAdminPanelList?.('vendors');return;}var reports=ev.target.closest('[data-review-reports]');if(reports){showAdminPanel('reports');history.replaceState(null,'','#reports');document.getElementById('reportSearch').value=reports.dataset.reviewReports;document.getElementById('reportTypeFilter').value='review';document.getElementById('reportStatusFilter').value='all';document.getElementById('reportTargetFilter').value='all';window.setAdminListState?.('reports',{page:1,q:reports.dataset.reviewReports,type:'review',status:'all',target:'all'});window.reloadAdminPanelList?.('reports');}});
})();
</script>

<script>
(function(){
  if(window.__adminRequestListsApiV1)return;
  window.__adminRequestListsApiV1=true;
  var pages={vendorRequests:Number(window.getAdminListState?.('vendorRequests').page||1),adCenter:Number(window.getAdminListState?.('adCenter').page||1)},busy={},timers={},limit=20,adStatus='all';
  function dt(v){if(!v)return '-';var d=new Date(v);if(isNaN(d.getTime()))return '-';return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0')+' '+String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0');}
  function short(v){v=String(v||'-');return v.length>140?v.slice(0,140)+'...':v;}
  function table(id){return document.querySelector('#'+id+' table');}
  function message(t,text){if(!t)return;var h=t.querySelector('tr'),cols=h?h.children.length:1;t.innerHTML='';if(h)t.appendChild(h);t.insertAdjacentHTML('beforeend','<tr class="loading-row"><td colspan="'+cols+'">'+esc(text)+'</td></tr>');}
  function pager(id,t,cls){var panel=document.getElementById(id);if(!panel||!t)return null;panel.querySelectorAll('.admin-pager').forEach(function(x){x.remove();});panel.querySelectorAll('.'+cls).forEach(function(x,i){if(i)x.remove();});var p=panel.querySelector('.'+cls);if(!p){p=document.createElement('div');p.className=cls+' server-vendor-pager';t.insertAdjacentElement('afterend',p);}return p;}
  function btn(text,disabled,active,fn){var b=document.createElement('button');b.type='button';b.textContent=text;b.disabled=!!disabled;if(active)b.classList.add('active');b.onclick=fn;return b;}
  function drawPager(p,data,loader){p.innerHTML='';var page=data.page||1,totalPages=data.totalPages||1,total=data.total||0;var from=total?((page-1)*data.limit+1):0,to=Math.min(page*data.limit,total);p.appendChild(btn('처음',page<=1,false,function(){loader(1);}));p.appendChild(btn('이전',page<=1,false,function(){loader(page-1);}));var start=Math.max(1,page-2),end=Math.min(totalPages,start+4);start=Math.max(1,end-4);for(var n=start;n<=end;n++){(function(x){p.appendChild(btn(String(x),false,x===page,function(){loader(x);}));})(n);}p.appendChild(btn('다음',page>=totalPages,false,function(){loader(page+1);}));p.appendChild(btn('마지막',page>=totalPages,false,function(){loader(totalPages);}));var info=document.createElement('span');info.className='server-vendor-info';info.textContent='총 '+total+'건 · 현재 '+from+'-'+to+'건 표시';p.appendChild(info);}
  async function load(id,cls,page,url,query,row,loader){if(busy[id]){clearTimeout(timers[id]);timers[id]=setTimeout(function(){load(id,cls,page,url,query,row,loader);},100);return;}var t=table(id);if(!t)return;page=page||Number(window.getAdminListState?.(id).page||1);pages[id]=Math.max(1,page||1);window.saveActiveAdminListState?.(id,pages[id]);var p=pager(id,t,cls);busy[id]=true;message(t,'목록을 불러오는 중입니다.');if(p)p.innerHTML='<span class="server-vendor-info">목록을 불러오는 중입니다.</span>';try{var res=await fetch(url+'?'+query(pages[id]).toString(),{credentials:'same-origin',headers:{Accept:'application/json'}});var data=await res.json();if(!res.ok||!data.ok)throw new Error(data.error||'load_failed');if(pages[id]>Math.max(1,Number(data.totalPages||1))){busy[id]=false;if(window.normalizeAdminListPage?.(id,data,loader))return;}var h=t.querySelector('tr');t.innerHTML='';if(h)t.appendChild(h);(data.rows||[]).forEach(function(x){t.insertAdjacentHTML('beforeend',row(x));});if(!(data.rows||[]).length)message(t,'조건에 맞는 요청이 없습니다.');if(id==='vendorRequests')Object.entries(data.summary||{}).forEach(function(entry){var el=document.querySelector('[data-vendor-request-summary="'+entry[0]+'"]');if(el)el.textContent=Number(entry[1]||0).toLocaleString();});if(p)drawPager(p,data,loader);}catch(e){message(t,'목록을 불러오지 못했습니다.');if(p)p.innerHTML='<span class="server-vendor-info">서버 데이터를 불러오지 못했습니다.</span>';}finally{busy[id]=false;}}

  var adPanel=document.getElementById('adCenter'),adSearch=document.getElementById('adCenterSearch');
  if(adPanel&&!adSearch){var at=document.createElement('div');at.className='admin-searchbar';at.innerHTML='<input id="adCenterSearch" placeholder="업체 / 신청자 / 상품 / TXID 검색"><select id="adCenterSource"><option value="all">전체 신청</option><option value="ad_request">광고상품</option><option value="banner_request">배너상품</option></select><select id="adCenterPayment"><option value="all">전체</option><option value="unpaid">입금대기</option><option value="waiting">입금확인중</option><option value="paid">입금완료</option><option value="expired">기한만료</option><option value="cancelled">취소</option></select><select id="adCenterType"><option value="all">전체 상품</option><option value="general">일반광고</option><option value="recommended">추천광고</option><option value="banner">프리미엄배너</option><option value="recommended_upgrade">일반→추천</option><option value="renewal_general">광고연장</option><option value="renewal_recommended">추천연장</option><option value="renewal_banner">배너연장</option></select><button type="button" id="adCenterReset">초기화</button>';adPanel.querySelector('table')?.insertAdjacentElement('beforebegin',at);adSearch=document.getElementById('adCenterSearch');}
  function adQuery(page){var p=new URLSearchParams();p.set('page',String(page));p.set('limit',String(limit));var q=(adSearch?.value||'').trim(),source=document.getElementById('adCenterSource')?.value||'all',pay=document.getElementById('adCenterPayment')?.value||'all',type=document.getElementById('adCenterType')?.value||'all';if(q)p.set('q',q);if(source!=='all')p.set('source',source);if(pay!=='all')p.set('payment_status',pay);if(type!=='all')p.set('request_type',type);if(['waiting','unpaid','paid','expired','cancelled'].includes(adStatus))p.set('payment_status',adStatus);return p;}
  function paymentLabel(x){if(x.payment_status==='paid')return '입금완료';if(x.payment_status==='waiting')return '입금확인중';if(x.payment_status==='rejected')return '반려';if(x.payment_status==='cancelled')return String(x.admin_memo||'').includes('만료')?'기한만료':'취소';return '입금대기';}
  function statusKey(x){if(x.payment_status==='paid'||x.status==='approved')return 'paid';if(x.status==='cancelled'||x.payment_status==='cancelled')return String(x.admin_memo||'').includes('만료')?'expired':'cancelled';if(x.status==='rejected'||x.payment_status==='rejected')return 'rejected';return x.payment_status==='waiting'?'waiting':'unpaid';}
  function statusLabel(x){return {paid:'입금완료',waiting:'입금확인중',unpaid:'입금대기',expired:'기한만료',cancelled:'취소',rejected:'취소'}[statusKey(x)]||paymentLabel(x);}
  function productLabel(x){var t=String(x.request_type||'');if(x.source==='banner_request')return '프리미엄배너';if(t==='renewal_banner')return '배너연장';if(t==='renewal_general'||t==='renewal_recommended')return '광고연장';if(t==='recommended'||t==='recommended_upgrade'||t==='schedule_to_recommended')return '추천광고';if(t==='apply')return '입점신청';return '기타';}
  function deadline(x){if(!x.payment_expires_at)return '<span class="payment-muted">-</span>';if(statusKey(x)==='paid')return '<span class="payment-deadline-badge normal">확인완료</span><br><small>'+esc(dt(x.payment_expires_at))+'</small>';var end=new Date(x.payment_expires_at),ms=end.getTime()-Date.now();if(!isFinite(end.getTime())||ms<=0)return '<span class="payment-deadline-badge expired">기한만료</span>';var minutes=Math.ceil(ms/60000),hours=Math.floor(minutes/60),mins=minutes%60,cls=minutes<=360?'soon':'normal';return '<span class="payment-deadline-badge '+cls+'">남은시간: '+hours+'시간 '+mins+'분</span><br><small>'+esc(dt(x.payment_expires_at))+'</small>';}
  function paid(x){var value=x.paid_usdt_amount||'';if(!value){var m=String(x.admin_memo||'').match(/실제입금:\s*([0-9.]+)/);if(m)value=m[1];}return value;}
  function cleanMemo(x){return String(x.admin_memo||'').replace(/\s*실제입금:\s*[0-9.]+\s*USDT\s*/g,'').trim();}
  function adActions(x){var key=statusKey(x);if(key==='paid')return '<span class="done">확인완료</span>';if(key==='expired')return '<span class="rejected">기한만료</span>';if(key==='cancelled'||key==='rejected')return '<span class="rejected">취소됨</span>';if(x.status!=='new')return '<span class="payment-muted">처리완료</span>';var base=x.source==='banner_request'?'banner-requests':'ad-requests';var html=key==='waiting'?'<form method="post" action="/admin/'+base+'/'+esc(x.id)+'/payment-confirm" class="payment-confirm-form"><input name="paid_usdt_amount" placeholder="실제 USDT" value="'+esc(x.usdt_amount||'')+'"><input name="payment_txid" placeholder="TXID / 거래해시"><input name="admin_memo" placeholder="입금확인 메모"><button class="approve-btn">입금확인</button></form>':'<span class="pending">입금대기</span>';html+='<form method="post" action="/admin/'+base+'/'+esc(x.id)+'/reject" class="report-done-form" style="margin-top:8px"><input name="admin_memo" placeholder="반려 사유"><button class="reject-btn">반려</button></form><form method="post" action="/admin/'+base+'/'+esc(x.id)+'/cancel" class="report-done-form" style="margin-top:8px"><input name="admin_memo" placeholder="취소 메모"><button class="cancel-edit">취소</button></form>';return html;}
