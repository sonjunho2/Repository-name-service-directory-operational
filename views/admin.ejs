  function koreanizeBadges(root){
    (root||document).querySelectorAll('.role-badge,.status-pending,.status-on,.status-off,.ad-badge').forEach(function(el){
      var t=String(el.textContent||'').trim();
      if(labelMap[t])el.textContent=labelMap[t];
    });
  }

  function run(){
    koreanizeSelects(document);
    koreanizeBadges(document);
  }

  document.addEventListener('DOMContentLoaded',function(){
    run();
    setTimeout(run,400);
    setTimeout(run,1000);
  });
  window.addEventListener('hashchange',function(){setTimeout(run,300);});
  document.addEventListener('click',function(){setTimeout(run,300);},true);

  var mo=new MutationObserver(function(muts){
    var need=false;
    muts.forEach(function(m){if(m.addedNodes&&m.addedNodes.length)need=true;});
    if(need)setTimeout(run,80);
  });
  document.addEventListener('DOMContentLoaded',function(){
    mo.observe(document.body,{childList:true,subtree:true});
  });
})();
