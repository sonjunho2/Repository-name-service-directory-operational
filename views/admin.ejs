<script>
(function(){
  if(window.__adminDatePickerEnhance)return;
  window.__adminDatePickerEnhance=true;
  function openNativeDatePicker(input){
    if(!input)return;
    try{
      if(typeof input.showPicker==='function'){ input.showPicker(); return; }
    }catch(e){}
    try{ input.focus(); input.click(); }catch(e){ try{ input.focus(); }catch(_){} }
  }
  function enhanceDateInput(input){
    if(!input||input.dataset.dateEnhanced==='1')return;
    input.dataset.dateEnhanced='1';
    input.classList.add('admin-date-input');
    input.setAttribute('autocomplete','off');
    if(!input.getAttribute('title'))input.setAttribute('title','달력에서 날짜를 선택하세요.');
    var wrap=input.closest('.admin-date-wrap');
    if(!wrap){
      wrap=document.createElement('div');
      wrap.className='admin-date-wrap';
      input.parentNode.insertBefore(wrap,input);
      wrap.appendChild(input);
    }
    if(!wrap.querySelector('.admin-date-pick-btn')){
      var btn=document.createElement('button');
      btn.type='button';
      btn.className='admin-date-pick-btn';
      btn.setAttribute('aria-label','달력 열기');
      btn.title='달력 열기';
      btn.textContent='📅';
      btn.addEventListener('click',function(e){e.preventDefault();e.stopPropagation();openNativeDatePicker(input);});
      wrap.appendChild(btn);
    }
    input.addEventListener('focus',function(){openNativeDatePicker(input);});
  }
  function enhanceAdminDatePickers(){
    document.querySelectorAll('.admin-content input[type="date"]').forEach(enhanceDateInput);
  }
  document.addEventListener('DOMContentLoaded',enhanceAdminDatePickers);
  document.addEventListener('click',function(e){
    if(e.target&&e.target.matches('.admin-content input[type="date"]'))openNativeDatePicker(e.target);
  },true);
  window.enhanceAdminDatePickers=enhanceAdminDatePickers;
})();
</script>

<script>
(function(){
  if(window.__notificationCenterV63)return;
  window.__notificationCenterV63=true;
  var root=document.getElementById('adminNotificationCenter');
  if(!root)return;
  var btn=document.getElementById('adminNotifyBtn');
  var count=document.getElementById('adminNotifyCount');
  var list=document.getElementById('adminNotifyList');
  var readAll=document.getElementById('adminNotifyReadAll');
  var soundBtn=document.getElementById('adminNotifySound');
  var lastUnread=null;
  var firstLoad=true;
  var soundOn=localStorage.getItem('adminNotifySoundV64')!=='0';
  var audioUnlocked=false;
  function updateSoundBtn(){if(!soundBtn)return;soundBtn.textContent=soundOn?'알림음 ON':'알림음 OFF';soundBtn.classList.toggle('on',soundOn);soundBtn.classList.toggle('off',!soundOn);}
  function unlockAudio(){audioUnlocked=true;try{var C=window.AudioContext||window.webkitAudioContext;if(C){var c=new C();if(c.state==='suspended')c.resume();setTimeout(function(){try{c.close();}catch(e){}},80);}}catch(e){}}
  document.addEventListener('pointerdown',unlockAudio,{once:true});
  function esc(s){return String(s||'').replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});}
  function fmt(v){try{return new Date(v).toLocaleString('ko-KR',{hour12:false});}catch(e){return '';}}
  function ring(){
    if(!soundOn)return;
    // 브라우저 정책상 관리자 페이지에서 한 번 클릭/터치 후부터 소리가 납니다.
    if(!audioUnlocked)return;
    try{
      var C=window.AudioContext||window.webkitAudioContext;if(!C)return;
      var ctx=new C();if(ctx.state==='suspended')ctx.resume();
      var osc=ctx.createOscillator(),gain=ctx.createGain();
      osc.type='sine';osc.frequency.value=880;gain.gain.value=.06;osc.connect(gain);gain.connect(ctx.destination);osc.start();
      setTimeout(function(){try{osc.stop();ctx.close();}catch(e){}},180);
    }catch(e){}
  }
  function flash(){
    if(btn){btn.classList.add('pulse');setTimeout(function(){btn.classList.remove('pulse');},1600);}
  }
  async function load(silent){
    try{
      var r=await fetch('/api/notifications?ts='+Date.now(),{headers:{'Accept':'application/json','Cache-Control':'no-cache'},credentials:'same-origin',cache:'no-store'});
      var j=await r.json();
      if(!j.ok)throw new Error(j.error||'failed');
      var unread=Number(j.unread||0);
      count.textContent=unread;
      btn.classList.toggle('has-unread',unread>0);
      var items=j.items||[];
      if(!items.length){list.innerHTML='<div class="admin-notify-empty">새 알림이 없습니다.</div>';}
      else{
        list.innerHTML=items.map(function(x){
          var href=x.link_url||'#';
          return '<a class="admin-notify-item '+(x.is_read?'':'unread')+'" href="'+esc(href)+'" data-id="'+x.id+'"><b>'+esc(x.title||'알림')+'</b><p>'+esc(x.message||'')+'</p><small>'+esc(fmt(x.created_at))+'</small></a>';
        }).join('');
      }
      if(!firstLoad && !silent && lastUnread!==null && unread>lastUnread){
        if(typeof toast==='function')toast('새 알림이 도착했습니다.','ok','미확인 '+unread+'건');
        flash();
        ring();
      }
      lastUnread=unread;
      firstLoad=false;
    }catch(e){
      list.innerHTML='<div class="admin-notify-empty">알림을 불러오지 못했습니다.</div>';
    }
  }
  btn.addEventListener('click',function(e){e.preventDefault();root.classList.toggle('open');load(true);});
  document.addEventListener('click',function(e){if(!root.contains(e.target))root.classList.remove('open');});
  list.addEventListener('click',function(e){
    var a=e.target.closest('.admin-notify-item');
    if(!a)return;
    fetch('/api/notifications/'+a.dataset.id+'/read',{method:'POST',credentials:'same-origin'}).catch(function(){});
  });
  if(readAll)readAll.addEventListener('click',async function(e){e.preventDefault();await fetch('/api/notifications/read-all',{method:'POST',credentials:'same-origin'}).catch(function(){});load(true);});
  if(soundBtn)soundBtn.addEventListener('click',function(e){e.preventDefault();soundOn=!soundOn;localStorage.setItem('adminNotifySoundV64',soundOn?'1':'0');updateSoundBtn();unlockAudio();});
  updateSoundBtn();
  load(true);
  setInterval(function(){load(false);},5000);
})();
</script>


<script>
(function(){
