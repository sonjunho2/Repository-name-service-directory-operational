<script>
(function(){
  if(window.__adminVendorRequestsModuleV2)return;
  window.__adminVendorRequestsModuleV2=true;
  var panel=document.getElementById('vendorRequests'),body=document.getElementById('vendorRequestTableBody'),pager=document.getElementById('vendorRequestPager');
  if(!panel||!body||!pager)return;
  var currentPage=1,currentStatus='all',currentSort='latest',currentSearch='',loading=false,searchTimer=null,limit=20,vendorRequestBodyOverflow='';
  var reviewModal=document.getElementById('vendorRequestReviewModal'),reviewBody=document.getElementById('vendorRequestReviewModalBody'),reviewSubtitle=panel.querySelector('[data-vendor-request-modal-subtitle]'),vendorRequestsById=new Map();
  var fieldMap=[['name','current_vendor_name','업체명'],['category','current_category','업종'],['region','current_region','지역'],['phone','current_phone','연락처'],['kakao_url','current_kakao_url','카카오'],['business_hours','current_business_hours','영업시간'],['tags','current_tags','태그'],['description','current_description','업체소개'],['sns_url','current_sns_url','SNS'],['line_url','current_line_url','LINE'],['telegram_url','current_telegram_url','텔레그램'],['holiday_info','current_holiday_info','휴무정보']];
  function esc(v){return String(v==null?'':v).replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});}
  function norm(v){return String(v==null?'':v).trim();}
  function shown(v){return norm(v)||'미입력';}
  function dt(v){if(!v)return '-';var d=new Date(v);return isNaN(d.getTime())?'-':d.toLocaleString('ko-KR',{hour12:false});}
  function fields(x){var result=fieldMap.map(function(f){var before=norm(x[f[1]]),after=norm(x[f[0]]);return {label:f[2],before:before,after:after,changed:before!==after};});if(x.has_image_data)result.push({label:'대표 이미지',before:'',after:'',changed:true,image:true});return result;}
  function statusText(v){return v==='approved'?'승인완료':v==='rejected'?'반려':v==='cancelled'?'취소':'승인대기';}
  function connectionProblems(x){var a=[];if(!x.vendor_exists)a.push('업체 없음');if(!x.user_exists)a.push('회원 없음');if(x.user_exists&&!x.link_matches_vendor)a.push('업체 연결 불일치');if(x.user_exists&&x.user_status!=='active')a.push('사용중지 회원');if(x.user_exists&&(!x.user_is_vendor||!x.linked_vendor_id))a.push('업체회원 연결 없음');return a;}
  function actions(x){if(x.status!=='new')return '<span class="done">처리완료</span>';var danger=connectionProblems(x).length||Number(x.changed_count||0)===0;var confirmText=danger?'회원 또는 업체 연결 상태에 문제가 있습니다. 상세 내용을 확인했습니다. 계속 승인할까요?':'현재 업체정보를 요청 내용으로 변경할까요?';return '<div class="vendor-request-actions"><form method="post" action="/admin/vendor-requests/'+esc(x.id)+'/approve" class="vendor-request-action-form"><input name="admin_memo" placeholder="승인 메모"><button class="approve-btn" onclick="if(!confirm(&quot;'+esc(confirmText)+'&quot;))return false;this.form.dataset.safeConfirmDone=\'1\'">변경 승인</button></form><form method="post" action="/admin/vendor-requests/'+esc(x.id)+'/reject" class="vendor-request-action-form"><input name="admin_memo" placeholder="반려 사유" required><button class="reject-btn" onclick="if(!confirm(&quot;이 업체정보 수정요청을 반려할까요?&quot;))return false;this.form.dataset.safeConfirmDone=\'1\'">반려</button></form></div>';}
  function row(x){var changed=fields(x).filter(function(f){return f.changed;}),labels=changed.map(function(f){return f.label;}),visibleFields=labels.slice(0,3),remaining=Math.max(0,labels.length-3),problems=connectionProblems(x),badges=visibleFields.map(function(v){return '<span class="change-field-badge">'+esc(v)+'</span>';}).join('');if(remaining)badges+='<span class="change-field-badge">외 '+remaining+'개</span>';if(!badges)badges='<span class="change-field-badge">실제 변경 없음</span>';var linkBadge='<span class="vendor-request-link-badge '+(problems.length?'warning':'safe')+'">'+(problems.length?'연결 확인 필요':'연결 정상')+'</span>';return '<tr class="vendor-request-row"><td><b>#'+esc(x.id)+'</b><br><small>'+esc(dt(x.created_at))+(x.processed_at?'<br>처리 '+esc(dt(x.processed_at)):'')+'</small></td><td>'+esc(x.username||'회원 없음')+'<br><small>'+esc(x.nickname||'-')+'</small><br>'+linkBadge+'</td><td><b>'+esc(x.vendor_exists?(x.current_vendor_name||x.name||'-'):'업체 없음')+'</b></td><td><small>변경 '+changed.length+'개</small><div class="vendor-request-change-badges">'+badges+'</div></td><td><span class="vendor-request-status '+esc(x.status||'new')+'">'+esc(statusText(x.status))+'</span>'+(x.admin_memo?'<span class="vendor-request-memo-clamp">'+esc(x.admin_memo)+'</span>':'')+'</td><td><div class="vendor-request-actions"><button type="button" data-vendor-request-review="'+esc(x.id)+'">요청 검토</button>'+actions(x)+'</div></td></tr>';}
  function comparison(x){var changed=fields(x).filter(function(f){return f.changed;});if(!changed.length)return '<div class="vendor-request-no-change">실제로 변경 요청된 정보가 없습니다.</div>';return '<div class="vendor-request-comparison"><div class="vendor-request-comparison-head"><span>항목</span><span>현재 정보</span><span>요청 정보</span></div>'+changed.map(function(f){var requested=f.image?'<button type="button" class="image-preview-btn vendor-request-image-btn" data-src="/admin/vendor-requests/'+esc(x.id)+'/image" data-title="'+esc(x.current_vendor_name||x.name||'업체')+' 요청 대표 이미지">요청 이미지 보기</button>':esc(shown(f.after));return '<div class="vendor-request-comparison-row"><b>'+esc(f.label)+'</b><div class="vendor-request-comparison-current">'+(f.image?'기존 이미지 유지':esc(shown(f.before)))+'</div><div class="vendor-request-comparison-requested">'+requested+'</div></div>';}).join('')+'</div>';}
  function reviewContent(x){var problems=connectionProblems(x),connection=problems.length?'<div class="vendor-request-warning-box"><b>연결상태 확인 필요</b><div>'+esc(problems.join(' · '))+'</div></div>':'<span class="vendor-request-link-badge safe">연결 정상</span>';return '<div class="vendor-request-review-grid"><section class="vendor-request-review-section"><h4>요청 정보</h4><dl><dt>요청 ID</dt><dd>#'+esc(x.id)+'</dd><dt>요청일</dt><dd>'+esc(dt(x.created_at))+'</dd><dt>현재 처리상태</dt><dd>'+esc(statusText(x.status))+'</dd><dt>처리일</dt><dd>'+esc(dt(x.processed_at))+'</dd><dt>관리자 메모</dt><dd>'+esc(shown(x.admin_memo))+'</dd></dl></section><section class="vendor-request-review-section"><h4>요청 회원</h4><dl><dt>회원 아이디</dt><dd>'+esc(x.username||'회원 없음')+'</dd><dt>닉네임</dt><dd>'+esc(x.nickname||'-')+'</dd><dt>회원 상태</dt><dd>'+esc(x.user_status||'-')+'</dd><dt>회원 유형</dt><dd>'+(x.user_is_vendor?'업체회원':'일반회원')+'</dd><dt>기존 연결 업체</dt><dd>'+esc(x.linked_vendor_id?'업체 #'+x.linked_vendor_id:'없음')+'</dd></dl></section><section class="vendor-request-review-section"><h4>대상 업체</h4><dl><dt>업체 존재 여부</dt><dd>'+(x.vendor_exists?'존재':'업체 없음')+'</dd><dt>현재 업체명</dt><dd>'+esc(x.current_vendor_name||'-')+'</dd><dt>요청 대상 업체</dt><dd>'+esc(x.vendor_id?'업체 #'+x.vendor_id:'없음')+'</dd><dt>회원 연결 업체</dt><dd>'+esc(x.linked_vendor_id?'업체 #'+x.linked_vendor_id:'없음')+'</dd><dt>연결 일치 여부</dt><dd>'+(x.link_matches_vendor?'일치':'확인 필요')+'</dd></dl></section><section class="vendor-request-review-section"><h4>연결상태 검토</h4>'+connection+'</section><section class="vendor-request-review-section wide"><h4>변경 전·후 비교</h4>'+comparison(x)+'</section></div>';}
  function openReview(x){if(!x)return;reviewSubtitle.textContent='#'+x.id+' · '+(x.current_vendor_name||x.name||'업체 없음');reviewBody.innerHTML=reviewContent(x);vendorRequestBodyOverflow=document.body.style.overflow;reviewModal.hidden=false;document.body.style.overflow='hidden';}
  function closeReview(){reviewModal.hidden=true;reviewBody.innerHTML='';reviewSubtitle.textContent='';document.body.style.overflow=vendorRequestBodyOverflow;}
  window.closeVendorRequestReviewModal=closeReview;
  function query(){var p=new URLSearchParams({page:String(currentPage),limit:String(limit),status:currentStatus,sort:currentSort});if(currentSearch)p.set('q',currentSearch);return p;}
  function drawPager(data){pager.innerHTML='';function add(label,page,disabled,active){var b=document.createElement('button');b.type='button';b.textContent=label;b.disabled=disabled;b.classList.toggle('active',active);b.addEventListener('click',function(){loadVendorRequests(page);});pager.appendChild(b);}add('이전',data.page-1,data.page<=1,false);for(var n=Math.max(1,data.page-2);n<=Math.min(data.totalPages,data.page+2);n++)add(String(n),n,false,n===data.page);add('다음',data.page+1,data.page>=data.totalPages,false);var s=document.createElement('span');s.className='server-vendor-info';s.textContent='총 '+data.total+'건 · '+data.page+'/'+data.totalPages+'페이지';pager.appendChild(s);}
  async function loadVendorRequests(page){if(loading)return false;currentPage=Math.max(1,Number(page||currentPage));currentSearch=(document.getElementById('vendorRequestSearch').value||'').trim();currentStatus=document.getElementById('vendorRequestStatus').value||'all';currentSort=document.getElementById('vendorRequestSort').value||'latest';loading=true;body.innerHTML='<tr><td colspan="6">업체 수정요청을 불러오는 중입니다.</td></tr>';try{var res=await fetch('/admin/api/vendor-update-requests?'+query().toString(),{credentials:'same-origin',cache:'no-store',headers:{Accept:'application/json','X-Requested-With':'fetch'}}),data=await res.json();if(!res.ok||!data.ok)throw new Error(data.error||'load_failed');if(currentPage>Math.max(1,Number(data.totalPages||1))){loading=false;return loadVendorRequests(Math.max(1,Number(data.totalPages||1)));}vendorRequestsById.clear();(data.rows||[]).forEach(function(item){vendorRequestsById.set(String(item.id),item);});body.innerHTML=(data.rows||[]).map(row).join('')||'<tr><td colspan="6">조건에 맞는 업체 수정요청이 없습니다.</td></tr>';Object.keys(data.summary||{}).forEach(function(k){var el=panel.querySelector('[data-vendor-request-summary="'+k+'"]');if(el)el.textContent=Number(data.summary[k]||0).toLocaleString();});drawPager(data);window.setAdminListState?.('vendorRequests',{page:currentPage,q:currentSearch,status:currentStatus,sort:currentSort});return true;}catch(e){body.innerHTML='<tr><td colspan="6">업체 수정요청을 불러오지 못했습니다.</td></tr>';return false;}finally{loading=false;}}
