xt){if(!box)return;const img=box.querySelector('img');const span=box.querySelector('span');if(src){img.src=src;box.style.display='flex';if(span)span.textContent=text||'선택한 이미지가 표시됩니다.';}else{box.style.display='none';if(img)img.removeAttribute('src');}}function bindPreview(input,box){if(!input)return;input.addEventListener('change',()=>{const f=input.files&&input.files[0];if(!f)return showPreview(box,null);showPreview(box,URL.createObjectURL(f),'새로 선택한 이미지입니다.');});}const vf=document.getElementById('vendorForm'),bf=document.getElementById('bannerForm');bindPreview(vf?.image,document.getElementById('vendorImagePreview'));bindPreview(bf?.image,document.getElementById('bannerImagePreview'));document.querySelectorAll('.edit-vendor-btn').forEach(btn=>btn.onclick=()=>{const v=ADMIN_VENDORS.find(x=>String(x.id)===String(btn.dataset.id));if(!v)return;showAdminPanel('vendors');vf.id.value=v.id||'';vf.name.value=v.name||'';vf.category.value=v.category||'';vf.region.value=v.region||'';vf.phone.value=v.phone||'';vf.kakao_url.value=v.kakao_url||'';vf.business_hours.value=v.business_hours||'';vf.tags.value=v.tags||'';vf.status.value=v.status||'active';vf.description.value=v.description||'';vf.is_recommended.checked=!!v.is_recommended;vf.is_premium.checked=!!v.is_premium;showPreview(document.getElementById('vendorImagePreview'),v.image_data,'현재 등록된 업체 이미지입니다. 새 파일 선택 시 교체됩니다.');vendorSubmitBtn.textContent='업체 수정';cancelVendorEdit.style.display='block';vf.scrollIntoView({behavior:'smooth'})});cancelVendorEdit.onclick=()=>{vf.reset();vf.id.value='';showPreview(document.getElementById('vendorImagePreview'),null);vendorSubmitBtn.textContent='업체 등록';cancelVendorEdit.style.display='none'};document.querySelectorAll('.edit-banner-btn').forEach(btn=>btn.onclick=()=>{const b=ADMIN_BANNERS.find(x=>String(x.id)===String(btn.dataset.id));if(!b)return;showAdminPanel('banners');bf.id.value=b.id||'';bf.title.value=b.title||'';bf.subtitle.value=b.subtitle||'';bf.link_url.value=b.link_url||'';bf.sor