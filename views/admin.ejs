    else if(key==='boardComments'){set('boardCommentSearch',s.q);set('boardCommentBoardFilter',s.board_id);set('boardCommentStatusFilter',s.status);set('boardCommentSort',s.sort);}
    else if(key==='adInquiries'){set('adInquirySearch',s.q);set('adInquiryStatus',s.status);}
    return s;
  };
  window.normalizeAdminListPage=function(key,data,reload){var pages=Math.max(1,Number(data?.totalPages||1)),page=Math.max(1,Number(data?.page||1));if(page>pages){window.setAdminListState(key,{page:pages});setTimeout(function(){reload(pages);},0);return true;}return false;};
  window.reloadAdminPanelList=function(key){var map={vendors:'loadAdminVendors',users:'loadAdminUsers',inquiries:'loadAdminInquiries',reports:'loadAdminReports',banners:'loadAdminBanners',notices:'loadAdminNotices',reviews:'loadAdminReviews',adminLogs:'loadAdminLogs',vendorRequests:'loadAdminVendorRequests',adCenter:'loadAdminAdCenter',payments:'loadAdminPayments',boardPosts:'loadAdminBoardPosts',boardComments:'loadAdminBoardComments',adInquiries:'loadAdminAdInquiries'};var fn=window[map[key]];if(typeof fn==='function')return fn(window.getAdminListState(key).page||1);};
  ['vendors','users','inquiries','reports','payments','vendorRequests'].forEach(function(key){try{window.restoreAdminListControls(key);}catch(err){console.error('admin list state restore failed:',key,err);}});
  document.addEventListener('submit',function(e){var form=e.target;if(!form||!form.closest('.admin-content'))return;var action=String(form.getAttribute('action')||'');if(action.includes('/settings/')||action.includes('/restore-json')||action.includes('/backup')||action.includes('/logout'))return;var key=window.getPanelKeyFromActivePanel();window.saveActiveAdminListState(key,window.getAdminListState(key).page||1);try{sessionStorage.setItem('adminReturnPanel',key);}catch(err){}},true);
})();
