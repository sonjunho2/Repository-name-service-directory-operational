  }
  function showTableMessage(table,msg,cls){
    var body=document.getElementById('vendorTableBody');
    if(body)body.innerHTML='<tr class="'+(cls||'loading-row')+'"><td colspan="7">'+esc(msg)+'</td></tr>';
  }
  function addPageNumbers(pager,page,totalPages){
    var start=Math.max(1,page-2);
    var end=Math.min(totalPages,start+4);
    start=Math.max(1,end-4);
    if(start>1){
      pager.appendChild(makePagerButton('1',false,page===1,function(){loadVendors(1);}));
      if(start>2){
        var dots=document.createElement('span');
        dots.className='dots';
        dots.textContent='...';
        pager.appendChild(dots);
      }
    }
    for(var p=start;p<=end;p++){
      (function(n){
        pager.appendChild(makePagerButton(String(n),false,n===page,function(){loadVendors(n);}));
      })(p);
    }
    if(end<totalPages){
      if(end<totalPages-1){
        var dots2=document.createElement('span');
        dots2.className='dots';
        dots2.textContent='...';
        pager.appendChild(dots2);
      }
      pager.appendChild(makePagerButton(String(totalPages),false,page===totalPages,function(){loadVendors(totalPages);}));
    }
  }
  async function loadVendors(page){
    page=page||Number(window.getAdminListState?.('vendors').page||1);
    if(vendorLoading){clearTimeout(vendorSearchTimer);return new Promise(function(resolve){vendorSearchTimer=setTimeout(async function(){resolve(await loadVendors(page));},100);});}
    var panel=document.getElementById('vendors');
    if(!panel)return false;
    var table=document.getElementById('vendorManagementTable');
    if(!table)return false;
    var pager=ensurePager(table);
