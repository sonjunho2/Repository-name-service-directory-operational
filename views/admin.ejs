<div id="adminLogSummaryGrid" class="admin-log-summary-grid"><button type="button" data-admin-log-card="all"><b>전체 로그</b><strong data-admin-log-summary="total">0</strong></button><button type="button" data-admin-log-card="today"><b>오늘 작업</b><strong data-admin-log-summary="today">0</strong></button><button type="button" data-admin-log-card="week"><b>최근 7일</b><strong data-admin-log-summary="last7Days">0</strong></button><button type="button" data-admin-log-card="vendor"><b>업체 관련</b><strong data-admin-log-summary="vendorActions">0</strong></button><button type="button" data-admin-log-card="user"><b>회원 관련</b><strong data-admin-log-summary="userActions">0</strong></button><button type="button" data-admin-log-card="finance"><b>결제·광고 관련</b><strong data-admin-log-summary="paymentAdActions">0</strong></button></div>
<div class="admin-log-filter"><input id="adminLogSearch" placeholder="로그 ID / 관리자 / 작업 / 대상 / 메모 검색"><select id="adminLogAdminFilter"><option value="all">전체 관리자</option></select><select id="adminLogActionFilter"><option value="all">전체 작업</option></select><select id="adminLogTargetFilter"><option value="all">전체 대상</option></select><input id="adminLogDateFrom" type="date" aria-label="시작일"><input id="adminLogDateTo" type="date" aria-label="종료일"><select id="adminLogSort"><option value="latest">최신 작업순</option><option value="oldest">오래된 작업순</option><option value="admin">관리자순</option><option value="action">작업명순</option><option value="target">대상 유형순</option></select><button type="button" id="adminLogFilterReset">초기화</button></div>
<div class="admin-log-table-wrap"><table id="adminLogManagementTable"><colgroup><col style="width:85px"><col style="width:175px"><col style="width:150px"><col style="width:210px"><col style="width:190px"><col style="width:430px"><col style="width:90px"></colgroup><thead><tr><th>로그 ID</th><th>작업시간</th><th>관리자</th><th>작업</th><th>대상</th><th>메모</th><th>상세</th></tr></thead><tbody id="adminLogTableBody"><tr class="loading-row"><td colspan="7">관리자 로그를 불러오는 중입니다.</td></tr></tbody></table></div><div id="adminLogPager" class="server-admin-log-pager"></div></section><section id="settings" class="panel admin-panel">
  <h2>환경설정</h2>

  <div class="settings-tabs">
    <button type="button" class="settings-tab active" data-settings-tab="basic">기본설정</button>
    <button type="button" class="settings-tab" data-settings-tab="payment">결제·광고설정</button>
    <button type="button" class="settings-tab" data-settings-tab="admin">관리자 계정관리</button>
    <button type="button" class="settings-tab" data-settings-tab="data">데이터 관리</button>
  </div>

  <div id="settings-basic" class="settings-panel active">
    <div class="settings-safe-notice">
      <b>운영 설정 안내</b>
      <span>브랜딩과 업종/지역은 메인 화면 표시에만 반영됩니다. 광고 결제, 승인, 만기 계산 로직은 별도로 유지됩니다.</span>
    </div>

    <form method="post" action="/admin/settings/options" enctype="multipart/form-data" class="settings-form">
      <input type="hidden" name="settings_section" value="basic">

      <div class="settings-box brand-settings-box" style="margin-bottom:18px">
        <h3 class="settings-section-title">사이트 브랜딩</h3>

        <div class="brand-config-section">
          <h4>기본 정보 / 이미지 등록</h4>
          <div class="brand-form-grid">
            <label for="siteNameInput">사이트명</label>
            <input id="siteNameInput" name="site_name" value="<%=(settings?.raw?.site_name)||'서비스 디렉터리'%>" placeholder="사이트명">

            <label for="siteLinkInput">링크 주소</label>
            <input id="siteLinkInput" name="site_link_url" value="<%=(settings?.raw?.site_link_url)||'/'%>" placeholder="/">

            <label>로고 이미지</label>
            <div class="brand-upload-row">
              <input type="file" name="site_logo" accept="image/*">
              <% if(settings?.raw?.site_logo_data){%><label class="brand-remove-check"><input type="checkbox" name="remove_site_logo"> 현재 로고 삭제</label><%}%>
            </div>

            <label>파비콘 이미지</label>
            <div class="brand-upload-row">
              <input type="file" name="site_favicon" accept="image/*">
              <% if(settings?.raw?.site_favicon_data){%><label class="brand-remove-check"><input type="checkbox" name="remove_site_favicon"> 현재 파비콘 삭제</label><%}%>
            </div>
          </div>

          <div class="brand-unified-preview-card">
            <b>브랜딩 미리보기</b>
            <div class="brand-unified-preview-header">
              <img class="brand-unified-preview-logo" <% if(settings?.raw?.site_logo_data){%>src="<%=settings.raw.site_logo_data%>"<%}%> alt="로고 미리보기">
              <span class="brand-unified-preview-name"><%=(settings?.raw?.site_name)||'서비스 디렉터리'%></span>
              <span class="brand-unified-preview-empty">브랜드 표시가 꺼져 있습니다.</span>
            </div>
            <div class="brand-unified-preview-meta">
              <img class="brand-unified-preview-favicon" <% if(settings?.raw?.site_favicon_data){%>src="<%=settings.raw.site_favicon_data%>"<%}%> alt="파비콘 미리보기">
              <span class="brand-unified-preview-favicon-default">기본</span>
              <span>링크: <span class="brand-unified-preview-link"><%=(settings?.raw?.site_link_url)||'/'%></span></span>
            </div>
          </div>
        </div>

        <div class="brand-config-section brand-display-section">
          <h4>표시 설정</h4>
          <div class="brand-display-options">
            <label><input type="checkbox" name="brand_show_logo" <%=settings?.raw?.brand_show_logo==='on'?'checked':''%>> 로고 사용</label>
            <label><input type="checkbox" name="brand_show_name" <%=settings?.raw?.brand_show_name==='off'?'':'checked'%>> 사이트명 사용</label>
          </div>
          <div class="brand-size-controls">
            <div class="brand-size-row"><label for="brandLogoHeightInput">로고 높이 (px)</label><input id="brandLogoHeightInput" type="number" name="brand_logo_height" min="24" max="120" step="1" value="<%=(settings?.raw?.brand_logo_height)||56%>"></div>
            <div class="brand-size-row"><label for="brandNameSizeInput">사이트명 글자 크기 (px)</label><input id="brandNameSizeInput" type="number" name="brand_name_size" min="14" max="72" step="1" value="<%=(settings?.raw?.brand_name_size)||32%>"></div>
          </div>
          <p class="settings-help">로고와 사이트명은 각각 선택해서 상단 중앙에 표시됩니다. 둘 다 꺼도 기본 사이트명은 관리자 설정값으로 유지됩니다.</p>
        </div>
      </div>
      <div class="settings-split">
        <div class="settings-box">
          <h3 class="settings-section-title">업종 관리</h3>
          <textarea name="categories" placeholder="한 줄에 하나씩 입력"><%=(settings?.raw?.categories)||''%></textarea>
          <p class="settings-help">예: 안마, 마사지, 카페처럼 한 줄에 하나씩 입력합니다.</p>
        </div>

        <div class="settings-box">
          <h3 class="settings-section-title">지역 관리</h3>
          <textarea name="regions" placeholder="한 줄에 하나씩 입력"><%=(settings?.raw?.regions)||''%></textarea>
          <p class="settings-help">메인페이지 업종/지역 선택과 검색창에 바로 반영됩니다.</p>
        </div>
      </div>

      <button style="margin-top:16px">기본설정 저장</button>
    </form>
  </div>

  <div id="settings-payment" class="settings-panel">
    <form method="post" action="/admin/settings/options" class="settings-form">
      <input type="hidden" name="settings_section" value="payment">

      <div class="settings-box">
        <h3 class="settings-section-title">USDT 결제 설정</h3>
        <style>
          .usdt-rate-status{display:grid;grid-template-columns:1.2fr 1fr 1fr auto;gap:10px;margin:0 0 16px;padding:14px;border:1px solid #10d9ff;border-radius:16px;background:linear-gradient(135deg,rgba(16,217,255,.12),rgba(255,63,180,.05))}
          .usdt-rate-status div{border:1px solid #29324f;border-radius:12px;background:#070b15;padding:12px;min-height:62px}
          .usdt-rate-status b{display:block;color:#8d98b8;font-size:12px;margin-bottom:6px}
          .usdt-rate-status strong{display:block;color:#10d9ff;font-size:22px;line-height:1.15}
          .usdt-rate-status small{display:block;color:#c8d0e8;line-height:1.35}
          .usdt-rate-status button{height:100%!important;min-height:62px!important;border-radius:12px!important;background:#222b43!important}
          @media(max-width:1000px){.usdt-rate-status{grid-template-columns:1fr 1fr}.usdt-rate-status button{height:44px!important;min-height:44px!important}}
          @media(max-width:650px){.usdt-rate-status{grid-template-columns:1fr}}
        </style>
        <div class="usdt-rate-status">
          <div>
            <b>현재 적용 환율</b>
            <strong>1 USDT = <%=Number((settings?.raw?.usdt_rate_effective_value)||(settings?.raw?.usdt_krw_rate)||1400).toLocaleString()%>원</strong>
          </div>
          <div>
            <b>환율 출처</b>
            <small><%=(settings?.raw?.usdt_rate_effective_source)||'manual'%></small>
          </div>
          <div>
            <b>마지막 갱신</b>
            <small><%=(settings?.raw?.usdt_rate_effective_updated_at)||'-'%></small>
            <% if(settings?.raw?.usdt_rate_effective_error){ %><small style="color:#ffdc4d">오류: <%=settings.raw.usdt_rate_effective_error%></small><% } %>
          </div>
          <button type="button" onclick="if(confirm('USDT 환율을 지금 갱신할까요?')){const f=document.createElement('form');f.method='post';f.action='/admin/settings/usdt-rate-refresh';document.body.appendChild(f);f.submit();}">지금 환율 갱신</button>
        </div>
        <div class="settings-pay-grid">
          <label>USDT 입금주소</label>
          <input name="usdt_address" value="<%=(settings?.raw?.usdt_address)||''%>" placeholder="USDT 입금주소">

          <label>USDT 네트워크</label>
          <select name="usdt_network">
            <option value="TRC20" <%=settings?.raw?.usdt_network==='TRC20'?'selected':''%>>TRC20</option>
            <option value="ERC20" <%=settings?.raw?.usdt_network==='ERC20'?'selected':''%>>ERC20</option>
            <option value="BEP20" <%=settings?.raw?.usdt_network==='BEP20'?'selected':''%>>BEP20</option>
          </select>

          <label>자동 환율 사용</label>
          <label style="justify-content:flex-start"><input type="checkbox" name="usdt_rate_auto" <%=settings?.raw?.usdt_rate_auto==='off'?'':'checked'%>> 자동으로 최신 USDT/KRW 적용</label>

          <label>환율 출처</label>
          <select name="usdt_rate_source">
            <option value="auto" <%=(!settings?.raw?.usdt_rate_source||settings.raw.usdt_rate_source==='auto')?'selected':''%>>자동 선택</option>
            <option value="upbit" <%=settings?.raw?.usdt_rate_source==='upbit'?'selected':''%>>업비트</option>
            <option value="bithumb" <%=settings?.raw?.usdt_rate_source==='bithumb'?'selected':''%>>빗썸</option>
          </select>

          <label>보정률</label>
          <input name="usdt_rate_margin_percent" type="number" step="0.1" min="-10" max="10" value="<%=(settings?.raw?.usdt_rate_margin_percent)||0%>" placeholder="예: 1">

          <label>수동 기준값</label>
          <input name="usdt_krw_rate" type="number" value="<%=(settings?.raw?.usdt_krw_manual_rate)||(settings?.raw?.usdt_krw_rate)||1400%>" placeholder="자동 실패 시 사용할 값">

          <label>기본 등록기간</label>
          <input name="default_register_days" type="number" value="<%=(settings?.raw?.default_register_days)||30%>">

          <label>결제요청 만료시간</label>
          <input name="payment_expire_hours" type="number" min="1" max="168" value="<%=(settings?.raw?.payment_expire_hours)||24%>" placeholder="예: 24">
        </div>
        <p class="settings-help">자동 환율 사용 시 결제 신청 생성 시점의 환율로 USDT 금액이 고정됩니다. 미입금 상태로 결제요청 만료시간이 지나면 자동 취소됩니다. 자동 조회 실패 시 마지막 성공 환율, 그 다음 수동 기준값 순서로 적용됩니다.</p>
      </div>

      <div class="settings-box" style="margin-top:18px">
        <h3 class="settings-section-title">상품 가격 설정</h3>
        <div class="settings-pay-grid">
          <label>일반등록 가격</label>
          <input name="general_register_price_krw" type="number" value="<%=(settings?.raw?.general_register_price_krw)||30000%>">

          <label>추천등록 가격</label>
          <input name="recommended_register_price_krw" type="number" value="<%=(settings?.raw?.recommended_register_price_krw)||70000%>">

          <label>일반 → 추천 업그레이드 가격</label>
          <input name="general_to_recommended_price_krw" type="number" value="<%=(settings?.raw?.general_to_recommended_price_krw)||40000%>">

          <label>일반 → 프리미엄배너 가격</label>
          <input name="general_to_banner_price_krw" type="number" value="<%=(settings?.raw?.general_to_banner_price_krw)||100000%>">

          <label>추천 → 프리미엄배너 가격</label>
          <input name="recommended_to_banner_price_krw" type="number" value="<%=(settings?.raw?.recommended_to_banner_price_krw)||70000%>">

          <label>기존 배너 가격</label>
          <input name="banner_price_krw" type="number" value="<%=(settings?.raw?.banner_price_krw)||100000%>">

          <label>기존 광고연장 30일 가격</label>
          <input name="ad_price_krw_30" type="number" value="<%=(settings?.raw?.ad_price_krw_30)||100000%>">

          <label>기존 광고연장 60일 가격</label>
          <input name="ad_price_krw_60" type="number" value="<%=(settings?.raw?.ad_price_krw_60)||180000%>">

          <label>기존 광고연장 90일 가격</label>
          <input name="ad_price_krw_90" type="number" value="<%=(settings?.raw?.ad_price_krw_90)||250000%>">
        </div>
        <p class="settings-help">USDT 수량 = 원화가격 / USDT 원화 기준값으로 계산됩니다.</p>
      </div>

      <button style="margin-top:16px">결제설정 저장</button>
    </form>
  </div>

  <div id="settings-admin" class="settings-panel">
      <div class="settings-box admin-accounts-box">
        <h3 class="settings-section-title">관리자 계정 관리</h3>
        <div class="admin-account-summary" id="adminAccountSummary"><div><b>전체 관리자</b><strong data-admin-account-summary="total">0</strong></div><div><b>사용중</b><strong data-admin-account-summary="active">0</strong></div><div><b>사용중지</b><strong data-admin-account-summary="suspended">0</strong></div></div>
        <form method="post" action="/admin/settings/admin-accounts/create" class="settings-form admin-account-create" data-admin-account-form="create" data-local-admin-ajax autocomplete="off">
          <div class="admin-account-create-grid"><input name="username" placeholder="관리자 아이디" autocomplete="off" required><input name="nickname" placeholder="관리자 닉네임" maxlength="50" required><label class="admin-password-field"><input name="password" type="password" placeholder="초기 비밀번호" autocomplete="new-password" required><button type="button" data-admin-password-toggle="password" aria-label="초기 비밀번호 보기">보기</button></label><label class="admin-password-field"><input name="password_confirm" type="password" placeholder="비밀번호 확인" autocomplete="new-password" required><button type="button" data-admin-password-toggle="password_confirm" aria-label="비밀번호 확인 보기">보기</button></label></div><div class="admin-password-tools"><button type="button" data-admin-password-generate="create">임시 비밀번호 생성</button><button type="button" data-admin-password-copy="password">비밀번호 복사</button></div><button>관리자 추가</button>
        </form>
        <div class="admin-account-table-wrap"><table class="admin-account-table"><thead><tr><th>ID</th><th>관리자 계정</th><th>상태</th><th>현재 세션</th><th>관리</th></tr></thead><tbody id="adminAccountRows"><tr><td colspan="5">관리자 목록을 불러오는 중입니다.</td></tr></tbody></table></div>
      </div>

    <div class="admin-account-modal" id="adminAccountModal" hidden><div class="admin-account-modal-card"><div class="admin-account-modal-head"><h3>관리자 관리</h3><button type="button" data-admin-account-close>닫기</button></div><p id="adminAccountSelfNotice" class="settings-help" hidden>현재 로그인한 관리자 계정입니다. 사용중지와 삭제는 할 수 없습니다.</p><input type="hidden" id="managedAdminId">
      <form method="post" data-admin-account-form="update" data-local-admin-ajax class="settings-form"><h4>기본정보 수정</h4><input name="username" placeholder="관리자 아이디" required><input name="nickname" placeholder="관리자 닉네임" required><button>저장</button></form>
