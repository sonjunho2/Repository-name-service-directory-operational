<script>
(function(){
  if(window.__vendorEditDelegatedFixV31)return;
  window.__vendorEditDelegatedFixV31=true;

  function setVal(form,name,value){
    var el=form&&form.elements&&form.elements[name];
    if(!el)return;
    el.value=value==null?'':value;
  }
  function setChecked(form,name,value){
    var el=form&&form.elements&&form.elements[name];
    if(!el)return;
    el.checked=!!value;
  }
  function showPreviewSafe(src,text){
    var box=document.getElementById('vendorImagePreview');
    if(!box)return;
    var img=box.querySelector('img');
    var span=box.querySelector('span');
    if(src){
      if(img)img.src=src;
      box.style.display='flex';
      if(span)span.textContent=text||'현재 등록된 업체 이미지입니다. 새 파일 선택 시 교체됩니다.';
    }else{
      box.style.display='none';
      if(img)img.removeAttribute('src');
    }
  }
  function openVendorModalForEdit(){
    var modal=document.getElementById('vendorModal');
    var title=document.getElementById('vendorModalTitle');
    var submit=document.getElementById('vendorSubmitBtn');
    var cancel=document.getElementById('cancelVendorEdit');
    if(title)title.textContent='업체 수정';
    if(submit)submit.textContent='업체 수정 저장';
    if(cancel)cancel.style.display='block';
    if(modal){
      if(modal.parentElement!==document.body) document.body.appendChild(modal);
      modal.style.display='';
      modal.removeAttribute('aria-hidden');
      modal.classList.add('active');
      document.body.style.overflow='hidden';
    }
  }
  function fillVendorForm(v,row){
    var form=document.getElementById('vendorForm');
    if(!form||!v)return;
    setVal(form,'id',v.id||'');
    setVal(form,'name',v.name||row?.dataset.vendorName||'');
    setVal(form,'category',v.category||row?.dataset.category||'');
    setVal(form,'region',v.region||row?.dataset.region||'');
    setVal(form,'phone',v.phone||'');
    setVal(form,'kakao_url',v.kakao_url||'');
    setVal(form,'business_hours',v.business_hours||row?.dataset.businessHours||'');
    setVal(form,'tags',v.tags||'');
    setVal(form,'status',v.status||row?.dataset.status||'active');
    setVal(form,'description',v.description||'');
    setVal(form,'ad_type',v.ad_type||row?.dataset.adType||'none');
    setVal(form,'expire_at',String(v.expire_at||row?.dataset.expire||'').slice(0,10));
    setChecked(form,'banner_active',!!v.banner_active || row?.dataset.bannerActive==='1');
    if(form.elements.banner_active&&form.elements.banner_active.checked&&form.elements.ad_type){
      form.elements.ad_type.value='recommended';
    }
    showPreviewSafe(v.image_exists?('/admin/vendors/'+encodeURIComponent(v.id)+'/image'):'', v.image_exists?'현재 등록된 업체 이미지입니다. 새 파일 선택 시 교체됩니다.':'새 파일 선택 시 이미지가 등록됩니다.');
    openVendorModalForEdit();
  }
  function findVendor(id){
    var key=String(id||'');
    var cached=window.__adminVendorRowsById&&window.__adminVendorRowsById[key];
    if(cached)return cached;
    return null;
  }
  function hasEnoughVendorDetail(v){
    if(!v)return false;
    return !!(v.name || v.phone || v.kakao_url || v.business_hours || v.tags || v.description || v.category || v.region);
  }
  async function fetchVendorDetail(id){
    var key=String(id||'');
    if(!key)return null;
    var res=await fetch('/admin/api/vendors/'+encodeURIComponent(key),{
      credentials:'same-origin',
      headers:{'Accept':'application/json','X-Requested-With':'fetch'}
    });
    var data=null;
    try{data=await res.json();}catch(e){}
    if(!res.ok || !data || data.ok===false || !data.vendor){
      throw new Error((data&&data.error)||('HTTP '+res.status));
    }
    window.__adminVendorRowsById=window.__adminVendorRowsById||{};
    window.__adminVendorRowsById[key]=data.vendor;
    return data.vendor;
  }
  document.addEventListener('click',async function(e){
    var btn=e.target&&e.target.closest&&e.target.closest('.edit-vendor-btn');
    if(!btn)return;
    e.preventDefault();
    e.stopImmediatePropagation();
    var row=btn.closest('.vendor-row');
    var id=btn.dataset.id || (row&&row.dataset.id);
    var fromBannerPanel=!!btn.closest('#banners');
    var oldText=btn.textContent;
    btn.disabled=true;
    btn.textContent='불러오는중...';
    try{
      var v=findVendor(id);
      // 배너목록의 업체연동 행은 별도 배너 row라 업체 상세정보가 부족할 수 있으므로 항상 최신 업체정보를 서버에서 다시 가져옵니다.
      if(fromBannerPanel || !hasEnoughVendorDetail(v)){
        var fresh=await fetchVendorDetail(id);
        if(fresh)v=fresh;
      }
      if(!v){
        toast('업체 정보를 찾지 못했습니다.','bad');
        return;
      }
      fillVendorForm(v,row);
    }catch(err){
      toast('업체 정보를 불러오지 못했습니다.','bad',err&&err.message?err.message:'잠시 후 다시 시도해주세요.');
    }finally{
      btn.disabled=false;
      btn.textContent=oldText;
    }
  },true);
})();
</script>


