  body.addEventListener('click',function(e){var button=e.target.closest('[data-vendor-request-detail]');if(!button)return;var target=body.querySelector('[data-vendor-request-detail-for="'+button.dataset.vendorRequestDetail+'"]'),opening=target&&target.hidden;body.querySelectorAll('.vendor-request-detail-row').forEach(function(r){r.hidden=true;});body.querySelectorAll('[data-vendor-request-detail]').forEach(function(b){b.textContent='비교보기';});if(target&&opening){target.hidden=false;button.textContent='비교닫기';}});
