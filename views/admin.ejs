  window.closeUserVendorLinkModal=closeUserVendorLinkModal;

  async function submitVendorLink(form){
    if(form.dataset.submitting==='1')return;
    if(!confirm('선택한 회원을 이 업체의 업체회원으로 연결할까요? 연결 후 해당 회원은 업체 대시보드를 사용할 수 있습니다.'))return;
    var userOption=form.elements.user_id.selectedOptions[0],vendorOption=form.elements.vendor_id.selectedOptions[0],fd=new FormData(form);
    var btn=form.querySelector('button');
    var old=btn?btn.textContent:'';
    form.dataset.submitting='1';if(btn){btn.disabled=true;btn.textContent='연결중...';}
    try{
      var res=await fetch('/admin/link-user-vendor',{method:'POST',body:fd,credentials:'same-origin',headers:{'X-Requested-With':'fetch'}});
      var data=null;
