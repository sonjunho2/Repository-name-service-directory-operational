    if(pager)pager.innerHTML='<span class="server-vendor-info">업체목록을 불러오는 중입니다.</span>';
    try{
      var res=await fetch('/admin/api/vendors?'+vendorQuery(vendorServerPage).toString(),{headers:{'Accept':'application/json'}});
      var data=await res.json();
      if(!data.ok)throw new Error('load failed');
      var header=table.querySelector('tr');
      table.innerHTML='';
      if(header)table.appendChild(header);
      (data.rows||[]).forEach(function(v){
        table.insertAdjacentHTML('beforeend',rowHtml(v));
      });
      if(typeof sortVendorRows==='function')sortVendorRows();
      if(pager){
        pager.innerHTML='';
        var from=data.total?((data.page-1)*data.limit+1):0;
        var to=Math.min(data.page*data.limit,data.total);
        pager.appendChild(makePagerButton('처음',data.page<=1,false,function(){loadVendors(1);}));
        pager.appendChild(makePagerButton('이전',data.page<=1,false,function(){loadVendors(data.page-1);}));
        addPageNumbers(pager,data.page,data.totalPages);
        pager.appendChild(makePagerButton('다음',data.page>=data.totalPages,false,function(){loadVendors(data.page+1);}));
        pager.appendChild(makePagerButton('마지막',data.page>=data.totalPages,false,function(){loadVendors(data.totalPages);}));
        var info=document.createElement('span');
        info.className='server-vendor-info';
        info.textContent='총 '+data.total+'개 업체 · 현재 '+from+'-'+to+'개 표시';
        pager.appendChild(info);
      }
      window.__adminVendorRowsById = window.__adminVendorRowsById || {};
      (data.rows||[]).forEach(function(v){ window.__adminVendorRowsById[String(v.id)] = v; });
      vendorServerReady=true;
      if(window.applyPanelPagination)try{window.applyPanelPagination(true);}catch(e){}
      vendorLoading=false;
    }catch(e){
      vendorLoading=false;
      showTableMessage(table,'업체목록을 불러오지 못했습니다.','loading-row');
      if(pager)pager.innerHTML='<span class="server-vendor-info">서버 페이지 데이터를 불러오지 못했습니다. 기존 목록을 표시합니다.</span>';
    }
  }
  function activePanelId(){
    var p=document.querySelector('.admin-panel.active');
    return p&&p.id;
  }
  function maybeLoad(){
    if(activePanelId()==='vendors')loadVendors(vendorServerPage||1);
  }
  document.addEventListener('DOMContentLoaded',function(){setTimeout(maybeLoad,200);});
  window.addEventListener('hashchange',function(){setTimeout(maybeLoad,200);});
  document.addEventListener('click',function(e){
    if(e.target&&e.target.matches('[data-panel],.admin-sidebar a')){
      setTimeout(maybeLoad,250);
    }
  });
  document.getElementById('vendorSearch')?.addEventListener('input',function(){
    clearTimeout(vendorSearchTimer);
    vendorSearchTimer=setTimeout(function(){loadVendors(1);},300);
  });
  document.getElementById('vendorTypeFilter')?.addEventListener('change',function(){loadVendors(1);});
  document.getElementById('vendorStatusFilter')?.addEventListener('change',function(){loadVendors(1);});
  document.getElementById('vendorFilterReset')?.addEventListener('click',function(){setTimeout(function(){loadVendors(1);},0);});
  setTimeout(maybeLoad,0);
})();
</script><script>
(function(){
  if(window.__adminUsersModuleV3)return;
  window.__adminUsersModuleV3=true;

  var userServerPage=1;
  var userServerLimit=20;
  var loading=false;
  var userSearchTimer=null;

  function userQuery(page){
    var params=new URLSearchParams();
    params.set('page',String(page));
    params.set('limit',String(userServerLimit));
    var search=(document.getElementById('userSearch')?.value||'').trim();
    var role=document.getElementById('userRoleFilter')?.value||'all';
    var status=document.getElementById('userStatusFilter')?.value||'all';
    if(search)params.set('q',search);
    if(role!=='all')params.set('role',role);
    if(status!=='all')params.set('status',status);
    return params;
  }

  function roleText(u){
    if(u.role==='admin')return '관리자';
    if(u.is_vendor || u.vendor_id)return '업체회원';
    return '일반회원';
  }
  function roleBadge(u){
    if(u.role==='admin')return '<span class="role-badge role-admin">관리자</span>';
    if(u.is_vendor || u.vendor_id)return '<span class="role-badge role-vendor">업체회원</span>';
    return '<span class="role-badge role-user">일반회원</span>';
  }
  function statusText(v){
    return {active:'정상',blocked:'차단',suspended:'일시정지',inactive:'휴면'}[v]||v||'정상';
  }
  function option(value,current,label){
    return '<option value="'+esc(value)+'" '+(value===current?'selected':'')+'>'+esc(label)+'</option>';
  }
  function roleOptions(current){
    return option('user',current,'일반회원')+option('admin',current,'관리자');
  }
  function statusOptions(current){
    current=current||'active';
    return option('active',current,'정상')+option('blocked',current,'차단')+option('suspended',current,'일시정지')+option('inactive',current,'휴면');
  }
  function userRow(u){
    var roleKey=u.role==='admin'?'admin':((u.is_vendor||u.vendor_id)?'vendor':'user');
    var searchText=[u.username,u.nickname].filter(Boolean).join(' ').toLowerCase();
    return '<tr class="user-row" data-id="'+esc(u.id)+'" data-text="'+esc(searchText)+'" data-role="'+esc(roleKey)+'" data-status="'+esc(u.status||'active')+'">'+
      '<td>'+esc(u.id)+'</td>'+
      '<td>'+esc(u.username||'')+'</td>'+
      '<td>'+roleBadge(u)+'</td>'+
      '<td><input name="nickname" value="'+esc(u.nickname||'')+'" autocomplete="off"></td>'+
      '<td><select name="role">'+roleOptions(u.role||'user')+'</select></td>'+
      '<td><select name="status">'+statusOptions(u.status||'active')+'</select></td>'+
      '<td><input name="password" placeholder="새 비번" autocomplete="new-password"></td>'+
      '<td><div class="row-actions">'+
        '<button type="button" class="user-save-btn" data-id="'+esc(u.id)+'">저장</button>'+
        (u.role==='admin'?'':'<button type="button" class="user-delete-btn" data-id="'+esc(u.id)+'">삭제</button>')+
      '</div></td>'+
    '</tr>';
  }
  function usersPanel(){
    return document.getElementById('users');
  }
  function usersTable(){
    var panel=usersPanel();
    return panel?panel.querySelector('table'):null;
  }
  function ensurePager(table){
    var panel=usersPanel();
    if(!panel||!table)return null;
    panel.querySelectorAll('.admin-pager').forEach(function(p){p.remove();});
    panel.querySelectorAll('.server-user-pager').forEach(function(p,i){if(i>0)p.remove();});
    var pager=panel.querySelector('.server-user-pager');
    if(!pager){
      pager=document.createElement('div');
      pager.className='server-user-pager';
      table.insertAdjacentElement('afterend',pager);
    }
    return pager;
  }
  function makeBtn(label,disabled,active,onClick){
    var b=document.createElement('button');
    b.type='button';
    b.textContent=label;
    if(disabled)b.disabled=true;
    if(active)b.classList.add('active');
    b.onclick=onClick;
    return b;
  }
  function showTableMessage(table,msg,cls){
    var header=table.querySelector('tr');
    var colspan=header?Math.max(1,header.children.length):1;
    table.innerHTML='';
    if(header)table.appendChild(header);
    fixHeaders(table);
    table.insertAdjacentHTML('beforeend','<tr class="'+(cls||'loading-row')+'"><td colspan="'+colspan+'">'+esc(msg)+'</td></tr>');
  }
  function renderPager(pager,data){
    pager.innerHTML='';
    var page=data.page||1,totalPages=data.totalPages||1,total=data.total||0,limit=data.limit||userServerLimit;
    var from=total?((page-1)*limit+1):0;
    var to=Math.min(page*limit,total);
    pager.appendChild(makeBtn('처음',page<=1,false,function(){loadUsers(1);}));
    pager.appendChild(makeBtn('이전',page<=1,false,function(){loadUsers(page-1);}));

    var start=Math.max(1,page-2);
    var end=Math.min(totalPages,start+4);
    start=Math.max(1,end-4);
    if(start>1){
      pager.appendChild(makeBtn('1',false,page===1,function(){loadUsers(1);}));
      if(start>2){
        var d=document.createElement('span'); d.className='dots'; d.textContent='...'; pager.appendChild(d);
      }
    }
    for(var p=start;p<=end;p++){
      (function(n){pager.appendChild(makeBtn(String(n),false,n===page,function(){loadUsers(n);}));})(p);
    }
    if(end<totalPages){
      if(end<totalPages-1){
        var d2=document.createElement('span'); d2.className='dots'; d2.textContent='...'; pager.appendChild(d2);
      }
      pager.appendChild(makeBtn(String(totalPages),false,page===totalPages,function(){loadUsers(totalPages);}));
    }

    pager.appendChild(makeBtn('다음',page>=totalPages,false,function(){loadUsers(page+1);}));
    pager.appendChild(makeBtn('마지막',page>=totalPages,false,function(){loadUsers(totalPages);}));
    var info=document.createElement('span');
    info.className='server-user-info';
    info.textContent='총 '+total+'명 · 현재 '+from+'-'+to+'명 표시';
    pager.appendChild(info);
  }
  function fixHeaders(table){
    var ths=table.querySelectorAll('th');
    var labels=['ID','아이디','계정구분','닉네임','권한','상태','새 비밀번호','관리'];
    ths.forEach(function(th,i){if(labels[i])th.textContent=labels[i];});
  }
  async function loadUsers(page){
    if(loading){clearTimeout(userSearchTimer);userSearchTimer=setTimeout(function(){loadUsers(page);},100);return;}
    var table=usersTable();
    if(!table)return;
    var pager=ensurePager(table);
    userServerPage=Math.max(1,page||1);
    loading=true;
    showTableMessage(table,'회원목록을 불러오는 중입니다.','loading-row');
    var loadOk=false;
    if(pager)pager.innerHTML='<span class="server-user-info">회원목록을 불러오는 중입니다.</span>';
    try{
      var res=await fetch('/admin/api/users?'+userQuery(userServerPage).toString(),{credentials:'same-origin',headers:{'Accept':'application/json'}});
      var data=await res.json();
      if(!data.ok)throw new Error(data.error||'회원목록 로드 실패');
      var header=table.querySelector('tr');
      table.innerHTML='';
      if(header)table.appendChild(header);
      fixHeaders(table);
      (data.rows||[]).forEach(function(u){table.insertAdjacentHTML('beforeend',userRow(u));});
      if(pager)renderPager(pager,data);
      loadOk=true;
    }catch(e){
      if(pager)pager.innerHTML='<span class="server-user-info">회원목록을 불러오지 못했습니다: '+esc(e.message||'오류')+'</span>';
    }finally{
      if(!loadOk)showTableMessage(table,'회원목록을 불러오지 못했습니다.','loading-row');
      loading=false;
    }
  }
  async function saveUser(btn){
    var row=btn.closest('tr');
    if(!row)return;
    var id=btn.dataset.id||row.dataset.id;
    var fd=new FormData();
    fd.append('nickname',row.querySelector('input[name="nickname"]')?.value||'');
    fd.append('role',row.querySelector('select[name="role"]')?.value||'user');
    fd.append('status',row.querySelector('select[name="status"]')?.value||'active');
    fd.append('password',row.querySelector('input[name="password"]')?.value||'');

    var old=btn.textContent;
    btn.disabled=true;
    btn.textContent='저장중...';
    try{
      var res=await fetch('/admin/users/'+encodeURIComponent(id)+'/update',{method:'POST',body:fd,credentials:'same-origin',headers:{'X-Requested-With':'fetch','Accept':'application/json'}});
      var data=null;
      try{data=await res.json();}catch(e){}
      if(!res.ok||data?.ok===false)throw new Error(data?.error||('HTTP '+res.status));
      if(data&&data.user){
        row.outerHTML=userRow(data.user);
      }else{
        await loadUsers(userServerPage);
      }
      toast('회원 정보가 저장되었습니다.','ok');
    }catch(e){
      toast('저장 실패: '+(e.message||'오류'),'bad');
    }finally{
      btn.disabled=false;
      btn.textContent=old;
    }
  }
  async function deleteUser(btn){
    var row=btn.closest('tr');
    if(!row)return;
    var id=btn.dataset.id||row.dataset.id;
    if(!confirm('회원을 삭제할까요? 삭제 후 되돌리기 어렵습니다.'))return;
    var old=btn.textContent;
    btn.disabled=true;
    btn.textContent='삭제중...';
    try{
      var res=await fetch('/admin/delete/users/'+encodeURIComponent(id),{method:'POST',body:new FormData(),credentials:'same-origin',headers:{'X-Requested-With':'fetch','Accept':'application/json'}});
      var data=null;
      try{data=await res.json();}catch(e){}
      if(!res.ok||data?.ok===false)throw new Error(data?.error||('HTTP '+res.status));
      toast('회원이 삭제되었습니다.','warn');
      await loadUsers(userServerPage);
    }catch(e){
      toast('삭제 실패: '+(e.message||'오류'),'bad');
      btn.disabled=false;
      btn.textContent=old;
    }
  }
  function activePanelId(){
    var p=document.querySelector('.admin-panel.active');
    return p&&p.id;
  }
  function maybeLoad(){
    if(activePanelId()!=='users')return;
    loadUsers(userServerPage||1);
  }
  document.addEventListener('click',function(e){
    var save=e.target.closest('.user-save-btn');
    if(save){e.preventDefault();e.stopPropagation();saveUser(save);return;}
    var del=e.target.closest('.user-delete-btn');
    if(del){e.preventDefault();e.stopPropagation();deleteUser(del);return;}
    if(e.target&&e.target.matches('[data-panel],.admin-sidebar a'))setTimeout(maybeLoad,250);
  },true);
  document.addEventListener('DOMContentLoaded',function(){setTimeout(maybeLoad,250);});
  window.addEventListener('hashchange',function(){setTimeout(maybeLoad,250);});
  document.getElementById('userSearch')?.addEventListener('input',function(){
    clearTimeout(userSearchTimer);
    userSearchTimer=setTimeout(function(){loadUsers(1);},300);
  });
  document.getElementById('userRoleFilter')?.addEventListener('change',function(){loadUsers(1);});
  document.getElementById('userStatusFilter')?.addEventListener('change',function(){loadUsers(1);});
  document.getElementById('userFilterReset')?.addEventListener('click',function(){setTimeout(function(){loadUsers(1);},0);});
  setTimeout(maybeLoad,0);
})();
</script><script>
(function(){
  var inquiryServerPage=1;
  var inquiryServerLimit=20;
  var inquiryLoading=false;
  var inquirySearchTimer=null;

  function inquiryQuery(page){
    var params=new URLSearchParams();
    params.set('page',String(page));
    params.set('limit',String(inquiryServerLimit));
    var search=(document.getElementById('inquirySearch')?.value||'').trim();
    if(search)params.set('q',search);
    if(currentInquiryFilter==='apply'||currentInquiryFilter==='ad')params.set('type',currentInquiryFilter);
    else if(currentInquiryFilter!=='all')params.set('status',currentInquiryFilter);
    return params;
  }

  function typeLabel(x){
    return x.type==='apply'?'입점신청':'광고문의';
  }
  function statusText(x){
    if(x.status==='approved')return '승인';
    if(x.status==='rejected')return '반려';
    return '대기';
  }
  function imageButtons(x){
    var html='';
    if(x.has_main_image_data){
      html+='<button type="button" class="image-preview-btn inquiry-image-preview" data-src="/admin/inquiry-image/'+esc(x.id)+'/main" data-title="'+esc(x.company_name||'대표 이미지')+'">대표보기</button>';
    }
    if(x.type==='apply'&&x.has_banner_image_data){
      html+='<button type="button" class="image-preview-btn inquiry-image-preview" data-src="/admin/inquiry-image/'+esc(x.id)+'/banner" data-title="'+esc((x.company_name||'입점신청')+' 배너 이미지')+'">배너보기</button>';
    }
    return html||'<span class="image-none">-</span>';
  }
  function actions(x){
    if(x.status==='approved'){
      var approved='<span class="done">업체 등록완료</span>';
      if(x.type==='apply'&&x.has_banner_image_data&&x.banner_status!=='approved'){
        approved+='<form method="post" action="/admin/inquiries/'+esc(x.id)+'/banner"><button class="banner-btn">배너등록</button></form>';
      }else if(x.type==='apply'&&x.banner_status==='approved'){
        approved+='<span class="banner-status">배너등록완료</span>';
      }
      return approved;
    }
    if(x.status==='rejected')return '<span class="rejected">반려</span>';
    var html='';
    if(x.type==='apply'){
      html+='<form method="post" action="/admin/inquiries/'+esc(x.id)+'/approve"><button class="approve-btn">업체등록</button></form>';
      if(x.has_banner_image_data&&x.banner_status!=='approved'){
        html+='<form method="post" action="/admin/inquiries/'+esc(x.id)+'/banner"><button class="banner-btn">배너등록</button></form>';
      }else if(x.banner_status==='approved'){
        html+='<span class="banner-status">배너등록완료</span>';
      }
    }
    html+='<form method="post" action="/admin/inquiries/'+esc(x.id)+'/reject"><button class="reject-btn">반려</button></form>';
    return html;
  }
  function rowHtml(x){
    var statusKey=x.status==='approved'?'approved':(x.status==='rejected'?'rejected':'new');
    var typeKey=x.type==='apply'?'apply':'ad';
    var searchText=[x.company_name,x.name,x.phone,x.kakao,x.email,x.region,x.category].filter(Boolean).join(' ').toLowerCase();
    return '<tr class="inquiry-row" data-id="'+esc(x.id)+'" data-status="'+esc(statusKey)+'" data-type="'+esc(typeKey)+'" data-search="'+esc(searchText)+'">'+
      '<td>'+esc(x.id)+'</td>'+
      '<td>'+esc(typeLabel(x))+'</td>'+
      '<td>'+esc(x.applicant_username||x.applicant_nickname||'-')+'</td>'+
      '<td>'+esc(x.company_name||'-')+'</td>'+
      '<td>'+esc(x.name||'-')+'</td>'+
      '<td>'+esc(x.phone||'-')+'<br>'+esc(x.kakao||'')+'<br>'+esc(x.email||'')+'</td>'+
      '<td>'+esc(x.region||'-')+'/'+esc(x.category||'-')+'</td>'+
      '<td>'+esc(x.content||'-')+'</td>'+
      '<td>'+imageButtons(x)+'</td>'+
      '<td>'+actions(x)+'</td>'+
      '</tr>';
  }
  function ensurePager(table){
    var panel=document.getElementById('inquiries');
    if(!panel||!table)return null;
    panel.querySelectorAll('.admin-pager').forEach(function(p){p.remove();});
    panel.querySelectorAll('.server-inquiry-pager').forEach(function(p,i){if(i>0)p.remove();});
    var pager=panel.querySelector('.server-inquiry-pager');
    if(!pager){
      pager=document.createElement('div');
      pager.className='server-inquiry-pager';
      table.insertAdjacentElement('afterend',pager);
    }
    return pager;
  }
  function showTableMessage(table,msg,cls){
    var header=table.querySelector('tr');
    var colspan=header?Math.max(1,header.children.length):1;
    table.innerHTML='';
    if(header)table.appendChild(header);
    table.insertAdjacentHTML('beforeend','<tr class="'+(cls||'loading-row')+'"><td colspan="'+colspan+'">'+esc(msg)+'</td></tr>');
  }
  function addPageNumbers(pager,page,totalPages){
    var start=Math.max(1,page-2);
    var end=Math.min(totalPages,start+4);
    start=Math.max(1,end-4);
    if(start>1){
      pager.appendChild(makeButton('1',false,page===1,function(){loadInquiries(1);}));
      if(start>2){
        var dots=document.createElement('span'); dots.className='dots'; dots.textContent='...'; pager.appendChild(dots);
      }
    }
    for(var p=start;p<=end;p++){
      (function(n){pager.appendChild(makeButton(String(n),false,n===page,function(){loadInquiries(n);}));})(p);
    }
    if(end<totalPages){
      if(end<totalPages-1){
        var dots2=document.createElement('span'); dots2.className='dots'; dots2.textContent='...'; pager.appendChild(dots2);
      }
      pager.appendChild(makeButton(String(totalPages),false,page===totalPages,function(){loadInquiries(totalPages);}));
    }
  }
  async function loadInquiries(page){
    if(inquiryLoading){clearTimeout(inquirySearchTimer);inquirySearchTimer=setTimeout(function(){loadInquiries(page);},100);return;}
    var panel=document.getElementById('inquiries');
    if(!panel)return;
    var table=panel.querySelector('table');
    if(!table)return;
    var pager=ensurePager(table);
    inquiryServerPage=Math.max(1,page||1);
    inquiryLoading=true;
    showTableMessage(table,'신청목록을 불러오는 중입니다.','loading-row');
    if(pager)pager.innerHTML='<span class="server-inquiry-info">신청목록을 불러오는 중입니다.</span>';
    try{
      var res=await fetch('/admin/api/inquiries?'+inquiryQuery(inquiryServerPage).toString(),{headers:{'Accept':'application/json'}});
      var data=await res.json();
      if(!data.ok)throw new Error('load failed');
      var header=table.querySelector('tr');
      table.innerHTML='';
      if(header)table.appendChild(header);
      (data.rows||[]).forEach(function(x){table.insertAdjacentHTML('beforeend',rowHtml(x));});
      inquiryLoading=false;
      sortInquiries();
      if(pager){
        pager.innerHTML='';
        var from=data.total?((data.page-1)*data.limit+1):0;
        var to=Math.min(data.page*data.limit,data.total);
        pager.appendChild(makeButton('처음',data.page<=1,false,function(){loadInquiries(1);}));
        pager.appendChild(makeButton('이전',data.page<=1,false,function(){loadInquiries(data.page-1);}));
        addPageNumbers(pager,data.page,data.totalPages);
        pager.appendChild(makeButton('다음',data.page>=data.totalPages,false,function(){loadInquiries(data.page+1);}));
        pager.appendChild(makeButton('마지막',data.page>=data.totalPages,false,function(){loadInquiries(data.totalPages);}));
        var info=document.createElement('span');
        info.className='server-inquiry-info';
        info.textContent='총 '+data.total+'건 · 현재 '+from+'-'+to+'건 표시';
