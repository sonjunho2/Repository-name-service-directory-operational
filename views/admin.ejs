.admin-pager{display:flex;align-items:center;justify-content:flex-end;gap:8px;margin:14px 0 0;flex-wrap:wrap}.admin-pager button{height:34px;min-width:34px;border-radius:999px;border:1px solid #29324f;background:#080d18;color:#dfe9ff;font-weight:900;padding:0 12px}.admin-pager button.active{background:linear-gradient(90deg,#ff3fb4,#10d9ff);border-color:transparent;color:#fff}.admin-pager button:disabled{opacity:.45;cursor:not-allowed}.admin-pager .pager-info{margin-right:auto;color:#8d98b8;font-weight:800}.admin-page-hidden{display:none!important}@media(max-width:700px){.admin-pager{justify-content:flex-start}.admin-pager .pager-info{width:100%;margin:0 0 6px}}.admin-activity-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:18px}.admin-activity-box{border:1px solid #29324f;border-radius:18px;background:#070b15;padding:18px;min-height:180px}.admin-activity-box h3{margin:0 0 14px;font-size:18px}.admin-activity-item{display:grid;gap:4px;padding:10px 0;border-bottom:1px solid #1d263d;color:#dfe9ff}.admin-activity-item:last-child{border-bottom:0}.admin-activity-item b{font-size:14px}.admin-activity-item small{color:#8d98b8;line-height:1.4}.admin-activity-empty{color:#8d98b8;border:1px dashed #29324f;border-radius:12px;padding:14px}.admin-activity-badge{display:inline-flex;align-items:center;width:max-content;height:24px;padding:0 9px;border-radius:999px;background:#29324f;color:#dfe9ff;font-size:12px;font-weight:900}.admin-activity-badge.wait{background:#3d3412;color:#ffdc4d;border:1px solid #ffdc4d}.admin-activity-badge.ok{background:#123b2b;color:#1fe087}.admin-activity-badge.bad{background:#3b1212;color:#ff6b6b}@media(max-width:1100px){.admin-activity-grid{grid-template-columns:1fr}}.server-vendor-pager{display:flex;align-items:center;justify-content:center;gap:8px;margin:18px 0 4px;flex-wrap:wrap}.server-vendor-pager button{height:36px;min-width:36px;border:1px solid #29324f;border-radius:999px;background:#080d18;color:#dfe9ff;padding:0 13px;font-weight:900}.server-vendor-pager button.active{background:linear-gradient(90deg,#ff3fb4,#10d9ff);border-color:transparent;color:#fff}.server-vendor-pager button:disabled{opacity:.45;cursor:not-allowed}.server-vendor-info{width:100%;text-align:center;color:#8d98b8;font-size:13px;font-weight:800}.server-user-pager,.server-inquiry-pager,.server-payment-pager,.server-report-pager{display:flex;align-items:center;justify-content:center;gap:8px;margin:18px 0 4px;flex-wrap:wrap}.server-user-pager button,.server-inquiry-pager button,.server-payment-pager button,.server-report-pager button{height:36px;min-width:36px;border:1px solid #29324f;border-radius:999px;background:#080d18;color:#dfe9ff;padding:0 13px;font-weight:900}.server-user-pager button.active,.server-inquiry-pager button.active,.server-payment-pager button.active,.server-report-pager button.active{background:linear-gradient(90deg,#ff3fb4,#10d9ff);border-color:transparent;color:#fff}.server-user-pager button:disabled,.server-inquiry-pager button:disabled,.server-payment-pager button:disabled,.server-report-pager button:disabled{opacity:.45;cursor:not-allowed}.server-user-info,.server-inquiry-info,.server-payment-info,.server-report-info{width:100%;text-align:center;color:#8d98b8;font-size:13px;font-weight:800}
</style>

<div class="dash-grid">
  <a class="dash-card dashboard-card-link today" href="#users" data-panel="users"><b>회원</b><strong class="<%=level(S.usersNew)%>"><%=num(S.usersNew)%></strong><span class="stat-note">신규/전체 <%=num(S.usersTotal)%></span><%- alertDot(S.usersNew) %></a>
  <a class="dash-card dashboard-card-link hot" href="#vendors" data-panel="vendors"><b>업체</b><strong class="<%=level(S.vendorsPending)%>"><%=num(S.vendorsPending)%></strong><span class="stat-note">검수/전체 <%=num(S.vendorsTotal)%></span><%- alertDot(S.vendorsPending) %></a>
  <a class="dash-card dashboard-card-link alert" href="#inquiries" data-panel="inquiries"><b>입점 승인</b><strong class="<%=level(S.inquiriesNew)%>"><%=num(S.inquiriesNew)%></strong><span class="stat-note">대기 신청</span><%- alertDot(S.inquiriesNew) %></a>
  <a class="dash-card dashboard-card-link warn" href="#adCenter" data-panel="adCenter"><b>입금 확인</b><strong class="<%=level(S.paymentsWaiting)%>"><%=num(S.paymentsWaiting)%></strong><span class="stat-note">광고/배너 결제</span><%- alertDot(S.paymentsWaiting) %></a>
  <a class="dash-card dashboard-card-link" href="#vendorRequests" data-panel="vendorRequests"><b>업체 수정요청</b><strong class="<%=level(S.vendorRequestsNew)%>"><%=num(S.vendorRequestsNew)%></strong><span class="stat-note">승인 대기</span><%- alertDot(S.vendorRequestsNew) %></a>
  <a class="dash-card dashboard-card-link" href="#reports" data-panel="reports"><b>신고</b><strong class="<%=level(S.reportsNew)%>"><%=num(S.reportsNew)%></strong><span class="stat-note">처리 대기</span><%- alertDot(S.reportsNew) %></a>
  <a class="dash-card dashboard-card-link" href="#revenue" data-panel="revenue"><b>오늘 매출</b><strong class="level-info"><%=money(S.todayRevenue)%></strong><span class="stat-note">이번달 <%=money(S.monthRevenue)%></span></a>
  <a class="dash-card dashboard-card-link" href="#banners" data-panel="banners"><b>활성 배너</b><strong class="level-info"><%=num(S.bannersActive)%></strong><span class="stat-note">노출중</span></a>
</div>

<div class="dashboard-simple dashboard-box">
