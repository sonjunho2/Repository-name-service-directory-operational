    params.set('sort',sort);
    return params;
  }

  function publicStatus(v){var key=v.public_state||'unknown';var text={active:'м†ХмГБлЕЄмґЬ',pending:'к≤АмИШм§С',hidden:'мИ®кєА',blocked:'м∞®лЛ®',expired:'лІМл£М',no_ad:'лєДлЕЄмґЬ',no_expire:'лєДлЕЄмґЬ',unknown:'нЩХмЭЄнХДмЪФ'}[key]||'нЩХмЭЄнХДмЪФ';return '<span class="vendor-status-badge '+key+'">'+text+'</span>';}
  function rowHtml(v){
    var linkedStatus={active:'м†ХмГБ',blocked:'м∞®лЛ®',suspended:'м†ХмІА',inactive:'лєДнЩЬмД±'}[v.linked_user_status]||v.linked_user_status||'-';
    var linked=v.has_linked_user?('<b>'+esc(v.linked_username||'-')+'</b><span class="vendor-subtext">'+esc(v.linked_nickname||'-')+' ¬Ј '+esc(linkedStatus)+'</span>'):'<span class="vendor-link-warning">лѓЄмЧ∞к≤∞</span>';
    var image=v.image_exists?'<button type="button" class="image-preview-btn vendor-image-btn" data-src="/admin/vendors/'+esc(v.id)+'/image" data-title="'+esc(v.name||'мЧЕм≤і')+' лМАнСЬ мЭілѓЄмІА" aria-label="'+esc(v.name||'мЧЕм≤і')+' лМАнСЬ мЭілѓЄмІА л≥ікЄ∞">мЭілѓЄмІА л≥ікЄ∞</button>':'<span class="vendor-image-state missing">мЭілѓЄмІА мЧЖмЭМ</span>';
