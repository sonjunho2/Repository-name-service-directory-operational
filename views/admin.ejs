  document.addEventListener('click',function(e){if(e.target.closest('[data-user-vendor-link-open]')){openUserVendorLinkModal();return;}if(e.target.closest('[data-user-vendor-link-close]')||e.target===document.getElementById('userVendorLinkModal'))closeUserVendorLinkModal();});
