  function toastMessage(text,type){if(typeof toast==='function')toast(text,type);else alert(text);}
  async function loadAdminAccounts(silent){var body=document.getElementById('adminAccountRows');if(!body)return false;try{var res=await fetch('/admin/api/admin-accounts',{credentials:'same-origin',headers:{Accept:'application/json','X-Requested-With':'fetch'}}),data=await res.json();if(!res.ok||!data.ok)throw new Error(data.error||'load_failed');rows=new Map((data.rows||[]).map(function(x){return [String(x.id),x];}));document.querySelectorAll('[data-admin-account-summary]').forEach(function(el){el.textContent=Number(data.summary?.[el.dataset.adminAccountSummary]||0).toLocaleString();});body.innerHTML=(data.rows||[]).map(function(x){return '<tr><td>'+esc(x.id)+'</td><td><b>'+esc(x.username)+'</b><br><small>'+esc(x.nickname)+'</small></td><td><span class="'+(x.status==='active'?'done':'rejected')+'">'+(x.status==='active'?'мВђмЪ©м§С':'мВђмЪ©м§СмІА')+'</span></td><td>'+(x.is_self?'<span class="admin-current-badge">нШДмЮђ л°ЬкЈЄмЭЄ</span>':'-')+'</td><td><button type="button" data-admin-account-manage="'+esc(x.id)+'">кіАл¶ђ</button></td></tr>';}).join('')||'<tr><td colspan="5">нСЬмЛЬнХ† кіАл¶ђмЮРк∞А мЧЖмКµлЛИлЛ§.</td></tr>';return true;}catch(e){if(!silent)toastMessage('кіАл¶ђмЮР л™©л°ЭмЭД к∞±мЛ†нХШмІА л™їнЦИмКµлЛИлЛ§.','bad');return false;}}
