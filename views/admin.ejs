<script>
(function(){
  if(window.__adminVendorRequestsModuleV2)return;
  window.__adminVendorRequestsModuleV2=true;
  var panel=document.getElementById('vendorRequests'),body=document.getElementById('vendorRequestTableBody'),pager=document.getElementById('vendorRequestPager');
  if(!panel||!body||!pager)return;
  var currentPage=1,currentStatus='all',currentChange='all',currentSort='latest',currentSearch='',loading=false,searchTimer=null,limit=20;
  var fieldMap=[['name','current_vendor_name','업체명'],['category','current_category','업종'],['region','current_region','지역'],['phone','current_phone','연락처'],['kakao_url','current_kakao_url','카카오'],['business_hours','current_business_hours','영업시간'],['tags','current_tags','태그'],['description','current_description','업체소개'],['sns_url','current_sns_url','SNS'],['line_url','current_line_url','LINE'],['telegram_url','current_telegram_url','텔레그램'],['holiday_info','current_holiday_info','휴무정보']];
  function esc(v){return String(v==null?'':v).replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];});}
  function norm(v){return String(v==null?'':v).trim();}
  function shown(v){return norm(v)||'미입력';}
  function dt(v){if(!v)return '-';var d=new Date(v);return isNaN(d.getTime())?'-':d.toLocaleString('ko-KR',{hour12:false});}
  function fields(x){var result=fieldMap.map(function(f){var before=norm(x[f[1]]),after=norm(x[f[0]]);return {label:f[2],before:before,after:after,changed:before!==after};});if(x.has_image_data)result.push({label:'대표 이미지',before:x.current_has_image_data?'현재 이미지 있음':'미입력',after:'요청 이미지 있음',changed:true,image:true});return result;}
  function statusText(v){return v==='approved'?'승인완료':v==='rejected'?'반려':v==='cancelled'?'취소':'승인대기';}
  function connectionProblems(x){var a=[];if(!x.vendor_exists)a.push('업체 없음');if(!x.user_exists)a.push('회원 없음');if(x.user_exists&&!x.link_matches_vendor)a.push('업체 연결 불일치');if(x.user_exists&&x.user_status!=='active')a.push('사용중지 회원');if(x.user_exists&&(!x.user_is_vendor||!x.linked_vendor_id))a.push('업체회원 연결 없음');return a;}
  function imageButtons(x){var buttons=[];if(x.has_image_data)buttons.push('<button type="button" class="image-preview-btn" data-src="/admin/vendor-requests/'+esc(x.id)+'/image" data-title="요청 이미지">요청 이미지</button>');if(x.current_has_image_data&&x.vendor_id)buttons.push('<button type="button" class="image-preview-btn" data-src="/admin/vendors/'+esc(x.vendor_id)+'/image" data-title="현재 이미지">현재 이미지</button>');return '<div class="vendor-request-images">'+(buttons.join('')||'이미지 없음')+'</div>';}
  function actions(x){if(x.status!=='new')return '<span class="done">처리완료</span>';var danger=connectionProblems(x).length||Number(x.changed_count||0)===0;var confirmText=danger?'회원 또는 업체 연결 상태에 문제가 있습니다. 상세 내용을 확인했습니다. 계속 승인할까요?':'현재 업체정보를 요청 내용으로 변경할까요?';return '<div class="vendor-request-actions"><form method="post" action="/admin/vendor-requests/'+esc(x.id)+'/approve" class="vendor-request-action-form"><input name="admin_memo" placeholder="승인 메모"><button class="approve-btn" onclick="if(!confirm(&quot;'+esc(confirmText)+'&quot;))return false;this.form.dataset.safeConfirmDone=\'1\'">변경 승인</button></form><form method="post" action="/admin/vendor-requests/'+esc(x.id)+'/reject" class="vendor-request-action-form"><input name="admin_memo" placeholder="반려 사유" required><button class="reject-btn" onclick="if(!confirm(&quot;이 업체정보 수정요청을 반려할까요?&quot;))return false;this.form.dataset.safeConfirmDone=\'1\'">반려</button></form></div>';}
  function infoList(x,prefix){return fieldMap.map(function(f){var key=prefix==='current'?f[1]:f[0];return '<b>'+esc(f[2])+'</b><div class="vendor-request-value">'+esc(shown(x[key]))+'</div>';}).join('');}
  function detail(x){var problems=connectionProblems(x),badges=problems.length?problems.map(function(v){return '<span class="vendor-request-link-badge">'+esc(v)+'</span>';}).join(''):'<span class="vendor-request-link-badge safe">연결 정상</span>';var diffs=fields(x).map(function(f){return '<div class="vendor-request-diff '+(f.changed?'changed':'unchanged')+'"><b>'+esc(f.label)+'</b><span class="vendor-request-old"><small>현재</small><br>'+esc(shown(f.before))+'</span><span class="vendor-request-new"><small>요청</small><br>'+esc(shown(f.after))+'</span></div>';}).join('');return '<tr class="vendor-request-detail-row" data-vendor-request-detail-for="'+esc(x.id)+'" hidden><td colspan="8"><div class="vendor-request-detail-grid"><section><h4>연결 상태</h4><div class="vendor-request-connection-badges">'+badges+'</div><p>요청 회원 ID: '+esc(x.user_id||'-')+'<br>회원: '+esc(x.username||'-')+' / '+esc(x.nickname||'-')+'<br>회원 상태: '+esc(x.user_status||'-')+'<br>회원 연결 vendor_id: '+esc(x.linked_vendor_id||'-')+'<br>요청 vendor_id: '+esc(x.vendor_id||'-')+'<br>업체 존재: '+(x.vendor_exists?'예':'아니오')+'<br>연결 일치: '+(x.link_matches_vendor?'예':'아니오')+'</p></section><section><h4>처리 정보</h4>상태: '+esc(statusText(x.status))+'<br>요청일: '+esc(dt(x.created_at))+'<br>처리일: '+esc(dt(x.processed_at))+'<br>관리자 메모: '+esc(x.admin_memo||'-')+'<h4>이미지 비교</h4>'+imageButtons(x)+'</section><section><h4>현재 등록 정보</h4>'+infoList(x,'current')+'</section><section><h4>변경 요청 정보</h4>'+infoList(x,'request')+'</section><section class="vendor-request-detail-wide"><h4>변경 항목 비교</h4>'+diffs+'</section></div></td></tr>';}
