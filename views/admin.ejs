      var data=await res.json();
      if(!data.ok)throw new Error('load failed');
      if(vendorServerPage>Math.max(1,Number(data.totalPages||1))){vendorLoading=false;window.normalizeAdminListPage?.('vendors',data,loadVendors);return true;}
      var body=document.getElementById('vendorTableBody');
      body.innerHTML=(data.rows||[]).length?(data.rows||[]).map(rowHtml).join(''):'<tr><td colspan="7">м°∞к±імЧР лІЮлКФ мЧЕм≤ік∞А мЧЖмКµлЛИлЛ§.</td></tr>';
      Object.entries(data.summary||{}).forEach(function(entry){var el=document.querySelector('[data-vendor-summary="'+entry[0]+'"]');if(el)el.textContent=Number(entry[1]||0).toLocaleString();});
      if(pager){
        pager.innerHTML='';
        var from=data.total?((data.page-1)*data.limit+1):0;
        var to=Math.min(data.page*data.limit,data.total);
        pager.appendChild(makePagerButton('м≤ШмЭМ',data.page<=1,false,function(){loadVendors(1);}));
        pager.appendChild(makePagerButton('мЭім†Д',data.page<=1,false,function(){loadVendors(data.page-1);}));
        addPageNumbers(pager,data.page,data.totalPages);
        pager.appendChild(makePagerButton('лЛ§мЭМ',data.page>=data.totalPages,false,function(){loadVendors(data.page+1);}));
        pager.appendChild(makePagerButton('лІИмІАлІЙ',data.page>=data.totalPages,false,function(){loadVendors(data.totalPages);}));
        var info=document.createElement('span');
        info.className='server-vendor-info';
        info.textContent='міЭ '+data.total+'к∞Ь мЧЕм≤і ¬Ј нШДмЮђ '+from+'-'+to+'к∞Ь нСЬмЛЬ';
        pager.appendChild(info);
      }
      window.__adminVendorRowsById = window.__adminVendorRowsById || {};
      (data.rows||[]).forEach(function(v){ window.__adminVendorRowsById[String(v.id)] = v; });
      vendorServerReady=true;
      vendorLoading=false;
      return true;
    }catch(e){
      vendorLoading=false;
      showTableMessage(table,'мЧЕм≤іл™©л°ЭмЭД лґИлЯђмШ§мІА л™їнЦИмКµлЛИлЛ§.','loading-row');
      if(pager)pager.innerHTML='<span class="server-vendor-info">мДЬл≤Д нОШмЭімІА лН∞мЭінД∞л•Љ лґИлЯђмШ§мІА л™їнЦИмКµлЛИлЛ§. кЄ∞м°і л™©л°ЭмЭД нСЬмЛЬнХ©лЛИлЛ§.</span>';
      return false;
    }
  }
  window.loadAdminVendors=loadVendors;
})();
