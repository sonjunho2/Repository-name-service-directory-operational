      '<td><div class="row-actions"><button type="button" class="edit-vendor-btn" data-id="'+esc(v.id)+'">мИШм†Х</button><form method="post" action="/admin/delete/vendors/'+esc(v.id)+'"><button onclick="return confirm(&quot;мВ≠м†ЬнХ†кєМмЪФ?&quot;)">мВ≠м†Ь</button></form></div></td></tr>';
  }
  function ensurePager(table){
    return document.getElementById('vendorPager');
  }
  function makePagerButton(label,disabled,active,onClick){
    var b=document.createElement('button');
    b.type='button';
