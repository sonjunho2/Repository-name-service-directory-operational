    }catch(e){}
  }
  function updateVisibility(){
    var el=document.getElementById('stage33Visible');
    if(el)el.textContent=document.hidden?'비활성: 갱신 중지':'활성: 자동 갱신';
    if(!document.hidden)fetchStage33();
  }
  document.addEventListener('DOMContentLoaded',function(){
    setTimeout(fetchStage33,1200);
    timer=setInterval(fetchStage33,30000);
    document.addEventListener('visibilitychange',updateVisibility);
    updateVisibility();
