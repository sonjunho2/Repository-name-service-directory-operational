<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>관리자</title><link rel="stylesheet" href="/public/css/style.css"><style>.admin-shell{display:grid;grid-template-columns:240px 1fr;min-height:calc(100vh - 68px)}.admin-sidebar{background:#080d18;border-right:1px solid #29324f;padding:22px}.admin-sidebar h2{margin:0 0 18px}.admin-sidebar a{display:flex;align-items:center;height:44px;margin:0 0 8px;padding:0 14px;border-radius:12px;color:#dfe9ff;text-decoration:none;font-weight:900}.admin-sidebar a.active,.admin-sidebar a:hover{background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff}.admin-sidebar .line{height:1px;background:#29324f;margin:16px 0}.admin-content{padding:26px;min-width:0}.admin-panel{display:none}.admin-panel.active{display:block}.admin-content .panel{max-width:none;width:100%;margin:0;padding:28px}.admin-content input,.admin-content select,.admin-content textarea{width:100%;height:42px;box-sizing:border-box;border-radius:10px;padding:0 12px;background:#070b15;border:1px solid #29324f;color:#fff}.admin-content textarea{height:82px;padding:12px}.gridform{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px}.gridform textarea,.form-actions,.img-preview{grid-column:1/5}.form-actions{display:grid;grid-template-columns:1fr 140px;gap:10px}.admin-content label{height:42px;display:flex;align-items:center;gap:8px;padding:0 12px;border:1px solid #29324f;border-radius:10px;background:#070b15}.admin-content button{height:38px;border:0;border-radius:999px;padding:0 16px;background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff;font-weight:900;cursor:pointer}.admin-content table{width:100%;border-collapse:collapse;margin-top:14px;background:#070b15}.admin-content th,.admin-content td{border:1px solid #29324f;padding:11px;white-space:nowrap;vertical-align:middle}.admin-content th{background:#171d30}.row-actions{display:flex;gap:8px}.cancel-edit{background:#222b43!important}.dash-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}.dash-card{padding:22px;border:1px solid #29324f;border-radius:18px;background:#070b15}.dash-card b{display:block;color:#c8d0e8;margin-bottom:10px}.dash-card strong{font-size:34px}.dash-card.hot{background:linear-gradient(135deg,rgba(255,63,180,.25),rgba(16,217,255,.13))}.dash-card.today{border-color:#10d9ff;background:linear-gradient(135deg,rgba(16,217,255,.16),rgba(255,63,180,.08))}.dash-card.alert{border-color:#ff6b6b;background:linear-gradient(135deg,rgba(255,107,107,.2),rgba(255,63,180,.08))}.dash-card.warn{border-color:#ffdc4d;background:linear-gradient(135deg,rgba(255,220,77,.16),rgba(16,217,255,.06))}.dash-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px}.dash-list{padding:18px;border:1px solid #29324f;border-radius:18px;background:#070b15}.dash-list a,.dash-list div{display:flex;justify-content:space-between;gap:12px;padding:10px 0;color:#dfe9ff;text-decoration:none;border-bottom:1px solid #1d263d}.dash-list a:last-child,.dash-list div:last-child{border-bottom:0}.dash-list small{color:#8d98b8}.vendor-admin-filter,.banner-admin-filter,.user-admin-filter{display:grid;grid-template-columns:1.5fr 1fr 1fr 120px;gap:10px;margin:0 0 18px}.notice-admin-filter,.review-admin-filter{display:grid;grid-template-columns:1.5fr 1fr 120px;gap:10px;margin:0 0 18px}.vendor-admin-filter button,.banner-admin-filter button,.user-admin-filter button,.notice-admin-filter button,.review-admin-filter button{height:42px}.vendor-admin-filter{grid-template-columns:1.5fr 1fr 1fr 1fr 120px}.status-on{color:#1fe087;font-weight:900}.status-off{color:#ff6b6b;font-weight:900}.status-pin{color:#ffdc4d;font-weight:900}.stat-cell{font-weight:900;color:#dfe9ff}.hidden-row{display:none!important}.img-preview{display:none;align-items:flex-start;gap:14px;padding:14px;border:1px solid #29324f;border-radius:14px;background:#070b15;color:#c8d0e8}.img-preview img{max-width:260px;max-height:150px;border-radius:12px;object-fit:cover;border:1px solid #29324f}.img-preview b{display:block;margin-bottom:6px;color:#fff}.external-content .top,.external-content header{display:none!important}.external-content .admin,.external-content .wrap{padding:0!important;margin:0!important;max-width:none!important}.external-content .panel{padding:0!important;background:transparent!important;border:0!important}@media(max-width:1200px){.gridform,.dash-grid,.dash-row,.vendor-admin-filter,.banner-admin-filter,.user-admin-filter,.notice-admin-filter,.review-admin-filter{grid-template-columns:1fr 1fr}.gridform textarea,.form-actions,.img-preview{grid-column:1/3}}@media(max-width:800px){.admin-shell,.gridform,.dash-grid,.dash-row,.vendor-admin-filter,.banner-admin-filter,.user-admin-filter,.notice-admin-filter,.review-admin-filter{grid-template-columns:1fr}.gridform textarea,.form-actions,.img-preview{grid-column:1}}</style></head><body><header class="top"><b>관리자</b><nav><a href="/">사이트</a><a href="/logout">로그아웃</a></nav></header><div class="admin-shell"><aside class="admin-sidebar"><h2>관리 메뉴</h2><a class="active" href="#dashboard" data-panel="dashboard">대시보드</a><a href="#vendors" data-panel="vendors">업체관리</a><a href="#banners" data-panel="banners">배너관리</a><a href="#users" data-panel="users">회원관리</a><a href="#notices" data-panel="notices">공지관리</a><a href="#reviews" data-panel="reviews">후기관리</a><div class="line"></div><a href="#inquiries" data-panel="inquiries">광고/입점 신청</a><a href="#reports" data-panel="reports">신고내역</a><a href="/">사이트 보기</a></aside><main class="admin-content"><section id="dashboard" class="panel admin-panel active"><% const _today=new Date().toISOString().slice(0,10); const _isToday=x=>x&&x.created_at&&new Date(x.created_at).toISOString().slice(0,10)===_today; %><h2>대시보드</h2><div class="dash-grid"><a class="dash-card alert" href="#inquiries" data-panel="inquiries"><b>승인 대기 입점신청</b><strong><%=inquiries.filter(x=>x.status!=='approved').length%></strong></a><a class="dash-card alert" href="#reports" data-panel="reports"><b>미처리 신고</b><strong id="pendingReportCount">확인중</strong></a><a class="dash-card warn" href="#vendors" data-panel="vendors"><b>숨김 업체</b><strong><%=vendors.filter(v=>v.status==='hidden').length%></strong></a><a class="dash-card warn" href="#banners" data-panel="banners"><b>비활성 배너</b><strong><%=banners.filter(b=>!b.is_active).length%></strong></a><div class="dash-card today"><b>오늘 가입 회원</b><strong><%=users.filter(_isToday).length%></strong></div><div class="dash-card today"><b>오늘 등록 업체</b><strong><%=vendors.filter(_isToday).length%></strong></div><div class="dash-card today"><b>오늘 작성 후기</b><strong><%=reviews.filter(_isToday).length%></strong></div><div class="dash-card today"><b>오늘 신청</b><strong><%=inquiries.filter(_isToday).length%></strong></div><div class="dash-card hot"><b>전체 업체</b><strong><%=vendors.length%></strong></div><div class="dash-card"><b>프리미엄 업체</b><strong><%=vendors.filter(v=>v.is_premium).length%></strong></div><div class="dash-card"><b>일반 업체</b><strong><%=vendors.filter(v=>!v.is_premium&&!v.is_recommended).length%></strong></div><div class="dash-card"><b>전체 회원</b><strong><%=users.length%></strong></div><div class="dash-card"><b>전체 배너</b><strong><%=banners.length%></strong></div><div class="dash-card"><b>전체 후기</b><strong><%=reviews.length%></strong></div><div class="dash-card"><b>신청내역</b><strong><%=inquiries.length%></strong></div><div class="dash-card"><b>신규 신청</b><strong><%=inquiries.filter(x=>x.status!=='approved').length%></strong></div></div><div class="dash-row"><div class="dash-list"><h3>조회수 TOP5</h3><% vendors.slice().sort((a,b)=>(b.views||0)-(a.views||0)).slice(0,5).forEach((v,i)=>{%><a href="#vendors" data-panel="vendors"><span><%=i+1%>. <%=v.name%></span><b>조회 <%=v.views||0%></b></a><%})%></div><div class="dash-list"><h3>바로가기</h3><a href="#inquiries" data-panel="inquiries"><span>광고/입점 신청</span><b><%=inquiries.length%>건</b></a><a href="#reports" data-panel="reports"><span>신고내역</span><b>확인</b></a><a href="#banners" data-panel="banners"><span>배너 관리</span><b><%=banners.length%>개</b></a><a href="#reviews" data-panel="reviews"><span>후기 관리</span><b><%=reviews.length%>개</b></a></div></div><div class="dash-row"><div class="dash-list"><h3>최근 가입 회원 5명</h3><% users.slice(0,5).forEach(u=>{%><div><span><%=u.nickname||u.username%></span><small><%=u.username%></small></div><%})%></div><div class="dash-list"><h3>최근 등록 업체 5개</h3><% vendors.slice(0,5).forEach(v=>{%><a href="#vendors" data-panel="vendors"><span><%=v.name%></span><small><%=v.region%> / <%=v.category%></small></a><%})%></div><div class="dash-list"><h3>최근 작성 후기 5개</h3><% reviews.slice(0,5).forEach(r=>{%><a href="#reviews" data-panel="reviews"><span><%=r.vendor_name%></span><small>★ <%=r.rating%> · <%=r.title%></small></a><%})%></div></div></section><section id="vendors" class="panel admin-panel"><% const vendorReviewStats={}; reviews.forEach(r=>{const id=r.vendor_id; if(id){vendorReviewStats[id]=vendorReviewStats[id]||{count:0,sum:0}; vendorReviewStats[id].count++; vendorReviewStats[id].sum+=Number(r.rating||0);}}); %><h2>업체 관리</h2><form id="vendorForm" method="post" action="/admin/vendor" enctype="multipart/form-data" class="gridform"><input type="hidden" name="id"><input name="name" placeholder="업체명" required><input name="category" placeholder="업종" required><input name="region" placeholder="지역" required><input name="phone" placeholder="연락처"><input name="kakao_url" placeholder="카카오톡 문의 링크"><input name="business_hours" placeholder="영업시간"><input name="tags" placeholder="태그"><select name="status"><option value="active">노출</option><option value="hidden">숨김</option></select><label><input type="checkbox" name="is_recommended">추천업체</label><label><input type="checkbox" name="is_premium">프리미엄</label><input type="file" name="image" accept="image/*"><div class="img-preview" id="vendorImagePreview"><img alt="업체 이미지 미리보기"><div><b>업체 이미지 미리보기</b><span>선택한 이미지가 표시됩니다.</span></div></div><textarea name="description" placeholder="업체소개"></textarea><div class="form-actions"><button id="vendorSubmitBtn">업체 등록</button><button type="button" id="cancelVendorEdit" class="cancel-edit" style="display:none">취소</button></div></form><div class="vendor-admin-filter"><input id="vendorSearch" placeholder="업체명 검색"><select id="vendorTypeFilter"><option value="all">전체 구분</option><option value="premium">프리미엄</option><option value="recommend">추천</option><option value="normal">일반</option></select><select id="vendorStatusFilter"><option value="all">전체 상태</option><option value="active">노출</option><option value="hidden">숨김</option></select><select id="vendorSortFilter"><option value="default">기본순</option><option value="views">조회수순</option><option value="reviews">후기순</option><option value="rating">평점순</option><option value="latest">최신등록순</option></select><button type="button" id="vendorFilterReset">초기화</button></div><table><tr><th>ID</th><th>구분</th><th>업체명</th><th>지역/업종</th><th>조회</th><th>후기</th><th>평점</th><th>영업시간</th><th>상태</th><th>관리</th></tr><% vendors.forEach(v=>{ const t=v.is_premium?'premium':v.is_recommended?'recommend':'normal'; const st=vendorReviewStats[v.id]||{count:0,sum:0}; const avg=st.count?(st.sum/st.count).toFixed(1):'-'; %><tr class="vendor-row" data-id="<%=v.id%>" data-views="<%=v.views||0%>" data-reviews="<%=st.count%>" data-rating="<%=avg==='-'?0:avg%>" data-name="<%=String(v.name||'').toLowerCase()%>" data-type="<%=t%>" data-status="<%=v.status%>"><td><%=v.id%></td><td><%=v.is_premium?'프리미엄':v.is_recommended?'추천':'일반'%></td><td><%=v.name%></td><td><%=v.region%>/<%=v.category%></td><td class="stat-cell"><%=v.views||0%></td><td class="stat-cell"><%=st.count%></td><td class="stat-cell"><%=avg==='-'?'-':'★ '+avg%></td><td><%=v.business_hours||'-'%></td><td><%=v.status%></td><td><div class="row-actions"><button type="button" class="edit-vendor-btn" data-id="<%=v.id%>">수정</button><form method="post" action="/admin/delete/vendors/<%=v.id%>"><button onclick="return confirm('삭제할까요?')">삭제</button></form></div></td></tr><%})%></table></section><section id="banners" class="panel admin-panel"><h2>배너 관리</h2><form id="bannerForm" method="post" action="/admin/banner" enctype="multipart/form-data" class="gridform"><input type="hidden" name="id"><input name="title" placeholder="배너 제목" required><input name="subtitle" placeholder="부제목"><input name="link_url" placeholder="링크 URL"><input name="sort_order" type="number" placeholder="정렬순서" value="0"><select name="position"><option value="premium">프리미엄</option><option value="main">메인</option></select><label><input type="checkbox" name="is_active" checked>노출</label><input type="file" name="image" accept="image/*"><div class="img-preview" id="bannerImagePreview"><img alt="배너 이미지 미리보기"><div><b>배너 이미지 미리보기</b><span>선택한 이미지가 표시됩니다.</span></div></div><div class="form-actions"><button id="bannerSubmitBtn">배너 등록</button><button type="button" id="cancelBannerEdit" class="cancel-edit" style="display:none">취소</button></div></form><div class="banner-admin-filter"><input id="bannerSearch" placeholder="배너 제목 검색"><select id="bannerPositionFilter"><option value="all">전체 위치</option><option value="premium">프리미엄</option><option value="main">메인</option></select><select id="bannerStatusFilter"><option value="all">전체 상태</option><option value="active">노출</option><option value="hidden">숨김</option></select><button type="button" id="bannerFilterReset">초기화</button></div><table><tr><th>ID</th><th>제목</th><th>위치</th><th>노출상태</th><th>정렬순서</th><th>관리</th></tr><% banners.forEach(b=>{%><tr class="banner-row" data-title="<%=String(b.title||'').toLowerCase()%>" data-position="<%=b.position%>" data-active="<%=b.is_active?'active':'hidden'%>"><td><%=b.id%></td><td><%=b.title%></td><td><%=b.position%></td><td><span class="<%=b.is_active?'status-on':'status-off'%>"><%=b.is_active?'● 노출':'● 숨김'%></span></td><td><%=b.sort_order%></td><td><div class="row-actions"><button type="button" class="edit-banner-btn" data-id="<%=b.id%>">수정</button><form method="post" action="/admin/delete/banners/<%=b.id%>"><button onclick="return confirm('삭제할까요?')">삭제</button></form></div></td></tr><%})%></table></section><section id="users" class="panel admin-panel"><h2>회원 관리</h2><div class="user-admin-filter"><input id="userSearch" placeholder="아이디/닉네임 검색"><select id="userRoleFilter"><option value="all">전체 권한</option><option value="user">일반회원</option><option value="admin">관리자</option></select><select id="userStatusFilter"><option value="all">전체 상태</option><option value="active">정상</option><option value="blocked">차단</option></select><button type="button" id="userFilterReset">초기화</button></div><table><tr><th>ID</th><th>아이디</th><th>닉네임</th><th>권한</th><th>상태</th><th>수정</th></tr><% users.forEach(u=>{%><tr class="user-row" data-text="<%=String((u.username||'')+' '+(u.nickname||'')).toLowerCase()%>" data-role="<%=u.role%>" data-status="<%=u.status%>"><td><%=u.id%></td><td><%=u.username%></td><td><input form="userForm<%=u.id%>" name="nickname" value="<%=u.nickname%>"></td><td><select form="userForm<%=u.id%>" name="role"><option <%=u.role==='user'?'selected':''%>>user</option><option <%=u.role==='admin'?'selected':''%>>admin</option></select></td><td><select form="userForm<%=u.id%>" name="status"><option <%=u.status==='active'?'selected':''%>>active</option><option <%=u.status==='blocked'?'selected':''%>>blocked</option></select></td><td><form id="userForm<%=u.id%>" method="post" action="/admin/user" class="row-actions"><input type="hidden" name="id" value="<%=u.id%>"><input name="password" placeholder="새 비번"><button>저장</button></form></td></tr><%})%></table></section><section id="notices" class="panel admin-panel"><h2>공지 관리</h2><form method="post" action="/admin/notice" class="gridform"><input name="title" placeholder="제목" required><textarea name="content" placeholder="내용" required></textarea><label><input type="checkbox" name="is_pinned">상단 고정</label><button>공지 등록</button></form><div class="notice-admin-filter"><input id="noticeSearch" placeholder="공지 제목 검색"><select id="noticePinnedFilter"><option value="all">전체 공지</option><option value="pinned">상단고정</option><option value="normal">일반공지</option></select><button type="button" id="noticeFilterReset">초기화</button></div><table><tr><th>ID</th><th>제목</th><th>고정상태</th><th>삭제</th></tr><% notices.forEach(n=>{%><tr class="notice-row" data-title="<%=String(n.title||'').toLowerCase()%>" data-pinned="<%=n.is_pinned?'pinned':'normal'%>"><td><%=n.id%></td><td><%=n.title%></td><td><span class="<%=n.is_pinned?'status-pin':'status-off'%>"><%=n.is_pinned?'● 상단고정':'● 일반공지'%></span></td><td><form method="post" action="/admin/delete/notices/<%=n.id%>"><button onclick="return confirm('삭제할까요?')">삭제</button></form></td></tr><%})%></table></section><section id="reviews" class="panel admin-panel"><h2>후기 관리</h2><div class="review-admin-filter"><input id="reviewSearch" placeholder="업체명/후기제목 검색"><select id="reviewRatingFilter"><option value="all">전체 평점</option><option value="5">5점</option><option value="4">4점</option><option value="low">3점 이하</option></select><button type="button" id="reviewFilterReset">초기화</button></div><table><tr><th>ID</th><th>업체</th><th>제목</th><th>평점</th><th>삭제</th></tr><% reviews.forEach(r=>{%><tr class="review-row" data-text="<%=String((r.vendor_name||'')+' '+(r.title||'')).toLowerCase()%>" data-rating="<%=r.rating%>"><td><%=r.id%></td><td><%=r.vendor_name%></td><td><%=r.title%></td><td>★ <%=r.rating%></td><td><form method="post" action="/admin/delete/reviews/<%=r.id%>"><button onclick="return confirm('삭제할까요?')">삭제</button></form></td></tr><%})%></table></section><section id="inquiries" class="panel admin-panel"><div class="external-content" data-url="/admin/inquiries"><div>신청내역을 불러오는 중...</div></div></section><section id="reports" class="panel admin-panel"><div class="external-content" data-url="/admin/reports"><div>신고내역을 불러오는 중...</div></div></section></main></div><script>const ADMIN_VENDORS=<%- JSON.stringify(vendors).replace(/</g,'\\u003c') %>;const ADMIN_BANNERS=<%- JSON.stringify(banners).replace(/</g,'\\u003c') %>;function showAdminPanel(id){document.querySelectorAll('.admin-panel').forEach(p=>p.classList.remove('active'));const p=document.getElementById(id);if(p){p.classList.add('active');loadExternal(p)}document.querySelectorAll('[data-panel]').forEach(a=>a.classList.toggle('active',a.dataset.panel===id));}document.querySelectorAll('[data-panel]').forEach(a=>a.addEventListener('click',e=>{e.preventDefault();showAdminPanel(a.dataset.panel);history.replaceState(null,'','#'+a.dataset.panel)}));async function loadExternal(p){const box=p.querySelector('.external-content[data-url]');if(!box||box.dataset.loaded)return;try{const res=await fetch(box.dataset.url,{credentials:'same-origin'});const html=await res.text();const doc=new DOMParser().parseFromString(html,'text/html');const inner=doc.querySelector('main .panel')||doc.querySelector('.panel')||doc.body;box.innerHTML=inner.innerHTML;box.dataset.loaded='1'}catch(e){box.innerHTML='내용을 불러오지 못했습니다.'}}function applyVendorFilter(){const q=(vendorSearch?.value||'').trim().toLowerCase();const t=vendorTypeFilter?.value||'all';const s=vendorStatusFilter?.value||'all';document.querySelectorAll('.vendor-row').forEach(row=>{const okName=!q||row.dataset.name.includes(q);const okType=t==='all'||row.dataset.type===t;const okStatus=s==='all'||row.dataset.status===s;row.classList.toggle('hidden-row',!(okName&&okType&&okStatus));});}function sortVendorRows(){const table=document.querySelector('#vendors table');if(!table)return;const rows=[...table.querySelectorAll('.vendor-row')];const mode=document.getElementById('vendorSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='views')return Number(b.dataset.views)-Number(a.dataset.views);if(mode==='reviews')return Number(b.dataset.reviews)-Number(a.dataset.reviews);if(mode==='rating')return Number(b.dataset.rating)-Number(a.dataset.rating);if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.id)-Number(b.dataset.id);});rows.forEach(r=>table.appendChild(r));}function applyBannerFilter(){const q=(bannerSearch?.value||'').trim().toLowerCase();const p=bannerPositionFilter?.value||'all';const s=bannerStatusFilter?.value||'all';document.querySelectorAll('.banner-row').forEach(row=>{const okTitle=!q||row.dataset.title.includes(q);const okPos=p==='all'||row.dataset.position===p;const okStatus=s==='all'||row.dataset.active===s;row.classList.toggle('hidden-row',!(okTitle&&okPos&&okStatus));});}function applyUserFilter(){const q=(userSearch?.value||'').trim().toLowerCase();const r=userRoleFilter?.value||'all';const s=userStatusFilter?.value||'all';document.querySelectorAll('.user-row').forEach(row=>{const okText=!q||row.dataset.text.includes(q);const okRole=r==='all'||row.dataset.role===r;const okStatus=s==='all'||row.dataset.status===s;row.classList.toggle('hidden-row',!(okText&&okRole&&okStatus));});}function applyNoticeFilter(){const q=(noticeSearch?.value||'').trim().toLowerCase();const f=noticePinnedFilter?.value||'all';document.querySelectorAll('.notice-row').forEach(row=>{const okTitle=!q||row.dataset.title.includes(q);const okPinned=f==='all'||row.dataset.pinned===f;row.classList.toggle('hidden-row',!(okTitle&&okPinned));});}function applyReviewFilter(){const q=(reviewSearch?.value||'').trim().toLowerCase();const f=reviewRatingFilter?.value||'all';document.querySelectorAll('.review-row').forEach(row=>{const rating=parseInt(row.dataset.rating||0,10);const okText=!q||row.dataset.text.includes(q);const okRating=f==='all'||(f==='5'&&rating===5)||(f==='4'&&rating===4)||(f==='low'&&rating<=3);row.classList.toggle('hidden-row',!(okText&&okRating));});}['input','change'].forEach(ev=>{vendorSearch?.addEventListener(ev,applyVendorFilter);vendorTypeFilter?.addEventListener(ev,applyVendorFilter);vendorStatusFilter?.addEventListener(ev,applyVendorFilter);vendorSortFilter?.addEventListener(ev,sortVendorRows);bannerSearch?.addEventListener(ev,applyBannerFilter);bannerPositionFilter?.addEventListener(ev,applyBannerFilter);bannerStatusFilter?.addEventListener(ev,applyBannerFilter);userSearch?.addEventListener(ev,applyUserFilter);userRoleFilter?.addEventListener(ev,applyUserFilter);userStatusFilter?.addEventListener(ev,applyUserFilter);noticeSearch?.addEventListener(ev,applyNoticeFilter);noticePinnedFilter?.addEventListener(ev,applyNoticeFilter);reviewSearch?.addEventListener(ev,applyReviewFilter);reviewRatingFilter?.addEventListener(ev,applyReviewFilter);});vendorFilterReset?.addEventListener('click',()=>{vendorSearch.value='';vendorTypeFilter.value='all';vendorStatusFilter.value='all';vendorSortFilter.value='default';applyVendorFilter();sortVendorRows();});bannerFilterReset?.addEventListener('click',()=>{bannerSearch.value='';bannerPositionFilter.value='all';bannerStatusFilter.value='all';applyBannerFilter();});userFilterReset?.addEventListener('click',()=>{userSearch.value='';userRoleFilter.value='all';userStatusFilter.value='all';applyUserFilter();});noticeFilterReset?.addEventListener('click',()=>{noticeSearch.value='';noticePinnedFilter.value='all';applyNoticeFilter();});reviewFilterReset?.addEventListener('click',()=>{reviewSearch.value='';reviewRatingFilter.value='all';applyReviewFilter();});function showPreview(box,src,text){if(!box)return;const img=box.querySelector('img');const span=box.querySelector('span');if(src){img.src=src;box.style.display='flex';if(span)span.textContent=text||'선택한 이미지가 표시됩니다.';}else{box.style.display='none';if(img)img.removeAttribute('src');}}function bindPreview(input,box){if(!input)return;input.addEventListener('change',()=>{const f=input.files&&input.files[0];if(!f)return showPreview(box,null);showPreview(box,URL.createObjectURL(f),'새로 선택한 이미지입니다.');});}const vf=document.getElementById('vendorForm'),bf=document.getElementById('bannerForm');bindPreview(vf?.image,document.getElementById('vendorImagePreview'));bindPreview(bf?.image,document.getElementById('bannerImagePreview'));document.querySelectorAll('.edit-vendor-btn').forEach(btn=>btn.onclick=()=>{const v=ADMIN_VENDORS.find(x=>String(x.id)===String(btn.dataset.id));if(!v)return;showAdminPanel('vendors');vf.id.value=v.id||'';vf.name.value=v.name||'';vf.category.value=v.category||'';vf.region.value=v.region||'';vf.phone.value=v.phone||'';vf.kakao_url.value=v.kakao_url||'';vf.business_hours.value=v.business_hours||'';vf.tags.value=v.tags||'';vf.status.value=v.status||'active';vf.description.value=v.description||'';vf.is_recommended.checked=!!v.is_recommended;vf.is_premium.checked=!!v.is_premium;showPreview(document.getElementById('vendorImagePreview'),v.image_data,'현재 등록된 업체 이미지입니다. 새 파일 선택 시 교체됩니다.');vendorSubmitBtn.textContent='업체 수정';cancelVendorEdit.style.display='block';vf.scrollIntoView({behavior:'smooth'})});cancelVendorEdit.onclick=()=>{vf.reset();vf.id.value='';showPreview(document.getElementById('vendorImagePreview'),null);vendorSubmitBtn.textContent='업체 등록';cancelVendorEdit.style.display='none'};document.querySelectorAll('.edit-banner-btn').forEach(btn=>btn.onclick=()=>{const b=ADMIN_BANNERS.find(x=>String(x.id)===String(btn.dataset.id));if(!b)return;showAdminPanel('banners');bf.id.value=b.id||'';bf.title.value=b.title||'';bf.subtitle.value=b.subtitle||'';bf.link_url.value=b.link_url||'';bf.sort_order.value=b.sort_order||0;bf.position.value=b.position||'premium';bf.is_active.checked=!!b.is_active;showPreview(document.getElementById('bannerImagePreview'),b.image_data,'현재 등록된 배너 이미지입니다. 새 파일 선택 시 교체됩니다.');bannerSubmitBtn.textContent='배너 수정';cancelBannerEdit.style.display='block';bf.scrollIntoView({behavior:'smooth'})});cancelBannerEdit.onclick=()=>{bf.reset();bf.id.value='';bf.is_active.checked=true;showPreview(document.getElementById('bannerImagePreview'),null);bannerSubmitBtn.textContent='배너 등록';cancelBannerEdit.style.display='none'};async function updateReportAlert(){try{const res=await fetch('/admin/reports',{credentials:'same-origin'});const html=await res.text();const doc=new DOMParser().parseFromString(html,'text/html');const pending=[...doc.querySelectorAll('tr[data-status]')].filter(r=>r.dataset.status!=='done').length;const el=document.getElementById('pendingReportCount');if(el)el.textContent=pending;}catch(e){const el=document.getElementById('pendingReportCount');if(el)el.textContent='확인';}}showAdminPanel((location.hash||'#dashboard').replace('#',''));updateReportAlert();</script></body></html>
