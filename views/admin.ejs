  document.addEventListener('click',function(e){var toggle=e.target.closest('[data-admin-password-toggle]');if(toggle){var form=toggle.closest('form'),input=form?.elements[toggle.dataset.adminPasswordToggle];if(input){var visible=input.type==='text';input.type=visible?'password':'text';toggle.textContent=visible?'л≥ікЄ∞':'мИ®кЄ∞кЄ∞';toggle.setAttribute('aria-label',(input.placeholder||'лєДл∞Ал≤ИнШЄ')+' '+(visible?'л≥ікЄ∞':'мИ®кЄ∞кЄ∞'));}return;}var generate=e.target.closest('[data-admin-password-generate]');if(generate){var form=generate.closest('form'),password=generatePassword(),a=generate.dataset.adminPasswordGenerate==='create'?'password':'new_password',b=generate.dataset.adminPasswordGenerate==='create'?'password_confirm':'new_password_confirm';form.elements[a].value=password;form.elements[b].value=password;form.elements[a].type='text';form.elements[b].type='text';form.querySelectorAll('[data-admin-password-toggle="'+a+'"],[data-admin-password-toggle="'+b+'"]').forEach(function(button){button.textContent='мИ®кЄ∞кЄ∞';});return;}var copy=e.target.closest('[data-admin-password-copy]');if(copy){copyText(copy.closest('form')?.elements[copy.dataset.adminPasswordCopy]?.value||'');return;}if(e.target.closest('[data-admin-password-result-copy]')){copyText(resultPassword);return;}if(e.target.closest('[data-admin-password-result-close]')||e.target===resultModal){closePasswordResult();return;}var logSettings=e.target.closest('[data-admin-log-navigate="settings"]');if(logSettings){showAdminPanel('settings');history.replaceState(null,'','#settings');window.activateAdminSettingsTab?.('admin');setTimeout(loadAdminAccounts,0);return;}var manage=e.target.closest('[data-admin-account-manage]');if(manage){openModal(manage.dataset.adminAccountManage);return;}if(e.target.closest('[data-admin-account-close]')||e.target===modal)closeModal();var tab=e.target.closest('.settings-tab[data-settings-tab="admin"]');if(tab)setTimeout(loadAdminAccounts,0);});
  document.addEventListener('submit',async function(e){var form=e.target.closest('[data-admin-account-form]');if(!form)return;e.preventDefault();e.stopPropagation();if(e.stopImmediatePropagation)e.stopImmediatePropagation();if(form.dataset.adminAccountSubmitting==='1')return;var kind=form.dataset.adminAccountForm,id=managedId?.value||'',plainUsername=kind==='create'?String(form.elements.username?.value||''):kind==='password'?String(rows.get(String(id))?.username||''):'',plainPassword=kind==='create'?String(form.elements.password?.value||''):kind==='password'?String(form.elements.new_password?.value||''):'';if(kind!=='create'&&!id){toastMessage('кіАл¶ђмЮР к≥Дм†ХмЭД лЛ§мЛЬ мД†нГЭнХім£ЉмДЄмЪФ.','bad');return;}if(kind==='delete'){var confirmInput=form.elements.confirm_text;if(String(confirmInput?.value||'').trim()!=='кіАл¶ђмЮРмВ≠м†Ь'){toastMessage('нЩХмЭЄ лђЄкµђмЧР кіАл¶ђмЮРмВ≠м†Ьл•Љ м†ХнЩХнЮИ мЮЕл†•нХім£ЉмДЄмЪФ.','bad');confirmInput?.focus();return;}if(!confirm('мЭі кіАл¶ђмЮР к≥Дм†ХмЭД мВ≠м†ЬнХ†кєМмЪФ? мЭі мЮСмЧЕмЭА лРШлПМл¶і мИШ мЧЖмКµлЛИлЛ§.'))return;}form.dataset.adminAccountSubmitting='1';var button=e.submitter||form.querySelector('button[type="submit"],button:not([type])');if(button)button.disabled=true;try{var url=kind==='create'?'/admin/settings/admin-accounts/create':'/admin/settings/admin-accounts/'+encodeURIComponent(id)+'/'+kind;form.action=url;var res=await fetch(url,{method:'POST',body:new FormData(form),credentials:'same-origin',headers:{Accept:'application/json','X-Requested-With':'fetch'}}),data=await res.json();if(!res.ok||!data.ok)throw new Error(data.error||'request_failed');if(kind==='create'){form.reset();form.querySelectorAll('input[name="password"],input[name="password_confirm"]').forEach(function(input){input.type='password';});form.querySelectorAll('[data-admin-password-toggle]').forEach(function(button){button.textContent='л≥ікЄ∞';});}else closeModal();var refreshed=await loadAdminAccounts(true);if((kind==='create'||kind==='password')&&plainPassword)showPasswordResult(plainUsername,plainPassword);plainUsername='';plainPassword='';if(!refreshed){toastMessage('мЮСмЧЕмЭА мЩДл£МлРРмІАлІМ кіАл¶ђмЮР л™©л°ЭмЭД к∞±мЛ†нХШмІА л™їнЦИмКµлЛИлЛ§.','bad');return;}toastMessage(kind==='create'?'кіАл¶ђмЮРл•Љ мґФк∞АнЦИмКµлЛИлЛ§.':kind==='delete'?'кіАл¶ђмЮРл•Љ мВ≠м†ЬнЦИмКµлЛИлЛ§.':kind==='update'?'кіАл¶ђмЮР м†Хл≥іл•Љ мИШм†ХнЦИмКµлЛИлЛ§.':kind==='password'?'кіАл¶ђмЮР лєДл∞Ал≤ИнШЄл•Љ л≥Ак≤љнЦИмКµлЛИлЛ§.':'кіАл¶ђмЮР мГБнГЬл•Љ л≥Ак≤љнЦИмКµлЛИлЛ§.','ok');}catch(err){toastMessage(message(err.message),'bad');}finally{plainUsername='';plainPassword='';form.dataset.adminAccountSubmitting='0';if(button)button.disabled=false;}},true);
