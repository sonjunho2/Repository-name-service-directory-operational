    document.querySelectorAll('[data-board-operation-target]').forEach(function(button){
      var active=button.dataset.boardOperationTarget===target;
      button.classList.toggle('active',active);
      button.setAttribute('aria-current',active?'page':'false');
    });
  }
  window.syncBoardOperationTabs=syncBoardOperationTabs;
  document.addEventListener('click',function(e){
    var button=e.target&&e.target.closest&&e.target.closest('[data-board-operation-target]');
    if(!button)return;
    var target=button.dataset.boardOperationTarget;
    if(!boardOperationTargets.includes(target))return;
    showAdminPanel(target);
    history.replaceState(null,'','#'+target);
    syncBoardOperationTabs(target);
    if(typeof window.scheduleAdminPanelLoad==='function')window.scheduleAdminPanelLoad();
  });
  window.addEventListener('hashchange',function(){
    var target=String(location.hash||'').replace(/^#/,'');
    if(boardOperationTargets.includes(target)){
      showAdminPanel(target);
      syncBoardOperationTabs(target);
    }
  });
  var initial=String(location.hash||'').replace(/^#/,'');
  if(boardOperationTargets.includes(initial))syncBoardOperationTabs(initial);
})();
</script>
<script>
(function(){
  if(window.__adminClientPagerV2)return;
  window.__adminClientPagerV2=true;

  var apiPanels={users:1,vendors:1,inquiries:1,revenue:1,reports:1,adminLogs:1};
  var configs={};
  var pageState={};
  var limit=20;
  var timer=null;

  function activePanelId(){
    var p=document.querySelector('.admin-panel.active');
    return p&&p.id;
  }
  function rowsFor(panel,cfg){
    var rows=[].slice.call(panel.querySelectorAll(cfg.selector));
    return rows;
  }
  function filterVisible(rows){
    return rows.filter(function(r){
      return !r.classList.contains('hidden-row')&&!r.classList.contains('hide');
    });
  }
  function makeBtn(label,disabled,active,onClick){
    var b=document.createElement('button');
    b.type='button';
    b.textContent=label;
    if(disabled)b.disabled=true;
    if(active)b.classList.add('active');
    b.addEventListener('click',onClick);
    return b;
  }
  function addPageButtons(pager,page,totalPages,panelId){
    var start=Math.max(1,page-2);
    var end=Math.min(totalPages,start+4);
    start=Math.max(1,end-4);
    if(start>1){
      pager.appendChild(makeBtn('1',false,page===1,function(){applyOne(panelId,1);}));
      if(start>2){var d=document.createElement('span');d.className='dots';d.textContent='...';pager.appendChild(d);}
    }
    for(var p=start;p<=end;p++){
      (function(n){pager.appendChild(makeBtn(String(n),false,n===page,function(){applyOne(panelId,n);}));})(p);
    }
    if(end<totalPages){
      if(end<totalPages-1){var d2=document.createElement('span');d2.className='dots';d2.textContent='...';pager.appendChild(d2);}
      pager.appendChild(makeBtn(String(totalPages),false,page===totalPages,function(){applyOne(panelId,totalPages);}));
    }
  }
  function ensurePager(panel,table){
    panel.querySelectorAll('.admin-pager').forEach(function(p,i){if(i>0)p.remove();});
    var pager=panel.querySelector('.admin-pager');
    if(!pager){
      pager=document.createElement('div');
      pager.className='admin-pager';
      table.insertAdjacentElement('afterend',pager);
    }
    return pager;
  }
  function clearApiPagers(){
    Object.keys(apiPanels).forEach(function(id){
      var panel=document.getElementById(id);
      if(panel)panel.querySelectorAll('.admin-pager').forEach(function(p){p.remove();});
    });
  }
  function applyOne(panelId,page){
    if(apiPanels[panelId])return clearApiPagers();
    var cfg=configs[panelId];
    var panel=document.getElementById(panelId);
    if(!cfg||!panel)return;
    var table=panel.querySelector('table');
    if(!table)return;
    var rows=rowsFor(panel,cfg);
    var visible=filterVisible(rows);
    var totalPages=Math.max(1,Math.ceil(visible.length/limit));
    page=Math.max(1,Math.min(page||pageState[panelId]||1,totalPages));
    pageState[panelId]=page;
    rows.forEach(function(r){r.classList.remove('admin-page-hidden');});
    visible.forEach(function(r,i){
      r.classList.toggle('admin-page-hidden',i<(page-1)*limit||i>=page*limit);
    });
    var pager=ensurePager(panel,table);
    pager.innerHTML='';
    var from=visible.length?((page-1)*limit+1):0;
    var to=Math.min(page*limit,visible.length);
    var info=document.createElement('span');
    info.className='pager-info';
    info.textContent='총 '+visible.length+cfg.label+' · 현재 '+from+'-'+to+cfg.label+' 표시';
    pager.appendChild(info);
    pager.appendChild(makeBtn('처음',page<=1,false,function(){applyOne(panelId,1);}));
    pager.appendChild(makeBtn('이전',page<=1,false,function(){applyOne(panelId,page-1);}));
    addPageButtons(pager,page,totalPages,panelId);
    pager.appendChild(makeBtn('다음',page>=totalPages,false,function(){applyOne(panelId,page+1);}));
    pager.appendChild(makeBtn('마지막',page>=totalPages,false,function(){applyOne(panelId,totalPages);}));
  }
  function applyAll(reset){
    clearApiPagers();
    Object.keys(configs).forEach(function(id){
      if(reset)pageState[id]=1;
      applyOne(id,pageState[id]||1);
    });
  }
  function schedule(reset){
    clearTimeout(timer);
    timer=setTimeout(function(){applyAll(reset);},80);
  }

  window.applyPanelPagination=function(reset){applyAll(!!reset);};
  document.addEventListener('DOMContentLoaded',function(){schedule(true);setTimeout(function(){schedule(false);},600);});
  window.addEventListener('hashchange',function(){schedule(false);});
  document.addEventListener('click',function(e){
    if(e.target.closest('[data-panel]'))schedule(false);
    if(e.target.closest('[data-ad-center-filter]'))schedule(true);
  },true);
  document.addEventListener('input',function(e){
    if(e.target.closest('#banners,#notices,#reviews,#adCenter,#vendorRequests,#adminLogs'))schedule(true);
  },true);
  document.addEventListener('change',function(e){
    if(e.target.closest('#banners,#notices,#reviews,#adCenter,#vendorRequests,#adminLogs'))schedule(true);
  },true);
})();
</script>
<script>
/* 공통 유틸(admin 전역 공용): esc, toast, num, money, makeButton
   각 관리자 패널(회원/업체/입점/결제·신고 등) 모듈에서 중복 정의되던 함수를 여기 하나로 통합합니다.
   아래 패널별 모듈들은 이 스크립트 다음에 로드되며, 자체 정의를 제거하고 이 전역 함수를 그대로 사용합니다. */
function esc(v){
  return String(v==null?'':v).replace(/[&<>"']/g,function(c){
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
  });
}
function toast(message,type,detail){
  var wrap=document.querySelector('.admin-toast-wrap');
  if(!wrap){
    wrap=document.createElement('div');
    wrap.className='admin-toast-wrap';
    document.body.appendChild(wrap);
  }
  var el=document.createElement('div');
  el.className='admin-toast '+(type||'ok');
  el.innerHTML=String(message||'처리되었습니다.')+(detail?'<small>'+String(detail)+'</small>':'');
  wrap.appendChild(el);
  setTimeout(function(){el.style.opacity='0';el.style.transform='translateY(-8px)';},2600);
  setTimeout(function(){el.remove();},3100);
}
function num(n){return Number(n||0).toLocaleString();}
function money(n){return Number(n||0).toLocaleString()+'원';}
function makeButton(label,disabled,active,onClick){
  var b=document.createElement('button');
  b.type='button';
  b.textContent=label;
  if(disabled)b.disabled=true;
  if(active)b.classList.add('active');
  b.onclick=onClick;
  return b;
}
</script>
<script>
document.querySelectorAll('[data-ad-center-filter]').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('[data-ad-center-filter]').forEach(x=>x.classList.remove('on'));
    btn.classList.add('on');
    const f=btn.dataset.adCenterFilter;
    if(window.isAdminApiPanel?.('adCenter'))return;
    document.querySelectorAll('.ad-center-row').forEach(row=>{
      row.classList.toggle('hide', f!=='all' && row.dataset.status!==f);
    });
  });
});
</script>

