  <a class="dash-card dashboard-card-link" href="#vendors" data-panel="vendors"><b>전체 업체/후기</b><strong><%=num(S.totalVendors)%> / <%=num(S.totalReviews)%></strong></a>
</div>
<div class="dashboard-simple">
  <div class="dashboard-box">
    <h3>빠른 이동</h3>
    <div class="dashboard-quick">
      <a href="#vendors" data-panel="vendors">🏢 업체목록<small>등록/수정/비활성화</small></a>
