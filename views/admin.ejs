  var originalShow=showAdminPanel;
  showAdminPanel=function(id){originalShow(id);var menuId=getAdminMenuPanel(id);document.querySelectorAll('.admin-sidebar [data-panel]').forEach(function(a){a.classList.toggle('active',a.dataset.panel===menuId);});document.querySelectorAll('[data-admin-panel-target]').forEach(function(b){b.classList.toggle('active',b.dataset.adminPanelTarget===id);});};
