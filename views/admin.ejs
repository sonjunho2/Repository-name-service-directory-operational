(function(){
  if(window.__adminStage32)return;
  window.__adminStage32=true;

      function set(key,val){
    document.querySelectorAll('[data-stage32="'+key+'"]').forEach(function(el){el.textContent=val;});
  }
  function cls(n){
    n=Number(n||0);
    if(n>=5)return 'danger';
    if(n>0)return 'warn';
    return 'good';
