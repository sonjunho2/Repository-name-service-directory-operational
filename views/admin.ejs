  function fmtDate(v){
    if(!v)return '-';
    var d=new Date(v);
    if(isNaN(d.getTime()))return '-';
    var y=d.getFullYear();
    var m=String(d.getMonth()+1).padStart(2,'0');
    var day=String(d.getDate()).padStart(2,'0');
    return y+'-'+m+'-'+day;
  }
  function daysLeft(v){
    if(!v)return null;
    var today=new Date(); today.setHours(0,0,0,0);
    var d=new Date(v); d.setHours(0,0,0,0);
    if(isNaN(d.getTime()))return null;
    return Math.ceil((d-today)/(1000*60*60*24));
  }
  function adBadge(v){
    if(v.banner_active)return '<span class="ad-badge ad-banner">추천광고 + 프리미엄배너</span><small>배너 사용중</small>';
    if(v.ad_type==='recommended')return '<span class="ad-badge ad-recommended">추천광고</span><small>배너 없음</small>';
    if(v.ad_type==='general')return '<span class="ad-badge ad-general">일반광고</span><small>배너 없음</small>';
    return '<span class="ad-badge ad-none">광고없음</span><small>배너 없음</small>';
  }
  function expiryBadge(v){
    var d=daysLeft(v.expire_at);
    if(!v.expire_at)return '<span class="expiry-badge expiry-empty">만기없음</span><br><small>-</small>';
    if(d<0||v.status==='expired')return '<span class="expiry-badge expiry-expired">만료</span><br><small>'+fmtDate(v.expire_at)+'</small>';
    if(d<=7)return '<span class="expiry-badge expiry-soon">'+d+'일 남음</span><br><small>'+fmtDate(v.expire_at)+'</small>';
    return '<span class="expiry-badge expiry-ok">'+d+'일 남음</span><br><small>'+fmtDate(v.expire_at)+'</small>';
  }
  function statusLabel(v){
    return v.status==='active'?'운영중':v.status==='pending'?'검수중':v.status==='hidden'?'숨김':v.status==='expired'?'광고만료':'-';
