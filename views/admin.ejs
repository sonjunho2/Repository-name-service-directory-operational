</style><section id="reports" class="panel admin-panel"><h2>신고·제보 관리</h2><nav class="board-operation-tabs" aria-label="게시판 운영 메뉴"><button type="button" data-board-operation-target="boardPosts">전체 게시글</button><button type="button" data-board-operation-target="notices">공지사항</button><button type="button" data-board-operation-target="reviews">이용후기</button><button type="button" data-board-operation-target="reports">신고·제보</button><button type="button" data-board-operation-target="adInquiries">광고문의</button></nav><div id="reportSummaryGrid" class="report-summary-grid"><button type="button" data-report-card="all"><b>전체 신고</b><strong data-report-summary="total">-</strong></button><button type="button" data-report-card="new"><b>처리 대기</b><strong data-report-summary="waiting">-</strong></button><button type="button" data-report-card="done"><b>처리완료</b><strong data-report-summary="done">-</strong></button><button type="button" data-report-card="rejected"><b>기각</b><strong data-report-summary="rejected">-</strong></button><button type="button" data-report-card="vendor"><b>업체 신고</b><strong data-report-summary="vendor">-</strong></button><button type="button" data-report-card="review"><b>후기 신고</b><strong data-report-summary="review">-</strong></button><button type="button" data-report-card="missing"><b>대상 없음</b><strong data-report-summary="missing_target">-</strong></button></div><div class="report-admin-filter"><input id="reportSearch" placeholder="대상명 / ID / 사유 / 신고내용 / 처리메모 검색"><select id="reportTypeFilter"><option value="all">전체 유형</option><option value="vendor">업체 신고</option><option value="review">후기 신고</option></select><select id="reportStatusFilter"><option value="all">전체 상태</option><option value="new">처리 대기</option><option value="done">처리완료</option><option value="rejected">기각</option><option value="cancelled">취소</option></select><select id="reportTargetFilter"><option value="all">전체 대상</option><option value="exists">대상 존재</option><option value="missing">대상 없음</option></select><select id="reportSort"><option value="latest">신고일 최신순</option><option value="oldest">신고일 오래된순</option><option value="status">처리상태순</option><option value="vendor">업체 신고 우선</option><option value="review">후기 신고 우선</option><option value="reason">신고사유순</option><option value="processed">최근 처리순</option></select><button type="button" id="reportSearchReset">초기화</button></div><div class="report-table-wrap"><table id="reportManagementTable"><colgroup><col style="width:96px"><col style="width:92px"><col style="width:190px"><col style="width:250px"><col style="width:120px"><col style="width:110px"><col style="width:210px"><col style="width:230px"></colgroup><thead><tr><th>ID / 신고일</th><th>유형</th><th>신고 대상</th><th>신고 내용</th><th>대상 상태</th><th>처리 상태</th><th>처리 이력</th><th>관리</th></tr></thead><tbody id="reportTableBody"><tr><td colspan="8" class="admin-list-loading">신고 목록을 불러오는 중입니다.</td></tr></tbody></table></div><div id="reportPager" class="server-report-pager"></div></section><section id="vendorRequests" class="panel admin-panel">
  <h2>업체 수정요청</h2>
  <p class="vendor-request-help">업체회원이 요청한 변경 내용을 현재 등록 정보와 비교한 뒤 승인하거나 반려합니다.<br>승인 시 변경된 정보만 업체에 반영됩니다.</p>
  <div id="vendorRequestSummaryGrid" class="vendor-request-summary-grid">
    <button type="button" class="active" data-vendor-request-card="all"><b>전체 요청</b><strong data-vendor-request-summary="total">0</strong></button>
    <button type="button" data-vendor-request-card="waiting"><b>승인대기</b><strong data-vendor-request-summary="waiting">0</strong></button>
    <button type="button" data-vendor-request-card="approved"><b>승인완료</b><strong data-vendor-request-summary="approved">0</strong></button>
    <button type="button" data-vendor-request-card="rejected"><b>반려</b><strong data-vendor-request-summary="rejected">0</strong></button>
    <button type="button" data-vendor-request-card="many"><b>변경항목 많음</b><strong data-vendor-request-summary="many">0</strong></button>
  </div>
  <div class="vendor-request-filter">
    <input id="vendorRequestSearch" placeholder="요청 ID, 업체명, 회원, 연락처, 지역, 업종, 변경내용 검색">
    <select id="vendorRequestStatus"><option value="all">전체 상태</option><option value="new">승인대기</option><option value="approved">승인완료</option><option value="rejected">반려</option><option value="cancelled">취소</option></select>
    <select id="vendorRequestChange"><option value="all">전체 변경범위</option><option value="changed">변경사항 있음</option><option value="many">변경항목 5개 이상</option><option value="image">이미지 변경</option><option value="none">실제 변경 없음</option></select>
    <select id="vendorRequestSort"><option value="latest">요청일 최신순</option><option value="oldest">요청일 오래된순</option><option value="waiting">승인대기 우선</option><option value="changes">변경항목 많은순</option><option value="vendor">업체명순</option><option value="processed">최근 처리순</option></select>
    <button type="button" id="vendorRequestReset">초기화</button>
  </div>
  <div class="vendor-request-table-wrap"><table id="vendorRequestManagementTable" class="vendor-request-table"><thead><tr><th>ID / 요청일</th><th>요청 회원</th><th>업체</th><th>변경 요약</th><th>이미지</th><th>상태</th><th>상세</th><th>관리</th></tr></thead><tbody id="vendorRequestTableBody"><tr><td colspan="8">업체 수정요청을 불러오는 중입니다.</td></tr></tbody></table></div>
  <div id="vendorRequestPager" class="server-vendor-request-pager"></div>
</section><section id="bannerRequests" class="panel admin-panel"><h2>배너신청관리</h2>
<%
  const _bannerReqSafe=(typeof bannerRequests!=='undefined'&&Array.isArray(bannerRequests))?bannerRequests:[];
  const _bannerNew=_bannerReqSafe.filter(x=>x.status==='new').length;
  const _bannerUnpaid=_bannerReqSafe.filter(x=>x.status==='new'&&x.payment_status==='unpaid').length;
  const _bannerWaiting=_bannerReqSafe.filter(x=>x.status==='new'&&x.payment_status==='waiting').length;
  const _bannerApproved=_bannerReqSafe.filter(x=>x.status==='approved').length;
  const _bannerRejected=_bannerReqSafe.filter(x=>x.status==='rejected').length;
  const _bannerCancelled=_bannerReqSafe.filter(x=>x.status==='cancelled').length;
%>
<div class="request-summary">
  <div class="request-summary-card"><b>전체 신청</b><strong><%=adminListStats?.bannerRequests?.total ?? _bannerReqSafe.length%></strong></div>
  <div class="request-summary-card waiting"><b>입금대기</b><strong><%=adminListStats?.bannerRequests?.unpaid ?? _bannerUnpaid%></strong></div>
  <div class="request-summary-card waiting"><b>입금확인중</b><strong><%=adminListStats?.bannerRequests?.waiting ?? _bannerWaiting%></strong></div>
  <div class="request-summary-card approved"><b>승인완료</b><strong><%=adminListStats?.bannerRequests?.approved ?? _bannerApproved%></strong></div>
  <div class="request-summary-card rejected"><b>반려/취소</b><strong><%=(adminListStats?.bannerRequests?.rejected ?? _bannerRejected)+(adminListStats?.bannerRequests?.cancelled ?? _bannerCancelled)%></strong></div>
</div>
<div class="integrated-tools"><div class="integrated-card"><b>전체 신청</b><strong><%=(bannerRequests||[]).length%></strong></div><div class="integrated-card"><b>대기</b><strong><%=(bannerRequests||[]).filter(x=>x.status==='new').length%></strong></div><div class="integrated-card"><b>승인</b><strong><%=(bannerRequests||[]).filter(x=>x.status==='approved').length%></strong></div><div class="integrated-card"><b>반려</b><strong><%=(bannerRequests||[]).filter(x=>x.status==='rejected').length%></strong></div></div><table><tr><th>ID</th><th>업체</th><th>제목</th><th>결제</th><th>링크</th><th>이미지</th><th>상태</th><th>처리</th></tr><% (bannerRequests||[]).forEach(x=>{%><tr><td><%=x.id%></td><td><%=x.vendor_name||x.vendor_id%><br><small><%=x.username||''%></small></td><td><b><%=x.title%></b><br><%=x.subtitle||''%></td><td><%=Number(x.krw_price||0).toLocaleString()%>원<br><%=x.usdt_amount||0%> USDT<br><% if(x.payment_expires_at){ %><small>기한: <%=fmtDateTime(x.payment_expires_at)%></small><br><% } %><small><%=_paymentRequestLabel(x)%></small><% if(x.status==='approved'||x.payment_status==='paid'||x.paid_usdt_amount||x.payment_txid){ %><span class="payment-trace">실제입금: <%=_centerPaidUsdt(x)||'미입력'%><% if(_centerPaidUsdt(x)){ %> USDT<% } %><em>TXID: <%=x.payment_txid||'미입력'%></em></span><% } %></td><td><%=x.link_url||'-'%></td><td><%=x.has_image_data?'이미지 있음':'-'%></td><td><span class="<%=x.status==='approved'?'done':(x.status==='rejected'||x.status==='cancelled')?'rejected':'pending'%>"><%=_paymentRequestStatusLabel(x)%></span><br><small><%=_cleanCenterMemo(x)%></small></td><td><% if(x.status==='new'){%><% if(x.payment_status==='waiting'){%><form method="post" action="/admin/banner-requests/<%=x.id%>/payment-confirm" class="payment-confirm-form"><input name="paid_usdt_amount" placeholder="실제 USDT" value="<%=x.usdt_amount||''%>"><input name="payment_txid" placeholder="TXID / 거래해시"><input name="admin_memo" placeholder="입금확인 메모"><button class="approve-btn">입금확인</button></form><%}else{%><span class="pending">입금대기</span><%}%><form method="post" action="/admin/banner-requests/<%=x.id%>/reject" class="report-done-form" style="margin-top:8px"><input name="admin_memo" placeholder="반려 사유"><button class="reject-btn">반려</button></form><form method="post" action="/admin/banner-requests/<%=x.id%>/cancel" class="report-done-form" style="margin-top:8px"><input name="admin_memo" placeholder="취소 메모"><button class="cancel-edit">취소</button></form><%}else{%>처리완료<%}%></td></tr><%})%></table></section>
<section id="adCenter" class="panel admin-panel">
<h2>광고센터</h2>
<%
  const _centerAds=(typeof adRequests!=='undefined'&&Array.isArray(adRequests)?adRequests:[]).map(x=>Object.assign({},x,{_kind:'ad',_kindLabel:'변경/연장',_product:x.plan||x.product_type||'-'}));
  const _centerBanners=(typeof bannerRequests!=='undefined'&&Array.isArray(bannerRequests)?bannerRequests:[]).map(x=>Object.assign({},x,{_kind:'banner',_kindLabel:'프리미엄배너',_product:'프리미엄배너 신청',_productSub:x.title||''}));
  const _centerAll=[..._centerAds,..._centerBanners].sort((a,b)=>(Number(b.id||0)-Number(a.id||0)));
  const _centerUnpaid=_centerAll.filter(x=>x.status==='new'&&(!x.payment_status||x.payment_status==='unpaid')).length;
  const _centerWaiting=_centerAll.filter(x=>x.status==='new'&&x.payment_status==='waiting').length;
  const _centerApproved=_centerAll.filter(x=>x.status==='approved').length;
  const _centerRejected=_centerAll.filter(x=>x.status==='rejected').length;
  const _centerCancelled=_centerAll.filter(x=>x.status==='cancelled').length;
  const _centerStatus=x=>x.status==='approved'?'approved':x.status==='rejected'?'rejected':x.status==='cancelled'?'cancelled':x.payment_status==='waiting'?'waiting':'unpaid';
%>

<div class="ad-center-summary">
  <div class="ad-center-card"><b>전체 신청</b><strong><%=adminListStats?.adCenter?.total ?? _centerAll.length%></strong></div>
  <div class="ad-center-card waiting"><b>입금대기</b><strong><%=adminListStats?.adCenter?.unpaid ?? _centerUnpaid%></strong></div>
  <div class="ad-center-card waiting"><b>입금확인중</b><strong><%=adminListStats?.adCenter?.waiting ?? _centerWaiting%></strong></div>
  <div class="ad-center-card done"><b>입금완료</b><strong><%=adminListStats?.adCenter?.approved ?? _centerApproved%></strong></div>
  <div class="ad-center-card bad"><b>만료/취소</b><strong><%=(adminListStats?.adCenter?.rejected ?? _centerRejected)+(adminListStats?.adCenter?.cancelled ?? _centerCancelled)%></strong></div>
</div>

<div class="ad-center-filter">
  <button type="button" class="on" data-ad-center-filter="all">전체</button>
  <button type="button" data-ad-center-filter="unpaid">입금대기</button>
  <button type="button" data-ad-center-filter="waiting">입금확인중</button>
  <button type="button" data-ad-center-filter="paid">입금완료</button>
  <button type="button" data-ad-center-filter="expired">기한만료</button>
  <button type="button" data-ad-center-filter="cancelled">취소</button>
</div>

<div class="table-wrap">
<table>
<tr>
  <th>요청ID</th><th>상품구분</th><th>업체명</th><th>신청자</th><th>상품명/기간</th><th>원화금액</th><th>요청 USDT</th><th>결제상태</th><th>결제기한</th><th>실제입금 USDT</th><th>TXID/메모</th><th>관리</th>
</tr>
<% _centerAll.forEach(x=>{ const st=_centerStatus(x); %>
<tr class="ad-center-row" data-status="<%=st%>">
  <td><%=x.id%></td>
  <td>
    <% if(x._kind==='banner'){%>
      <span class="ad-kind-badge ad-kind-banner">프리미엄배너</span>
    <%}else{%>
      <span class="ad-kind-badge ad-kind-plan">변경/연장</span>
    <%}%>
  </td>
  <td><%=x.vendor_name||x.vendor_id||'-'%><br><small><%=x.username||''%></small></td>
  <td><b><%=x._product%></b><br><small><%=x._kind==='banner'?(x._productSub?'배너명: '+x._productSub:''):(x.period?x.period+'일':'')%></small></td>
  <td>
    <%=Number(x.krw_price||0).toLocaleString()%>원<br>
    <%=x.usdt_amount||0%> USDT<br>
    <% if(x.payment_expires_at){ %><small>기한: <%=fmtDateTime(x.payment_expires_at)%></small><br><% } %>
    <small><%=_paymentRequestLabel(x)%></small><% if(x.status==='approved'||x.payment_status==='paid'||x.paid_usdt_amount||x.payment_txid){ %><span class="payment-trace">실제입금: <%=_centerPaidUsdt(x)||'미입력'%><% if(_centerPaidUsdt(x)){ %> USDT<% } %><em>TXID: <%=x.payment_txid||'미입력'%></em></span><% } %>
  </td>
  <td>
    <span class="<%=x.status==='approved'?'done':x.status==='rejected'?'rejected':x.status==='cancelled'?'rejected':'pending'%>">
      <%=_paymentRequestStatusLabel(x)%>
    </span>
    <br><small><%=_cleanCenterMemo(x)%></small>
  </td>
  <td>
    <% if(x.status==='new'){%>
      <% if(x.payment_status==='waiting'){%>
        <form method="post" action="/admin/<%=x._kind==='banner'?'banner-requests':'ad-requests'%>/<%=x.id%>/payment-confirm" class="payment-confirm-form">
          <input name="paid_usdt_amount" placeholder="실제 USDT" value="<%=x.usdt_amount||''%>">
          <input name="payment_txid" placeholder="TXID / 거래해시">
          <input name="admin_memo" placeholder="입금확인 메모">
          <button class="approve-btn">입금확인</button>
        </form>
      <%}else{%>
        <span class="pending">입금대기</span>
      <%}%>
      <form method="post" action="/admin/<%=x._kind==='banner'?'banner-requests':'ad-requests'%>/<%=x.id%>/reject" class="report-done-form" style="margin-top:8px">
        <input name="admin_memo" placeholder="반려 사유">
        <button class="reject-btn">반려</button>
      </form>
      <form method="post" action="/admin/<%=x._kind==='banner'?'banner-requests':'ad-requests'%>/<%=x.id%>/cancel" class="report-done-form" style="margin-top:8px">
        <input name="admin_memo" placeholder="취소 메모">
        <button class="cancel-edit">취소</button>
      </form>
    <%}else{%>
      처리완료
    <%}%>
  </td>
</tr>
<%})%>
<% if(!_centerAll.length){%>
<tr><td colspan="12">광고 신청내역이 없습니다.</td></tr>
<%}%>
</table>
</div>
</section>
<section id="adRequests" class="panel admin-panel"><h2>광고연장관리</h2>
<%
  const _adReqSafe=(typeof adRequests!=='undefined'&&Array.isArray(adRequests))?adRequests:[];
  const _adNew=_adReqSafe.filter(x=>x.status==='new').length;
  const _adUnpaid=_adReqSafe.filter(x=>x.status==='new'&&x.payment_status==='unpaid').length;
  const _adWaiting=_adReqSafe.filter(x=>x.status==='new'&&x.payment_status==='waiting').length;
  const _adApproved=_adReqSafe.filter(x=>x.status==='approved').length;
  const _adRejected=_adReqSafe.filter(x=>x.status==='rejected').length;
  const _adCancelled=_adReqSafe.filter(x=>x.status==='cancelled').length;
%>
<div class="request-summary">
  <div class="request-summary-card"><b>전체 신청</b><strong><%=adminListStats?.adRequests?.total ?? _adReqSafe.length%></strong></div>
  <div class="request-summary-card waiting"><b>입금대기</b><strong><%=adminListStats?.adRequests?.unpaid ?? _adUnpaid%></strong></div>
  <div class="request-summary-card waiting"><b>입금확인중</b><strong><%=adminListStats?.adRequests?.waiting ?? _adWaiting%></strong></div>
  <div class="request-summary-card approved"><b>승인완료</b><strong><%=adminListStats?.adRequests?.approved ?? _adApproved%></strong></div>
  <div class="request-summary-card rejected"><b>반려/취소</b><strong><%=(adminListStats?.adRequests?.rejected ?? _adRejected)+(adminListStats?.adRequests?.cancelled ?? _adCancelled)%></strong></div>
</div>
<div class="integrated-tools"><div class="integrated-card"><b>전체 신청</b><strong><%=(adRequests||[]).length%></strong></div><div class="integrated-card"><b>대기</b><strong><%=(adRequests||[]).filter(x=>x.status==='new').length%></strong></div><div class="integrated-card"><b>승인</b><strong><%=(adRequests||[]).filter(x=>x.status==='approved').length%></strong></div><div class="integrated-card"><b>반려</b><strong><%=(adRequests||[]).filter(x=>x.status==='rejected').length%></strong></div></div><table><tr><th>ID</th><th>업체</th><th>상품</th><th>상품구분</th><th>기간</th><th>결제</th><th>내용</th><th>상태</th><th>처리</th></tr><% (adRequests||[]).forEach(x=>{%><tr><td><%=x.id%></td><td><%=x.vendor_name||x.vendor_id%><br><small><%=x.username||''%></small></td><td><%=x.plan||'-'%></td><td><%=x.product_type==="recommended_upgrade"?"일반→추천":x.product_type==="banner_from_general"?"일반→배너":x.product_type==="banner_from_recommended"?"추천→배너":x.product_type==="renewal_general"?"일반연장":x.product_type==="renewal_recommended"?"추천연장":x.product_type==="renewal_banner"?"배너신청/연장":x.product_type==="schedule_to_general"?"일반변경/연장":x.product_type==="schedule_remove_banner"?"배너제거예약":x.product_type==="schedule_to_recommended"?"추천변경/연장":x.product_type||"추천등록"%></td><td><%=x.period||'-'%>일</td><td><%=Number(x.krw_price||0).toLocaleString()%>원<br><%=x.usdt_amount||0%> USDT<br><% if(x.payment_expires_at){ %><small>기한: <%=fmtDateTime(x.payment_expires_at)%></small><br><% } %><small><%=_paymentRequestLabel(x)%></small><% if(x.status==='approved'||x.payment_status==='paid'||x.paid_usdt_amount||x.payment_txid){ %><span class="payment-trace">실제입금: <%=_centerPaidUsdt(x)||'미입력'%><% if(_centerPaidUsdt(x)){ %> USDT<% } %><em>TXID: <%=x.payment_txid||'미입력'%></em></span><% } %></td><td class="memo"><%=x.content||'-'%></td><td><span class="<%=x.status==='approved'?'done':(x.status==='rejected'||x.status==='cancelled')?'rejected':'pending'%>"><%=_paymentRequestStatusLabel(x)%></span><br><small><%=_cleanCenterMemo(x)%></small></td><td><% if(x.status==='new'){%><% if(x.payment_status==='waiting'){%><form method="post" action="/admin/ad-requests/<%=x.id%>/payment-confirm" class="payment-confirm-form"><input name="paid_usdt_amount" placeholder="실제 USDT" value="<%=x.usdt_amount||''%>"><input name="payment_txid" placeholder="TXID / 거래해시"><input name="admin_memo" placeholder="입금확인 메모"><button class="approve-btn">입금확인</button></form><%}else{%><span class="pending">입금대기</span><%}%><form method="post" action="/admin/ad-requests/<%=x.id%>/reject" class="report-done-form" style="margin-top:8px"><input name="admin_memo" placeholder="반려 사유"><button class="reject-btn">반려</button></form><form method="post" action="/admin/ad-requests/<%=x.id%>/cancel" class="report-done-form" style="margin-top:8px"><input name="admin_memo" placeholder="취소 메모"><button class="cancel-edit">취소</button></form><%}else{%>처리완료<%}%></td></tr><%})%></table></section><section id="revenue" class="panel admin-panel"><h2>결제내역</h2>
<div id="paymentSummaryGrid" class="payment-summary-grid"><button type="button" data-payment-card="today"><b>오늘 매출</b><strong data-payment-summary="todayKrw">0원</strong></button><button type="button" data-payment-card="week"><b>최근 7일 매출</b><strong data-payment-summary="last7DaysKrw">0원</strong></button><button type="button" data-payment-card="month"><b>이번달 매출</b><strong data-payment-summary="monthKrw">0원</strong></button><button type="button" class="active" data-payment-card="all"><b>누적 매출</b><strong data-payment-summary="totalKrw">0원</strong></button><button type="button" data-payment-card="count"><b>결제 건수</b><strong data-payment-summary="paymentCount">0건</strong></button><button type="button" data-payment-card="actual"><b>실제입금 USDT</b><strong data-payment-summary="totalActualUsdt">0.00</strong></button><button type="button" data-payment-card="different"><b>금액 차이</b><strong data-payment-summary="amountMismatchCount">0건</strong></button><button type="button" data-payment-card="missing"><b>실제입금 미입력</b><strong data-payment-summary="missingActualAmountCount">0건</strong></button></div>
<div class="payment-history-filter"><input id="paymentHistorySearch" placeholder="결제 ID / 업체 / 회원 / TXID / 메모 검색"><select id="paymentProductFilter"><option value="all">전체 상품</option></select><select id="paymentSourceFilter"><option value="all">전체 신청경로</option></select><select id="paymentAmountFilter"><option value="all">전체 입금상태</option><option value="matched">요청·실제 금액 일치</option><option value="different">요청·실제 금액 차이</option><option value="missing">실제입금 미입력</option></select><input id="paymentDateFrom" type="date" aria-label="결제 시작일"><input id="paymentDateTo" type="date" aria-label="결제 종료일"><select id="paymentHistorySort"><option value="latest">최신 결제순</option><option value="oldest">오래된 결제순</option><option value="krw_desc">원화금액 높은순</option><option value="krw_asc">원화금액 낮은순</option><option value="usdt_desc">실제 USDT 높은순</option><option value="product">상품순</option><option value="vendor">업체명순</option></select><button type="button" id="paymentHistoryReset">초기화</button></div>
<div class="payment-history-table-wrap"><table id="paymentHistoryTable"><colgroup><col style="width:65px"><col style="width:125px"><col style="width:125px"><col style="width:145px"><col style="width:125px"><col style="width:100px"><col style="width:105px"><col style="width:115px"><col style="width:155px"><col style="width:190px"><col style="width:70px"></colgroup><thead><tr><th>결제 ID</th><th>결제일</th><th>상품</th><th>업체</th><th>회원</th><th>원화금액</th><th>요청 USDT</th><th>실제입금 USDT</th><th>TXID</th><th>메모</th><th>상세</th></tr></thead><tbody id="paymentHistoryBody"><tr class="loading-row"><td colspan="11">결제내역을 불러오는 중입니다.</td></tr></tbody></table></div><div id="paymentHistoryPager" class="server-payment-pager"></div></section><section id="adminLogs" class="panel admin-panel"><h2>관리자 로그</h2>
<div id="adminLogSummaryGrid" class="admin-log-summary-grid"><button type="button" data-admin-log-card="all"><b>전체 로그</b><strong data-admin-log-summary="total">0</strong></button><button type="button" data-admin-log-card="today"><b>오늘 작업</b><strong data-admin-log-summary="today">0</strong></button><button type="button" data-admin-log-card="week"><b>최근 7일</b><strong data-admin-log-summary="last7Days">0</strong></button><button type="button" data-admin-log-card="vendor"><b>업체 관련</b><strong data-admin-log-summary="vendorActions">0</strong></button><button type="button" data-admin-log-card="user"><b>회원 관련</b><strong data-admin-log-summary="userActions">0</strong></button><button type="button" data-admin-log-card="finance"><b>결제·광고 관련</b><strong data-admin-log-summary="paymentAdActions">0</strong></button></div>
<div class="admin-log-filter"><input id="adminLogSearch" placeholder="로그 ID / 관리자 / 작업 / 대상 / 메모 검색"><select id="adminLogAdminFilter"><option value="all">전체 관리자</option></select><select id="adminLogActionFilter"><option value="all">전체 작업</option></select><select id="adminLogTargetFilter"><option value="all">전체 대상</option></select><input id="adminLogDateFrom" type="date" aria-label="시작일"><input id="adminLogDateTo" type="date" aria-label="종료일"><select id="adminLogSort"><option value="latest">최신 작업순</option><option value="oldest">오래된 작업순</option><option value="admin">관리자순</option><option value="action">작업명순</option><option value="target">대상 유형순</option></select><button type="button" id="adminLogFilterReset">초기화</button></div>
<div class="admin-log-table-wrap"><table id="adminLogManagementTable"><colgroup><col style="width:85px"><col style="width:175px"><col style="width:150px"><col style="width:210px"><col style="width:190px"><col style="width:430px"><col style="width:90px"></colgroup><thead><tr><th>로그 ID</th><th>작업시간</th><th>관리자</th><th>작업</th><th>대상</th><th>메모</th><th>상세</th></tr></thead><tbody id="adminLogTableBody"><tr class="loading-row"><td colspan="7">관리자 로그를 불러오는 중입니다.</td></tr></tbody></table></div><div id="adminLogPager" class="server-admin-log-pager"></div></section><section id="settings" class="panel admin-panel">
  <h2>환경설정</h2>

