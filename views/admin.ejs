<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>관리자</title><link rel="stylesheet" href="/public/css/style.css"><style>body{overflow-x:hidden}.admin-shell{display:grid;grid-template-columns:240px 1fr;min-height:calc(100vh - 68px)}.admin-sidebar{position:sticky;top:0;align-self:start;height:calc(100vh - 68px);padding:22px;background:#080d18;border-right:1px solid #29324f}.admin-sidebar h2{margin:0 0 18px;color:#fff;font-size:22px}.admin-sidebar a{display:flex;align-items:center;height:46px;margin-bottom:8px;padding:0 14px;border-radius:12px;color:#dfe9ff;text-decoration:none;font-weight:900;border:1px solid transparent}.admin-sidebar a:hover,.admin-sidebar a.active{background:linear-gradient(90deg,#ff3fb4,#10d9ff);color:#fff}.admin-sidebar .line{height:1px;background:#29324f;margin:16px 0}.admin-content{padding:24px 32px!important;min-width:0;width:100%!important;max-width:none!important;margin:0!important}.admin-content .panel{width:100%!important;max-width:none!important;margin:0!important;padding:30px!important}.admin-panel{display:none}.admin-panel.active{display:block}.admin-panel h2{margin:0 0 22px!important;font-size:28px!important}.admin-content form{margin:0 0 24px!important}.admin-content input,.admin-content select,.admin-content textarea{width:100%!important;height:46px!important;box-sizing:border-box!important;border-radius:12px!important;padding:0 14px!important;background:#070b15!important;border:1px solid #29324f!important;color:#fff!important;font-size:14px!important}.admin-content textarea{height:88px!important;padding:14px!important;resize:vertical!important}.admin-content input[type="file"]{display:flex!important;align-items:center!important;padding:10px 12px!important}.admin-content input[type="checkbox"]{width:18px!important;height:18px!important;accent-color:#10d9ff}.admin-content label{height:46px!important;display:flex!important;align-items:center!important;gap:8px!important;padding:0 14px!important;border:1px solid #29324f!important;border-radius:12px!important;background:#070b15!important;color:#dfe9ff!important;font-weight:800!important;box-sizing:border-box!important}.admin-content button{height:42px!important;min-width:90px!important;padding:0 18px!important;border:0!important;border-radius:999px!important;background:linear-gradient(90deg,#ff3fb4,#10d9ff)!important;color:#fff!important;font-weight:900!important;cursor:pointer!important;white-space:nowrap!important}.admin-content .gridform{display:grid!important;grid-template-columns:repeat(4,minmax(0,1fr))!important;gap:12px!important;align-items:center!important}.admin-content .gridform textarea{grid-column:1/5!important}.admin-content .gridform button{grid-column:1/5!important;width:100%!important;height:48px!important}.admin-content table{width:100%!important;table-layout:auto!important;border-collapse:collapse!important;margin-top:12px!important;background:#070b15!important;border-radius:14px!important;overflow:hidden!important}.admin-content th,.admin-content td{white-space:nowrap!important;vertical-align:middle!important;padding:13px 14px!important;border:1px solid #29324f!important;line-height:1.35!important}.admin-content th{background:#171d30!important;color:#fff!important;font-weight:900!important}.admin-content td{color:#f5f7ff!important}.admin-content td form{margin:0!important}.admin-content td button{height:32px!important;min-width:68px!important;padding:0 12px!important;font-size:13px!important}.admin-content td input,.admin-content td select{height:34px!important}.external-content{width:100%;overflow-x:auto}.external-content .top,.external-content header{display:none!important}.external-content .admin,.external-content .wrap{padding:0!important;margin:0!important;max-width:none!important}.external-content .panel{max-width:none!important;width:100%!important;margin:0!important;padding:0!important;background:transparent!important;border:0!important}.external-content table{width:100%!important}.external-loading{padding:30px;border:1px solid #29324f;border-radius:16px;color:#c8d0e8;background:#101525}@media(max-width:1300px){.admin-content .gridform{grid-template-columns:repeat(2,minmax(0,1fr))!important}.admin-content .gridform textarea,.admin-content .gridform button{grid-column:1/3!important}}@media(max-width:900px){.admin-shell{grid-template-columns:1fr}.admin-sidebar{position:relative;height:auto}.admin-content{padding:18px!important}.admin-content .gridform{grid-template-columns:1fr!important}.admin-content .gridform textarea,.admin-content .gridform button{grid-column:1!important}.admin-content .panel{overflow-x:auto;padding:20px!important}}</style></head><body><header class="top"><b>관리자</b><nav><a href="/">사이트</a><a href="/logout">로그아웃</a></nav></header><div class="admin-shell"><aside class="admin-sidebar"><h2>관리 메뉴</h2><a class="active" href="#vendors" data-panel="vendors">업체관리</a><a href="#banners" data-panel="banners">배너관리</a><a href="#users" data-panel="users">회원관리</a><a href="#notices" data-panel="notices">공지관리</a><a href="#reviews" data-panel="reviews">후기관리</a><div class="line"></div><a href="#inquiries" data-panel="inquiries">광고/입점 신청</a><a href="#reports" data-panel="reports">신고내역</a><a href="/">사이트 보기</a></aside><main class="admin admin-content">
<section id="vendors" class="panel admin-panel active"><h2>업체 관리</h2><form method="post" action="/admin/vendor" enctype="multipart/form-data" class="form gridform"><input name="name" placeholder="업체명" required><input name="category" placeholder="업종" required><input name="region" placeholder="지역" required><input name="phone" placeholder="연락처"><input name="kakao_url" placeholder="카카오톡 문의 링크"><input name="business_hours" placeholder="영업시간 예: 10:00 ~ 24:00 / 연중무휴"><input name="tags" placeholder="태그"><select name="status"><option value="active">노출</option><option value="hidden">숨김</option></select><label><input type="checkbox" name="is_recommended">추천업체</label><label><input type="checkbox" name="is_premium">프리미엄</label><input type="file" name="image" accept="image/*"><textarea name="description" placeholder="업체소개"></textarea><button>업체 등록</button></form><table><tr><th>ID</th><th>구분</th><th>업체명</th><th>지역/업종</th><th>영업시간</th><th>카카오</th><th>상태</th><th>삭제</th></tr><% vendors.forEach(v=>{%><tr><td><%=v.id%></td><td><%=v.is_premium?'프리미엄':v.is_recommended?'추천':'일반'%></td><td><%=v.name%></td><td><%=v.region%>/<%=v.category%></td><td><%=v.business_hours||'-'%></td><td><%=v.kakao_url?'등록':'-'%></td><td><%=v.status%></td><td><form method="post" action="/admin/delete/vendors/<%=v.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
<section id="banners" class="panel admin-panel"><h2>프리미엄 슬라이드 배너 관리</h2><form method="post" action="/admin/banner" enctype="multipart/form-data" class="form gridform"><input name="title" placeholder="배너 제목" required><input name="subtitle" placeholder="부제목"><input name="link_url" placeholder="링크 URL"><input name="sort_order" type="number" placeholder="정렬순서" value="0"><select name="position"><option value="premium">프리미엄</option><option value="main">메인</option></select><label><input type="checkbox" name="is_active" checked>노출</label><input type="file" name="image" accept="image/*"><button>배너 등록</button></form><table><tr><th>ID</th><th>제목</th><th>위치</th><th>순서</th><th>삭제</th></tr><% banners.forEach(b=>{%><tr><td><%=b.id%></td><td><%=b.title%></td><td><%=b.position%></td><td><%=b.sort_order%></td><td><form method="post" action="/admin/delete/banners/<%=b.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
<section id="users" class="panel admin-panel"><h2>회원 관리</h2><table><tr><th>ID</th><th>아이디</th><th>닉네임</th><th>권한</th><th>상태</th><th>수정</th></tr><% users.forEach(u=>{%><tr><form method="post" action="/admin/user"><td><%=u.id%><input type="hidden" name="id" value="<%=u.id%>"></td><td><%=u.username%></td><td><input name="nickname" value="<%=u.nickname%>"></td><td><select name="role"><option <%=u.role==='user'?'selected':''%>>user</option><option <%=u.role==='admin'?'selected':''%>>admin</option></select></td><td><select name="status"><option <%=u.status==='active'?'selected':''%>>active</option><option <%=u.status==='blocked'?'selected':''%>>blocked</option></select></td><td><input name="password" placeholder="새 비번"><button>저장</button></td></form></tr><%})%></table></section>
<section id="notices" class="panel admin-panel"><h2>공지 관리</h2><form method="post" action="/admin/notice" class="form"><input name="title" placeholder="제목" required><textarea name="content" placeholder="내용" required></textarea><label><input type="checkbox" name="is_pinned">상단 고정</label><button>공지 등록</button></form><table><tr><th>ID</th><th>제목</th><th>삭제</th></tr><% notices.forEach(n=>{%><tr><td><%=n.id%></td><td><%=n.title%></td><td><form method="post" action="/admin/delete/notices/<%=n.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
<section id="reviews" class="panel admin-panel"><h2>후기 관리</h2><table><tr><th>ID</th><th>업체</th><th>제목</th><th>평점</th><th>삭제</th></tr><% reviews.forEach(r=>{%><tr><td><%=r.id%></td><td><%=r.vendor_name%></td><td><%=r.title%></td><td><%=r.rating%></td><td><form method="post" action="/admin/delete/reviews/<%=r.id%>"><button>삭제</button></form></td></tr><%})%></table></section>
<section id="inquiries" class="panel admin-panel"><div class="external-content" data-url="/admin/inquiries"><div class="external-loading">신청내역을 불러오는 중...</div></div></section>
<section id="reports" class="panel admin-panel"><div class="external-content" data-url="/admin/reports"><div class="external-loading">신고내역을 불러오는 중...</div></div></section>
</main></div><script>async function loadExternal(panel){const box=panel.querySelector('.external-content[data-url]');if(!box||box.dataset.loaded)return;try{const res=await fetch(box.dataset.url,{credentials:'same-origin'});const html=await res.text();const doc=new DOMParser().parseFromString(html,'text/html');const inner=doc.querySelector('main .panel')||doc.querySelector('.panel')||doc.body;box.innerHTML=inner.innerHTML;box.dataset.loaded='1';}catch(e){box.innerHTML='<div class="external-loading">내용을 불러오지 못했습니다.</div>';}}function showAdminPanel(id){document.querySelectorAll('.admin-panel').forEach(p=>p.classList.remove('active'));const panel=document.getElementById(id);if(panel){panel.classList.add('active');loadExternal(panel)}document.querySelectorAll('.admin-sidebar a[data-panel]').forEach(a=>a.classList.toggle('active',a.dataset.panel===id));}document.querySelectorAll('.admin-sidebar a[data-panel]').forEach(a=>a.addEventListener('click',e=>{e.preventDefault();showAdminPanel(a.dataset.panel);history.replaceState(null,'','#'+a.dataset.panel)}));const start=(location.hash||'#vendors').replace('#','');if(document.getElementById(start))showAdminPanel(start);</script></body></html>