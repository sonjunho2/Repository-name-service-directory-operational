            <div class="brand-size-row"><label for="brandNameSizeInput">사이트명 글자 크기 (px)</label><input id="brandNameSizeInput" type="number" name="brand_name_size" min="14" max="72" step="1" value="<%=(settings?.raw?.brand_name_size)||32%>"></div>
