  window.__adminUserVendorLinkModalV1=true;
  function closeUserVendorLinkModal(){var modal=document.getElementById('userVendorLinkModal'),form=modal?.querySelector('form');if(!modal)return;if(form){form.reset();form.dataset.submitting='0';}modal.hidden=true;document.body.style.overflow='';}
