</style><script>
(function(){
  if(window.__adminUsersModuleV3)return;
  window.__adminUsersModuleV3=true;

  var userServerPage=Number(window.getAdminListState?.('users').page||1);
  var userServerLimit=20;
  var loading=false;
  var userSearchTimer=null;
  var usersById=new Map();
  function ensureUserTools(){
    if(!document.getElementById('users'))return;
    window.restoreAdminListControls?.('users');
  }
  ensureUserTools();

  function userQuery(page){
    var params=new URLSearchParams();
    params.set('member_scope','general');
    params.set('page',String(page));
    params.set('limit',String(userServerLimit));
    var search=(document.getElementById('userSearch')?.value||'').trim();
    var status=document.getElementById('userStatusFilter')?.value||'all';
    var sort=document.getElementById('userSortFilter')?.value||'latest';
    if(search)params.set('q',search);
    if(status!=='all')params.set('status',status);
    params.set('sort',sort);
    return params;
  }

  function statusText(v){
    return {active:'м†ХмГБ',blocked:'м∞®лЛ®',suspended:'м†ХмІА',inactive:'лєДнЩЬмД±'}[v]||v||'м†ХмГБ';
  }
  function userDate(v){if(!v)return '-';var d=new Date(v);return isNaN(d.getTime())?'-':d.toLocaleString('ko-KR',{timeZone:'Asia/Seoul',year:'numeric',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit',hour12:false});}
  function option(value,current,label){
    return '<option value="'+esc(value)+'" '+(value===current?'selected':'')+'>'+esc(label)+'</option>';
  }
  function statusOptions(current){
    current=current||'active';
    return option('active',current,'м†ХмГБ')+option('blocked',current,'м∞®лЛ®')+option('suspended',current,'м†ХмІА')+option('inactive',current,'лєДнЩЬмД±');
  }
  function userRow(u){return '<tr class="user-row" data-id="'+esc(u.id)+'"><td>'+esc(u.id)+'</td><td><b>'+esc(u.username||'')+'</b><br><small>лЛЙлД§мЮД: '+esc(u.nickname||'-')+'</small></td><td><span class="'+(u.status==='active'?'done':'rejected')+'">'+esc(statusText(u.status))+'</span></td><td>'+esc(userDate(u.created_at))+'</td><td><button type="button" class="user-manage-btn" data-id="'+esc(u.id)+'">кіАл¶ђ</button></td></tr>';}
  function usersPanel(){
    return document.getElementById('users');
  }
  function usersTable(){
    return document.getElementById('userManagementTable');
  }
  function ensurePager(table){
    return table?document.getElementById('userPager'):null;
  }
  function makeBtn(label,disabled,active,onClick){
    var b=document.createElement('button');
    b.type='button';
    b.textContent=label;
    if(disabled)b.disabled=true;
    if(active)b.classList.add('active');
    b.onclick=onClick;
    return b;
  }
  function showTableMessage(table,msg,cls){
    var body=document.getElementById('userTableBody');if(body)body.innerHTML='<tr class="'+(cls||'loading-row')+'"><td colspan="5">'+esc(msg)+'</td></tr>';
  }
  function renderPager(pager,data){
    pager.innerHTML='';
    var page=data.page||1,totalPages=data.totalPages||1,total=data.total||0,limit=data.limit||userServerLimit;
    var from=total?((page-1)*limit+1):0;
    var to=Math.min(page*limit,total);
    pager.appendChild(makeBtn('м≤ШмЭМ',page<=1,false,function(){loadUsers(1);}));
    pager.appendChild(makeBtn('мЭім†Д',page<=1,false,function(){loadUsers(page-1);}));

    var start=Math.max(1,page-2);
    var end=Math.min(totalPages,start+4);
    start=Math.max(1,end-4);
    if(start>1){
      pager.appendChild(makeBtn('1',false,page===1,function(){loadUsers(1);}));
      if(start>2){
        var d=document.createElement('span'); d.className='dots'; d.textContent='...'; pager.appendChild(d);
      }
    }
    for(var p=start;p<=end;p++){
      (function(n){pager.appendChild(makeBtn(String(n),false,n===page,function(){loadUsers(n);}));})(p);
    }
    if(end<totalPages){
      if(end<totalPages-1){
        var d2=document.createElement('span'); d2.className='dots'; d2.textContent='...'; pager.appendChild(d2);
      }
      pager.appendChild(makeBtn(String(totalPages),false,page===totalPages,function(){loadUsers(totalPages);}));
    }

    pager.appendChild(makeBtn('лЛ§мЭМ',page>=totalPages,false,function(){loadUsers(page+1);}));
    pager.appendChild(makeBtn('лІИмІАлІЙ',page>=totalPages,false,function(){loadUsers(totalPages);}));
    var info=document.createElement('span');
    info.className='server-user-info';
    info.textContent='міЭ '+total+'л™Е ¬Ј нШДмЮђ '+from+'-'+to+'л™Е нСЬмЛЬ';
    pager.appendChild(info);
  }
  function fixHeaders(table){
    return table;
  }
  function renderSummary(summary){document.querySelectorAll('#userSummaryGrid [data-user-summary]').forEach(function(el){el.textContent=Number(summary?.[el.dataset.userSummary]||0).toLocaleString('ko-KR');});}
  async function loadUsers(page){
    page=page||Number(window.getAdminListState?.('users').page||1);
    if(loading){clearTimeout(userSearchTimer);userSearchTimer=setTimeout(function(){loadUsers(page);},100);return;}
    var table=usersTable();
    if(!table)return;
    var pager=ensurePager(table);
    userServerPage=Math.max(1,page||1);
    window.saveActiveAdminListState?.('users',userServerPage);
    loading=true;
    showTableMessage(table,'нЪМмЫРл™©л°ЭмЭД лґИлЯђмШ§лКФ м§СмЮЕлЛИлЛ§.','loading-row');
    var loadOk=false;
    if(pager)pager.innerHTML='<span class="server-user-info">нЪМмЫРл™©л°ЭмЭД лґИлЯђмШ§лКФ м§СмЮЕлЛИлЛ§.</span>';
    try{
      var res=await fetch('/admin/api/users?'+userQuery(userServerPage).toString(),{credentials:'same-origin',headers:{'Accept':'application/json'}});
      var data=await res.json();
      if(!data.ok)throw new Error(data.error||'нЪМмЫРл™©л°Э л°ЬлУЬ мЛ§нМ®');
      if(userServerPage>Math.max(1,Number(data.totalPages||1))){loading=false;window.normalizeAdminListPage?.('users',data,loadUsers);return;}
      var body=document.getElementById('userTableBody');
      if(!body)throw new Error('нЪМмЫР нЕМмЭілЄФ л≥ЄлђЄмЭД м∞ЊмЭД мИШ мЧЖмКµлЛИлЛ§.');
      usersById.clear();(data.rows||[]).forEach(function(u){usersById.set(String(u.id),u);});
      body.innerHTML=(data.rows||[]).map(userRow).join('')||'<tr class="loading-row"><td colspan="5">нСЬмЛЬнХ† мЭЉл∞ШнЪМмЫРмЭі мЧЖмКµлЛИлЛ§.</td></tr>';
      renderSummary(data.summary||{});
      if(pager)renderPager(pager,data);
      loadOk=true;
    }catch(e){
      if(pager)pager.innerHTML='<span class="server-user-info">нЪМмЫРл™©л°ЭмЭД лґИлЯђмШ§мІА л™їнЦИмКµлЛИлЛ§: '+esc(e.message||'мШ§л•Ш')+'</span>';
    }finally{
      if(!loadOk)showTableMessage(table,'нЪМмЫРл™©л°ЭмЭД лґИлЯђмШ§мІА л™їнЦИмКµлЛИлЛ§.','loading-row');
      loading=false;
    }
  }
  window.loadAdminUsers=loadUsers;
  function refreshUserRelated(){if(typeof window.loadAdminVendors==='function')window.loadAdminVendors(window.getAdminListState?.('vendors').page||1);if(typeof window.loadDashboardSummary==='function')window.loadDashboardSummary();}
  function closeUserModal(){var modal=document.getElementById('userManagementModal'),form=document.getElementById('userManagementForm');if(!modal||!form)return;modal.hidden=true;form.reset();form.dataset.submitting='0';document.body.style.overflow='';}
  function openUserModal(id){var u=usersById.get(String(id)),modal=document.getElementById('userManagementModal'),form=document.getElementById('userManagementForm');if(!u||!modal||!form)return;form.elements.id.value=u.id;form.elements.username.value=u.username||'';form.elements.nickname.value=u.nickname||'';form.elements.status.value=u.status||'active';form.elements.password.value='';modal.hidden=false;document.body.style.overflow='hidden';}
  async function saveUser(form){
    window.saveActiveAdminListState?.('users',userServerPage);
    if(form.dataset.submitting==='1')return;
    var id=form.elements.id.value,btn=form.querySelector('button[type="submit"]');
    var fd=new FormData();
    fd.append('nickname',form.elements.nickname.value||'');
    fd.append('status',form.elements.status.value||'active');
    fd.append('password',form.elements.password.value||'');

    var old=btn.textContent;
    form.dataset.submitting='1';
    btn.disabled=true;
    btn.textContent='м†АмЮ•м§С...';
    try{
      var res=await fetch('/admin/users/'+encodeURIComponent(id)+'/update',{method:'POST',body:fd,credentials:'same-origin',headers:{'X-Requested-With':'fetch','Accept':'application/json'}});
      var data=null;
      try{data=await res.json();}catch(e){}
      if(!res.ok||data?.ok===false)throw new Error(data?.error||('HTTP '+res.status));
      form.elements.password.value='';closeUserModal();
      await loadUsers(userServerPage);
      refreshUserRelated();
      toast('нЪМмЫР м†Хл≥ік∞А м†АмЮ•лРШмЧИмКµлЛИлЛ§.','ok');
    }catch(e){
      toast('м†АмЮ• мЛ§нМ®: '+(e.message||'мШ§л•Ш'),'bad');
    }finally{
      form.dataset.submitting='0';
      btn.disabled=false;
      btn.textContent=old;
    }
  }
  async function deleteUser(btn){
    window.saveActiveAdminListState?.('users',userServerPage);
    var form=document.getElementById('userManagementForm'),id=form?.elements.id.value;
    if(!id||btn.dataset.submitting==='1')return;
    if(!confirm('мЭі мЭЉл∞ШнЪМмЫР к≥Дм†ХмЭД мВ≠м†ЬнХ†кєМмЪФ?\nмЮСмД±нХЬ к≤МмЛЬкЄА¬ЈнЫДкЄ∞ лУ±мЭШ мЮСмД±мЮР м†Хл≥ік∞А л≥Ак≤љлР† мИШ мЮИмКµлЛИлЛ§.'))return;
    var old=btn.textContent;
    btn.dataset.submitting='1';
    btn.disabled=true;
    btn.textContent='мВ≠м†Ьм§С...';
    try{
      var res=await fetch('/admin/delete/users/'+encodeURIComponent(id),{method:'POST',body:new FormData(),credentials:'same-origin',headers:{'X-Requested-With':'fetch','Accept':'application/json'}});
      var data=null;
      try{data=await res.json();}catch(e){}
      if(!res.ok||data?.ok===false)throw new Error(data?.error||('HTTP '+res.status));
      toast('нЪМмЫРмЭі мВ≠м†ЬлРШмЧИмКµлЛИлЛ§.','warn');
      closeUserModal();
      await loadUsers(userServerPage);
      refreshUserRelated();
    }catch(e){
      toast('мВ≠м†Ь мЛ§нМ®: '+(e.message||'мШ§л•Ш'),'bad');
      btn.disabled=false;
      btn.textContent=old;
    }finally{
      btn.dataset.submitting='0';
    }
  }
  document.addEventListener('click',function(e){
    var manage=e.target.closest('.user-manage-btn');if(manage){e.preventDefault();openUserModal(manage.dataset.id);return;}
    if(e.target.closest('[data-user-modal-close]')){closeUserModal();return;}
    var del=e.target.closest('.user-delete-btn');
    if(del){e.preventDefault();e.stopPropagation();deleteUser(del);return;}
    if(e.target===document.getElementById('userManagementModal'))closeUserModal();
  },true);
  document.getElementById('userManagementForm')?.addEventListener('submit',function(e){e.preventDefault();e.stopPropagation();saveUser(this);});
  document.addEventListener('keydown',function(e){if(e.key==='Escape'&&!document.getElementById('userManagementModal')?.hidden)closeUserModal();});
})();
</script><script>
(function(){
