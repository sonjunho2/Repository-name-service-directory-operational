  var boardSettingsRows=document.getElementById('boardSettingsRows');
  function refreshBoardMoveButtons(){if(!boardSettingsRows)return;var rows=Array.from(boardSettingsRows.querySelectorAll('tr[data-board-id]'));rows.forEach(function(row,index){var up=row.querySelector('[data-board-move="up"]'),down=row.querySelector('[data-board-move="down"]');if(up)up.disabled=index===0;if(down)down.disabled=index===rows.length-1;});}
