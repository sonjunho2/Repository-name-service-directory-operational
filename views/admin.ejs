>{const okTitle=!q||row.dataset.title.includes(q);const okPos=p==='all'||row.dataset.position===p;const okStatus=s==='all'||row.dataset.active===s;row.classList.toggle('hidden-row',!(okTitle&&okPos&&okStatus));});}function sortBannerRows(){const table=document.querySelector('#banners table');if(!table)return;const rows=[...table.querySelectorAll('.banner-row')];const mode=document.getElementById('bannerSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='order')return Number(a.dataset.order)-Number(b.dataset.order)||Number(b.dataset.id)-Number(a.dataset.id);if(mode==='active')return (b.dataset.active==='active')-(a.dataset.active==='active')||Number(a.dataset.order)-Number(b.dataset.order);if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.order)-Number(b.dataset.order)||Number(b.dataset.id)-Number(a.dataset.id);});rows.forEach(r=>table.appendChild(r));}function applyUserFilter(){const q=(userSearch?.value||'').trim().toLowerCase();const r=userRoleFilter?.value||'all';const s=userStatusFilter?.value||'all';document.querySelectorAll('.user-row').forEach(row=>{const okText=!q||(row.dataset.text||'').includes(q);const okRole=r==='all'||row.dataset.role===r;const okStatus=s==='all'||row.dataset.status===s;row.classList.toggle('hidden-row',!(okText&&okRole&&okStatus));});}function sortUserRows(){const table=document.querySelector('#users table');if(!table)return;const rows=[...table.querySelectorAll('.user-row')];const mode=document.getElementById('userSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);if(mode==='admin')return (b.dataset.role==='admin')-(a.dataset.role==='admin')||Number(b.dataset.id)-Number(a.dataset.id);if(mode==='blocked')return (b.dataset.status==='blocked')-(a.dataset.status==='blocked')||Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.id)-Number(b.dataset.id);});rows.forEach(r=>table.appendChild(r));}function applyNoticeFilter(){const q=(noticeSearch?.value||'').trim().toLowerCase();const f=noticePinnedFilter?.value||'all';document.querySelectorAll('.notice-row').forEach(row=>{const okTitle=!q||row.dataset.title.includes(q);const okPinned=f==='all'||row.dataset.pinned===f;row.classList.toggle('hidden-row',!(okTitle&&okPinned));});}function sortNoticeRows(){const table=document.querySelector('#notices table');if(!table)return;const rows=[...table.querySelectorAll('.notice-row')];const mode=document.getElementById('noticeSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);if(mode==='pinned')return (b.dataset.pinned==='pinned')-(a.dataset.pinned==='pinned')||Number(b.dataset.id)-Number(a.dataset.id);if(mode==='normal')return (b.dataset.pinned==='normal')-(a.dataset.pinned==='normal')||Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.id)-Number(b.dataset.id);});rows.forEach(r=>table.appendChild(r));}function applyReviewFilter(){const q=(reviewSearch?.value||'').trim().toLowerCase();const f=reviewRatingFilter?.value||'all';document.querySelectorAll('.review-row').forEach(row=>{const rating=parseInt(row.dataset.rating||0,10);const okText=!q||row.dataset.text.includes(q);const okRating=f==='all'||(f==='5'&&rating===5)||(f==='4'&&rating===4)||(f==='low'&&rating<=3);row.classList.toggle('hidden-row',!(okText&&okRating));});}function sortReviewRows(){const table=document.querySelector('#reviews table');if(!table)return;const rows=[...table.querySelectorAll('.review-row')];const mode=document.getElementById('reviewSortFilter')?.value||'default';rows.sort((a,b)=>{if(mode==='latest')return Number(b.dataset.id)-Number(a.dataset.id);if(mode==='high')return Number(b.dataset.rating)-Number(a.dataset.rating)||Number(b.dataset.id)-Number(a.dataset.id);if(mode==='low')return Number(a.dataset.rating)-Number(b.dataset.rating)||Number(b.dataset.id)-Number(a.dataset.id);return Number(a.dataset.id)-Number(b.dataset.id);});rows.forEach(r=>table.appendChild(r));}['input','change'].forEach(ev=>{vendorSearch?.addEventListener(ev,applyVendorFilter);vendorTypeFilter?.addEventListener(ev,applyVendorFilter);vendorStatusFilter?.addEventListener(ev,applyVendorFilter);vendorSortFilter?.addEventListener(ev,sortVendorRows);bannerSearch?.addEventListener(ev,applyBannerFilter);bannerPositionFilter?.addEventListener(ev,applyBannerFilter);bannerStatusFilter?.addEventListener(ev,applyBannerFilter);bannerSortFilter?.addEventListener(ev,sortBannerRows);userSearch?.addEventListener(ev,applyUserFilter);userRoleFilter?.addEventListener(ev,applyUserFilter);userStatusFilter?.addEventListener(ev,applyUserFilter);userSortFilter?.addEventListener(ev,sortUserRows);noticeSearch?.addEventListener(ev,applyNoticeFilter);noticePinnedFilter?.addEventListener(ev,applyNoticeFilter);noticeSortFilter?.addEventListener(ev,sortNoticeRows);reviewSearch?.addEventListener(ev,applyReviewFilter);reviewRatingFilter?.addEventListener(ev,applyReviewFilter);reviewSortFilter?.addEventListener(ev,sortReviewRows);});vendorFilterReset?.addEventListener('click',()=>{vendorSearch.value='';vendorTypeFilter.value='all';vendorStatusFilter.value='all';vendorSortFilter.value='default';applyVendorFilter();sortVendorRows();});bannerFilterReset?.addEventListener('click',()=>{bannerSearch.value='';bannerPositionFilter.value='all';bannerStatusFilter.value='all';bannerSortFilter.value='default';applyBannerFilter();sortBannerRows();});userFilterReset?.addEventListener('click',()=>{userSearch.value='';userRoleFilter.value='all';userStatusFilter.value='all';userSortFilter.value='default';applyUserFilter();sortUserRows();});noticeFilterReset?.addEventListener('click',()=>{noticeSearch.value='';noticePinnedFilter.value='all';noticeSortFilter.value='default';applyNoticeFilter();sortNoticeRows();});reviewFilterReset?.addEventListener('click',()=>{reviewSearch.value='';reviewRatingFilter.value='all';reviewSortFilter.value='default';applyReviewFilter();sortReviewRows();});function showPreview(box,src,text){if(!box)return;const img=box.querySelector('img');const span=box.querySelector('span');if(src){img.src=src;box.style.display='flex';if(span)span.textContent=text||'선택한 이미지가 표시됩니다.';}else{box.style.display='none';if(img)img.removeAttribute('src');}}function bindPreview(input,box){if(!input)return;input.addEventListener('change',()=>{const f=input.files&&input.files[0];if(!f)return showPreview(box,null);showPreview(box,URL.createObjectURL(f),'새로 선택한 이미지입니다.');});}const vf=document.getElementById('vendorForm'),bf=document.getElementById('bannerForm');bindPreview(vf?.image,document.getElementById('vendorImagePreview'));bindPreview(bf?.image,document.getElementById('bannerImagePreview'));document.querySelectorAll('.edit-vendor-btn').forEach(btn=>btn.onclick=()=>{const v=ADMIN_VENDORS.find(x=>String(x.id)===String(btn.dataset.id));if(!v)return;vf.id.value=v.id||'';vf.name.value=v.name||'';vf.category.value=v.category||'';vf.region.value=v.region||'';vf.phone.value=v.phone||'';vf.kakao_url.value=v.kakao_url||'';vf.business_hours.value=v.business_hours||'';vf.tags.value=v.tags||'';vf.status.value=v.status||'active';vf.description.value=v.description||'';if(vf.ad_type)vf.ad_type.value=v.ad_type||'none';if(vf.expire_at)vf.expire_at.value=(v.expire_at||'').slice(0,10);if(vf.banner_active)vf.banner_active.checked=!!v.banner_active;showPreview(document.getElementById('vendorImagePreview'),null,v.has_image_data?'현재 등록된 업체 이미지가 있습니다. 새 파일 선택 시 교체됩니다.':'새 파일 선택 시 이미지가 등록됩니다.');vendorSubmitBtn.textContent='업체 수정 저장';cancelVendorEdit.style.display='block';const vm=document.getElementById('vendorModal');const vt=document.getElementById('vendorModalTitle');if(vt)vt.textContent='업체 수정';if(vm&&vm.parentElement!==document.body)document.body.appendChild(vm);if(vm){vm.classList.add('active');document.body.style.overflow='hidden';}});cancelVendorEdit.onclick=()=>{vf.reset();vf.id.value='';showPreview(document.getElementById('vendorImagePreview'),null);vendorSubmitBtn.textContent='업체 등록';cancelVendorEdit.style.display='none'};function bannerEl(name){return bf&&bf.elements?bf.elements[name]:null;}
document.addEventListener('click',function(e){const btn=e.target.closest('.edit-banner-btn');if(!btn)return;const b=ADMIN_BANNERS.find(x=>String(x.id)===String(btn.dataset.id));if(!b||!bf)return;showAdminPanel('banners');bannerEl('id').value=b.id||'';bannerEl('title').value=b.title||'';if(bannerEl('subtitle'))bannerEl('subtitle').value=b.subtitle||'';bannerEl('link_url').value=b.link_url||'';bannerEl('sort_order').value=b.sort_order||0;if(bannerEl('position'))bannerEl('position').value=b.position||'premium';bannerEl('is_active').checked=!!b.is_active;showPreview(document.getElementById('bannerImagePreview'),null,b.has_image_data?'현재 등록된 배너 이미지가 있습니다. 새 파일 선택 시 교체됩니다.':'새 파일 선택 시 이미지가 등록됩니다.');bannerSubmitBtn.textContent='관리자 배너 수정';cancelBannerEdit.style.display='block';bf.scrollIntoView({behavior:'smooth'});});cancelBannerEdit.onclick=()=>{bf.reset();bannerEl('id').value='';bannerEl('is_active').checked=true;showPreview(document.getElementById('bannerImagePreview'),null);bannerSubmitBtn.textContent='관리자 배너 등록';cancelBannerEdit.style.display='none'};function updateReportAlert(){const el=document.getElementById('pendingReportCount');if(el)el.textContent=document.querySelectorAll('.report-row[data-status="new"]').length;}
window.ADMIN_VENDORS=ADMIN_VENDORS;window.ADMIN_BANNERS=ADMIN_BANNERS;
let currentInquiryFilter='all';
function applyInquiryFilter(){
  const q=(document.getElementById('inquirySearch')?.value||'').trim().toLowerCase();
  document.querySelectorAll('.inquiry-row').forEach(row=>{
    const status=row.dataset.status||'';
    const type=row.dataset.type||'';
    const search=row.dataset.search||'';
    const okFilter=currentInquiryFilter==='all'||status===currentInquiryFilter||type===currentInquiryFilter;
    const okSearch=!q||search.includes(q);
    row.classList.toggle('hidden-row',!(okFilter&&okSearch));
  });
}
function sortInquiries(){
  const table=document.querySelector('#inquiries table'); if(!table)return;
  const rows=[...table.querySelectorAll('.inquiry-row')];
  const mode=document.getElementById('inquirySort')?.value||'latest';
  const statusRank={new:0,rejected:1,approved:2};
  rows.sort((a,b)=>{
    const aid=Number(a.dataset.id||0), bid=Number(b.dataset.id||0);
    if(mode==='oldest')return aid-bid;
    if(mode==='status')return (statusRank[a.dataset.status||'']??9)-(statusRank[b.dataset.status||'']??9)||bid-aid;
    if(mode==='type')return (a.dataset.type||'').localeCompare(b.dataset.type||'')||bid-aid;
    return bid-aid;
  });
  rows.forEach(r=>table.appendChild(r));
}
document.querySelectorAll('.inquiry-filterbar button').forEach(btn=>btn.addEventListener('click',()=>{
  document.querySelectorAll('.inquiry-filterbar button').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on'); currentInquiryFilter=btn.dataset.filter; applyInquiryFilter();
}));
document.getElementById('inquirySearch')?.addEventListener('input',applyInquiryFilter);
document.getElementById('inquirySort')?.addEventListener('change',sortInquiries);
document.getElementById('inquirySearchReset')?.addEventListener('click',()=>{
  inquirySearch.value=''; inquirySort.value='latest'; currentInquiryFilter='all';
  document.querySelectorAll('.inquiry-filterbar button').forEach(b=>b.classList.toggle('on',b.dataset.filter==='all'));
  applyInquiryFilter(); sortInquiries();
});
let currentReportFilter='all';
function applyReportFilter(){
  const q=(document.getElementById('reportSearch')?.value||'').trim().toLowerCase();
  document.querySelectorAll('.report-row').forEach(row=>{
    const status=row.dataset.status||'';
    const type=row.dataset.type||'';
    const search=row.dataset.search||'';
    const okFilter=currentReportFilter==='all'||status===currentReportFilter||type===currentReportFilter;
    const okSearch=!q||search.includes(q);
    row.classList.toggle('hidden-row',!(okFilter&&okSearch));
  });
}
function sortReports(){
  const table=document.querySelector('#reports table'); if(!table)return;
  const rows=[...table.querySelectorAll('.report-row')];
  const mode=document.getElementById('reportSort')?.value||'latest';
  rows.sort((a,b)=>{
    const aid=Number(a.dataset.id||0), bid=Number(b.dataset.id||0);
    if(mode==='oldest')return aid-bid;
    if(mode==='status')return ((a.dataset.status||'')==='done')-((b.dataset.status||'')==='done')||bid-aid;
    if(mode==='reason')return (a.dataset.reason||'').localeCompare(b.dataset.reason||'')||bid-aid;
    return bid-aid;
  });
  rows.forEach(r=>table.appendChild(r));
}
document.querySelectorAll('.report-filterbar button').forEach(btn=>btn.addEventListener('click',()=>{
  document.querySelectorAll('.report-filterbar button').forEach(b=>b.classList.remove('on'));
