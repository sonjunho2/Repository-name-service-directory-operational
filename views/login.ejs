<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>로그인</title><link rel="stylesheet" href="/public/css/style.css"></head><body><main class="auth"><form method="post" class="form"><h1><%=mode==='join'?'회원가입':'로그인'%></h1><% if(error){%><p class="err"><%=error%></p><%}%><input name="username" placeholder="아이디" required><input name="password" type="password" placeholder="비밀번호" required><% if(mode==='join'){%><input name="nickname" placeholder="닉네임"><%}%><button><%=mode==='join'?'가입':'로그인'%></button><a href="<%=mode==='join'?'/login':'/join'%>"><%=mode==='join'?'로그인으로':'회원가입으로'%></a></form></main></body></html>
